@{
    ViewData["Title"] = "Trip Preferences";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-surface flex flex-col justify-center items-center py-12 px-4" x-data="tripQuiz()">
    <div class="w-full max-w-3xl bg-white shadow-2xl rounded-3xl overflow-hidden tonal-elevation">
        <!-- Progress Bar -->
        <div class="w-full bg-gray-200 h-2">
            <div class="bg-primary h-2 transition-all duration-500" :style="`width: ${(step / totalSteps) * 100}%`"></div>
        </div>

        <div class="p-10 md:p-16">
            <!-- Header -->
            <div class="mb-10 text-center">
                <span class="text-primary font-bold tracking-widest uppercase text-sm mb-2 block" x-text="`STEP ${step} OF ${totalSteps}`"></span>
                <h2 class="text-4xl font-extrabold text-on-surface mb-4" x-text="getStepTitle()"></h2>
                <p class="text-on-surface-variant text-lg" x-text="getStepDescription()"></p>
            </div>

            <!-- Step 1: Destination -->
            <div x-show="step === 1" x-transition.opacity class="space-y-4">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <template x-for="dest in destinations" :key="dest">
                        <label class="cursor-pointer">
                            <input type="radio" name="destination" :value="dest" x-model="answers.destination" class="peer sr-only">
                            <div class="h-32 rounded-xl border-2 border-outline-variant/30 flex flex-col items-center justify-center gap-2 hover:bg-primary-container hover:border-primary transition-all peer-checked:bg-primary-container peer-checked:border-primary peer-checked:text-primary">
                                <span class="material-symbols-outlined text-4xl" x-text="dest === 'Other' ? 'add_circle' : 'location_city'"></span>
                                <span class="font-bold" x-text="dest"></span>
                            </div>
                        </label>
                    </template>
                </div>
                <!-- Custom Destination Input -->
                <div x-show="answers.destination === 'Other'" x-transition class="mt-4">
                    <input type="text" list="vietnam_locations" x-model="answers.customDestination" placeholder="Type your destination..." class="w-full bg-white border-outline-variant/50 rounded-lg p-4 text-on-surface focus:ring-primary focus:border-primary">
                </div>
            </div>

            <!-- Step 2: Vibe -->
            <div x-show="step === 2" x-transition.opacity class="space-y-4" style="display: none;">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <template x-for="v in vibes" :key="v.name">
                        <label class="cursor-pointer">
                            <input type="radio" name="vibe" :value="v.name" x-model="answers.vibe" class="peer sr-only">
                            <div class="p-6 rounded-xl border-2 border-outline-variant/30 flex items-center gap-4 hover:bg-primary-container hover:border-primary transition-all peer-checked:bg-primary-container peer-checked:border-primary peer-checked:text-primary">
                                <div class="w-12 h-12 bg-gray-100 peer-checked:bg-primary/10 rounded-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-2xl" x-text="v.icon"></span>
                                </div>
                                <div>
                                    <h4 class="font-bold text-lg" x-text="v.name"></h4>
                                    <p class="text-sm text-on-surface-variant" x-text="v.desc"></p>
                                </div>
                            </div>
                        </label>
                    </template>
                </div>
                <!-- Custom Vibe Input -->
                <div x-show="answers.vibe === 'Other'" x-transition class="mt-4">
                    <input type="text" x-model="answers.customVibe" placeholder="What kind of experience are you looking for?" class="w-full bg-white border-outline-variant/50 rounded-lg p-4 text-on-surface focus:ring-primary focus:border-primary">
                </div>
            </div>

            <!-- Step 3: Dates -->
            <div x-show="step === 3" x-transition.opacity class="space-y-6" style="display: none;">
                <div class="bg-gray-50 p-6 rounded-xl border border-outline-variant/30">
                    <label class="block text-sm font-bold text-on-surface mb-4">When are you traveling?</label>
                        <div class="col-span-1 md:col-span-2">
                            <label class="block text-xs font-bold text-on-surface-variant mb-1 uppercase tracking-wider">Travel Dates</label>
                            <input type="text" x-model="answers.dateRange" placeholder="Select your travel dates..." class="date-picker cursor-pointer w-full bg-white border-outline-variant/50 rounded-lg p-3 text-on-surface focus:ring-primary focus:border-primary">
                        </div>
                </div>
                <div class="bg-gray-50 p-6 rounded-xl border border-outline-variant/30">
                    <label class="block text-sm font-bold text-on-surface mb-2">How many people?</label>
                    <div class="flex items-center gap-4">
                        <button type="button" x-on:click="if(answers.guests > 1) answers.guests--" class="w-10 h-10 rounded-full border border-primary text-primary flex items-center justify-center hover:bg-primary-container">-</button>
                        <span class="text-xl font-bold w-8 text-center" x-text="answers.guests"></span>
                        <button type="button" x-on:click="answers.guests++" class="w-10 h-10 rounded-full border border-primary text-primary flex items-center justify-center hover:bg-primary-container">+</button>
                    </div>
                </div>
            </div>

            <!-- Step 4: Budget -->
            <div x-show="step === 4" x-transition.opacity class="space-y-4" style="display: none;">
                <div class="grid grid-cols-1 gap-4">
                    <template x-for="b in budgets" :key="b.label">
                        <label class="cursor-pointer">
                            <input type="radio" name="budget" :value="b.label" x-model="answers.budget" class="peer sr-only">
                            <div class="p-5 rounded-xl border-2 border-outline-variant/30 flex justify-between items-center hover:bg-primary-container hover:border-primary transition-all peer-checked:bg-primary-container peer-checked:border-primary peer-checked:text-primary">
                                <span class="font-bold text-lg" x-text="b.label"></span>
                                <span class="text-on-surface-variant peer-checked:text-primary font-medium" x-text="b.price"></span>
                            </div>
                        </label>
                    </template>
                </div>
            </div>

            <!-- Navigation Buttons -->
            <div class="mt-12 flex justify-between items-center">
                <button 
                    x-show="step > 1" 
                    x-on:click="step--"
                    class="px-6 py-3 rounded-full font-bold text-on-surface-variant hover:bg-gray-100 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Back
                </button>
                <div x-show="step === 1"></div> <!-- Spacer -->

                <button 
                    x-show="step < totalSteps" 
                    x-on:click="nextStep()"
                    :disabled="!canProceed()"
                    class="px-8 py-3 rounded-full font-bold text-on-primary bg-primary hover:bg-primary/90 transition-all flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                    Next
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>

                <button 
                    x-show="step === totalSteps" 
                    x-on:click="submitSurvey()"
                    :disabled="!canProceed()"
                    class="px-8 py-3 rounded-full font-bold text-on-primary bg-primary hover:bg-primary/90 transition-all flex items-center gap-2 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed">
                    Find My Guide
                    <span class="material-symbols-outlined">magic_button</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Alpine.js is included in _Layout.cshtml -->

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('tripQuiz', () => ({
            step: 1,
            totalSteps: 4,
            answers: {
                destination: '',
                customDestination: '',
                vibe: '',
                customVibe: '',
                dateRange: '',
                guests: 1,
                budget: ''
            },
            destinations: ['Hanoi', 'Ho Chi Minh', 'Da Nang', 'Hoi An', 'Da Lat', 'Other'],
            vibes: [
                { name: 'Chill & Relax', desc: 'Coffee shops, spas, gentle walks.', icon: 'coffee' },
                { name: 'Adventure', desc: 'Trekking, motorbiking, nature.', icon: 'hiking' },
                { name: 'Cultural Deep-dive', desc: 'Museums, history, local life.', icon: 'temple_buddhist' },
                { name: 'Foodie Tour', desc: 'Street food, local specialties.', icon: 'restaurant' },
                { name: 'Other', desc: 'I have something else in mind.', icon: 'add_circle' }
            ],
            budgets: [
                { label: 'Budget-friendly', price: '~$20 - $40 / day' },
                { label: 'Standard', price: '~$50 - $80 / day' },
                { label: 'Premium', price: '~$100+ / day' }
            ],

            getStepTitle() {
                const titles = [
                    "Where are you heading?",
                    "What's your preferred vibe?",
                    "When are you traveling?",
                    "What's your daily budget?"
                ];
                return titles[this.step - 1];
            },

            getStepDescription() {
                const descriptions = [
                    "Choose a city you want to explore with a local guide.",
                    "Let us know what kind of activities you enjoy the most.",
                    "Tell us your timeline so we can find available guides.",
                    "This helps us suggest experiences that match your comfort level."
                ];
                return descriptions[this.step - 1];
            },

            canProceed() {
                if (this.step === 1) {
                    if (this.answers.destination === 'Other') return this.answers.customDestination.trim() !== '';
                    return this.answers.destination !== '';
                }
                if (this.step === 2) {
                    if (this.answers.vibe === 'Other') return this.answers.customVibe.trim() !== '';
                    return this.answers.vibe !== '';
                }
                if (this.step === 3) return this.answers.dateRange !== '';
                if (this.step === 4) return this.answers.budget !== '';
                return true;
            },

            nextStep() {
                if (this.canProceed() && this.step < this.totalSteps) {
                    this.step++;
                }
            },

            submitSurvey() {
                if (this.canProceed()) {
                    // Save to local storage for the next step (Matching/Auth)
                    localStorage.setItem('tripPreferences', JSON.stringify(this.answers));
                    
                    // Show loading state or redirect
                    // Redirect to the Matches page
                    window.location.href = '/Survey/Matches'; 
                }
            }
        }))
    })
</script>
