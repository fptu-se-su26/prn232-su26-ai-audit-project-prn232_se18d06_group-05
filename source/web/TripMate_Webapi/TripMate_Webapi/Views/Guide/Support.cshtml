@{
    ViewData["Title"] = "Trợ Giúp & Hỗ Trợ";
    ViewData["ActivePage"] = "Support";
    Layout = "_GuideLayout";
    
    var tickets = ViewBag.Tickets as IEnumerable<dynamic>;
}

<!-- JSON data cho AlpineJS -->
<script>
    window.initialTickets = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(tickets));
</script>

<div class="max-w-5xl mx-auto" x-data="supportApp()">

    
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-2">Trợ Giúp & Hỗ Trợ</h2>
            <p class="text-gray-500 text-sm">Tìm câu trả lời hoặc liên hệ trực tiếp với đội ngũ hỗ trợ của chúng tôi.</p>
        </div>
        <div class="relative w-full md:w-80">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-[20px]">search</span>
            <input type="text" x-model="searchQuery" placeholder="Tìm kiếm câu hỏi thường gặp..." 
                   class="w-full bg-white border border-gray-200 text-gray-900 text-sm rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary/50 outline-none shadow-sm transition-all">
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
        
        <!-- LEFT: FAQ -->
        <div class="lg:col-span-2 space-y-6">
            
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-5 border-b border-gray-100 bg-gray-50/50">
                    <h3 class="font-bold text-gray-900 uppercase tracking-wider text-xs">CÂU HỎI THƯỜNG GẶP (FAQ)</h3>
                </div>
                
                <div class="p-2">
                    <!-- FAQ Group: Booking -->
                    <div class="mb-2">
                        <div class="px-4 py-2 text-xs font-bold text-gray-400 uppercase tracking-wider">Booking & Lịch Trình</div>
                        
                        <button @@click="openFaq === 1 ? openFaq = null : openFaq = 1" class="w-full flex justify-between items-center p-4 hover:bg-gray-50 rounded-xl transition-colors text-left group">
                            <span class="font-medium text-gray-900 group-hover:text-primary transition-colors">Tôi có thể hủy booking đã xác nhận không?</span>
                            <span class="material-symbols-outlined text-gray-400 transition-transform duration-200" :class="openFaq === 1 ? 'rotate-180' : ''">expand_more</span>
                        </button>
                        <div x-show="openFaq === 1" x-collapse>
                            <div class="px-4 pb-4 pt-1 text-sm text-gray-600 leading-relaxed bg-gray-50 rounded-lg mx-2 mb-2">
                                Bạn có thể hủy booking ở trạng thái "Chờ duyệt" mà không bị ảnh hưởng. Đối với booking đã "Xác nhận", việc hủy sát ngày (dưới 48h) có thể ảnh hưởng đến tỷ lệ hiển thị hồ sơ của bạn và bạn sẽ phải chịu phí phạt theo chính sách.
                            </div>
                        </div>

                        <button @@click="openFaq === 2 ? openFaq = null : openFaq = 2" class="w-full flex justify-between items-center p-4 hover:bg-gray-50 rounded-xl transition-colors text-left group">
                            <span class="font-medium text-gray-900 group-hover:text-primary transition-colors">Khách không đến (No-show), tôi phải làm sao?</span>
                            <span class="material-symbols-outlined text-gray-400 transition-transform duration-200" :class="openFaq === 2 ? 'rotate-180' : ''">expand_more</span>
                        </button>
                        <div x-show="openFaq === 2" x-collapse>
                            <div class="px-4 pb-4 pt-1 text-sm text-gray-600 leading-relaxed bg-gray-50 rounded-lg mx-2 mb-2">
                                Nếu khách không có mặt sau 30 phút so với giờ hẹn, vui lòng liên hệ trực tiếp khách qua chat hoặc điện thoại. Nếu không liên lạc được, hãy chụp ảnh check-in tại điểm hẹn và nhấn "Đánh dấu khách không đến" trong chi tiết booking. Bạn vẫn sẽ nhận được thanh toán đầy đủ.
                            </div>
                        </div>
                    </div>

                    <!-- FAQ Group: Payment -->
                    <div class="mb-2 border-t border-gray-100 pt-2">
                        <div class="px-4 py-2 text-xs font-bold text-gray-400 uppercase tracking-wider">Thanh toán</div>
                        
                        <button @@click="openFaq === 3 ? openFaq = null : openFaq = 3" class="w-full flex justify-between items-center p-4 hover:bg-gray-50 rounded-xl transition-colors text-left group">
                            <span class="font-medium text-gray-900 group-hover:text-primary transition-colors">Bao lâu tôi nhận được tiền giải ngân?</span>
                            <span class="material-symbols-outlined text-gray-400 transition-transform duration-200" :class="openFaq === 3 ? 'rotate-180' : ''">expand_more</span>
                        </button>
                        <div x-show="openFaq === 3" x-collapse>
                            <div class="px-4 pb-4 pt-1 text-sm text-gray-600 leading-relaxed bg-gray-50 rounded-lg mx-2 mb-2">
                                Tiền sẽ được giữ ở trạng thái "Tạm giữ" an toàn tại hệ thống TripMate. Ngay sau khi tour kết thúc (thời gian dự kiến kết thúc + 2 giờ), hệ thống sẽ tự động giải ngân vào ví "Đã nhận" của bạn.
                            </div>
                        </div>
                        
                        <button @@click="openFaq === 4 ? openFaq = null : openFaq = 4" class="w-full flex justify-between items-center p-4 hover:bg-gray-50 rounded-xl transition-colors text-left group">
                            <span class="font-medium text-gray-900 group-hover:text-primary transition-colors">Phí nền tảng tính như thế nào?</span>
                            <span class="material-symbols-outlined text-gray-400 transition-transform duration-200" :class="openFaq === 4 ? 'rotate-180' : ''">expand_more</span>
                        </button>
                        <div x-show="openFaq === 4" x-collapse>
                            <div class="px-4 pb-4 pt-1 text-sm text-gray-600 leading-relaxed bg-gray-50 rounded-lg mx-2 mb-2">
                                TripMate thu phí nền tảng là 15% trên tổng giá trị tour. Phí này được dùng để duy trì hệ thống marketing tìm khách hàng mới, bảo vệ quyền lợi bảo hiểm chuyến đi và duy trì cổng thanh toán quốc tế.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- My Tickets -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-5 border-b border-gray-100 bg-gray-50/50 flex justify-between items-center">
                    <h3 class="font-bold text-gray-900 uppercase tracking-wider text-xs">Yêu cầu hỗ trợ của tôi (Tickets)</h3>
                    <button @@click="isModalOpen = true" class="text-primary hover:text-primary-dark font-bold text-sm transition-colors flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">add_circle</span> Tạo ticket mới
                    </button>
                </div>
                
                <div class="p-2">
                    <template x-for="t in tickets" :key="t.Id">
                        <div class="flex items-center justify-between p-4 hover:bg-gray-50 rounded-xl transition-colors border-b border-gray-50 last:border-0 cursor-pointer">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
                                     :class="t.Status === 'Pending' ? 'bg-amber-100 text-amber-600' : 'bg-green-100 text-green-600'">
                                    <span class="material-symbols-outlined text-[20px]" x-show="t.Status === 'Pending'">hourglass_empty</span>
                                    <span class="material-symbols-outlined text-[20px]" x-show="t.Status === 'Resolved'">check_circle</span>
                                </div>
                                <div>
                                    <div class="flex items-center gap-2 mb-0.5">
                                        <span class="font-mono text-xs font-bold text-gray-400" x-text="'#' + t.Id"></span>
                                        <h4 class="font-bold text-gray-900 text-sm" x-text="t.Title"></h4>
                                    </div>
                                    <p class="text-xs text-gray-500" x-text="t.Date"></p>
                                </div>
                            </div>
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase"
                                  :class="t.Status === 'Pending' ? 'bg-amber-50 text-amber-700 border border-amber-100' : 'bg-green-50 text-green-700 border border-green-100'"
                                  x-text="t.Status === 'Pending' ? 'Đang xử lý' : 'Đã giải quyết'">
                            </span>
                        </div>
                    </template>
                </div>
            </div>

        </div>

        <!-- RIGHT: DIRECT CONTACT -->
        <div class="space-y-6">
            <div class="bg-gray-900 rounded-2xl p-6 text-white shadow-xl relative overflow-hidden">
                <!-- Decorative elements -->
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-white opacity-5 rounded-full blur-2xl"></div>
                <div class="absolute right-10 bottom-10 w-20 h-20 bg-primary opacity-20 rounded-full blur-xl"></div>
                
                <h3 class="font-bold uppercase tracking-wider text-xs text-gray-400 mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px]">headset_mic</span> Liên hệ trực tiếp
                </h3>
                
                <div class="space-y-6 relative z-10">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-white text-[20px]">mail</span>
                        </div>
                        <div>
                            <p class="text-sm text-gray-400 mb-1">Gửi Email</p>
                            <a href="mailto:support@tripmate.com" class="font-bold text-lg hover:text-primary transition-colors">support@tripmate.com</a>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-white text-[20px]">forum</span>
                        </div>
                        <div>
                            <p class="text-sm text-gray-400 mb-1">Live Chat</p>
                            <p class="font-bold text-lg">Thứ 2 - Thứ 6</p>
                            <p class="text-sm text-gray-400">08:00 AM - 18:00 PM</p>
                            <button class="mt-3 w-full bg-primary hover:bg-primary-dark text-white font-bold py-2.5 rounded-xl transition-colors shadow-sm">
                                Bắt đầu Chat
                            </button>
                        </div>
                    </div>
                </div>
                
                <div class="mt-6 pt-6 border-t border-gray-700/50 flex items-center gap-2 text-sm text-gray-400">
                    <span class="material-symbols-outlined text-green-400 text-[18px]">bolt</span>
                    Thời gian phản hồi dự kiến: <b>&lt; 4 giờ</b>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Ticket Modal -->
    <div x-show="isModalOpen" class="relative z-[100]" aria-labelledby="modal-title" role="dialog" aria-modal="true" style="display: none;">
        
        <div x-show="isModalOpen" 
             x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" 
             x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" 
             class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" @@click="isModalOpen = false"></div>

        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div x-show="isModalOpen" 
                     x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" 
                     x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" 
                     class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-xl">
                    
                    <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                        <h3 class="text-lg font-bold text-gray-900" id="modal-title">Gửi Yêu Cầu Hỗ Trợ Mới</h3>
                        <button type="button" @@click="isModalOpen = false" class="text-gray-400 hover:bg-gray-200 hover:text-gray-600 rounded-full w-8 h-8 flex items-center justify-center transition-colors">
                            <span class="material-symbols-outlined text-[20px]">close</span>
                        </button>
                    </div>
                    
                    <form @@submit.prevent="submitTicket" class="px-6 py-6 space-y-5">
                        
                        <div>
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Loại vấn đề <span class="text-red-500">*</span></label>
                            <select x-model="newTicket.type" required class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary/50 outline-none">
                                <option value="" disabled>-- Chọn loại vấn đề --</option>
                                <option value="booking">Booking / Lịch trình</option>
                                <option value="payment">Thanh toán / Giải ngân</option>
                                <option value="account">Tài khoản / Xác minh</option>
                                <option value="technical">Lỗi kỹ thuật hệ thống</option>
                                <option value="other">Khác</option>
                            </select>
                        </div>
                        
                        <div x-show="newTicket.type === 'booking' || newTicket.type === 'payment'" style="display: none;">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Booking liên quan (Tùy chọn)</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[18px]">search</span>
                                <input type="text" x-model="newTicket.bookingId" placeholder="Nhập mã booking (VD: BKG-260612)..." class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 pl-10 focus:ring-2 focus:ring-primary/50 outline-none">
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Tiêu đề <span class="text-red-500">*</span></label>
                            <input type="text" x-model="newTicket.title" required placeholder="Tóm tắt vấn đề của bạn..." class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary/50 outline-none">
                        </div>
                        
                        <div>
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Mô tả chi tiết <span class="text-red-500">*</span></label>
                            <textarea x-model="newTicket.description" required rows="4" placeholder="Cung cấp chi tiết vấn đề bạn đang gặp phải..." class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary/50 outline-none resize-none"></textarea>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Đính kèm ảnh minh chứng (Tùy chọn)</label>
                            <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center bg-gray-50 hover:bg-orange-50 hover:border-primary transition-colors cursor-pointer group">
                                <span class="material-symbols-outlined text-[32px] text-gray-400 group-hover:text-primary mb-2 transition-colors">upload_file</span>
                                <p class="text-sm font-bold text-gray-700">Kéo thả file vào đây hoặc nhấp để tải lên</p>
                                <p class="text-xs text-gray-500 mt-1">Hỗ trợ JPG, PNG, PDF (Tối đa 5MB)</p>
                            </div>
                        </div>
                        
                        <div class="pt-2 flex justify-end gap-3">
                            <button type="button" @@click="isModalOpen = false" class="px-6 py-2.5 rounded-xl font-bold text-gray-600 hover:bg-gray-100 transition-colors">
                                Hủy
                            </button>
                            <button type="submit" class="px-6 py-2.5 rounded-xl font-bold bg-primary text-white hover:bg-primary-dark transition-colors shadow-sm flex items-center gap-2">
                                Gửi yêu cầu <span class="material-symbols-outlined text-[18px]">send</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function supportApp() {
            return {
                searchQuery: '',
                isModalOpen: false,
                openFaq: null,
                tickets: window.initialTickets || [],
                newTicket: { type: '', bookingId: '', title: '', description: '' },
                
                submitTicket() {
                    if(!this.newTicket.title || !this.newTicket.description) return;
                    showToast('success', 'Đã gửi yêu cầu hỗ trợ thành công. Chúng tôi sẽ phản hồi sớm nhất có thể!');
                    this.tickets.unshift({
                        Id: 'TK-003',
                        Title: this.newTicket.title,
                        Status: 'Pending',
                        Date: new Date().toLocaleDateString('vi-VN')
                    });
                    this.isModalOpen = false;
                    this.newTicket = { type: '', bookingId: '', title: '', description: '' };
                }
            }
        }
    </script>
}
