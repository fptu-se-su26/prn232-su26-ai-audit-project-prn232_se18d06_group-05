                            </template>
                            <template x-if="!selectedRequest || !selectedRequest.travelerAvatar">
                                <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl bg-white text-lg font-bold text-orange-600 ring-1 ring-orange-100"
