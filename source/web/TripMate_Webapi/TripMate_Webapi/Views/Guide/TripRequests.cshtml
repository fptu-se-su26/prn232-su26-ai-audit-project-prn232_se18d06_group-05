                                    <span x-text="offerStatusLabel(offer.status)"></span>
                                </span>
                                <span class="truncate font-mono text-xs text-gray-400" x-text="'#' + shortId(offer.id)"></span>
                            </div>
                            <p class="flex items-center gap-1 text-xs font-medium text-gray-500"><span class="material-symbols-outlined text-sm">schedule</span> Sent <span x-text="formatTimeAgo(offer.sentAt)"></span></p>
                        </div>

                        <div class="grid gap-5 p-5 lg:grid-cols-[1fr_220px]">
                            <div class="min-w-0">
                                <div class="flex items-start gap-3">
                                    <img :src="offer.travelerAvatar || '/images/AVATAR.png'" :alt="offer.travelerName + ' avatar'" onerror="this.src='/images/AVATAR.png'" class="h-11 w-11 flex-shrink-0 rounded-xl object-cover ring-1 ring-gray-200">
                                    <div class="min-w-0 flex-1">
                                        <p class="text-xs font-semibold text-gray-500">Offer to <span class="font-bold text-gray-800" x-text="offer.travelerName"></span></p>
                                        <h2 class="mt-0.5 truncate text-lg font-bold text-gray-900" x-text="offer.destination" :title="offer.destination"></h2>
                                    </div>
                                </div>

                                <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-gray-600">
                                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-violet-50 px-2.5 py-1.5 text-violet-700"><span class="material-symbols-outlined text-base">calendar_month</span><span x-text="formatDateRange(offer.startDate, offer.endDate)"></span></span>
                                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-50 px-2.5 py-1.5 text-emerald-700"><span class="material-symbols-outlined text-base">group</span><span x-text="offer.groupSize + (offer.groupSize === 1 ? ' traveler' : ' travelers')"></span></span>
                                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-amber-50 px-2.5 py-1.5 capitalize text-amber-700"><span class="material-symbols-outlined text-base">payments</span><span x-text="offer.budget || 'Flexible budget'"></span></span>
                                </div>

                                <div class="mt-4 rounded-xl border border-gray-100 bg-gray-50 px-4 py-3">
                                    <p class="mb-1 text-[11px] font-bold uppercase tracking-wide text-gray-400">Your pitch</p>
                                    <p class="line-clamp-2 text-sm leading-relaxed text-gray-600" x-text="offer.message"></p>
                                </div>
                            </div>

                            <div class="flex flex-col justify-between border-t border-gray-100 pt-4 lg:border-l lg:border-t-0 lg:pl-5 lg:pt-0">
                                <div class="lg:text-right">
                                    <p class="text-[11px] font-bold uppercase tracking-wide text-gray-400">Proposed total</p>
                                    <p class="mt-1 text-2xl font-black text-orange-600" x-text="formatCurrency(offer.proposedPrice)"></p>
                                    <p class="mt-1 text-xs text-gray-400">Entire trip duration</p>
                                </div>
                                <button type="button" @@click="openOfferDetail(offer)" class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-bold text-gray-700 transition-colors hover:border-orange-200 hover:bg-orange-50 hover:text-orange-700">
                                    <span class="material-symbols-outlined text-lg">visibility</span> View details
                                </button>
                            </div>
                        </div>
                    </article>
                </template>
            </div>
        </section>
    </div>

    <!-- Send Offer Modal -->
    <div x-show="isModalOpen"
         class="fixed inset-0 z-50 flex items-center justify-center bg-gray-950/60 p-3 backdrop-blur-sm sm:p-6"
         style="display: none;"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @@click.self="if (!isSubmitting) closeOfferModal()"
         @@keydown.escape.window="if (isModalOpen && !isSubmitting) closeOfferModal()">

        <div role="dialog"
             aria-modal="true"
             aria-labelledby="offer-modal-title"
             aria-describedby="offer-modal-description"
             class="flex max-h-[92vh] w-full max-w-xl flex-col overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-black/5"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="translate-y-3 scale-95 opacity-0"
             x-transition:enter-end="translate-y-0 scale-100 opacity-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="translate-y-0 scale-100 opacity-100"
             x-transition:leave-end="translate-y-3 scale-95 opacity-0">

            <!-- Modal Header -->
            <div class="flex items-start justify-between gap-4 bg-gradient-to-r from-orange-500 to-orange-600 px-5 py-4 sm:px-6 sm:py-5">
                <div class="flex min-w-0 items-center gap-3">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-white/15 text-white ring-1 ring-white/20">
                        <span class="material-symbols-outlined" aria-hidden="true">outgoing_mail</span>
                    </div>
                    <div class="min-w-0">
                        <h3 id="offer-modal-title" class="text-lg font-bold text-white sm:text-xl">Send Custom Offer</h3>
