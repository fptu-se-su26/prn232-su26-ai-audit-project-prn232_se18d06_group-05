                    <p class="mt-2 whitespace-pre-line rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm leading-relaxed text-gray-700" x-text="selectedOffer ? selectedOffer.message : ''"></p>
                </section>

                <section>
                    <h4 class="flex items-center gap-2 text-sm font-bold text-gray-900"><span class="material-symbols-outlined text-lg text-orange-500">format_quote</span>Traveler request notes</h4>
                    <p class="mt-2 whitespace-pre-line rounded-xl border border-amber-100 bg-amber-50/60 px-4 py-3 text-sm italic leading-relaxed text-gray-700" x-text="selectedOffer && selectedOffer.requestNotes ? selectedOffer.requestNotes : 'The traveler did not add any special notes.'"></p>
                </section>

                <div class="flex items-start gap-2 rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-xs leading-relaxed text-blue-800">
