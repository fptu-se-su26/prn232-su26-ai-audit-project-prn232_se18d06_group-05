                                    class="inline-flex flex-1 items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-2.5 text-sm font-bold text-white shadow-sm transition-all hover:from-orange-600 hover:to-orange-700 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 sm:flex-none"
                                    :disabled="isSubmitting">
                                <span class="material-symbols-outlined text-base" :class="isSubmitting ? 'animate-spin' : ''" aria-hidden="true" x-text="isSubmitting ? 'progress_activity' : 'send'"></span>
                                <span x-text="isSubmitting ? 'Sending...' : 'Send Offer'">Send Offer</span>
                            </button>
