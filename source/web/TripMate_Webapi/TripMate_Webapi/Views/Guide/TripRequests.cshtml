            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // A global factory works on first load and after Turbo replaces the page body.
        window.tripRequestsBoard = function () {
            return {
                viewMode: 'requests',
                requests: [],
                offers: [],
                stats: { offersSentThisWeek: 0, acceptedOffers: 0, successRate: 0 },
                searchQuery: '',
                sortBy: 'newest',
                isLoading: true,
                isLoadingStats: true,
                activeTab: 'all',
                offerSearchQuery: '',
                offerSortBy: 'newest',
                offerStatusFilter: 'all',
                isOffersLoading: true,
                isModalOpen: false,
                selectedRequest: null,
                isOfferDetailOpen: false,
                selectedOffer: null,
                isSubmitting: false,
                offerForm: {
                    message: '',
                    rawPrice: null,
                    displayPrice: ''
                },
                offerErrors: {
                    message: '',
                    price: ''
                },

                initData() {
                    this.fetchRequests();
                    this.fetchStats();
                    this.fetchOffers();
                },

                setViewMode(mode) {
                    this.viewMode = mode === 'offers' ? 'offers' : 'requests';
                },

                async fetchRequests() {
                    this.isLoading = true;
                    try {
                        const response = await fetch('/Guide/GetTripRequestsData');
                        if (response.ok) {
                            const data = await response.json();
                            this.requests = Array.isArray(data)
                                ? data.filter(request => request && request.id).map(request => this.normalizeRequest(request))
                                : [];
                        } else {
                            showToast('error', 'Failed to load requests');
                        }
                    } catch (err) {
                        console.error('Error fetching requests:', err);
                        showToast('error', 'Error loading requests');
                    } finally {
                        this.isLoading = false;
                    }
                },

                async fetchStats() {
                    this.isLoadingStats = true;
                    try {
                        const response = await fetch('/Guide/GetOfferStats');
                        if (response.ok) {
                            this.stats = await response.json();
                        }
                    } catch (err) {
                        console.error('Error fetching stats:', err);
                    } finally {
                        this.isLoadingStats = false;
                    }
                },

                async fetchOffers() {
                    this.isOffersLoading = true;
                    try {
                        const response = await fetch('/Guide/GetMyOffersData');
                        if (response.ok) {
                            const data = await response.json();
                            this.offers = Array.isArray(data)
                                ? data.filter(offer => offer && offer.id).map(offer => this.normalizeOffer(offer))
                                : [];
                        } else {
                            showToast('error', 'Failed to load your offers');
                        }
                    } catch (err) {
                        console.error('Error fetching guide offers:', err);
                        showToast('error', 'Error loading your offers');
                    } finally {
                        this.isOffersLoading = false;
                    }
                },

                filteredRequests() {
                    let filtered = [...this.requests];

                    // Apply business-focused filters.
                    if (this.activeTab === 'new') {
                        filtered = filtered.filter(req => this.isNew(req.postedAt));
                    } else if (this.activeTab === 'not-offered') {
                        filtered = filtered.filter(req => !req.hasSentOffer);
                    } else if (this.activeTab === 'starting-soon') {
                        filtered = filtered.filter(req => this.isStartingSoon(req.startDate));
                    }

                    // Apply a safe, case-insensitive search across visible request fields.
                    const query = this.searchQuery.trim().toLowerCase();
                    if (query) {
                        filtered = filtered.filter(req =>
                            String(req.destination ?? '').toLowerCase().includes(query) ||
                            String(req.notes ?? '').toLowerCase().includes(query) ||
                            String(req.travelerName ?? '').toLowerCase().includes(query)
                        );
                    }

                    // Apply client-side sorting without mutating the API response.
                    filtered.sort((a, b) => {
                        if (this.sortBy === 'soonest') {
                            return this.dateValue(a.startDate, Number.MAX_SAFE_INTEGER) - this.dateValue(b.startDate, Number.MAX_SAFE_INTEGER);
                        }
                        if (this.sortBy === 'highest-budget') {
                            return this.budgetRank(b.budget) - this.budgetRank(a.budget);
                        }
                        if (this.sortBy === 'largest-group') {
                            return Number(b.groupSize ?? 0) - Number(a.groupSize ?? 0);
                        }
                        return this.dateValue(b.postedAt, 0) - this.dateValue(a.postedAt, 0);
                    });

                    return filtered;
                },

                filteredOffers() {
                    let filtered = [...this.offers];
                    if (this.offerStatusFilter !== 'all') {
                        filtered = filtered.filter(offer => this.normalizedOfferStatus(offer.status) === this.offerStatusFilter);
                    }

                    const query = this.offerSearchQuery.trim().toLowerCase();
                    if (query) {
                        filtered = filtered.filter(offer =>
                            String(offer.travelerName ?? '').toLowerCase().includes(query) ||
                            String(offer.destination ?? '').toLowerCase().includes(query) ||
                            String(offer.message ?? '').toLowerCase().includes(query) ||
                            String(offer.requestNotes ?? '').toLowerCase().includes(query)
                        );
                    }

                    filtered.sort((a, b) => {
                        if (this.offerSortBy === 'oldest') {
                            return this.dateValue(a.sentAt, Number.MAX_SAFE_INTEGER) - this.dateValue(b.sentAt, Number.MAX_SAFE_INTEGER);
                        }
                        if (this.offerSortBy === 'highest-price') {
                            return Number(b.proposedPrice ?? 0) - Number(a.proposedPrice ?? 0);
                        }
                        if (this.offerSortBy === 'soonest') {
                            return this.dateValue(a.startDate, Number.MAX_SAFE_INTEGER) - this.dateValue(b.startDate, Number.MAX_SAFE_INTEGER);
                        }
                        return this.dateValue(b.sentAt, 0) - this.dateValue(a.sentAt, 0);
                    });

                    return filtered;
                },

                countByTab(tab) {
                    if (tab === 'new') return this.requests.filter(req => this.isNew(req.postedAt)).length;
                    if (tab === 'not-offered') return this.requests.filter(req => !req.hasSentOffer).length;
                    if (tab === 'starting-soon') return this.requests.filter(req => this.isStartingSoon(req.startDate)).length;
                    return this.requests.length;
                },

                offerCountByStatus(status) {
                    if (status === 'all') return this.offers.length;
                    return this.offers.filter(offer => this.normalizedOfferStatus(offer.status) === status).length;
                },

                requestTabClass(tab) {
                    return this.activeTab === tab
                        ? 'border-orange-500 bg-orange-500 text-white shadow-sm'
                        : 'border-gray-200 bg-white text-gray-600 hover:border-orange-200 hover:bg-orange-50 hover:text-orange-700';
                },

                requestTabCountClass(tab) {
                    return this.activeTab === tab ? 'bg-white/20 text-white' : 'bg-gray-100 text-gray-500';
                },

                offerTabClass(status) {
                    return this.offerStatusFilter === status
                        ? 'border-orange-500 bg-orange-500 text-white shadow-sm'
                        : 'border-gray-200 bg-white text-gray-600 hover:border-orange-200 hover:bg-orange-50 hover:text-orange-700';
                },

                offerTabCountClass(status) {
                    return this.offerStatusFilter === status ? 'bg-white/20 text-white' : 'bg-gray-100 text-gray-500';
                },

                normalizeRequest(request) {
                    return {
                        id: '',
                        travelerAvatar: '',
                        travelerName: 'Traveler',
                        destination: 'Unknown Destination',
                        postedAt: null,
                        startDate: null,
                        endDate: null,
                        groupSize: 0,
                        budget: '',
                        notes: '',
                        hasSentOffer: false,
                        ...(request || {})
                    };
                },

                normalizeOffer(offer) {
                    return {
                        id: '',
                        status: 'pending',
                        travelerAvatar: '',
                        travelerName: 'Traveler',
                        destination: 'Unknown Destination',
                        sentAt: null,
                        startDate: null,
                        endDate: null,
                        groupSize: 0,
                        budget: '',
                        message: '',
                        requestNotes: '',
                        proposedPrice: 0,
                        ...(offer || {})
                    };
                },

                normalizedOfferStatus(status) {
                    return String(status ?? 'pending').trim().toLowerCase();
                },

                offerStatusLabel(status) {
                    const labels = { pending: 'Pending', accepted: 'Accepted', rejected: 'Rejected', expired: 'Expired', withdrawn: 'Withdrawn' };
                    return labels[this.normalizedOfferStatus(status)] ?? 'Unknown';
                },

                offerStatusIcon(status) {
                    const icons = { pending: 'schedule', accepted: 'check_circle', rejected: 'cancel', expired: 'timer_off', withdrawn: 'undo' };
                    return icons[this.normalizedOfferStatus(status)] ?? 'help';
                },

                offerStatusClass(status) {
                    const classes = {
                        pending: 'border-amber-200 bg-amber-50 text-amber-700',
                        accepted: 'border-emerald-200 bg-emerald-50 text-emerald-700',
                        rejected: 'border-red-200 bg-red-50 text-red-700',
                        expired: 'border-gray-200 bg-gray-100 text-gray-600',
                        withdrawn: 'border-slate-200 bg-slate-100 text-slate-600'
                    };
                    return classes[this.normalizedOfferStatus(status)] ?? 'border-gray-200 bg-gray-50 text-gray-600';
                },

                offerStatusHint(status) {
                    const hints = {
                        pending: 'The traveler has not responded yet. You can monitor the result here.',
                        accepted: 'The traveler accepted this proposal. Continue the trip workflow from your bookings area.',
                        rejected: 'The traveler chose not to proceed with this proposal. The offer remains here for your records.',
                        expired: 'This proposal is no longer actionable because the request closed or its trip date has passed.',
                        withdrawn: 'This proposal has been withdrawn and is kept here for your records.'
                    };
                    return hints[this.normalizedOfferStatus(status)] ?? 'This offer is kept here for your records.';
                },

                isStartingSoon(dateStr) {
                    if (!dateStr) return false;
                    const start = new Date(dateStr);
                    if (Number.isNaN(start.getTime())) return false;

                    const today = new Date();
                    today.setHours(0, 0, 0, 0);
                    start.setHours(0, 0, 0, 0);

                    const fourteenDaysFromNow = new Date(today);
                    fourteenDaysFromNow.setDate(today.getDate() + 14);
                    return start >= today && start <= fourteenDaysFromNow;
                },

                dateValue(dateStr, fallback) {
                    const value = new Date(dateStr).getTime();
                    return Number.isNaN(value) ? fallback : value;
                },

                budgetRank(budget) {
                    const ranks = { economy: 1, standard: 2, premium: 3, luxury: 4 };
                    return ranks[String(budget ?? '').toLowerCase()] ?? 0;
                },

                formatPriceInput(e) {
                    // Remove non-digits
                    let raw = e.target.value.replace(/\D/g, '');
                    if (raw) {
                        this.offerForm.rawPrice = parseInt(raw, 10);
                        this.offerForm.displayPrice = new Intl.NumberFormat('vi-VN').format(this.offerForm.rawPrice);
                        this.offerErrors.price = '';
                    } else {
                        this.offerForm.rawPrice = null;
                        this.offerForm.displayPrice = '';
                    }
                },

                formatCurrency(value) {
                    if (value === null || value === undefined || value === '') return '';
                    return new Intl.NumberFormat('vi-VN', {
                        style: 'currency',
                        currency: 'VND',
                        maximumFractionDigits: 0
                    }).format(value);
                },

                resetOfferForm() {
                    this.offerForm = { message: '', rawPrice: null, displayPrice: '' };
                    this.offerErrors = { message: '', price: '' };
                },

                validateOfferForm() {
                    const message = this.offerForm.message.trim();
                    this.offerErrors.message = message ? '' : 'Please add a short pitch and suggested itinerary.';
                    this.offerErrors.price = this.offerForm.rawPrice > 0 ? '' : 'Please enter a valid total price greater than 0.';
                    return !this.offerErrors.message && !this.offerErrors.price;
                },

                openOfferModal(request) {
                    this.selectedRequest = request;
                    this.resetOfferForm();
                    this.isModalOpen = true;
                    document.body.style.overflow = 'hidden';
                    this.$nextTick(() => this.$refs.offerMessage?.focus());
                },

                closeOfferModal() {
                    this.isModalOpen = false;
                    setTimeout(() => {
                        this.selectedRequest = null;
                        this.resetOfferForm();
                    }, 300);
                    document.body.style.overflow = '';
                },

                openOfferDetail(offer) {
                    this.selectedOffer = offer;
                    this.isOfferDetailOpen = true;
                    document.body.style.overflow = 'hidden';
                },

                closeOfferDetail() {
                    this.isOfferDetailOpen = false;
                    setTimeout(() => { this.selectedOffer = null; }, 250);
                    document.body.style.overflow = '';
                },

                async submitOffer() {
                    if (!this.selectedRequest || !this.validateOfferForm()) {
                        return;
                    }

                    this.isSubmitting = true;
                    try {
                        const response = await fetch('/Guide/SendTripOffer', {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: {
                                'Accept': 'application/json',
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                tripRequestId: this.selectedRequest.id,
                                message: this.offerForm.message.trim(),
                                proposedPrice: parseFloat(this.offerForm.rawPrice)
                            })
                        });

                        const contentType = response.headers.get('content-type') ?? '';
                        const result = contentType.includes('application/json')
                            ? await response.json()
                            : {};

                        if (!response.ok || result.success !== true || !result.offerId) {
                            const fallbackMessage = `Unable to send offer (HTTP ${response.status}).`;
                            const traceSuffix = result.traceId ? ` (Trace: ${result.traceId})` : '';
                            throw new Error((result.message || fallbackMessage) + traceSuffix);
                        }

                        if (result.success === true) {
                            // Update local state
                            const index = this.requests.findIndex(r => r.id === this.selectedRequest.id);
                            if (index !== -1) {
                                this.requests[index].hasSentOffer = true;
                            }
                            // Refresh all guide-side offer summaries.
                            this.fetchStats();
                            this.fetchOffers();

                            // Close modal
                            this.closeOfferModal();

                            // Use the shared Guide layout toast only after persistence succeeds.
                            showToast(
                                'success',
                                'Offer của bạn đã được lưu và gửi tới traveler.',
                                'Gửi offer thành công',
                                4500
                            );
                        }
                    } catch (err) {
                        console.error('Error sending offer:', err);
                        const errorMessage = err instanceof Error && err.message
                            ? err.message
                            : 'Đã xảy ra lỗi. Vui lòng thử lại.';
                        showToast('error', errorMessage, 'Không thể gửi offer');
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                formatDate(dateStr) {
                    if (!dateStr) return '';
                    const date = new Date(dateStr);
                    if (Number.isNaN(date.getTime())) return '';
                    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' });
                },

                formatDateRange(startDate, endDate) {
                    const start = this.formatDate(startDate);
                    const end = this.formatDate(endDate);
                    if (!end || start === end) return start;
                    return `${start} - ${end}`;
                },

                formatDateTime(dateStr) {
                    if (!dateStr) return '';
                    const date = new Date(dateStr);
                    if (Number.isNaN(date.getTime())) return '';
                    return date.toLocaleString('en-US', {
                        month: 'short', day: 'numeric', year: 'numeric',
                        hour: '2-digit', minute: '2-digit'
                    });
                },

                shortId(value) {
                    const id = String(value ?? '');
                    return id ? id.slice(0, 8) : 'N/A';
                },

                formatTimeAgo(dateStr) {
                    if (!dateStr) return '';
                    const date = new Date(dateStr);
                    if (Number.isNaN(date.getTime())) return '';
                    const now = new Date();
                    const diffMs = now - date;
                    const diffMins = Math.max(0, Math.floor(diffMs / 60000));

                    if (diffMins < 60) return `${diffMins}m ago`;
                    const diffHours = Math.floor(diffMins / 60);
                    if (diffHours < 24) return `${diffHours}h ago`;
                    const diffDays = Math.floor(diffHours / 24);
                    return `${diffDays}d ago`;
                },

                isNew(dateStr) {
                    if (!dateStr) return false;
                    const date = new Date(dateStr);
                    if (Number.isNaN(date.getTime())) return false;
                    const now = new Date();
                    const diffMs = now - date;
                    return diffMs >= 0 && diffMs < (24 * 60 * 60 * 1000);
                }
            };
        };
    </script>
}
