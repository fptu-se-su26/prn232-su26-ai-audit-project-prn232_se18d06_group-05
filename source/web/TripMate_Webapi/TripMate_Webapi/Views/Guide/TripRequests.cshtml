                        <div class="flex gap-3 sm:flex-shrink-0">
                            <button type="button"
                                    @@click="closeOfferModal()"
                                    class="flex-1 rounded-xl px-5 py-2.5 text-sm font-semibold text-gray-700 transition-colors hover:bg-gray-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 sm:flex-none"
                                    :disabled="isSubmitting">
