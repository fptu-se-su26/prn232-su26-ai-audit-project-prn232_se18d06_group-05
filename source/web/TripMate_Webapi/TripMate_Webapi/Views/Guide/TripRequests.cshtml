         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @@click.self="closeOfferDetail()"
         @@keydown.escape.window="if (isOfferDetailOpen) closeOfferDetail()">
        <div role="dialog"
             aria-modal="true"
             aria-labelledby="offer-detail-title"
             class="flex max-h-[92vh] w-full max-w-2xl flex-col overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-black/5"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="translate-y-3 scale-95 opacity-0"
             x-transition:enter-end="translate-y-0 scale-100 opacity-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="translate-y-0 scale-100 opacity-100"
             x-transition:leave-end="translate-y-3 scale-95 opacity-0">
            <div class="flex items-start justify-between gap-4 border-b border-gray-100 bg-gradient-to-r from-gray-900 to-gray-800 px-5 py-4 sm:px-6 sm:py-5">
                <div class="min-w-0">
                    <div class="mb-2 flex flex-wrap items-center gap-2">
                        <span class="inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide"
                              :class="offerStatusClass(selectedOffer ? selectedOffer.status : '')">
                            <span class="material-symbols-outlined text-sm" x-text="offerStatusIcon(selectedOffer ? selectedOffer.status : '')"></span>
                            <span x-text="offerStatusLabel(selectedOffer ? selectedOffer.status : '')"></span>
                        </span>
                        <span class="font-mono text-xs text-gray-400" x-text="selectedOffer ? '#' + shortId(selectedOffer.id) : ''"></span>
                    </div>
                    <h3 id="offer-detail-title" class="truncate text-lg font-bold text-white sm:text-xl" x-text="selectedOffer ? selectedOffer.destination : 'Offer details'">Offer details</h3>
                    <p class="mt-1 flex items-center gap-1 text-xs text-gray-300">
                        <span class="material-symbols-outlined text-sm">schedule</span>
                        <span x-text="selectedOffer ? 'Sent ' + formatDateTime(selectedOffer.sentAt) : ''"></span>
                    </p>
                </div>
                <button type="button" @@click="closeOfferDetail()" class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg text-white/70 transition-colors hover:bg-white/10 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white" aria-label="Close offer details">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="min-h-0 flex-1 space-y-5 overflow-y-auto px-5 py-5 sm:px-6">
                <section class="rounded-xl border border-orange-100 bg-orange-50/70 p-4" aria-label="Traveler request summary">
                    <div class="flex items-center gap-3">
                        <img :src="selectedOffer && selectedOffer.travelerAvatar ? selectedOffer.travelerAvatar : '/images/AVATAR.png'"
                             :alt="selectedOffer ? selectedOffer.travelerName + ' avatar' : 'Traveler avatar'"
                             onerror="this.src='/images/AVATAR.png'"
                             class="h-11 w-11 flex-shrink-0 rounded-xl object-cover ring-2 ring-white">
                        <div class="min-w-0 flex-1">
                            <p class="text-xs font-semibold uppercase tracking-wide text-orange-700">Offer sent to</p>
                            <p class="truncate text-sm font-bold text-gray-900" x-text="selectedOffer ? selectedOffer.travelerName : ''"></p>
                        </div>
                        <div class="text-right">
                            <p class="text-[11px] font-bold uppercase tracking-wide text-gray-400">Proposed total</p>
                            <p class="mt-0.5 text-xl font-black text-orange-600" x-text="selectedOffer ? formatCurrency(selectedOffer.proposedPrice) : ''"></p>
                        </div>
                    </div>
                    <div class="mt-4 grid gap-2 border-t border-orange-100 pt-4 text-xs font-medium sm:grid-cols-3">
                        <div class="flex items-center gap-2 rounded-lg bg-white/80 px-3 py-2 text-violet-700"><span class="material-symbols-outlined text-base">calendar_month</span><span x-text="selectedOffer ? formatDateRange(selectedOffer.startDate, selectedOffer.endDate) : ''"></span></div>
                        <div class="flex items-center gap-2 rounded-lg bg-white/80 px-3 py-2 text-emerald-700"><span class="material-symbols-outlined text-base">group</span><span x-text="selectedOffer ? selectedOffer.groupSize + (selectedOffer.groupSize === 1 ? ' traveler' : ' travelers') : ''"></span></div>
                        <div class="flex items-center gap-2 rounded-lg bg-white/80 px-3 py-2 capitalize text-amber-700"><span class="material-symbols-outlined text-base">payments</span><span x-text="selectedOffer && selectedOffer.budget ? selectedOffer.budget : 'Flexible budget'"></span></div>
