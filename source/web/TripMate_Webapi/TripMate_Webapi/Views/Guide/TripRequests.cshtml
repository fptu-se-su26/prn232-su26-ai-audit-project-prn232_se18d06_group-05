                                   type="text"
                                   inputmode="numeric"
                                   autocomplete="off"
                                   x-model="offerForm.displayPrice"
                                   @@input="formatPriceInput"
                                   required
                                   aria-describedby="offer-price-help offer-price-error"
                                   :aria-invalid="offerErrors.price ? 'true' : 'false'"
                                   :class="offerErrors.price ? 'border-red-400 bg-red-50/40 focus:border-red-500 focus:ring-red-500/20' : 'border-gray-300 bg-gray-50 focus:border-orange-400 focus:bg-white focus:ring-orange-500/20'"
                                   class="w-full rounded-xl border py-3 pl-10 pr-24 text-base font-bold text-gray-900 outline-none transition-all placeholder:font-normal placeholder:text-gray-400 focus:ring-2"
                                   placeholder="2.500.000">
                            <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-400">VND</span>
                        </div>
                        <div id="offer-price-help" class="mt-2 flex items-start justify-between gap-3 text-xs">
                            <p class="flex items-center gap-1 text-gray-500">
                                <span class="material-symbols-outlined text-sm" aria-hidden="true">info</span>
                                Total amount for the entire trip.
                            </p>
                            <p x-show="offerForm.rawPrice" class="whitespace-nowrap font-semibold text-orange-600" x-text="formatCurrency(offerForm.rawPrice)"></p>
