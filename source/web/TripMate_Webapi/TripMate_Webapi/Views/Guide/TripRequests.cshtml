@{
    ViewData["Title"] = "Trip Requests & Offers";
    ViewData["ActivePage"] = "TripRequests";
    // Do not restore Alpine-rendered x-for nodes from a Turbo snapshot. Those
    // clones no longer own the original iteration scope (tab/request/offer).
    ViewData["TurboVisitControl"] = "reload";
    ViewData["TurboCacheControl"] = "no-cache";
    Layout = "_GuideLayout";
}

<div class="min-h-screen bg-gray-50" x-data="tripRequestsBoard()" x-init="initData()" data-turbo-temporary>
    <div class="mx-auto max-w-[1440px]">
        <!-- Marketplace header and controls -->
        <section class="mb-6 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm" aria-labelledby="trip-requests-title">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
                <div class="min-w-0">
                    <div class="flex items-center gap-3">
                        <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-orange-500 to-red-500 shadow-sm">
                            <span class="material-symbols-outlined text-xl text-white" aria-hidden="true" x-text="viewMode === 'requests' ? 'travel_explore' : 'outbox'"></span>
                        </div>
                        <div class="min-w-0">
                            <h1 id="trip-requests-title" class="truncate text-2xl font-bold tracking-tight text-gray-900" x-text="viewMode === 'requests' ? 'Trip Requests Board' : 'My Offers'">Trip Requests Board</h1>
                            <p class="mt-0.5 text-sm text-gray-500" x-text="viewMode === 'requests' ? 'Browse traveler plans and send a tailored offer.' : 'Track every proposal you have sent to travelers.'"></p>
                        </div>
                    </div>

                    <div class="mt-4 inline-flex rounded-xl bg-gray-100 p-1" role="tablist" aria-label="Trip request workspace">
                        <button type="button"
                                role="tab"
                                @@click="setViewMode('requests')"
                                :aria-selected="viewMode === 'requests'"
                                :class="viewMode === 'requests' ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-800'"
                                class="inline-flex items-center gap-2 rounded-lg px-3.5 py-2 text-sm font-semibold transition-all">
                            <span class="material-symbols-outlined text-lg" aria-hidden="true">explore</span>
                            Browse Requests
                        </button>
                        <button type="button"
                                role="tab"
                                @@click="setViewMode('offers')"
                                :aria-selected="viewMode === 'offers'"
                                :class="viewMode === 'offers' ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-800'"
                                class="inline-flex items-center gap-2 rounded-lg px-3.5 py-2 text-sm font-semibold transition-all">
                            <span class="material-symbols-outlined text-lg" aria-hidden="true">outgoing_mail</span>
                            My Offers
                            <span class="rounded-full bg-orange-100 px-1.5 py-0.5 text-[10px] font-bold text-orange-700" x-text="offers.length">0</span>
                        </button>
                    </div>
                </div>

                <!-- Context-aware quick stats -->
                <div class="grid w-full grid-cols-3 gap-2 lg:w-auto" aria-live="polite">
                    <div class="min-w-0 rounded-xl border border-orange-100 bg-orange-50/70 px-3 py-2.5 text-center lg:min-w-[112px]">
                        <p class="truncate text-[11px] font-semibold uppercase tracking-wide text-orange-700" x-text="viewMode === 'requests' ? 'Open requests' : 'Total offers'"></p>
                        <p class="mt-0.5 text-lg font-bold text-orange-600">
                            <span x-show="viewMode === 'requests' ? isLoading : isOffersLoading" class="inline-block h-5 w-6 animate-pulse rounded bg-orange-200"></span>
                            <span x-show="viewMode === 'requests' ? !isLoading : !isOffersLoading" x-text="viewMode === 'requests' ? requests.length : offers.length">0</span>
                        </p>
                    </div>
                    <div class="min-w-0 rounded-xl border border-gray-200 bg-gray-50 px-3 py-2.5 text-center lg:min-w-[112px]">
                        <p class="truncate text-[11px] font-semibold uppercase tracking-wide text-gray-500" x-text="viewMode === 'requests' ? 'Offers / week' : 'Pending'"></p>
                        <p class="mt-0.5 text-lg font-bold text-gray-900">
                            <span x-show="viewMode === 'requests' ? isLoadingStats : isOffersLoading" class="inline-block h-5 w-6 animate-pulse rounded bg-gray-200"></span>
                            <span x-show="viewMode === 'requests' ? !isLoadingStats : !isOffersLoading" x-text="viewMode === 'requests' ? stats.offersSentThisWeek : offerCountByStatus('pending')">0</span>
                        </p>
                    </div>
                    <div class="min-w-0 rounded-xl border border-emerald-100 bg-emerald-50/70 px-3 py-2.5 text-center lg:min-w-[112px]">
                        <p class="truncate text-[11px] font-semibold uppercase tracking-wide text-emerald-700" x-text="viewMode === 'requests' ? 'Success rate' : 'Accepted'"></p>
                        <p class="mt-0.5 text-lg font-bold text-emerald-600">
                            <span x-show="viewMode === 'requests' ? isLoadingStats : isOffersLoading" class="inline-block h-5 w-6 animate-pulse rounded bg-emerald-200"></span>
                            <span x-show="viewMode === 'requests' ? !isLoadingStats : !isOffersLoading" x-text="viewMode === 'requests' ? (stats.successRate > 0 ? stats.successRate + '%' : '—') : offerCountByStatus('accepted')">—</span>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Browse request controls -->
            <div x-show="viewMode === 'requests'">
                <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                    <div class="relative flex-1">
                        <label for="trip-request-search" class="sr-only">Search trip requests by destination, traveler, or notes</label>
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-xl text-gray-400" aria-hidden="true">search</span>
                        <input id="trip-request-search" type="search" x-model.debounce.200ms="searchQuery" placeholder="Search destination, traveler, or notes..." class="w-full rounded-xl border border-gray-200 bg-gray-50 py-3 pl-12 pr-11 text-sm text-gray-900 outline-none transition-all placeholder:text-gray-400 focus:border-orange-400 focus:bg-white focus:ring-2 focus:ring-orange-500/20">
                        <button type="button" x-show="searchQuery" @@click="searchQuery = ''" class="absolute right-3 top-1/2 flex h-7 w-7 -translate-y-1/2 items-center justify-center rounded-full text-gray-400 hover:bg-gray-200 hover:text-gray-700" aria-label="Clear search">
                            <span class="material-symbols-outlined text-lg" aria-hidden="true">close</span>
                        </button>
                    </div>
                    <div class="relative sm:w-52">
                        <label for="trip-request-sort" class="sr-only">Sort trip requests</label>
                        <span class="material-symbols-outlined pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-lg text-gray-400" aria-hidden="true">sort</span>
                        <select id="trip-request-sort" x-model="sortBy" class="w-full appearance-none rounded-xl border border-gray-200 bg-gray-50 py-3 pl-10 pr-9 text-sm font-medium text-gray-700 outline-none focus:border-orange-400 focus:bg-white focus:ring-2 focus:ring-orange-500/20">
                            <option value="newest">Newest first</option>
                            <option value="soonest">Starting soon</option>
                            <option value="highest-budget">Highest budget</option>
                            <option value="largest-group">Largest group</option>
                        </select>
                        <span class="material-symbols-outlined pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-lg text-gray-400" aria-hidden="true">expand_more</span>
                    </div>
                </div>

                <div class="mt-3 flex flex-col gap-3 border-t border-gray-100 pt-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex gap-2 overflow-x-auto pb-1" role="group" aria-label="Filter trip requests">
                        <button type="button" @@click="activeTab = 'all'" :aria-pressed="activeTab === 'all'" :class="requestTabClass('all')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span>All</span>
                            <span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="requestTabCountClass('all')" x-text="countByTab('all')">0</span>
                        </button>
                        <button type="button" @@click="activeTab = 'new'" :aria-pressed="activeTab === 'new'" :class="requestTabClass('new')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span class="material-symbols-outlined text-base" aria-hidden="true">new_releases</span>
                            <span>New</span>
                            <span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="requestTabCountClass('new')" x-text="countByTab('new')">0</span>
                        </button>
                        <button type="button" @@click="activeTab = 'not-offered'" :aria-pressed="activeTab === 'not-offered'" :class="requestTabClass('not-offered')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span class="material-symbols-outlined text-base" aria-hidden="true">mark_email_unread</span>
                            <span>Not offered</span>
                            <span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="requestTabCountClass('not-offered')" x-text="countByTab('not-offered')">0</span>
                        </button>
                        <button type="button" @@click="activeTab = 'starting-soon'" :aria-pressed="activeTab === 'starting-soon'" :class="requestTabClass('starting-soon')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span class="material-symbols-outlined text-base" aria-hidden="true">event_upcoming</span>
                            <span>Starting soon</span>
                            <span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="requestTabCountClass('starting-soon')" x-text="countByTab('starting-soon')">0</span>
                        </button>
                    </div>
                    <p class="whitespace-nowrap text-xs font-medium text-gray-500" aria-live="polite"><span class="font-bold text-gray-800" x-text="filteredRequests().length">0</span> results</p>
                </div>
            </div>

            <!-- My Offers controls -->
            <div x-show="viewMode === 'offers'">
                <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                    <div class="relative flex-1">
                        <label for="offer-search" class="sr-only">Search sent offers</label>
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-xl text-gray-400" aria-hidden="true">search</span>
                        <input id="offer-search" type="search" x-model.debounce.200ms="offerSearchQuery" placeholder="Search traveler, destination, or pitch..." class="w-full rounded-xl border border-gray-200 bg-gray-50 py-3 pl-12 pr-11 text-sm text-gray-900 outline-none placeholder:text-gray-400 focus:border-orange-400 focus:bg-white focus:ring-2 focus:ring-orange-500/20">
                        <button type="button" x-show="offerSearchQuery" @@click="offerSearchQuery = ''" class="absolute right-3 top-1/2 flex h-7 w-7 -translate-y-1/2 items-center justify-center rounded-full text-gray-400 hover:bg-gray-200 hover:text-gray-700" aria-label="Clear offer search"><span class="material-symbols-outlined text-lg">close</span></button>
                    </div>
                    <div class="relative sm:w-52">
                        <label for="offer-sort" class="sr-only">Sort sent offers</label>
                        <span class="material-symbols-outlined pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-lg text-gray-400">sort</span>
                        <select id="offer-sort" x-model="offerSortBy" class="w-full appearance-none rounded-xl border border-gray-200 bg-gray-50 py-3 pl-10 pr-9 text-sm font-medium text-gray-700 outline-none focus:border-orange-400 focus:bg-white focus:ring-2 focus:ring-orange-500/20">
                            <option value="newest">Recently sent</option>
                            <option value="oldest">Oldest first</option>
                            <option value="highest-price">Highest price</option>
                            <option value="soonest">Trip starting soon</option>
                        </select>
                        <span class="material-symbols-outlined pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-lg text-gray-400">expand_more</span>
                    </div>
                </div>

                <div class="mt-3 flex flex-col gap-3 border-t border-gray-100 pt-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex gap-2 overflow-x-auto pb-1" role="group" aria-label="Filter sent offers">
                        <button type="button" @@click="offerStatusFilter = 'all'" :aria-pressed="offerStatusFilter === 'all'" :class="offerTabClass('all')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span>All</span><span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="offerTabCountClass('all')" x-text="offerCountByStatus('all')">0</span>
                        </button>
                        <button type="button" @@click="offerStatusFilter = 'pending'" :aria-pressed="offerStatusFilter === 'pending'" :class="offerTabClass('pending')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span>Pending</span><span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="offerTabCountClass('pending')" x-text="offerCountByStatus('pending')">0</span>
                        </button>
                        <button type="button" @@click="offerStatusFilter = 'accepted'" :aria-pressed="offerStatusFilter === 'accepted'" :class="offerTabClass('accepted')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span>Accepted</span><span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="offerTabCountClass('accepted')" x-text="offerCountByStatus('accepted')">0</span>
                        </button>
                        <button type="button" @@click="offerStatusFilter = 'rejected'" :aria-pressed="offerStatusFilter === 'rejected'" :class="offerTabClass('rejected')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span>Rejected</span><span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="offerTabCountClass('rejected')" x-text="offerCountByStatus('rejected')">0</span>
                        </button>
                        <button type="button" @@click="offerStatusFilter = 'expired'" :aria-pressed="offerStatusFilter === 'expired'" :class="offerTabClass('expired')" class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border px-4 py-2 text-sm font-semibold transition-all">
                            <span>Expired</span><span class="rounded-full px-1.5 py-0.5 text-[10px]" :class="offerTabCountClass('expired')" x-text="offerCountByStatus('expired')">0</span>
                        </button>
                    </div>
                    <p class="whitespace-nowrap text-xs font-medium text-gray-500" aria-live="polite"><span class="font-bold text-gray-800" x-text="filteredOffers().length">0</span> offers</p>
                </div>
            </div>
        </section>

        <!-- Main Content with Sidebar Layout -->
        <div x-show="viewMode === 'requests'" class="flex gap-6">
            <!-- Left Column: Request Grid -->
            <div class="flex-1">
                <!-- Loading State -->
                <template x-if="isLoading">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <template x-for="i in 8">
                            <div class="bg-white rounded-xl border border-gray-100 p-4 animate-pulse">
                                <div class="h-4 bg-gray-200 rounded mb-3 w-24"></div>
                                <div class="h-20 bg-gray-100 rounded mb-3"></div>
                                <div class="h-10 bg-gray-200 rounded"></div>
                            </div>
                        </template>
                    </div>
                </template>

                <!-- Empty State -->
                <template x-if="!isLoading && filteredRequests().length === 0">
                    <div class="bg-white rounded-2xl p-16 text-center border border-gray-200">
                        <span class="material-symbols-outlined text-5xl text-gray-300 mx-auto block mb-4">search_off</span>
                        <h3 class="text-2xl font-bold text-gray-900 mb-2">No requests found</h3>
                        <p class="text-gray-500">Try adjusting your filters or check back later</p>
                    </div>
                </template>

                <!-- Request Cards Grid (3 Columns on Desktop) -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" x-show="!isLoading && filteredRequests().length > 0">
                    <template x-for="requestItem in filteredRequests()" :key="requestItem.id">
                        <div x-data="{ request: normalizeRequest(typeof requestItem === 'undefined' ? null : requestItem) }" class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:border-orange-300 hover:shadow-md transition-all duration-200 flex flex-col">

                            <!-- Card Header -->
                            <div class="px-4 pt-3 pb-2 border-b border-gray-100">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="flex items-center gap-2 flex-1 min-w-0">
                                        <template x-if="request.travelerAvatar && request.travelerAvatar !== ''">
                                            <img :src="request.travelerAvatar" alt="Avatar" class="w-7 h-7 rounded-full object-cover flex-shrink-0" onerror="this.src='/images/AVATAR.png'">
                                        </template>
                                        <template x-if="!request.travelerAvatar || request.travelerAvatar === ''">
                                            <div class="w-7 h-7 bg-gradient-to-br from-orange-400 to-orange-500 text-white rounded-full flex items-center justify-center font-bold text-xs flex-shrink-0" x-text="request.travelerName.charAt(0)"></div>
                                        </template>
                                        <span class="text-xs font-semibold text-gray-700 truncate" x-text="request.travelerName" :title="request.travelerName"></span>
                                    </div>
                                    <span x-show="isNew(request.postedAt)" class="bg-green-500 text-white text-[9px] font-bold px-2 py-0.5 rounded-full flex-shrink-0">NEW</span>
                                </div>
                                <p class="text-[10px] text-gray-400" x-text="formatTimeAgo(request.postedAt)"></p>
                            </div>

                            <!-- Card Body -->
                            <div class="px-4 py-3 flex-1">
                                <!-- Destination -->
                                <h2 class="font-bold text-gray-900 text-sm leading-snug mb-2" x-text="request.destination || 'Unknown Destination'" :title="request.destination"></h2>

                                <!-- Meta Tags -->
                                <div class="flex flex-wrap gap-1.5 mb-2">
                                    <span class="flex items-center gap-0.5 text-[9px] text-violet-600 bg-violet-50 px-1.5 py-0.5 rounded-lg font-medium whitespace-nowrap">
                                        <span class="material-symbols-outlined text-[10px]">calendar_month</span>
                                        <span x-text="formatDate(request.startDate)"></span>
                                    </span>
                                    <span class="flex items-center gap-0.5 text-[9px] text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded-lg font-medium">
                                        <span class="material-symbols-outlined text-[10px]">group</span>
                                        <span x-text="request.groupSize"></span>
                                    </span>
                                    <template x-if="request.budget">
                                        <span class="flex items-center gap-0.5 text-[9px] text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded-lg font-medium whitespace-nowrap">
                                            <span class="material-symbols-outlined text-[10px]">payments</span>
                                            <span x-text="request.budget.length > 8 ? request.budget.substring(0, 8) + '...' : request.budget" :title="request.budget"></span>
                                        </span>
                                    </template>
                                </div>

                                <!-- Notes -->
                                <p class="text-xs text-gray-500 leading-tight line-clamp-2" x-text="request.notes || 'No notes'" :title="request.notes"></p>
                            </div>

                            <!-- Card Footer -->
                            <div class="px-4 pb-3 pt-3 border-t border-gray-100">
                                <template x-if="!request.hasSentOffer">
                                    <button @@click="openOfferModal(request)" class="w-full flex items-center justify-center gap-1.5 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white text-xs font-bold py-2.5 rounded-lg transition-all shadow-sm hover:shadow-md active:scale-95">
                                        <span class="material-symbols-outlined text-[14px]">send</span> Offer
                                    </button>
                                </template>
                                <template x-if="request.hasSentOffer">
                                    <div class="w-full flex items-center justify-center gap-1.5 bg-green-50 text-green-700 text-xs font-bold py-2.5 rounded-lg border border-green-200">
                                        <span class="material-symbols-outlined text-[14px]">check_circle</span> Sent
                                    </div>
                                </template>
                            </div>
                        </div>
                    </template>
                </div>
            </div>

            <!-- Right Column: Sticky Tips Sidebar (Hidden on Mobile/Tablet) -->
            <div class="hidden lg:block w-64 flex-shrink-0">
                <div class="sticky top-8 bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
                    <!-- Header -->
                    <div class="px-5 py-4 bg-gradient-to-r from-orange-50 to-red-50 border-b border-gray-100 flex items-center gap-3">
                        <span class="material-symbols-outlined text-orange-600 text-xl">lightbulb</span>
                        <h3 class="font-bold text-gray-900 text-sm">Pro Tips</h3>
                    </div>
                    
                    <!-- Tips Content -->
                    <div class="px-5 py-4 space-y-3.5">
                        <!-- Tip 1 -->
                        <div class="flex gap-3">
                            <span class="material-symbols-outlined text-orange-500 flex-shrink-0 text-base mt-0.5">check_circle</span>
                            <p class="text-xs text-gray-700 leading-relaxed">Read traveler notes carefully and personalize your offer.</p>
                        </div>

                        <!-- Tip 2 -->
                        <div class="flex gap-3">
                            <span class="material-symbols-outlined text-orange-500 flex-shrink-0 text-base mt-0.5">check_circle</span>
                            <p class="text-xs text-gray-700 leading-relaxed">Include a clear itinerary and transparent pricing.</p>
                        </div>

                        <!-- Tip 3 -->
                        <div class="flex gap-3">
                            <span class="material-symbols-outlined text-orange-500 flex-shrink-0 text-base mt-0.5">check_circle</span>
                            <p class="text-xs text-gray-700 leading-relaxed">Respond quickly - travelers pick from first 3 good offers.</p>
                        </div>
                    </div>
                    
                    <!-- Footer Divider -->
                    <div class="px-5 py-3 border-t border-gray-100 bg-gray-50">
                        <p class="text-[11px] text-gray-500 font-medium">💡 Your response time matters!</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- My Offers workspace -->
        <section x-show="viewMode === 'offers'" aria-label="My sent offers">
            <div x-show="isOffersLoading" class="space-y-4">
                <template x-for="i in 3" :key="i">
                    <div class="animate-pulse rounded-2xl border border-gray-200 bg-white p-5">
                        <div class="mb-4 flex justify-between"><div class="h-5 w-28 rounded bg-gray-200"></div><div class="h-5 w-20 rounded bg-gray-100"></div></div>
                        <div class="grid gap-4 md:grid-cols-[1fr_180px]"><div><div class="mb-3 h-6 w-52 rounded bg-gray-200"></div><div class="h-16 rounded-xl bg-gray-100"></div></div><div class="h-24 rounded-xl bg-gray-100"></div></div>
                    </div>
                </template>
            </div>

            <div x-show="!isOffersLoading && filteredOffers().length === 0" class="rounded-2xl border border-gray-200 bg-white px-6 py-16 text-center shadow-sm">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-orange-50 text-orange-500"><span class="material-symbols-outlined text-3xl">outbox</span></div>
                <h2 class="mt-4 text-xl font-bold text-gray-900" x-text="offers.length === 0 ? 'No offers sent yet' : 'No matching offers'"></h2>
                <p class="mx-auto mt-2 max-w-md text-sm text-gray-500" x-text="offers.length === 0 ? 'Browse traveler requests and send a personalized proposal to start building your pipeline.' : 'Try another status, keyword, or sorting option.'"></p>
                <button x-show="offers.length === 0" type="button" @@click="setViewMode('requests')" class="mt-5 inline-flex items-center gap-2 rounded-xl bg-orange-500 px-5 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-orange-600">
                    <span class="material-symbols-outlined text-lg">travel_explore</span> Browse Requests
                </button>
            </div>

            <div x-show="!isOffersLoading && filteredOffers().length > 0" class="space-y-4">
                <template x-for="offerItem in filteredOffers()" :key="offerItem.id">
