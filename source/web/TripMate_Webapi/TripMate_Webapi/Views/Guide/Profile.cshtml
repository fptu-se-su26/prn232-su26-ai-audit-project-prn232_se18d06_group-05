@model TripMate_Webapi.Entities.GuideProfileEntity
@{
    ViewData["Title"] = "Hồ Sơ Của Tôi";
    ViewData["ActivePage"] = "Profile";
    Layout = "_GuideLayout";
    
    var profile = ViewBag.Profile as dynamic;
}

<!-- JSON data cho AlpineJS -->
<script>
    window.initialProfile = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(profile));
</script>

<div class="max-w-7xl mx-auto" x-data="profileSettings()">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-2">Hồ Sơ Của Tôi</h2>
            <p class="text-gray-500 text-sm">Xây dựng hồ sơ ấn tượng để thu hút nhiều du khách hơn.</p>
        </div>
        <div class="flex items-center gap-3">
            <button class="bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-xl text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">visibility</span>
                Xem hồ sơ công khai
            </button>
            <div class="bg-green-50 text-green-700 px-3 py-2 rounded-xl text-sm font-bold border border-green-100 flex items-center gap-1">
                <span class="material-symbols-outlined text-[18px]">verified</span>
                Đã xác minh
            </div>
        </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- LEFT: FORM -->
        <div class="flex-grow space-y-6 w-full lg:w-2/3">
            
            <!-- Tabs -->
            <div class="flex gap-1 bg-gray-50 p-1 rounded-xl border border-gray-200 w-max">
                <button @@click="currentTab = 'basic'" 
                        :class="currentTab === 'basic' ? 'bg-white shadow-sm font-bold text-gray-900' : 'text-gray-500 font-medium'" 
                        class="px-6 py-2.5 rounded-lg text-sm transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">person</span> Thông tin cơ bản
                </button>
                <button @@click="currentTab = 'expertise'" 
                        :class="currentTab === 'expertise' ? 'bg-white shadow-sm font-bold text-gray-900' : 'text-gray-500 font-medium'" 
                        class="px-6 py-2.5 rounded-lg text-sm transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">workspace_premium</span> Chuyên môn & Ngôn ngữ
                </button>
            </div>

            <form @@submit.prevent="saveProfile">
                
                <!-- TAB 1: THÔNG TIN CƠ BẢN -->
                <div x-show="currentTab === 'basic'" class="space-y-6" x-transition.opacity>
                    
                    <!-- Cover Photo -->
                    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                        <h3 class="text-sm font-bold text-gray-900 mb-4 uppercase tracking-wider">Ảnh Bìa (Cover)</h3>
                        <div class="relative h-48 rounded-xl overflow-hidden group bg-gray-100 border-2 border-dashed border-gray-300 flex items-center justify-center cursor-pointer hover:border-primary transition-colors">
                            <template x-if="form.CoverUrl">
                                <img :src="form.CoverUrl" class="absolute inset-0 w-full h-full object-cover">
                            </template>
                            <div class="absolute inset-0 bg-gray-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center text-white">
                                <span class="material-symbols-outlined text-3xl mb-1">upload_file</span>
                                <span class="text-sm font-medium">Thay đổi ảnh bìa</span>
                            </div>
                            <template x-if="!form.CoverUrl">
                                <div class="text-center text-gray-500">
                                    <span class="material-symbols-outlined text-3xl mb-1">image</span>
                                    <p class="text-sm">Tải ảnh lên (16:9)</p>
                                </div>
                            </template>
                        </div>
                    </div>

                    <!-- Avatar & Info -->
                    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                        <div class="flex flex-col sm:flex-row gap-8 mb-6">
                            <!-- Avatar -->
                            <div class="flex flex-col items-center gap-3">
                                <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider w-full">Ảnh Đại Diện</h3>
                                <div class="relative w-32 h-32 rounded-full overflow-hidden group bg-gray-100 border-2 border-dashed border-gray-300 flex items-center justify-center cursor-pointer hover:border-primary transition-colors">
                                    <img :src="form.AvatarUrl" class="absolute inset-0 w-full h-full object-cover" x-show="form.AvatarUrl">
                                    <div class="absolute inset-0 bg-gray-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center text-white">
                                        <span class="material-symbols-outlined text-2xl">photo_camera</span>
                                    </div>
                                </div>
                                <span class="text-xs text-gray-500">JPG/PNG, Tỷ lệ 1:1</span>
                            </div>

                            <!-- Basic Info -->
                            <div class="flex-grow space-y-4">
                                <div>
                                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Họ và tên <span class="text-red-500">*</span></label>
                                    <input type="text" x-model="form.FullName" required
                                           class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Số điện thoại</label>
                                    <input type="tel" x-model="form.PhoneNumber"
                                           class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Khu vực hoạt động <span class="text-red-500">*</span></label>
                                    <select x-model="form.CityArea" required class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
                                        <option value="Hội An">Hội An</option>
                                        <option value="Đà Nẵng">Đà Nẵng</option>
                                        <option value="Huế">Huế</option>
                                        <option value="Hà Nội">Hà Nội</option>
                                        <option value="TP.HCM">TP.HCM</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Bio -->
                        <div>
                            <div class="flex justify-between items-end mb-2">
                                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider">Giới thiệu bản thân (Bio) <span class="text-red-500">*</span></label>
                                <span class="text-xs text-gray-400" x-text="`${form.Bio.length}/1000`"></span>
                            </div>
                            <textarea x-model="form.Bio" required maxlength="1000" rows="5"
                                      placeholder="Kể về bản thân bạn — bạn là ai, điều gì làm bạn trở thành người hướng dẫn đặc biệt..." 
                                      class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all"></textarea>
                        </div>
                    </div>
                </div>

                <!-- TAB 2: CHUYÊN MÔN & NGÔN NGỮ -->
                <div x-show="currentTab === 'expertise'" class="space-y-6" style="display: none;" x-transition.opacity>
                    
                    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                        <h3 class="text-sm font-bold text-gray-900 mb-4 uppercase tracking-wider">Ngôn ngữ sử dụng</h3>
                        <div class="flex flex-wrap gap-3">
                            <template x-for="lang in availableLanguages" :key="lang">
                                <label class="flex items-center gap-2 p-2.5 bg-gray-50 border border-gray-200 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors"
                                       :class="{'border-primary bg-orange-50': form.Languages.includes(lang)}">
                                    <input type="checkbox" :value="lang" x-model="form.Languages" class="hidden">
                                    <div class="w-5 h-5 rounded border border-gray-300 flex items-center justify-center"
                                         :class="{'bg-primary border-primary text-white': form.Languages.includes(lang)}">
                                        <span class="material-symbols-outlined text-[14px]" x-show="form.Languages.includes(lang)">check</span>
                                    </div>
                                    <span class="text-sm font-medium text-gray-700" x-text="lang"></span>
                                </label>
                            </template>
                        </div>
                    </div>

                    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                        <h3 class="text-sm font-bold text-gray-900 mb-4 uppercase tracking-wider">Chuyên môn (Specialties)</h3>
                        <div class="flex flex-wrap gap-3">
                            <template x-for="spec in availableSpecialties" :key="spec">
                                <label class="flex items-center gap-2 p-2.5 bg-gray-50 border border-gray-200 rounded-xl cursor-pointer hover:bg-gray-100 transition-colors"
                                       :class="{'border-primary bg-orange-50': form.Specialties.includes(spec)}">
                                    <input type="checkbox" :value="spec" x-model="form.Specialties" class="hidden">
                                    <div class="w-5 h-5 rounded border border-gray-300 flex items-center justify-center"
                                         :class="{'bg-primary border-primary text-white': form.Specialties.includes(spec)}">
                                        <span class="material-symbols-outlined text-[14px]" x-show="form.Specialties.includes(spec)">check</span>
                                    </div>
                                    <span class="text-sm font-medium text-gray-700" x-text="spec"></span>
                                </label>
                            </template>
                        </div>
                    </div>

                    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                        <h3 class="text-sm font-bold text-gray-900 mb-4 uppercase tracking-wider">Giá cơ bản mỗi giờ</h3>
                        <div class="relative max-w-sm mb-2">
                            <input type="number" x-model.number="form.BaseRate" required min="50000" step="10000"
                                   class="w-full bg-gray-50 border border-gray-200 text-gray-900 font-bold rounded-xl px-4 py-3 pl-10 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">₫</span>
                        </div>
                        <div class="flex items-start gap-2 text-amber-600 bg-amber-50 p-3 rounded-lg text-sm">
                            <span class="material-symbols-outlined text-[18px]">warning</span>
                            <span>Giá theo gói cụ thể sẽ được thiết lập chi tiết trong phần <b>My Tours</b>. Giá cơ bản chỉ dùng để hiển thị mức giá tối thiểu trên hồ sơ của bạn.</span>
                        </div>
                    </div>
                </div>

                <!-- Sticky Form Footer -->
                <div class="mt-6 flex justify-end gap-4 sticky bottom-6 bg-white/90 backdrop-blur-md p-4 rounded-2xl border border-gray-200 shadow-lg z-20">
                    <button type="button" @@click="resetForm" class="px-6 py-2.5 rounded-xl font-bold text-gray-600 hover:bg-gray-100 transition-colors">
                        Hủy
                    </button>
                    <button type="submit" class="px-8 py-2.5 rounded-xl font-bold bg-primary text-white hover:bg-primary-dark transition-colors shadow-sm flex items-center gap-2" :disabled="isSaving">
                        <span class="material-symbols-outlined text-[20px]" x-show="!isSaving">save</span>
                        <span class="material-symbols-outlined text-[20px] animate-spin" x-show="isSaving">autorenew</span>
                        <span x-text="isSaving ? 'Đang lưu...' : 'Lưu Thay Đổi'"></span>
                    </button>
                </div>

            </form>
        </div>

        <!-- RIGHT: LIVE PREVIEW (Desktop Only) -->
        <div class="hidden lg:block lg:w-1/3">
            <div class="sticky top-24">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 ml-1 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">preview</span> Xem trước (Bản Mobile)
                </h3>
                
                <!-- Mockup Phone Frame -->
                <div class="w-[320px] bg-white rounded-[2rem] shadow-2xl border-8 border-gray-900 overflow-hidden relative mx-auto h-[650px] flex flex-col">
                    
                    <!-- Cover -->
                    <div class="h-40 bg-gray-200 relative shrink-0">
                        <img :src="form.CoverUrl" class="w-full h-full object-cover" x-show="form.CoverUrl">
                        <!-- Top actions -->
                        <div class="absolute top-4 left-4 right-4 flex justify-between">
                            <div class="w-8 h-8 rounded-full bg-white/50 backdrop-blur-sm flex items-center justify-center text-gray-800">
                                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                            </div>
                            <div class="flex gap-2">
                                <div class="w-8 h-8 rounded-full bg-white/50 backdrop-blur-sm flex items-center justify-center text-gray-800">
                                    <span class="material-symbols-outlined text-[18px]">share</span>
                                </div>
                                <div class="w-8 h-8 rounded-full bg-white/50 backdrop-blur-sm flex items-center justify-center text-gray-800">
                                    <span class="material-symbols-outlined text-[18px]">favorite</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Avatar overlap -->
                    <div class="px-5 relative shrink-0">
                        <div class="w-20 h-20 rounded-full border-4 border-white overflow-hidden bg-gray-100 absolute -top-10 shadow-sm">
                            <img :src="form.AvatarUrl" class="w-full h-full object-cover" x-show="form.AvatarUrl">
                        </div>
                        <div class="flex justify-end pt-3">
                            <span class="bg-amber-100 text-amber-800 text-[10px] font-bold px-2 py-1 rounded-full flex items-center gap-0.5">
                                <span class="material-symbols-outlined text-[12px]">workspace_premium</span> LOCAL GUIDE
                            </span>
                        </div>
                    </div>

                    <!-- Info Scrollable -->
                    <div class="px-5 pb-5 pt-2 flex-grow overflow-y-auto hide-scrollbar">
                        <!-- Name & Rating -->
                        <div class="mb-4">
                            <h2 class="text-xl font-bold text-gray-900 flex items-center gap-1">
                                <span x-text="form.FullName || 'Tên của bạn'"></span>
                                <span class="material-symbols-outlined text-blue-500 text-[16px]" title="Đã xác minh">verified</span>
                            </h2>
                            <div class="flex items-center gap-2 mt-1 text-sm text-gray-600">
                                <span class="flex items-center text-amber-400 font-medium">
                                    <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                    <span x-text="form.Rating" class="text-gray-800 ml-0.5"></span>
                                </span>
                                <span>•</span>
                                <span x-text="`${form.ReviewsCount} đánh giá`"></span>
                            </div>
                            <div class="flex items-center gap-1 mt-1.5 text-sm text-gray-500">
                                <span class="material-symbols-outlined text-[16px]">location_on</span>
                                <span x-text="form.CityArea"></span>
                            </div>
                        </div>

                        <!-- Price & Lang -->
                        <div class="flex flex-wrap gap-2 mb-5">
                            <div class="bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100 text-xs text-gray-700 flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-[14px]">payments</span>
                                <span>Từ <strong x-text="formatCurrency(form.BaseRate)"></strong> /giờ</span>
                            </div>
                            <div class="bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100 text-xs text-gray-700 flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-[14px]">language</span>
                                <span x-text="form.Languages.join(', ') || 'Chưa chọn'"></span>
                            </div>
                        </div>

                        <!-- Bio excerpt -->
                        <div class="mb-5">
                            <h3 class="text-sm font-bold text-gray-900 mb-2">Giới thiệu</h3>
                            <p class="text-sm text-gray-600 leading-relaxed line-clamp-4" x-text="form.Bio || 'Chưa có thông tin giới thiệu...'"></p>
                            <button class="text-primary text-xs font-bold mt-1">Đọc thêm</button>
                        </div>

                        <!-- Specialties -->
                        <div>
                            <h3 class="text-sm font-bold text-gray-900 mb-2">Chuyên môn</h3>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="spec in form.Specialties" :key="spec">
                                    <span class="bg-orange-50 text-orange-700 border border-orange-100 px-2.5 py-1 rounded-md text-xs font-medium" x-text="spec"></span>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function profileSettings() {
            return {
                currentTab: 'basic',
                isSaving: false,
                
                availableLanguages: ['Tiếng Việt', 'Tiếng Anh', 'Tiếng Hàn', 'Tiếng Nhật', 'Tiếng Pháp', 'Tiếng Trung'],
                availableSpecialties: ['Ẩm thực đường phố', 'Văn hóa - Lịch sử', 'Nhiếp ảnh', 'Mạo hiểm', 'Nightlife', 'Thiên nhiên', 'Nghệ thuật địa phương', 'Mua sắm'],
                
                // Deep copy initial data
                form: {
                    FullName: '', PhoneNumber: '', Bio: '', AvatarUrl: '', CoverUrl: '', CityArea: 'Hội An',
                    Languages: [], Specialties: [], Rating: 5.0, ReviewsCount: 0, BaseRate: 50000
                },

                async init() {
                    const token = localStorage.getItem('accessToken');
                    if (!token) {
                        window.location.href = '/Auth/Login';
                        return;
                    }
                    try {
                        const res = await fetch('/api/auth/profile', {
                            headers: { 'Authorization': `Bearer ${token}` }
                        });
                        if (res.ok) {
                            const data = await res.json();
                            this.form.FullName = data.full_name || '';
                            this.form.PhoneNumber = data.phone_number || '';
                            this.form.Bio = data.bio || '';
                            this.form.AvatarUrl = data.avatar_url || '/images/AVATAR.png';
                            this.form.CoverUrl = data.cover_photo_url || '';
                            this.form.CityArea = data.specialization || 'Hội An';
                            this.form.Languages = data.languages ? (typeof data.languages === 'string' ? data.languages.split(',').map(s => s.trim()) : data.languages) : [];
                            this.form.Specialties = data.specialization ? data.specialization.split(',').map(s => s.trim()) : [];
                            this.form.Rating = data.average_rating || 5.0;
                            this.form.ReviewsCount = data.total_reviews || 0;
                            window.initialProfile = JSON.parse(JSON.stringify(this.form));
                        }
                    } catch (err) {
                        console.error('Error loading profile:', err);
                    }
                },

                formatCurrency(val) {
                    if (!val) return '0 ₫';
                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val);
                },

                resetForm() {
                    if (confirm('Bạn có chắc muốn hủy các thay đổi chưa lưu?')) {
                        this.form = JSON.parse(JSON.stringify(window.initialProfile));
                    }
                },

                async saveProfile() {
                    this.isSaving = true;
                    if (this.form.Languages.length === 0) {
                        showToast('error', 'Vui lòng chọn ít nhất 1 ngôn ngữ!');
                        this.isSaving = false;
                        this.currentTab = 'expertise';
                        return;
                    }
                    const token = localStorage.getItem('accessToken');
                    try {
                        const res = await fetch('/api/auth/profile', {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                            body: JSON.stringify({
                                fullName: this.form.FullName,
                                phoneNumber: this.form.PhoneNumber,
                                bio: this.form.Bio,
                                languages: this.form.Languages.join(', '),
                                specialization: this.form.Specialties.join(', '),
                                avatarUrl: this.form.AvatarUrl
                            })
                        });
                        const data = await res.json();
                        if (res.ok) {
                            showToast('success', 'Đã lưu thông tin hồ sơ thành công!');
                            window.initialProfile = JSON.parse(JSON.stringify(this.form));
                        } else {
                            showToast('error', data.message || 'Lỗi khi lưu thông tin');
                        }
                    } catch (err) {
                        console.error('Error saving profile:', err);
                        showToast('error', 'Không thể kết nối đến máy chủ');
                    } finally {
                        this.isSaving = false;
                    }
                }
            }
        }
    </script>
}
