@{
    ViewData["Title"] = "Tin Nhắn";
    ViewData["ActivePage"] = "Messages";
    Layout = "_GuideLayout";

}

<!-- JSON data cho AlpineJS -->
<script>
    window.initialActiveBookings = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ActiveBookings ?? new object[0]));
</script>

<div class="h-[calc(100vh-120px)] bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex" x-data="messengerApp()" x-init="init()">
    
    <!-- LEFT: CONVERSATION LIST -->
    <div class="w-full md:w-80 flex-shrink-0 flex flex-col border-r border-gray-100 transition-all duration-300"
         :class="{'hidden md:flex': activeThread !== null}">
        
        <!-- Header & Search -->
        <div class="p-4 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-900 mb-4">Tin nhắn</h2>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[18px]">search</span>
                <input type="text" x-model="searchQuery" placeholder="Tìm kiếm cuộc trò chuyện..." 
                       class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl py-2 pl-10 pr-4 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
            </div>
        </div>

        <!-- Thread List -->
        <div class="flex-1 overflow-y-auto hide-scrollbar p-2 space-y-1">
            <template x-if="filteredThreads.length === 0">
                <div class="p-4 text-center text-gray-500 text-sm">
                    Không tìm thấy cuộc trò chuyện nào.
                </div>
            </template>
            
            <template x-for="t in filteredThreads" :key="t.Id">
                <button @@click="selectThread(t)" 
                        class="w-full text-left p-3 rounded-xl transition-colors flex items-start gap-3 relative group"
                        :class="[
                            activeThread && activeThread.Id === t.Id ? 'bg-orange-50' : 'hover:bg-gray-50',
                            t.IsLocked ? 'opacity-70' : ''
                        ]">
                    
                    <div class="relative">
                        <img :src="t.TravelerAvatar" class="w-12 h-12 rounded-full object-cover border border-gray-200 flex-shrink-0">
                        <span x-show="t.UnreadCount > 0" class="absolute -top-1 -right-1 bg-primary text-white text-[10px] font-bold w-5 h-5 flex items-center justify-center rounded-full border-2 border-white" x-text="t.UnreadCount"></span>
                        <div x-show="t.IsLocked" class="absolute inset-0 bg-gray-900/50 rounded-full flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-[16px]">lock</span>
                        </div>
                    </div>
                    
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline mb-0.5">
                            <h4 class="font-bold text-gray-900 text-sm truncate pr-2" :class="{'text-primary': t.UnreadCount > 0}" x-text="t.TravelerName"></h4>
                            <span class="text-[11px] text-gray-400 whitespace-nowrap" :class="{'text-primary font-bold': t.UnreadCount > 0}" x-text="t.TimeAgo"></span>
                        </div>
                        
                        <p class="text-xs text-gray-500 truncate" :class="{'font-bold text-gray-800': t.UnreadCount > 0}" x-text="getThreadPreview(t)"></p>
                    </div>
                </button>
            </template>
        </div>
    </div>

    <!-- RIGHT: CHAT WINDOW -->
    <div class="flex-1 flex flex-col bg-gray-50/30 transition-all duration-300"
         :class="{'hidden md:flex': activeThread === null}">
        
        <!-- Empty State -->
        <template x-if="!activeThread">
            <div class="flex-1 flex flex-col items-center justify-center p-8 text-center">
                <div class="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center text-blue-500 mb-6">
                    <span class="material-symbols-outlined text-[40px]">forum</span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Giao tiếp là chìa khóa</h3>
                <p class="text-gray-500 max-w-md">Khi booking được xác nhận, kênh chat sẽ tự động mở. Chọn một cuộc trò chuyện ở cột trái để bắt đầu!</p>
            </div>
        </template>

        <!-- Active Chat -->
        <template x-if="activeThread">
            <div class="flex-1 flex flex-col h-full">
                <!-- Chat Header -->
                <div class="h-20 bg-white border-b border-gray-100 flex items-center justify-between px-6 flex-shrink-0">
                    <div class="flex items-center gap-4">
                        <button @@click="activeThread = null" class="md:hidden text-gray-400 hover:text-gray-700">
                            <span class="material-symbols-outlined">arrow_back</span>
                        </button>
                        
                        <img :src="activeThread.TravelerAvatar" class="w-10 h-10 rounded-full object-cover border border-gray-200">
                        <div>
                            <h3 class="font-bold text-gray-900" x-text="activeThread.TravelerName"></h3>
                            <div class="flex items-center gap-1.5 text-xs text-gray-500">
                                <span class="material-symbols-outlined text-[14px]">tour</span>
                                <span class="truncate max-w-[200px] md:max-w-[400px]" x-text="activeThread.TourName"></span>
                            </div>
                        </div>
                    </div>
                    
                    <button class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-50 transition-colors" title="Chi tiết booking">
                        <span class="material-symbols-outlined text-[20px]">info</span>
                    </button>
                </div>

                <!-- Chat Messages Area -->
                <div class="flex-1 overflow-y-auto p-6 space-y-4" id="chatContainer">
                    <div class="text-center mb-4">
                        <template x-if="activeThread && activeThread._hasMore">
                            <div class="mb-3">
                                <button type="button" @@click="loadMoreMessages()" class="text-sm text-primary underline">Load older messages</button>
                            </div>
                        </template>
                        <span class="text-xs font-medium bg-gray-100 text-gray-500 px-3 py-1 rounded-full" x-text="activeThread.Date"></span>
                    </div>

                    <template x-for="(msg, index) in activeThread.Messages" :key="index">
                        <div class="flex flex-col group" :class="msg.IsMine ? 'items-end' : 'items-start'" :data-msg-id="msg.Id">
                            <div class="flex items-center gap-2 max-w-[75%]">
                                <!-- Edit button outside the message bubble -->
                                <template x-if="msg.IsMine && !activeThread.IsLocked && !msg.editing && !isUrl(msg.Text)">
                                    <button type="button" @@click.stop="startEdit(msg)" class="hidden group-hover:flex items-center justify-center w-8 h-8 rounded-full bg-white border border-gray-200 text-gray-500 shadow-sm hover:bg-gray-50 hover:text-primary transition-colors" title="Edit" aria-label="Edit message">
                                        <span class="material-symbols-outlined text-[14px]">edit</span>
                                    </button>
                                </template>

                                <div class="relative min-w-0 px-4 py-2.5 shadow-sm text-[15px]"
                                     :class="[
                                        msg.IsMine ? 'bg-primary text-white rounded-2xl rounded-br-sm' : 'bg-white border border-gray-200 text-gray-900 rounded-2xl rounded-bl-sm'
                                     ]">

                                <!-- Editing state -->
                                <template x-if="msg.editing">
                                    <div class="">
                                        <textarea x-model="msg.editText" rows="1" class="w-full resize-none p-2 rounded bg-white text-gray-900" data-edit-textarea @@input="resizeEditTextarea($event)"></textarea>
                                        <div class="flex justify-end gap-2 mt-2">
                                            <button type="button" @@click="saveEdit(msg)" class="bg-primary text-white px-3 py-1 rounded">Save</button>
                                            <button type="button" @@click="cancelEdit(msg)" class="bg-gray-100 text-gray-700 px-3 py-1 rounded">Cancel</button>
                                        </div>
                                    </div>
                                </template>

                                <template x-if="!msg.editing">
                                    <div>
                                        <template x-if="isImageUrl(msg.Text)">
                                            <div class="flex flex-col gap-2">
                                                <img :src="msg.Text" class="max-w-[320px] rounded-md" />
                                                <a :href="msg.Text" target="_blank" rel="noopener" :class="msg.IsMine ? 'text-white text-sm underline' : 'text-primary text-sm underline'" x-text="getFilename(msg.Text)"></a>
                                            </div>
                                        </template>
                                        <template x-if="!isImageUrl(msg.Text) && isUrl(msg.Text)">
                                            <a :href="msg.Text" target="_blank" rel="noopener" class="flex items-center gap-3 p-3 rounded-md" :class="msg.IsMine ? 'bg-primary/20 text-white' : 'bg-white'">
                                                <span class="material-symbols-outlined text-[20px]" x-text="fileIconForUrl(msg.Text)"></span>
                                                <div class="min-w-0">
                                                    <div class="font-medium truncate" :class="msg.IsMine ? 'text-white' : 'text-on-surface'" x-text="getFilename(msg.Text)"></div>
                                                    <div class="text-xs opacity-70 truncate" :class="msg.IsMine ? 'text-white/80' : 'text-on-surface-variant'" x-text="getFileType(msg.Text)"></div>
                                                </div>
                                            </a>
                                        </template>
                                        <template x-if="!isUrl(msg.Text)">
                                            <div :class="msg.IsMine ? 'text-white break-words' : 'text-gray-900 break-words'" style="white-space: pre-wrap;" x-text="msg.Text"></div>
                                        </template>
                                    </div>
                                </template>

                            </div>
                            </div>

                            <!-- Metadata below message -->
                            <div class="flex items-center gap-1 mt-1 text-[11px] text-gray-400 px-1">
                                <span x-text="msg.Time"></span>
                                <template x-if="msg.IsMine">
                                    <span class="material-symbols-outlined text-[14px]" :class="msg.IsRead ? 'text-blue-500' : ''" x-text="msg.IsRead ? 'done_all' : 'check'"></span>
                                </template>
                            </div>
                        </div>
                    </template>
                    
                </div>

                <!-- Chat Input Area -->
                <div class="bg-white border-t border-gray-100 p-4">
                    <template x-if="activeThread.IsLocked">
                        <div class="max-w-4xl mx-auto h-16 rounded-2xl border border-gray-200 bg-gray-50 flex items-center justify-center text-gray-400">
                            <span class="material-symbols-outlined text-[26px]">lock</span>
                        </div>
                    </template>
                    <template x-if="!activeThread.IsLocked">
                        <form @@submit.prevent="sendMessage" class="max-w-4xl mx-auto" onsubmit="event.preventDefault(); return false;">
                            <div class="rounded-2xl border border-gray-200 bg-gray-50 overflow-hidden focus-within:ring-2 focus-within:ring-primary/50 focus-within:border-primary transition-all">
                                <div x-show="pendingFiles.length > 0" class="flex flex-wrap gap-2 px-3 pt-3">
                                    <template x-for="(item, index) in pendingFiles" :key="item.Id">
                                        <div class="relative flex items-center gap-2 max-w-[240px] rounded-xl border border-gray-200 bg-white p-2 pr-8 shadow-sm">
                                            <template x-if="item.PreviewUrl">
                                                <img :src="item.PreviewUrl" class="h-10 w-10 rounded-lg object-cover flex-shrink-0" />
                                            </template>
                                            <template x-if="!item.PreviewUrl">
                                                <span class="material-symbols-outlined h-10 w-10 rounded-lg bg-gray-100 text-gray-500 flex items-center justify-center flex-shrink-0">insert_drive_file</span>
                                            </template>
                                            <div class="min-w-0">
                                                <p class="truncate text-xs font-semibold text-gray-700" x-text="item.Name"></p>
                                                <p class="text-[11px] text-gray-400" x-text="formatFileSize(item.Size)"></p>
                                            </div>
                                            <button type="button" @@click="removePendingFile(index)" :disabled="isSending" class="absolute right-1.5 top-1.5 h-6 w-6 rounded-full text-gray-400 hover:bg-gray-100 hover:text-gray-700 disabled:opacity-40">
                                                <span class="material-symbols-outlined text-[16px]">close</span>
                                            </button>
                                        </div>
                                    </template>
                                </div>
                                <div class="flex items-end gap-1 px-2 py-2">
                                    <label class="h-10 w-10 flex-shrink-0 flex items-center justify-center rounded-full text-gray-400 hover:bg-white hover:text-primary cursor-pointer transition-colors">
                                        <input type="file" multiple class="hidden" :disabled="isSending" @@change="queueAttachments($event)" />
                                        <span class="material-symbols-outlined text-[22px]">attach_file</span>
                                    </label>
                                    <textarea x-model="newMessage"
                                              @@keydown.enter.prevent="sendMessage"
                                              @@input="resizeMessageTextarea"
                                              :disabled="isSending"
                                              rows="1"
                                              placeholder="Nhập tin nhắn..."
                                              class="min-h-10 flex-1 bg-transparent border-none text-gray-900 text-sm px-2 py-2.5 max-h-32 resize-none focus:ring-0 outline-none"></textarea>
                                    <button x-show="canSend" x-transition type="button" @@click="sendMessage()" :disabled="isSending"
                                            class="h-10 w-10 flex-shrink-0 rounded-full bg-primary text-white flex items-center justify-center hover:bg-primary-dark disabled:opacity-50 transition-all">
                                        <span class="material-symbols-outlined text-[20px]">send</span>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </template>
                </div>
            </div>
        </template>
    </div>
</div>

@section Scripts {
    <script>
        function messengerApp() {
            return {
                threads: window.initialThreads || [],
                activeThread: null,
                searchQuery: '',
                newMessage: '',
                pendingFiles: [],
                isSending: false,
                _pendingFileSequence: 0,
                _messageCreatedHandler: null,
                _messageUpdatedHandler: null,
                _chatReconnectedHandler: null,

                // Called by x-init
                async init() {
                    this._messageCreatedHandler = event => this.handleRealtimeMessage(event.detail);
                    this._messageUpdatedHandler = event => this.handleRealtimeMessageUpdate(event.detail);
                    this._chatReconnectedHandler = () => this.reloadAfterReconnect();
                    document.addEventListener('tripmate:message-created', this._messageCreatedHandler);
                    document.addEventListener('tripmate:message-updated', this._messageUpdatedHandler);
                    document.addEventListener('tripmate:chat-reconnected', this._chatReconnectedHandler);
                    await this.loadConversations();
                    const requestedBookingId = new URLSearchParams(window.location.search).get('bookingId');
                    if (requestedBookingId) {
                        const requestedThread = this.threads.find(thread =>
                            (thread.BookingIds || [thread.BookingId])
                                .some(id => String(id) === String(requestedBookingId)));
                        if (requestedThread) await this.selectThread(requestedThread);
                    }
                    window.TripMateChat?.start();
                },
                destroy() {
                    document.removeEventListener('tripmate:message-created', this._messageCreatedHandler);
                    document.removeEventListener('tripmate:message-updated', this._messageUpdatedHandler);
                    document.removeEventListener('tripmate:chat-reconnected', this._chatReconnectedHandler);
                    this.clearPendingFiles();
                },
                normalizeMessage(raw) {
                    if (!raw) return null;
                    return {
                        Id: raw.id ?? raw.Id,
                        BookingId: raw.bookingId ?? raw.BookingId,
                        SenderId: raw.senderId ?? raw.SenderId ?? '',
                        ReceiverId: raw.receiverId ?? raw.ReceiverId ?? '',
                        Text: raw.messageText ?? raw.MessageText ?? raw.Text ?? '',
                        SentAt: raw.sentAt ?? raw.SentAt,
                        IsRead: !!(raw.isRead ?? raw.IsRead)
                    };
                },
                toDisplayMessage(message) {
                    const userId = localStorage.getItem('userId');
                    return {
                        Id: message.Id,
                        Text: message.Text,
                        SentAt: message.SentAt,
                        SenderId: message.SenderId,
                        ReceiverId: message.ReceiverId,
                        IsMine: message.SenderId === userId,
                        Time: new Date(message.SentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }),
                        IsRead: message.IsRead
                    };
                },
                appendMessageIfMissing(thread, raw) {
                    const message = this.normalizeMessage(raw);
                    if (!message || message.Id == null) return false;
                    thread.Messages ||= [];
                    const displayMessage = this.toDisplayMessage(message);
                    const existing = thread.Messages.find(item => String(item.Id) === String(message.Id));
                    if (existing) {
                        existing.Text = displayMessage.Text;
                        existing.SentAt = displayMessage.SentAt;
                        existing.SenderId = displayMessage.SenderId;
                        existing.ReceiverId = displayMessage.ReceiverId;
                        existing.IsMine = displayMessage.IsMine;
                        existing.Time = displayMessage.Time;
                        existing.IsRead = displayMessage.IsRead;
                        return false;
                    }
                    thread.Messages.push(displayMessage);
                    return true;
                },
                async handleRealtimeMessage(raw) {
                    const message = this.normalizeMessage(raw);
                    if (!message?.BookingId) return;

                    const participantId = this.getMessageParticipantId(message);
                    let thread = this.threads.find(item => String(this.getParticipantId(item)) === String(participantId));
                    if (!thread) {
                        await this.loadConversations();
                        thread = this.threads.find(item => String(this.getParticipantId(item)) === String(participantId));
                        if (!thread) return;
                    }

                    const added = this.appendMessageIfMissing(thread, message);
                    thread.LastMessage = message.Text;
                    thread.LastMessageAt = message.SentAt;
                    thread.TimeAgo = this.formatTimeAgo(message.SentAt);

                    const userId = localStorage.getItem('userId');
                    const isActive = String(this.getParticipantId(this.activeThread)) === String(participantId);
                    if (message.ReceiverId === userId) {
                        if (isActive) {
                            thread.UnreadCount = 0;
                            await this.markThreadRead(thread);
                        } else if (added) {
                            thread.UnreadCount = (thread.UnreadCount || 0) + 1;
                        }
                    }

                    const index = this.threads.indexOf(thread);
                    if (index > 0) this.threads.unshift(this.threads.splice(index, 1)[0]);
                    if (isActive) this.scrollToBottom();
                },
                handleRealtimeMessageUpdate(raw) {
                    const message = this.normalizeMessage(raw);
                    if (!message?.BookingId) return;
                    const participantId = this.getMessageParticipantId(message);
                    const thread = this.threads.find(item => String(this.getParticipantId(item)) === String(participantId));
                    const existing = thread?.Messages?.find(item => String(item.Id) === String(message.Id));
                    if (!existing) return;
                    existing.Text = message.Text;
                    existing.SentAt = message.SentAt;
                    existing.Time = new Date(message.SentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                    if (thread.Messages[thread.Messages.length - 1] === existing) thread.LastMessage = message.Text;
                },
                async markThreadRead(thread) {
                    const token = localStorage.getItem('accessToken');
                    if (!token || !thread) return;
                    try {
                        const response = await fetch(this.getMarkReadUrl(thread), {
                            method: 'POST',
                            headers: { 'Authorization': 'Bearer ' + token }
                        });
                        if (response.ok) window.TripMateMessages?.refreshUnreadThreads();
                    } catch (error) {
                        console.warn('Failed to mark realtime message as read', error);
                    }
                },
                async reloadAfterReconnect() {
                    const participantId = this.getParticipantId(this.activeThread);
                    await this.loadConversations();
                    if (!participantId) return;
                    const thread = this.threads.find(item => String(this.getParticipantId(item)) === String(participantId));
                    if (thread) {
                        this.activeThread = thread;
                        await this.loadMessagesForThread(thread);
                        this.scrollToBottom();
                    }
                },
                resizeEditTextarea(e) {
                    try {
                        const ta = e.target;
                        ta.style.height = 'auto';
                        ta.style.height = (ta.scrollHeight) + 'px';
                    } catch (err) { console.warn('resizeEditTextarea', err); }
                },
                getFilename(url) {
                    if (!url) return '';
                    try {
                        const u = new URL(url);
                        const parts = u.pathname.split('/');
                        return decodeURIComponent(parts[parts.length-1].split('.')[0]) || url;
                    } catch (e) { return url; }
                },
                getFileType(url) {
                    if (!this.isUrl(url)) return '';
                    const m = url.match(/\.([a-z0-9]+)(\?|$)/i);
                    if (!m) return 'file';
                    const ext = m[1].toLowerCase();
                    if (['jpg','jpeg','png','gif','webp','bmp'].includes(ext)) return 'image';
                    if (['pdf'].includes(ext)) return 'pdf';
                    if (['mp4','mov','webm','mkv'].includes(ext)) return 'video';
                    if (['mp3','wav','m4a','flac'].includes(ext)) return 'audio';
                    if (['doc','docx','txt','rtf'].includes(ext)) return 'document';
                    return ext;
                },
                fileIconForUrl(url) {
                    const t = this.getFileType(url);
                    switch (t) {
                        case 'image': return 'image';
                        case 'pdf': return 'picture_as_pdf';
                        case 'video': return 'movie';
                        case 'audio': return 'audiotrack';
                        case 'document': return 'description';
                        default: return 'insert_drive_file';
                    }
                },
                isUrl(s) {
                    return !!(s && typeof s === 'string' && (s.startsWith('http://') || s.startsWith('https://')));
                },
                isImageUrl(s) {
                    if (!this.isUrl(s)) return false;
                    return (s.match(/\.(jpg|jpeg|png|gif|webp|bmp)(\?|$)/i) != null);
                },
                truncateText(s, n = 80) {
                    if (!s) return '';
                    return s.length > n ? s.slice(0, n - 1) + '…' : s;
                },
                getThreadPreview(thread) {
                    const m = thread?.LastMessage || '';
                    if (!m) return '';
                    if (this.isUrl(m)) {
                        const t = this.getFileType(m);
                        switch (t) {
                            case 'image': return 'Image';
                            case 'pdf': return 'PDF';
                            case 'video': return 'Video';
                            case 'audio': return 'Audio';
                            case 'document': return 'Document';
                            default: return 'Attachment';
                        }
                    }
                    return this.truncateText(m, 80);
                },
                getParticipantId(thread) {
                    return thread?.ParticipantId || thread?.OtherId || thread?.TravelerId || '';
                },
                getMessageParticipantId(message) {
                    const userId = localStorage.getItem('userId');
                    return String(message?.SenderId) === String(userId)
                        ? message?.ReceiverId
                        : message?.SenderId;
                },
                getMessagesUrl(thread) {
                    const participantId = this.getParticipantId(thread);
                    return participantId
                        ? `/api/chat/conversations/participants/${encodeURIComponent(participantId)}/messages`
                        : `/api/chat/conversations/${encodeURIComponent(thread?.BookingId || '')}/messages`;
                },
                getMarkReadUrl(thread) {
                    const participantId = this.getParticipantId(thread);
                    return participantId
                        ? `/api/chat/conversations/participants/${encodeURIComponent(participantId)}/mark-read`
                        : `/api/chat/conversations/${encodeURIComponent(thread?.BookingId || '')}/mark-read`;
                },

                get canSend() {
                    return !!this.newMessage.trim() || this.pendingFiles.length > 0;
                },
                queueAttachments(event) {
                    const files = Array.from(event.target.files || []);
                    for (const file of files) {
                        this.pendingFiles.push({
                            Id: `pending-${Date.now()}-${this._pendingFileSequence++}`,
                            File: file,
                            Name: file.name,
                            Size: file.size,
                            PreviewUrl: file.type.startsWith('image/') ? URL.createObjectURL(file) : null
                        });
                    }
                    event.target.value = '';
                },
                removePendingFile(index) {
                    const [removed] = this.pendingFiles.splice(index, 1);
                    if (removed?.PreviewUrl) URL.revokeObjectURL(removed.PreviewUrl);
                },
                clearPendingFiles() {
                    for (const item of this.pendingFiles) {
                        if (item.PreviewUrl) URL.revokeObjectURL(item.PreviewUrl);
                    }
                    this.pendingFiles = [];
                },
                formatFileSize(bytes) {
                    if (!Number.isFinite(bytes) || bytes <= 0) return '0 B';
                    const units = ['B', 'KB', 'MB', 'GB'];
                    const unit = Math.min(Math.floor(Math.log(bytes) / Math.log(1024)), units.length - 1);
                    const value = bytes / Math.pow(1024, unit);
                    return `${value >= 10 || unit === 0 ? value.toFixed(0) : value.toFixed(1)} ${units[unit]}`;
                },
                async uploadPendingAttachment(file) {
                    const token = localStorage.getItem('accessToken');
                    const userId = localStorage.getItem('userId');
                    const receiverId = this.activeThread.ParticipantId || this.activeThread.OtherId;

                    const fd = new FormData();
                    fd.append('file', file);
                    fd.append('receiverId', receiverId || '');

                    const res = await fetch(`/api/chat/conversations/${encodeURIComponent(this.activeThread.ConfirmedBookingId)}/attachments`, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token },
                        body: fd
                    });
                    if (!res.ok) throw new Error('Upload failed');
                    const msg = await res.json();
                    this.appendMessageIfMissing(this.activeThread, {
                        ...msg,
                        senderId: userId,
                        receiverId
                    });
                    this.activeThread.LastMessage = msg.messageText || msg.MessageText || '';
                    this.activeThread.TimeAgo = 'Vừa xong';
                    this.scrollToBottom();
                },

                // Message editing helpers
                startEdit(msg) {
                    msg.editing = true;
                    msg.editText = msg.Text;
                    // after DOM update, auto-size textarea and focus
                    setTimeout(() => {
                        try {
                            const ta = document.querySelector(`[data-msg-id="${msg.Id}"] [data-edit-textarea]`);
                            if (ta) {
                                ta.style.height = 'auto';
                                ta.style.height = (ta.scrollHeight) + 'px';
                                ta.focus();
                            }
                        } catch (e) { console.warn('startEdit resize failed', e); }
                    }, 0);
                },
                cancelEdit(msg) {
                    msg.editing = false;
                    delete msg.editText;
                },
                async saveEdit(msg) {
                    if (!this.activeThread || !msg || !msg.Id) return;
                    if (this.activeThread.IsLocked || !this.activeThread.ConfirmedBookingId) return;
                    const token = localStorage.getItem('accessToken');
                    if (!token) return;
                    // prevent editing attachments
                    if (this.isUrl(msg.Text)) { showToast('warning', 'Không thể chỉnh sửa tệp đính kèm'); msg.editing = false; return; }
                    try {
                        const res = await fetch(`/api/chat/conversations/${encodeURIComponent(this.activeThread.ConfirmedBookingId)}/messages/${encodeURIComponent(msg.Id)}`, {
                            method: 'PATCH',
                            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                            body: JSON.stringify({ Content: msg.editText })
                        });
                        if (!res.ok) throw new Error('Edit failed');
                        const updated = await res.json();
                        msg.Text = updated.messageText || updated.MessageText || msg.editText;
                        msg.SentAt = updated.sentAt || updated.SentAt || msg.SentAt;
                        msg.Time = msg.SentAt ? new Date(msg.SentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) : msg.Time;
                        msg.editing = false;
                    } catch (e) {
                        console.error(e);
                        showToast('error', 'Chỉnh sửa tin nhắn thất bại');
                    }
                },

                get filteredThreads() {
                    if (!this.searchQuery) return this.threads;
                    const q = this.searchQuery.toLowerCase();
                    return this.threads.filter(t => (t.TravelerName || '').toLowerCase().includes(q));
                },

                async loadConversations() {
                    const token = localStorage.getItem('accessToken');
                    const userId = localStorage.getItem('userId');
                    if (!token || !userId) {
                        showToast('warning', 'Bạn cần đăng nhập để xem tin nhắn');
                        return;
                    }

                    try {
                        const res = await fetch('/api/chat/conversations', {
                            headers: { 'Authorization': 'Bearer ' + token }
                        });
                        if (!res.ok) throw new Error('Không thể tải cuộc trò chuyện');
                        const data = await res.json();
                        const convs = data?.conversations || [];

                        const threads = [];
                        for (const c of convs) {
                            const bookingId = c.bookingId || c.BookingId;
                            const travelerId = c.travelerId || c.TravelerId || '';
                            const guideId = c.guideId || c.GuideId || '';
                            const otherId = (travelerId === userId) ? guideId : travelerId;

                            // Fetch the permanent participant-pair history for the preview.
                            const mres = await fetch(this.getMessagesUrl({ ParticipantId: otherId, BookingId: bookingId }), {
                                headers: { 'Authorization': 'Bearer ' + token }
                            });
                            const mdata = await mres.json();
                            const rows = mdata?.messages || [];

                            const messages = rows.map(r => ({
                                Id: r.id || r.Id,
                                Text: r.messageText || r.MessageText || '',
                                SenderId: r.senderId || r.SenderId || '',
                                ReceiverId: r.receiverId || r.ReceiverId || '',
                                IsRead: !!(r.isRead || r.IsRead),
                                SentAt: r.sentAt || r.SentAt
                            }));

                            // The API returns newest-first. Keep that item for the sidebar
                            // preview, but reverse the collection used by the chat window.
                            const newest = messages.length ? messages[0] : null;
                            const chronologicalMessages = messages.slice().reverse();

                            threads.push({
                                Id: bookingId,
                                BookingId: bookingId,
                                BookingIds: [bookingId],
                                TravelerId: travelerId,
                                GuideId: guideId,
                                ParticipantId: otherId,
                                TravelerName: otherId || (travelerId || guideId) || 'User',
                                TravelerAvatar: '/images/AVATAR.png',
                                Messages: chronologicalMessages.map(m => ({
                                    Id: m.Id,
                                    Text: m.Text,
                                    SentAt: m.SentAt,
                                    IsMine: m.SenderId === userId,
                                    Time: new Date(m.SentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }),
                                    IsRead: m.IsRead
                                })),
                                LastMessage: newest ? newest.Text : 'Không có tin nhắn',
                                TimeAgo: newest ? this.formatTimeAgo(newest.SentAt) : '',
                                Date: newest ? new Date(newest.SentAt).toLocaleDateString('vi-VN') : '',
                                LastMessageAt: newest ? newest.SentAt : null,
                                UnreadCount: messages.filter(m => !m.IsRead && m.ReceiverId === userId).length,
                                IsLocked: true,
                                OtherId: otherId
                            });
                        }

                        // Sort threads by most recent message
                        threads.sort((a, b) => {
                            const aLast = a.LastMessageAt ? new Date(a.LastMessageAt) : new Date(0);
                            const bLast = b.LastMessageAt ? new Date(b.LastMessageAt) : new Date(0);
                            return bLast - aLast;
                        });

                        this.threads = threads;

                        // Merge server-provided active bookings (confirmed trips) so guide can chat even if no messages exist
                        try {
                            const active = window.initialActiveBookings || [];
                            for (const ab of active) {
                                const bid = ab.bookingId || ab.BookingId || ab.Id || ab.id;
                                if (!bid) continue;
                                // Determine traveler participant info from ActiveBookingDto
                                const participantId = ab.travelerId || ab.TravelerId || ab.TravelerId || ab.TravelerUserId || ab.TravelerUserId || '';
                                const displayName = ab.travelerName || ab.TravelerName || ab.TravelerName || 'Traveler';
                                const avatar = ab.travelerAvatar || ab.TravelerAvatar || '/images/AVATAR.png';
                                const bookingDate = ab.bookingDate || ab.BookingDate || '';
                                const bookingStatus = Number(ab.status ?? ab.Status);
                                const confirmedBookingId = bookingStatus === 1 ? bid : null;
                                if (!participantId) continue;
                                const existing = this.threads.find(t => String(t.BookingId) === String(bid));
                                if (existing) {
                                    // Booking data is authoritative for the guide/traveler relationship.
                                    existing.ParticipantId = participantId;
                                    existing.OtherId = participantId;
                                    existing.TravelerId = participantId;
                                    existing.TravelerName = displayName || existing.TravelerName;
                                    existing.TravelerAvatar = avatar || existing.TravelerAvatar;
                                    existing.TourName = ab.tourName || ab.TourName || existing.TourName;
                                    existing.BookingDate = bookingDate || existing.BookingDate;
                                    existing.BookingStatus = bookingStatus;
                                    existing.BookingIds = Array.from(new Set([...(existing.BookingIds || [existing.BookingId]), bid]));
                                    existing.ConfirmedBookingId = confirmedBookingId || existing.ConfirmedBookingId;
                                    existing.IsLocked = !existing.ConfirmedBookingId;
                                    existing.Date ||= bookingDate ? new Date(bookingDate).toLocaleDateString('vi-VN') : '';
                                } else {
                                    this.threads.push({
                                        Id: bid,
                                        BookingId: bid,
                                        BookingIds: [bid],
                                        BookingStatus: bookingStatus,
                                        ConfirmedBookingId: confirmedBookingId,
                                        ParticipantId: participantId,
                                        TravelerId: participantId,
                                        GuideId: ab.guideProfileId || ab.GuideProfileId || ab.GuideId || '',
                                        TravelerName: displayName,
                                        TravelerAvatar: avatar,
                                        TourName: ab.tourName || ab.TourName || '',
                                        BookingDate: bookingDate,
                                        Messages: [],
                                        LastMessage: 'Không có tin nhắn',
                                        LastMessageAt: null,
                                        TimeAgo: '',
                                        Date: bookingDate ? new Date(bookingDate).toLocaleDateString('vi-VN') : '',
                                        UnreadCount: 0,
                                        IsLocked: !confirmedBookingId,
                                        OtherId: participantId
                                    });
                                }
                            }
                        } catch (e) { console.warn('merge active bookings failed', e); }

                        // Show one sidebar thread per person. Always retain real
                        // message data over an empty booking-only placeholder.
                        try {
                            const map = new Map();
                            const requestedBookingId = new URLSearchParams(window.location.search).get('bookingId');
                            const getThreadTime = thread => {
                                const value = thread?.LastMessageAt || thread?.BookingDate;
                                const time = value ? new Date(value).getTime() : 0;
                                return Number.isNaN(time) ? 0 : time;
                            };
                            const getMessageTime = thread => {
                                const time = thread?.LastMessageAt ? new Date(thread.LastMessageAt).getTime() : 0;
                                return Number.isNaN(time) ? 0 : time;
                            };
                            for (const th of this.threads) {
                                const participantId = th.ParticipantId || th.OtherId || th.TravelerId;
                                const bookingId = th.BookingId || th.Id || '';
                                const key = participantId
                                    ? `participant:${String(participantId).trim().toLowerCase()}`
                                    : (bookingId ? `booking:${String(bookingId)}` : null);
                                if (!key) continue;

                                const existing = map.get(key);
                                if (!existing) {
                                    th.BookingIds = Array.from(new Set([...(th.BookingIds || []), bookingId].filter(Boolean)));
                                    th.IsLocked = !th.ConfirmedBookingId;
                                    if (th.ConfirmedBookingId) th.BookingId = th.ConfirmedBookingId;
                                    map.set(key, th);
                                    continue;
                                }

                                const thMessageTime = getMessageTime(th);
                                const existingMessageTime = getMessageTime(existing);
                                const thHasMessages = thMessageTime > 0 || (th.Messages?.length || 0) > 0;
                                const existingHasMessages = existingMessageTime > 0 || (existing.Messages?.length || 0) > 0;
                                const preferThis = (thHasMessages && !existingHasMessages)
                                    || (thHasMessages === existingHasMessages && thHasMessages
                                        && (thMessageTime > existingMessageTime
                                            || (thMessageTime === existingMessageTime
                                                && (th.Messages?.length || 0) > (existing.Messages?.length || 0))))
                                    || (!thHasMessages && !existingHasMessages
                                        && getThreadTime(th) > getThreadTime(existing));

                                const winner = preferThis ? th : existing;
                                const bookingIds = Array.from(new Set([
                                    ...(existing.BookingIds || [existing.BookingId]),
                                    ...(th.BookingIds || [th.BookingId])
                                ].filter(Boolean)));
                                const confirmedThreads = [existing, th].filter(item => item.ConfirmedBookingId);
                                const requestedConfirmed = confirmedThreads.find(item =>
                                    requestedBookingId && String(item.ConfirmedBookingId) === String(requestedBookingId));
                                const confirmedThread = requestedConfirmed || confirmedThreads
                                    .sort((a, b) => getThreadTime(b) - getThreadTime(a))[0];

                                winner.BookingIds = bookingIds;
                                winner.ConfirmedBookingId = confirmedThread?.ConfirmedBookingId || null;
                                winner.IsLocked = !winner.ConfirmedBookingId;
                                if (winner.ConfirmedBookingId) winner.BookingId = winner.ConfirmedBookingId;
                                map.set(key, winner);
                            }
                            this.threads = Array.from(map.values());
                        } catch (e) { console.warn('dedupe threads failed', e); }

                        // Fetch profiles (avatar + full name) for each thread's other participant
                        for (const th of this.threads) {
                            const other = th.ParticipantId || th.OtherId || th.TravelerId || th.GuideId;
                            if (!other) continue;
                            fetch(`/api/chat/profiles/${encodeURIComponent(other)}`, {
                                headers: { 'Authorization': 'Bearer ' + token }
                            }).then(r => {
                                if (!r.ok) return null;
                                return r.json();
                            }).then(p => {
                                if (!p) return;
                                th.TravelerAvatar = p.avatarUrl || p.AvatarUrl || th.TravelerAvatar || '/images/AVATAR.png';
                                th.TravelerName = p.fullName || p.FullName || th.TravelerName;
                            }).catch(() => {});
                        }

                    } catch (err) {
                        console.error(err);
                        showToast('error', 'Lỗi khi tải cuộc trò chuyện');
                    }
                },

                async selectThread(thread) {
                    if (this.isSending) return;
                    this.newMessage = '';
                    this.clearPendingFiles();
                    this.activeThread = thread;

                    // Refresh messages for selected thread
                    await this.loadMessagesForThread(thread);

                    // Reset unread count locally
                    const t = this.threads.find(x => x.Id === thread.Id);
                    if (t) t.UnreadCount = 0;
                    this.scrollToBottom();
                },

                async loadMessagesForThread(thread) {
                    const token = localStorage.getItem('accessToken');
                    const userId = localStorage.getItem('userId');
                    if (!token) return;
                    try {
                        const pageSize = 30;
                        // Initialize paging state on thread
                        thread._pageSize = pageSize;
                        thread._offset = 0; // offset in pages (0 == newest page)
                        // Fetch newest page (newest-first) and then reverse for chronological
                        const res = await fetch(`${this.getMessagesUrl(thread)}?limit=${pageSize}&offset=0`, {
                            headers: { 'Authorization': 'Bearer ' + token }
                        });
                        if (!res.ok) throw new Error('Không thể tải tin nhắn');
                        const data = await res.json();
                        const rows = data?.messages || [];
                        console.log('loaded rows for', thread.BookingId, rows);
                        // rows are newest-first; reverse to chronological
                        const ordered = (rows || []).slice().reverse();
                        thread.Messages = ordered.map(r => ({
                            Id: r.id || r.Id,
                            Text: r.messageText || r.MessageText || '',
                            SentAt: r.sentAt || r.SentAt,
                            IsMine: (r.senderId || r.SenderId) === userId,
                            Time: new Date(r.sentAt || r.SentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }),
                            IsRead: !!(r.isRead || r.IsRead)
                        }));
                        thread._loaded = rows.length;
                        console.log('thread.Messages', thread.Messages);
                        thread._hasMore = (rows.length === pageSize);

                        const newest = rows.length ? rows[0] : null;
                        thread.LastMessage = newest ? (newest.messageText || newest.MessageText) : thread.LastMessage;
                        thread.LastMessageAt = newest ? (newest.sentAt || newest.SentAt) : thread.LastMessageAt;
                        thread.TimeAgo = newest ? this.formatTimeAgo(newest.sentAt || newest.SentAt) : thread.TimeAgo;
                        thread.UnreadCount = rows.filter(m => !(m.isRead || m.IsRead) && (m.receiverId || m.ReceiverId) === userId).length;
                        // Mark messages as read on server for this user
                        try {
                            const markReadResponse = await fetch(this.getMarkReadUrl(thread), {
                                method: 'POST',
                                headers: { 'Authorization': 'Bearer ' + token }
                            });
                            if (markReadResponse.ok) window.TripMateMessages?.refreshUnreadThreads();
                        } catch (e) {
                            console.warn('Failed to mark messages as read', e);
                        }
                    } catch (err) {
                        console.error(err);
                    }
                },

                async loadMoreMessages() {
                    const thread = this.activeThread;
                    if (!thread || !thread._hasMore) return;
                    const token = localStorage.getItem('accessToken');
                    if (!token) return;
                    try {
                        const pageSize = thread._pageSize || 30;
                        const offset = thread._loaded || 0;
                        const res = await fetch(`${this.getMessagesUrl(thread)}?limit=${pageSize}&offset=${offset}`, {
                            headers: { 'Authorization': 'Bearer ' + token }
                        });
                        if (!res.ok) throw new Error('Không thể tải tin nhắn cũ');
                        const data = await res.json();
                        const rows = data?.messages || [];
                        const ordered = (rows || []).slice().reverse();
                        // Prepend older messages
                        const prep = ordered.map(r => ({
                            Id: r.id || r.Id,
                            Text: r.messageText || r.MessageText || '',
                            SentAt: r.sentAt || r.SentAt,
                            IsMine: (r.senderId || r.SenderId) === localStorage.getItem('userId'),
                            Time: new Date(r.sentAt || r.SentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }),
                            IsRead: !!(r.isRead || r.IsRead)
                        }));
                        thread.Messages = prep.concat(thread.Messages || []);
                        thread._loaded = (thread._loaded || 0) + rows.length;
                        thread._hasMore = (rows.length === pageSize);
                    } catch (e) {
                        console.error(e);
                        showToast('error', 'Không thể tải thêm tin nhắn');
                    }
                },

                async sendMessage() {
                    const text = this.newMessage.trim();
                    if ((!text && this.pendingFiles.length === 0) || !this.activeThread || this.isSending) return;
                    if (this.activeThread.IsLocked || !this.activeThread.ConfirmedBookingId) {
                        return;
                    }

                    const token = localStorage.getItem('accessToken');
                    const userId = localStorage.getItem('userId');
                    const receiverId = this.activeThread.ParticipantId || this.activeThread.OtherId;

                    this.isSending = true;
                    try {
                        if (text) {
                            const res = await fetch(`/api/chat/conversations/${encodeURIComponent(this.activeThread.ConfirmedBookingId)}/messages`, {
                                method: 'POST',
                                headers: {
                                    'Authorization': 'Bearer ' + token,
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ Content: text, ReceiverId: receiverId })
                            });
                            if (!res.ok) throw new Error('Không gửi được tin nhắn');
                            const msg = await res.json();
                            this.appendMessageIfMissing(this.activeThread, {
                                ...msg,
                                senderId: userId,
                                receiverId
                            });
                            this.activeThread.LastMessage = msg.messageText || msg.MessageText || text;
                            this.activeThread.TimeAgo = 'Vừa xong';
                            this.newMessage = '';
                        }

                        while (this.pendingFiles.length > 0) {
                            await this.uploadPendingAttachment(this.pendingFiles[0].File);
                            this.removePendingFile(0);
                        }

                        // Move thread to top
                        const index = this.threads.findIndex(t => t.Id === this.activeThread.Id);
                        if (index > 0) {
                            const t = this.threads.splice(index, 1)[0];
                            this.threads.unshift(t);
                        }

                        this.scrollToBottom();
                    } catch (err) {
                        console.error(err);
                        showToast('error', 'Không thể gửi tin nhắn hoặc tệp đính kèm');
                    } finally {
                        this.isSending = false;
                    }
                },

                resizeMessageTextarea() {
                    const textarea = this.$event.target;
                    textarea.style.height = 'auto';
                    textarea.style.height = (textarea.scrollHeight) + 'px';
                },

                scrollToBottom() {
                    setTimeout(() => {
                        const container = document.getElementById('chatContainer');
                        if (container) container.scrollTop = container.scrollHeight;
                    }, 50);
                },

                formatTimeAgo(iso) {
                    if (!iso) return '';
                    const d = new Date(iso);
                    const diff = (Date.now() - d.getTime()) / 1000;
                    if (diff < 60) return 'Vừa xong';
                    if (diff < 3600) return Math.floor(diff / 60) + ' phút trước';
                    if (diff < 86400) return Math.floor(diff / 3600) + ' giờ trước';
                    return d.toLocaleDateString('vi-VN');
                }
            }
        }
    </script>
}
