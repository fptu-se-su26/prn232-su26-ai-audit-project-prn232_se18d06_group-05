@model IReadOnlyList<TripMate_WebAPI.DTOs.Tour.Responses.MyTourDashboardDto>
@using System.Text.Json
@{
    ViewData["Title"] = "My Tours";
    ViewData["ActivePage"] = "MyTours";
    ViewData["TurboCacheControl"] = "no-cache";
    Layout = "_GuideLayout";
    var serializedTours = JsonSerializer.Serialize(Model ?? [], new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    });
}

<script>
    window.myToursInitialData = @Html.Raw(serializedTours);
    function myToursApp(initialTours) {
        return {
            tours: initialTours || [], filter: 'all', searchQuery: '', sortBy: 'updated', openDropdown: null,
            previewTour: null, qualityTour: null, actionDialogOpen: false, pendingAction: null,
            isProcessingAction: false, failedImages: {},
            statusTabs: [{id:'all',label:'All'}, {id:'published',label:'Published'}, {id:'draft',label:'Drafts'}, {id:'hidden',label:'Hidden'}],
            get filteredTours() {
                const query = this.searchQuery.trim().toLocaleLowerCase();
                return this.tours
                    .filter(tour => (this.filter === 'all' || tour.publicationStatus === this.filter)
                        && (!query || `${tour.name} ${tour.city}`.toLocaleLowerCase().includes(query)))
                    .sort((a, b) => {
                        if (this.sortBy === 'bookings') return b.bookingCount - a.bookingCount;
                        if (this.sortBy === 'revenue') return b.revenue - a.revenue;
                        if (this.sortBy === 'quality') return b.completenessScore - a.completenessScore;
                        if (this.sortBy === 'name') return (a.name || '').localeCompare(b.name || '');
                        return new Date(b.updatedAt) - new Date(a.updatedAt);
                    });
            },
            get totalBookings() { return this.tours.reduce((sum, tour) => sum + tour.bookingCount, 0); },
            get totalRevenue() { return this.tours.reduce((sum, tour) => sum + Number(tour.revenue || 0), 0); },
            get totalReviews() { return this.tours.reduce((sum, tour) => sum + tour.reviewCount, 0); },
            get portfolioRating() {
                const rated = this.tours.filter(tour => tour.averageRating && tour.reviewCount);
                if (!rated.length) return null;
                return (rated.reduce((sum, tour) => sum + tour.averageRating * tour.reviewCount, 0)
                    / rated.reduce((sum, tour) => sum + tour.reviewCount, 0)).toFixed(1);
            },
            countByStatus(status) { return status === 'all' ? this.tours.length : this.tours.filter(tour => tour.publicationStatus === status).length; },
            formatCurrency(value) { return new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND', maximumFractionDigits:0 }).format(Number(value || 0)); },
            formatDate(value) { return value ? new Intl.DateTimeFormat('en-GB', { day:'numeric', month:'short', year:'numeric' }).format(new Date(value)) : 'recently'; },
            statusLabel(status) { return ({published:'Published', draft:'Draft', hidden:'Hidden'})[status] || 'Hidden'; },
            statusClass(status) { return status === 'published' ? 'bg-white/95 text-green-700' : status === 'draft' ? 'bg-amber-50 text-amber-700' : 'bg-slate-900/80 text-white'; },
            ratingLabel(tour) { return tour.reviewCount ? `${Number(tour.averageRating).toFixed(1)} (${tour.reviewCount})` : 'No reviews'; },
            qualityLabel(tour) { return tour.completenessScore === 100 ? 'Strong listing' : `${tour.completenessScore}% quality`; },
            priceCaption(tour) {
                if (!tour) return '';
                const included = `Includes ${tour.includedGuests} ${tour.includedGuests === 1 ? 'guest' : 'guests'}`;
                return tour.additionalGuestFee > 0 && tour.maxGuests > tour.includedGuests
                    ? `${included} · +${this.formatCurrency(tour.additionalGuestFee)}/extra guest`
                    : included;
            },
            closeOverlays() { this.openDropdown = null; this.previewTour = null; this.qualityTour = null; if (!this.isProcessingAction) this.actionDialogOpen = false; },
            requestAction(type, tour) {
                this.openDropdown = null;
                const active = tour.publicationStatus === 'published';
                const copy = {
                    toggle: { title: active ? 'Hide this tour?' : 'Publish this tour?', description: active ? 'Travelers will no longer be able to make new bookings.' : 'This tour will be visible and bookable again.', confirmLabel: active ? 'Hide tour' : 'Publish tour' },
                    duplicate: { title:'Create a draft copy?', description:'A separate draft will be created for you to review and edit.', confirmLabel:'Create copy' },
                    delete: { title:'Remove this tour?', description:'Tours with booking history are archived. Tours without bookings are permanently deleted.', confirmLabel:'Remove tour' }
                }[type];
                this.pendingAction = { type, tour, ...copy }; this.actionDialogOpen = true;
            },
            async confirmAction() {
                if (!this.pendingAction || this.isProcessingAction) return;
                const action = this.pendingAction;
                const endpoints = { toggle:[`/ToggleTourStatus/${action.tour.id}`,'PATCH'], duplicate:[`/DuplicateTour/${action.tour.id}`,'POST'], delete:[`/DeleteTour/${action.tour.id}`,'DELETE'] };
                this.isProcessingAction = true;
                try {
                    const [url, method] = endpoints[action.type];
                    const response = await fetch(url, { method });
                    const result = await response.json();
                    if (!response.ok || !result.success) throw new Error(result.message || 'The action could not be completed.');
                    if (action.type === 'toggle') {
                        action.tour.publicationStatus = action.tour.publicationStatus === 'published' ? 'hidden' : 'published';
                        action.tour.isActive = action.tour.publicationStatus === 'published'; action.tour.updatedAt = new Date().toISOString();
                    } else if (action.type === 'delete') {
                        if (result.data?.outcome === 'archived') { action.tour.publicationStatus = 'hidden'; action.tour.isActive = false; }
                        else this.tours = this.tours.filter(tour => tour.id !== action.tour.id);
                    } else {
                        this.tours.unshift({ ...action.tour, id:result.data.id, name:`${action.tour.name} (Copy)`, publicationStatus:'draft', isActive:false, bookingCount:0, completedBookingCount:0, revenue:0, averageRating:null, reviewCount:0, updatedAt:new Date().toISOString() });
                    }
                    this.actionDialogOpen = false; showToast('success', result.message || 'Tour updated.');
                } catch (error) { showToast('error', error.message || 'Please try again.'); }
                finally { this.isProcessingAction = false; }
            }
        };
    }
</script>

<div x-data="myToursApp(window.myToursInitialData)" @@keydown.escape.window="closeOverlays()" class="space-y-5">
    <header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-primary">Tour management</p>
            <h1 class="mt-0.5 text-2xl font-black tracking-tight text-slate-950">My Tours</h1>
            <p class="mt-1 text-sm text-slate-500">Manage availability, listing quality, and performance.</p>
        </div>
        <a href="/Guide/CreateTour" data-turbo="false" class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-4 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-primary-dark focus:outline-none focus:ring-4 focus:ring-orange-200">
            <span class="material-symbols-outlined text-[18px]">add</span> Create Tour
        </a>
    </header>

    <section class="grid grid-cols-2 gap-3 xl:grid-cols-4" aria-label="Tour performance summary">
        <article class="rounded-xl border border-slate-100 bg-white p-3 shadow-sm"><div class="flex items-center justify-between"><span class="text-[11px] font-bold uppercase tracking-wide text-slate-500">Published</span><span class="material-symbols-outlined text-[19px] text-green-500">visibility</span></div><p class="mt-1.5 text-xl font-black text-slate-950" x-text="countByStatus('published')"></p><p class="text-xs text-slate-500">Visible to travelers</p></article>
        <article class="rounded-xl border border-slate-100 bg-white p-3 shadow-sm"><div class="flex items-center justify-between"><span class="text-[11px] font-bold uppercase tracking-wide text-slate-500">Bookings</span><span class="material-symbols-outlined text-[19px] text-blue-500">confirmation_number</span></div><p class="mt-1.5 text-xl font-black text-slate-950" x-text="totalBookings"></p><p class="text-xs text-slate-500">Active and completed</p></article>
        <article class="rounded-xl border border-slate-100 bg-white p-3 shadow-sm"><div class="flex items-center justify-between"><span class="text-[11px] font-bold uppercase tracking-wide text-slate-500">Net earnings</span><span class="material-symbols-outlined text-[19px] text-emerald-500">payments</span></div><p class="mt-1.5 text-lg font-black text-slate-950" x-text="formatCurrency(totalRevenue)"></p><p class="text-xs text-slate-500">Completed bookings</p></article>
        <article class="rounded-xl border border-slate-100 bg-white p-3 shadow-sm"><div class="flex items-center justify-between"><span class="text-[11px] font-bold uppercase tracking-wide text-slate-500">Average rating</span><span class="material-symbols-outlined text-[19px] text-amber-500">star</span></div><p class="mt-1.5 text-xl font-black text-slate-950" x-text="portfolioRating || '—'"></p><p class="text-xs text-slate-500" x-text="totalReviews ? `${totalReviews} verified review${totalReviews === 1 ? '' : 's'}` : 'No reviews yet'"></p></article>
    </section>

    <section class="rounded-2xl border border-slate-100 bg-white p-3 shadow-sm">
        <div class="grid gap-3 xl:grid-cols-[minmax(280px,1fr)_auto_210px] xl:items-center">
            <label class="relative min-w-0"><span class="sr-only">Search tours</span><span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400">search</span><input x-model.debounce.200ms="searchQuery" type="search" placeholder="Search by tour name or city" class="w-full rounded-xl border border-slate-200 bg-slate-50 py-2.5 pl-11 pr-4 text-sm outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-orange-100"></label>
            <div class="flex gap-1 overflow-x-auto rounded-xl bg-slate-50 p-1" role="group" aria-label="Filter tours"><template x-for="tab in statusTabs" :key="tab.id"><button type="button" @@click="filter=tab.id" :aria-pressed="filter===tab.id" :class="filter===tab.id ? 'bg-white text-slate-950 shadow-sm' : 'text-slate-500 hover:text-slate-800'" class="inline-flex items-center gap-2 whitespace-nowrap rounded-lg px-3 py-2 text-xs font-bold transition"><span x-text="tab.label"></span><span class="rounded-full bg-slate-100 px-1.5 py-0.5 text-[11px]" x-text="countByStatus(tab.id)"></span></button></template></div>
            <label><span class="sr-only">Sort tours</span><select x-model="sortBy" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-700 outline-none focus:border-primary"><option value="updated">Recently updated</option><option value="bookings">Most booked</option><option value="revenue">Highest earnings</option><option value="quality">Best listing quality</option><option value="name">Name A–Z</option></select></label>
        </div>
    </section>

    <section x-show="filteredTours.length" class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3" aria-live="polite">
        <template x-for="tour in filteredTours" :key="tour.id">
            <article class="relative rounded-2xl border border-slate-100 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg">
                <button type="button" @@click="previewTour=tour" :aria-label="`Preview ${tour.name || 'untitled tour'}`" class="group relative block w-full aspect-video overflow-hidden rounded-t-2xl bg-gradient-to-br from-orange-100 via-amber-50 to-slate-100 text-left focus:outline-none focus:ring-4 focus:ring-inset focus:ring-orange-300">
                    <div x-show="!tour.imageUrl || failedImages[tour.id]" class="absolute inset-0 flex flex-col items-center justify-center text-orange-400"><span class="material-symbols-outlined text-4xl">landscape</span><span class="mt-1 text-xs font-bold">Add a cover photo</span></div>
                    <img x-show="tour.imageUrl && !failedImages[tour.id]" :src="tour.imageUrl" :alt="tour.name" @@error="failedImages[tour.id]=true" class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/65 via-transparent to-slate-950/5"></div>
                    <span class="absolute left-3 top-3 inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-black shadow-sm" :class="statusClass(tour.publicationStatus)"><span class="h-1.5 w-1.5 rounded-full bg-current"></span><span x-text="statusLabel(tour.publicationStatus)"></span></span>
                    <span x-show="tour.city" class="absolute bottom-3 left-3 inline-flex items-center gap-1 rounded-lg bg-white/90 px-2 py-1 text-xs font-bold text-slate-700 backdrop-blur"><span class="material-symbols-outlined text-[14px] text-primary">location_on</span><span x-text="tour.city"></span></span>
                    <span class="absolute bottom-3 right-3 inline-flex items-center gap-1 rounded-lg bg-slate-950/75 px-2 py-1 text-[11px] font-bold text-white backdrop-blur"><span class="material-symbols-outlined text-[14px]">visibility</span> Preview</span>
                </button>

                <div class="p-3.5">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0"><h2 class="line-clamp-1 text-[17px] font-black text-slate-950" x-text="tour.name || 'Untitled draft'"></h2><p class="text-xs font-medium text-slate-500" x-text="`Updated ${formatDate(tour.updatedAt)}`"></p></div>
                        <div class="relative"><button type="button" @@click.stop="openDropdown=openDropdown===tour.id?null:tour.id" :aria-expanded="openDropdown===tour.id" :aria-label="`More actions for ${tour.name}`" class="flex h-9 w-9 items-center justify-center rounded-full text-slate-500 hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-orange-300"><span class="material-symbols-outlined">more_vert</span></button><div x-show="openDropdown===tour.id" @@click.outside="openDropdown=null" x-transition.opacity style="display:none" class="absolute right-0 top-10 z-40 w-48 overflow-hidden rounded-xl border border-slate-100 bg-white py-1 shadow-xl"><a :href="`/Guide/CreateTour?id=${tour.id}`" data-turbo="false" class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50"><span class="material-symbols-outlined text-[18px]">edit</span><span x-text="tour.publicationStatus==='draft'?'Continue editing':'Edit tour'"></span></a><button x-show="tour.publicationStatus!=='draft'" type="button" @@click="requestAction('toggle',tour)" class="flex w-full items-center gap-2 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50"><span class="material-symbols-outlined text-[18px]" x-text="tour.publicationStatus==='published'?'visibility_off':'visibility'"></span><span x-text="tour.publicationStatus==='published'?'Hide tour':'Publish tour'"></span></button><button type="button" @@click="requestAction('duplicate',tour)" class="flex w-full items-center gap-2 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50"><span class="material-symbols-outlined text-[18px]">content_copy</span>Duplicate</button><button type="button" @@click="requestAction('delete',tour)" class="flex w-full items-center gap-2 border-t border-slate-100 px-4 py-2.5 text-sm font-bold text-red-600 hover:bg-red-50"><span class="material-symbols-outlined text-[18px]">delete</span>Remove</button></div></div>
                    </div>

                    <div class="mt-3 grid grid-cols-3 divide-x divide-slate-200 rounded-xl bg-slate-50 py-2.5 text-center">
                        <div><p class="text-sm font-black text-slate-900" x-text="tour.bookingCount"></p><p class="text-[10px] font-bold uppercase tracking-wide text-slate-500">Bookings</p></div>
                        <div><p class="text-sm font-black text-slate-900" x-text="tour.reviewCount ? Number(tour.averageRating).toFixed(1) : '—'"></p><p class="text-[10px] font-bold uppercase tracking-wide text-slate-500">Rating</p></div>
                        <button type="button" @@click="qualityTour=tour" class="focus:outline-none focus:ring-2 focus:ring-inset focus:ring-orange-300" :aria-label="`View listing quality for ${tour.name}`"><p class="text-sm font-black" :class="tour.completenessScore===100?'text-green-600':'text-amber-600'" x-text="`${tour.completenessScore}%`"></p><p class="text-[10px] font-bold uppercase tracking-wide text-slate-500">Quality</p></button>
                    </div>

                    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-xs font-semibold text-slate-600">
                        <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">schedule</span><span x-text="`${tour.duration} hours`"></span></span>
                        <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">group</span><span x-text="`Up to ${tour.maxGuests}`"></span></span>
                    </div>

                    <div class="mt-3 flex items-end justify-between gap-3 border-t border-slate-100 pt-2.5">
                        <div class="min-w-0"><p class="text-[17px] font-black text-primary" x-text="formatCurrency(tour.price)"></p><p class="truncate text-[10px] font-medium text-slate-500" x-text="priceCaption(tour)"></p></div>
                        <a :href="`/Guide/CreateTour?id=${tour.id}`" data-turbo="false" class="inline-flex shrink-0 items-center gap-1 rounded-lg bg-slate-950 px-3 py-2 text-xs font-bold text-white transition hover:bg-primary focus:outline-none focus:ring-4 focus:ring-orange-200"><span class="material-symbols-outlined text-[15px]">edit</span><span x-text="tour.publicationStatus==='draft'?'Complete':'Edit'"></span></a>
                    </div>
                </div>
            </article>
        </template>
    </section>

    <section x-show="!filteredTours.length" class="flex flex-col items-center justify-center rounded-2xl border border-slate-100 bg-white px-6 py-14 text-center" style="display:none"><span class="material-symbols-outlined text-5xl text-slate-300" x-text="tours.length?'search_off':'map'"></span><h2 class="mt-3 text-lg font-black text-slate-900" x-text="tours.length?'No tours match these filters':'Create your first tour'"></h2><p class="mt-1 text-sm text-slate-500" x-text="tours.length?'Try another status or search term.':'Turn your local knowledge into a bookable experience.'"></p><button x-show="tours.length" type="button" @@click="searchQuery='';filter='all'" class="mt-4 rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-bold text-slate-700">Clear filters</button><a x-show="!tours.length" href="/Guide/CreateTour" data-turbo="false" class="mt-4 inline-flex rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white">Create Tour</a></section>

    <div x-show="qualityTour" class="fixed inset-0 z-[95] flex items-center justify-center p-4" style="display:none" role="dialog" aria-modal="true" aria-labelledby="quality-dialog-title"><div class="absolute inset-0 bg-slate-950/55 backdrop-blur-sm" @@click="qualityTour=null"></div><section class="relative w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl"><button type="button" @@click="qualityTour=null" class="absolute right-4 top-4 flex h-9 w-9 items-center justify-center rounded-full text-slate-500 hover:bg-slate-100" aria-label="Close listing quality"><span class="material-symbols-outlined">close</span></button><p class="text-xs font-bold uppercase tracking-wider text-primary">Listing quality</p><h2 id="quality-dialog-title" class="mt-1 pr-10 text-xl font-black text-slate-950" x-text="qualityTour?.name || 'Untitled draft'"></h2><div class="mt-5 flex items-center gap-4"><div class="flex h-16 w-16 items-center justify-center rounded-full bg-orange-50 text-lg font-black text-primary" x-text="`${qualityTour?.completenessScore || 0}%`"></div><p class="flex-1 text-sm leading-6 text-slate-500" x-text="qualityTour?.completenessScore===100?'This listing contains all recommended information.':'Complete the items below to help travelers book with confidence.'"></p></div><ul class="mt-5 space-y-2"><template x-for="item in qualityTour?.missingQualityItems || []" :key="item"><li class="flex items-start gap-2 rounded-xl bg-amber-50 px-3 py-2.5 text-sm font-semibold text-amber-800"><span class="material-symbols-outlined text-[18px]">error</span><span x-text="item"></span></li></template><li x-show="qualityTour?.completenessScore===100" class="flex items-center gap-2 rounded-xl bg-green-50 px-3 py-3 text-sm font-semibold text-green-700"><span class="material-symbols-outlined text-[18px]">check_circle</span>All recommended details are complete.</li></ul><a :href="`/Guide/CreateTour?id=${qualityTour?.id}`" data-turbo="false" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-slate-950 px-4 py-3 text-sm font-bold text-white hover:bg-primary"><span class="material-symbols-outlined text-[18px]">edit</span>Improve listing</a></section></div>

    <div x-show="previewTour" class="fixed inset-0 z-[90] flex items-center justify-center p-4" style="display:none" role="dialog" aria-modal="true" aria-label="Traveler preview"><div class="absolute inset-0 bg-slate-950/55 backdrop-blur-sm" @@click="previewTour=null"></div><article class="relative max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-3xl bg-white shadow-2xl"><div class="relative h-64 bg-gradient-to-br from-orange-100 to-slate-200"><div x-show="!previewTour?.imageUrl || failedImages[previewTour?.id]" class="absolute inset-0 flex items-center justify-center text-orange-300"><span class="material-symbols-outlined text-6xl">landscape</span></div><img x-show="previewTour?.imageUrl && !failedImages[previewTour?.id]" :src="previewTour?.imageUrl" alt="" class="h-full w-full object-cover"><div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 to-transparent"></div><button @@click="previewTour=null" class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/90 text-slate-700" aria-label="Close preview"><span class="material-symbols-outlined">close</span></button><div class="absolute bottom-5 left-6 right-6 text-white"><p class="text-xs font-bold uppercase tracking-wider" x-text="previewTour?.city"></p><h2 class="mt-1 text-2xl font-black" x-text="previewTour?.name || 'Untitled draft'"></h2></div></div><div class="space-y-5 p-6"><div class="flex flex-wrap gap-4 text-sm font-semibold text-slate-600"><span x-text="`${previewTour?.duration} hours`"></span><span x-text="`Up to ${previewTour?.maxGuests} guests`"></span><span x-text="previewTour?.languages?.join(' · ') || 'Languages not added'"></span></div><p class="whitespace-pre-line text-sm leading-7 text-slate-600" x-text="previewTour?.description || 'Add a description to help travelers understand this experience.'"></p><div class="rounded-2xl bg-orange-50 p-4"><p class="text-xs font-bold uppercase text-orange-500">Tour price</p><p class="mt-1 text-2xl font-black text-primary" x-text="formatCurrency(previewTour?.price)"></p><p class="text-xs text-orange-700" x-text="priceCaption(previewTour)"></p></div><p class="text-center text-xs text-slate-400">This preview approximates what travelers will see.</p></div></article></div>

    <div x-show="actionDialogOpen" class="fixed inset-0 z-[100] flex items-center justify-center p-4" style="display:none" role="dialog" aria-modal="true" aria-labelledby="tour-action-title"><div class="absolute inset-0 bg-slate-950/55" @@click="!isProcessingAction&&(actionDialogOpen=false)"></div><div class="relative w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl"><h2 id="tour-action-title" class="text-lg font-black text-slate-950" x-text="pendingAction?.title"></h2><p class="mt-2 text-sm leading-6 text-slate-500" x-text="pendingAction?.description"></p><p class="mt-3 truncate rounded-xl bg-slate-50 px-3 py-2 text-xs font-bold text-slate-600" x-text="pendingAction?.tour?.name"></p><div class="mt-6 flex justify-end gap-2"><button @@click="actionDialogOpen=false" :disabled="isProcessingAction" class="rounded-xl px-4 py-2.5 text-sm font-bold text-slate-600">Cancel</button><button @@click="confirmAction" :disabled="isProcessingAction" :class="pendingAction?.type==='delete'?'bg-red-600':'bg-primary'" class="inline-flex min-w-28 items-center justify-center rounded-xl px-4 py-2.5 text-sm font-bold text-white disabled:opacity-60"><span x-text="isProcessingAction?'Working…':pendingAction?.confirmLabel"></span></button></div></div></div>
</div>
