@{
    ViewData["Title"] = "Tour Package Management";
    ViewData["ActivePage"] = "MyTours";
    Layout = "_GuideLayout";
}

<div x-data="myToursComponent()">
    <!-- Header Area -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <h2 class="text-3xl font-bold text-gray-900">My Tours</h2>
                <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-sm font-bold border border-blue-100" x-text="`${activeCount}/${tours.length} active packages`">
                </span>
            </div>
            <p class="text-gray-500 text-sm">Manage and customize the experiences you offer.</p>
        </div>
        <a href="/Guide/CreateTour" class="bg-primary hover:bg-primary-dark text-white px-6 py-3 rounded-xl font-bold transition-colors shadow-sm flex items-center gap-2 flex-shrink-0">
            <span class="material-symbols-outlined text-[20px]">add</span> Create New Package
        </a>
    </div>

    <!-- Filters Bar -->
    <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col md:flex-row gap-4 mb-8">
        <div class="relative flex-grow">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">search</span>
            <input type="text" x-model="searchQuery" placeholder="Search by package name..."
                   class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
        </div>
        <div class="flex bg-gray-50 p-1 rounded-xl border border-gray-200">
            <button @@click="filter = 'all'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'all', 'text-gray-500 font-medium': filter !== 'all'}" class="px-6 py-2 rounded-lg text-sm transition-all">
                All
            </button>
            <button @@click="filter = 'active'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'active', 'text-gray-500 font-medium': filter !== 'active'}" class="px-6 py-2 rounded-lg text-sm transition-all">
                Active
            </button>
            <button @@click="filter = 'hidden'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'hidden', 'text-gray-500 font-medium': filter !== 'hidden'}" class="px-6 py-2 rounded-lg text-sm transition-all">
                Hidden
            </button>
        </div>
    </div>

    <!-- Tour List -->
    <div class="space-y-6">
        <template x-for="tour in filteredTours" :key="tour.id">
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 transition-all hover:shadow-md relative overflow-hidden">
                
                <div x-show="!tour.isActive" class="absolute inset-0 bg-white/40 backdrop-blur-[1px] z-10 pointer-events-none"></div>

                <div class="flex flex-col md:flex-row justify-between gap-6 relative z-20">
                    <div class="flex-grow">
                        <div class="flex items-center gap-3 mb-2">
                            <h3 class="text-xl font-bold text-gray-900" x-text="tour.title"></h3>
                            <template x-if="tour.isActive">
                                <span class="flex items-center gap-1 bg-green-50 text-green-700 px-2.5 py-0.5 rounded-md text-xs font-bold border border-green-200">
                                    <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div> Active
                                </span>
                            </template>
                            <template x-if="!tour.isActive">
                                <span class="flex items-center gap-1 bg-gray-100 text-gray-600 px-2.5 py-0.5 rounded-md text-xs font-bold border border-gray-200">
                                    Hidden
                                </span>
                            </template>
                        </div>
                        
                        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-gray-600 mb-4">
                            <div class="flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-[18px] text-gray-400">schedule</span>
                                <span x-text="`${tour.durationHours} hours`"></span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-[18px] text-gray-400">group</span>
                                <span x-text="`Up to ${tour.maxGroupSize} people`"></span>
                            </div>
                            <div class="flex items-center gap-1.5 font-bold text-primary">
                                <span class="material-symbols-outlined text-[18px]">payments</span>
                                <span x-text="formatCurrency(tour.pricePerSession)"></span>
                            </div>
                        </div>
                        
                        <div class="flex flex-wrap gap-2 mb-4">
                            <template x-for="tag in tour.tags" :key="tag">
                                <span class="bg-gray-100 text-gray-600 px-2.5 py-1 rounded-md text-xs font-medium border border-gray-200" x-text="`#${tag}`">
                                </span>
                            </template>
                        </div>
                    </div>

                    <div class="flex flex-row md:flex-col justify-end gap-3 min-w-[140px]">
                        <a :href="`/Guide/CreateTour?id=${tour.id}`" class="flex-1 md:flex-none text-center bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-xl font-medium transition-colors text-sm">
                            Edit
                        </a>
                        <button @@click="toggleTourActive(tour)" class="flex-1 md:flex-none text-center bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-xl font-medium transition-colors text-sm" x-text="tour.isActive ? 'Hide Package' : 'Show Package'">
                        </button>
                        <button @@click="deleteTour(tour)" class="flex-1 md:flex-none text-center bg-white border border-red-200 text-red-600 hover:bg-red-50 px-4 py-2 rounded-xl font-medium transition-colors text-sm">
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        </template>
        
        <div x-show="filteredTours.length === 0" class="bg-white rounded-2xl p-16 border border-gray-100 text-center text-gray-500 shadow-sm" x-cloak>
            <span class="material-symbols-outlined text-5xl mb-2 text-gray-300">explore_off</span>
            <p class="text-sm">No experience packages found.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function myToursComponent() {
            return {
                tours: [],
                searchQuery: '',
                filter: 'all',
                
                async init() {
                    const token = localStorage.getItem('accessToken');
                    if (!token) {
                        window.location.href = '/Auth/Login';
                        return;
                    }
                    await this.loadTours();
                },

                async loadTours() {
                    try {
                        const res = await fetch('/api/tours/my', {
                            headers: { 'Authorization': `Bearer ${localStorage.getItem('accessToken')}` }
                        });
                        if (res.ok) {
                            this.tours = await res.json();
                        } else {
                            showToast('error', 'Failed to load tours.');
                        }
                    } catch (err) {
                        console.error('Error loading tours:', err);
                        showToast('error', 'Unable to connect to the server.');
                    }
                },

                get activeCount() {
                    return this.tours.filter(t => t.isActive).length;
                },

                get filteredTours() {
                    return this.tours.filter(t => {
                        const title = (t.title || '').toLowerCase();
                        const search = this.searchQuery.toLowerCase();
                        const matchesSearch = title.includes(search);
                        const matchesFilter = this.filter === 'all' ||
                                              (this.filter === 'active' && t.isActive) ||
                                              (this.filter === 'hidden' && !t.isActive);
                        return matchesSearch && matchesFilter;
                    });
                },

                formatCurrency(val) {
                    if (!val) return '0 ₫';
                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val);
                },

                async toggleTourActive(tour) {
                    const nextState = !tour.isActive;
                    const actionText = nextState ? 'show' : 'hide';
                    const actionPast = nextState ? 'shown' : 'hidden';
                    if (!confirm(`Are you sure you want to ${actionText} this experience package?`)) return;

                    try {
                        const res = await fetch(`/api/tours/${tour.id}`, {
                            method: 'PATCH',
                            headers: { 
                                'Content-Type': 'application/json',
                                'Authorization': `Bearer ${localStorage.getItem('accessToken')}` 
                            },
                            body: JSON.stringify({ isActive: nextState })
                        });
                        if (res.ok) {
                            tour.isActive = nextState;
                            showToast('success', `Experience package ${actionPast} successfully.`);
                        } else {
                            const err = await res.json();
                            showToast('error', err.message || 'Failed to update tour status.');
                        }
                    } catch (err) {
                        console.error(err);
                        showToast('error', 'Unable to connect to the server.');
                    }
                },

                async deleteTour(tour) {
                    if (!confirm('Are you sure you want to delete this experience package? This action cannot be undone.')) return;

                    try {
                        const res = await fetch(`/api/tours/${tour.id}`, {
                            method: 'DELETE',
                            headers: { 
                                'Authorization': `Bearer ${localStorage.getItem('accessToken')}` 
                            }
                        });
                        if (res.status === 204) {
                            this.tours = this.tours.filter(t => t.id !== tour.id);
                            showToast('success', 'Experience package deleted successfully.');
                        } else if (res.ok) {
                            const data = await res.json();
                            showToast('success', data.message || 'The deletion request has been processed.');
                            await this.loadTours(); // Reload list to see changes (like soft-delete archives)
                        } else {
                            const err = await res.json();
                            showToast('error', err.message || 'Failed to delete the experience package.');
                        }
                    } catch (err) {
                        console.error(err);
                        showToast('error', 'Unable to connect to the server.');
                    }
                }
            }
        }
    </script>
}
