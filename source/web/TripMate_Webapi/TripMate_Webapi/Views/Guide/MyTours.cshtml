@{
    ViewData["Title"] = "Quản lý Gói Tour";
    ViewData["ActivePage"] = "MyTours";
    Layout = "_GuideLayout";
    
    var tours = ViewBag.Tours as IEnumerable<dynamic>;
    var activeCount = tours?.Count(t => t.IsActive) ?? 0;
}

<div x-data="{ filter: 'all', searchQuery: '' }">
    <!-- Header Area -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <h2 class="text-3xl font-bold text-gray-900">My Tours</h2>
                <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-sm font-bold border border-blue-100">
                    @activeCount/10 gói đang dùng
                </span>
            </div>
            <p class="text-gray-500 text-sm">Quản lý và tùy chỉnh các trải nghiệm bạn cung cấp.</p>
        </div>
        <a href="/Guide/CreateTour" class="bg-primary hover:bg-primary-dark text-white px-6 py-3 rounded-xl font-bold transition-colors shadow-sm flex items-center gap-2 flex-shrink-0">
            <span class="material-symbols-outlined text-[20px]">add</span> Tạo Gói Mới
        </a>
    </div>

    <!-- Filters Bar -->
    <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col md:flex-row gap-4 mb-8">
        <div class="relative flex-grow">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">search</span>
            <input type="text" x-model="searchQuery" placeholder="Tìm kiếm theo tên gói..." 
                   class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
        </div>
        <div class="flex bg-gray-50 p-1 rounded-xl border border-gray-200">
            <button @@click="filter = 'all'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'all', 'text-gray-500 font-medium': filter !== 'all'}" class="px-6 py-2 rounded-lg text-sm transition-all">
                Tất cả
            </button>
            <button @@click="filter = 'active'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'active', 'text-gray-500 font-medium': filter !== 'active'}" class="px-6 py-2 rounded-lg text-sm transition-all">
                Đang hoạt động
            </button>
            <button @@click="filter = 'hidden'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'hidden', 'text-gray-500 font-medium': filter !== 'hidden'}" class="px-6 py-2 rounded-lg text-sm transition-all">
                Đã ẩn
            </button>
        </div>
    </div>

    <!-- Tour List -->
    <div class="space-y-6">
        @if (tours != null)
        {
            foreach (var tour in tours)
            {
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 transition-all hover:shadow-md relative overflow-hidden"
                     x-show="(filter === 'all' || (filter === 'active' && @(tour.IsActive ? "true" : "false")) || (filter === 'hidden' && @(!tour.IsActive ? "true" : "false"))) && ('@(tour.Name)'.toLowerCase().includes(searchQuery.toLowerCase()))">
                    
                    @if (!tour.IsActive)
                    {
                        <div class="absolute inset-0 bg-white/40 backdrop-blur-[1px] z-10 pointer-events-none"></div>
                    }

                    <div class="flex flex-col md:flex-row justify-between gap-6 relative z-20">
                        <div class="flex-grow">
                            <div class="flex items-center gap-3 mb-2">
                                <h3 class="text-xl font-bold text-gray-900">@tour.Name</h3>
                                @if (tour.IsActive)
                                {
                                    <span class="flex items-center gap-1 bg-green-50 text-green-700 px-2.5 py-0.5 rounded-md text-xs font-bold border border-green-200">
                                        <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div> Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-1 bg-gray-100 text-gray-600 px-2.5 py-0.5 rounded-md text-xs font-bold border border-gray-200">
                                        Đã ẩn
                                    </span>
                                }
                            </div>
                            
                            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-gray-600 mb-4">
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[18px] text-gray-400">schedule</span>
                                    <span>@tour.Duration giờ</span>
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[18px] text-gray-400">group</span>
                                    <span>Tối đa @tour.MaxGuests người</span>
                                </div>
                                <div class="flex items-center gap-1.5 font-bold text-primary">
                                    <span class="material-symbols-outlined text-[18px]">payments</span>
                                    <span>₫@tour.Price.ToString("N0") / buổi</span>
                                </div>
                            </div>
                            
                            <div class="flex flex-wrap gap-2 mb-4">
                                @foreach (var tag in tour.Tags)
                                {
                                    <span class="bg-gray-100 text-gray-600 px-2.5 py-1 rounded-md text-xs font-medium border border-gray-200">
                                        #@tag
                                    </span>
                                }
                            </div>

                            <div class="flex gap-6 text-sm">
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[18px] text-blue-500">bar_chart</span>
                                    <span class="font-medium text-gray-900">@tour.Bookings</span>
                                    <span class="text-gray-500">lượt đặt</span>
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[18px] text-amber-400" style="font-variation-settings: 'FILL' 1;">star</span>
                                    <span class="font-medium text-gray-900">@tour.Rating</span>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-row md:flex-col justify-end gap-3 min-w-[140px]">
                            <a href="/Guide/CreateTour?id=@tour.Id" class="flex-1 md:flex-none text-center bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-xl font-medium transition-colors text-sm">
                                Chỉnh sửa
                            </a>
                            <button class="flex-1 md:flex-none text-center bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-xl font-medium transition-colors text-sm">
                                @(tour.IsActive ? "Ẩn gói" : "Hiện gói")
                            </button>
                            <button class="flex-1 md:flex-none text-center bg-white border border-red-200 text-red-600 hover:bg-red-50 px-4 py-2 rounded-xl font-medium transition-colors text-sm">
                                Xóa
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
