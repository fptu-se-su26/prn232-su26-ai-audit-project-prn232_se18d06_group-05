@using TripMate_WebAPI.DTOs.Tour.Responses
@{
    ViewData["Title"] = "Quản lý Gói Tour";
    ViewData["ActivePage"] = "MyTours";
    Layout = "_GuideLayout";
    
    var tours = ViewBag.Tours as IEnumerable<MyTourDashboardDto>;
    var activeCount = tours?.Count(t => t.IsActive) ?? 0;
}

<div x-data="myToursApp()" @@click.outside="openDropdown = null">
    <!-- Header Area -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <h2 class="text-3xl font-bold text-gray-900">My Tours</h2>
                <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-sm font-bold border border-blue-100">
                    @activeCount/10 gói đang dùng
                </span>
            </div>
            <p class="text-gray-500 text-sm">Quản lý và tùy chỉnh các trải nghiệm bạn cung cấp.</p>
        </div>
        <a href="/Guide/CreateTour" class="bg-primary hover:bg-primary-dark text-white px-6 py-3 rounded-xl font-bold transition-colors shadow-sm flex items-center gap-2 flex-shrink-0">
            <span class="material-symbols-outlined text-[20px]">add</span> Tạo Gói Mới
        </a>
    </div>

    <!-- Filters Bar -->
    <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col lg:flex-row gap-4 mb-8">
        <div class="relative flex-grow">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">search</span>
            <input type="text" x-model="searchQuery" placeholder="Tìm kiếm theo tên gói..." 
                   class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all">
        </div>
        <div class="flex bg-gray-50 p-1 rounded-xl border border-gray-200 overflow-x-auto hide-scrollbar">
            <button @@click="filter = 'all'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'all', 'text-gray-500 font-medium hover:text-gray-900': filter !== 'all'}" class="px-6 py-2 rounded-lg text-sm transition-all whitespace-nowrap">
                Tất cả
            </button>
            <button @@click="filter = 'active'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'active', 'text-gray-500 font-medium hover:text-gray-900': filter !== 'active'}" class="px-6 py-2 rounded-lg text-sm transition-all whitespace-nowrap">
                Đang hoạt động
            </button>
            <button @@click="filter = 'hidden'" :class="{'bg-white shadow-sm font-bold text-gray-900': filter === 'hidden', 'text-gray-500 font-medium hover:text-gray-900': filter !== 'hidden'}" class="px-6 py-2 rounded-lg text-sm transition-all whitespace-nowrap">
                Đã ẩn
            </button>
        </div>
    </div>

    <!-- Tour Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if (tours != null)
        {
            foreach (var tour in tours)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 transition-all hover:shadow-lg relative flex flex-col group"
                     x-show="(filter === 'all' || (filter === 'active' && @(tour.IsActive ? "true" : "false")) || (filter === 'hidden' && @(!tour.IsActive ? "true" : "false"))) && ('@(tour.Name)'.toLowerCase().includes(searchQuery.toLowerCase()))"
                     :class="{'opacity-60 grayscale-[30%]': !@(tour.IsActive ? "true" : "false")}">
                    
                    <!-- Image Header -->
                    <div class="h-48 w-full relative overflow-hidden rounded-t-2xl">
                        <img src="@tour.ImageUrl" alt="@tour.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <!-- Gradient Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/20"></div>
                        
                        <!-- Status Badge -->
                        <div class="absolute top-4 left-4">
                            @if (tour.IsActive)
                            {
                                <span class="flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-green-700 px-3 py-1 rounded-full text-xs font-bold shadow-sm">
                                    <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div> Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="flex items-center gap-1.5 bg-gray-900/80 backdrop-blur-sm text-white px-3 py-1 rounded-full text-xs font-bold shadow-sm">
                                    <span class="material-symbols-outlined text-[14px]">visibility_off</span> Đã ẩn
                                </span>
                            }
                        </div>

                        <!-- Rating & Bookings Badge -->
                        <div class="absolute bottom-4 left-4 flex gap-2">
                            <span class="flex items-center gap-1 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-lg text-xs font-bold text-gray-900 shadow-sm">
                                <span class="material-symbols-outlined text-[14px] text-amber-500" style="font-variation-settings: 'FILL' 1;">star</span>
                                @tour.Rating
                            </span>
                            <span class="flex items-center gap-1 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-lg text-xs font-bold text-gray-900 shadow-sm">
                                <span class="material-symbols-outlined text-[14px] text-blue-500">book_online</span>
                                @tour.Bookings lượt
                            </span>
                        </div>
                    </div>

                    <!-- Content Body -->
                    <div class="p-5 flex-grow flex flex-col">
                        <h3 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2" title="@tour.Name">@tour.Name</h3>
                        
                        <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">schedule</span>
                                <span>@tour.Duration giờ</span>
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">group</span>
                                <span>Tối đa @tour.MaxGuests</span>
                            </div>
                        </div>
                        
                        <div class="flex flex-wrap gap-1.5 mb-auto pb-4">
                            @foreach (var tag in tour.Tags)
                            {
                                <span class="bg-gray-50 text-gray-600 px-2 py-1 rounded-md text-[10px] uppercase tracking-wider font-bold border border-gray-100">
                                    #@tag
                                </span>
                            }
                        </div>
                        
                        <!-- Divider -->
                        <hr class="border-gray-100 mb-4 mt-2">
                        
                        <!-- Footer Action Area -->
                        <div class="flex items-center justify-between">
                            <div class="font-bold text-primary text-lg">
                                ₫@tour.Price.ToString("N0") <span class="text-xs font-normal text-gray-400">/khách</span>
                            </div>
                            
                            <!-- Actions -->
                            <div class="flex items-center gap-2 relative">
                                <a href="/Guide/CreateTour?id=@tour.Id" class="w-9 h-9 rounded-full bg-orange-50 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors" title="Chỉnh sửa">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </a>
                                
                                <button @@click.stop="openDropdown === @tour.Id ? openDropdown = null : openDropdown = @tour.Id" class="w-9 h-9 rounded-full bg-gray-50 text-gray-600 flex items-center justify-center hover:bg-gray-200 transition-colors" title="Thêm hành động">
                                    <span class="material-symbols-outlined text-[20px]">more_vert</span>
                                </button>
                                
                                <!-- Dropdown Menu -->
                                <div x-show="openDropdown === @tour.Id" 
                                     x-transition.opacity.duration.200ms
                                     style="display: none;"
                                     class="absolute right-0 bottom-12 w-48 bg-white rounded-xl shadow-xl border border-gray-100 z-30 overflow-hidden">
                                    <button @@click="toggleStatus('@tour.Id')" class="w-full text-left px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                        @(tour.IsActive ? "Ẩn gói tour này" : "Hiện gói tour này")
                                    </button>
                                    <button class="w-full text-left px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">content_copy</span>
                                        Nhân bản (Duplicate)
                                    </button>
                                    <div class="border-t border-gray-100 my-1"></div>
                                    <button @@click="deleteTour('@tour.Id')" class="w-full text-left px-4 py-2.5 text-sm font-bold text-red-600 hover:bg-red-50 flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                        Xóa gói tour
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('myToursApp', () => ({
                filter: 'all',
                searchQuery: '',
                openDropdown: null,
                
                async toggleStatus(tourId) {
                    this.openDropdown = null;
                    if(!confirm("Bạn có chắc muốn thay đổi trạng thái gói tour này?")) return;
                    
                    try {
                        const res = await fetch(`/ToggleTourStatus/${tourId}`, { method: 'PATCH' });
                        const result = await res.json();
                        if (result.success) {
                            window.location.reload();
                        } else {
                            alert(result.message);
                        }
                    } catch(e) {
                        alert("Lỗi hệ thống");
                    }
                },
                
                async deleteTour(tourId) {
                    this.openDropdown = null;
                    if(!confirm("Bạn có chắc muốn XÓA VĨNH VIỄN gói tour này?")) return;
                    
                    try {
                        const res = await fetch(`/DeleteTour/${tourId}`, { method: 'DELETE' });
                        const result = await res.json();
                        if (result.success) {
                            window.location.reload();
                        } else {
                            alert(result.message);
                        }
                    } catch(e) {
                        alert("Lỗi hệ thống");
                    }
                }
            }));
        });
    </script>
}
