@{
    ViewData["Title"] = "Quản lý Lịch";
    ViewData["ActivePage"] = "Calendar";
    Layout = "_GuideLayout";
}

<!-- FullCalendar CSS & Script -->
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js'></script>
<style>
    /* FullCalendar Overrides */
    .fc-toolbar-title { font-size: 1.25rem !important; font-weight: 700 !important; color: #1f2937 !important; }
    .fc-button-primary { background-color: #FF6B35 !important; border-color: #FF6B35 !important; }
    .fc-button-primary:hover { background-color: #E55A2B !important; border-color: #E55A2B !important; }
    .fc-button-active { background-color: #E55A2B !important; }
    .fc-day-today { background-color: transparent !important; }
    .fc-day-today .fc-daygrid-day-number { background-color: #FF6B35; color: white !important; border-radius: 50%; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; }
    .fc-daygrid-day-number { color: #4b5563 !important; font-weight: 600 !important; padding: 8px !important; text-decoration: none !important;}
    
    .fc-blocked-day { background-color: #fee2e2 !important; cursor: pointer; transition: all 0.2s; }
    .fc-booked-day { background-color: #f0f9ff !important; cursor: not-allowed; }
    .fc-available-day { cursor: pointer; transition: all 0.2s; }
    .fc-available-day:hover { background-color: #f3f4f6 !important; }
    
    .fc-scrollgrid { border-color: #f3f4f6 !important; border-radius: 12px; overflow: hidden; }
    .fc-daygrid-day-frame { padding: 0 !important; min-height: 100px !important; position: relative !important; }
    .fc-daygrid-day-top { display: flex !important; flex-direction: column !important; height: 100% !important; opacity: 1 !important; z-index: 2; }
    .fc-daygrid-day-events { display: none !important; }
    
    /* Custom booking label */
    .booking-label { background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; padding: 6px 8px; border-radius: 8px; font-size: 0.75rem; margin-top: 4px; display: flex; flex-direction: column; gap: 4px; box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2); }
    .blocked-label { background: #fca5a5; color: #991b1b; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; margin-top: 4px; font-weight: 600; text-align: center; }
</style>

<script>
    function calendarManager() {
        return {
            activeTab: 'stats', // 'stats' or 'upcoming'
            calendar: null,
            currentMonth: new Date().getMonth() + 1,
            daysInMonth: 30, // Tạm thời
            
            // Mock data from server -> REMOVED, now fetched dynamically
            originalBlockedDates: [],
            bookings: {},
            
            // Current state
            blockedDates: [],
            hasChanges: false,
            isSaving: false,
            isFetching: true, // Track API loading state for skeleton

            initCalendar(attempt = 0) {
                if (typeof FullCalendar === 'undefined') {
                    if (attempt >= 20) { console.warn('FullCalendar failed to load.'); return; }
                    setTimeout(() => this.initCalendar(attempt + 1), 50);
                    return;
                }

                this.blockedDates = [...this.originalBlockedDates];
                
                const calendarEl = document.getElementById('calendar');
                
                this.calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    locale: 'vi',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: '' 
                    },
                    buttonText: {
                        today: 'Hôm nay',
                    },
                    firstDay: 1, // Start on Monday
                    height: 'auto', // Removes internal scrollbar completely
                    contentHeight: 'auto',
                    fixedWeekCount: false,
                    
                    // Fetch data dynamically based on view range
                    events: async (fetchInfo, successCallback, failureCallback) => {
                        try {
                            const startStr = fetchInfo.startStr.split('T')[0];
                            const endStr = fetchInfo.endStr.split('T')[0];
                            
                            const res = await fetch(`/Guide/GetCalendarData?start=${startStr}&end=${endStr}`);
                            if (!res.ok) throw new Error('Network response was not ok');
                            
                            const data = await res.json();
                            
                            // Update Alpine state
                            this.originalBlockedDates = data.blockedDates.map(d => d.date);
                            this.blockedDates = [...this.originalBlockedDates];
                            
                            this.bookings = {};
                            data.bookings.forEach(b => {
                                this.bookings[b.bookingDate] = {
                                    guest: b.guestName,
                                    pax: b.guestCount,
                                    revenue: b.guideEarnings,
                                    title: b.packageTitle,
                                    status: b.status
                                };
                            });
                            
                            // Let FullCalendar know we're done
                            successCallback([]);
                        } catch (error) {
                            console.error('Error fetching calendar data:', error);
                            showToast('error', 'Lỗi tải dữ liệu lịch');
                            failureCallback(error);
                        }
                    },
                    
                    // Triggered when fetch starts/stops
                    loading: (isLoading) => {
                        this.isFetching = isLoading;
                        // Force a re-render so dayCellContent can switch between Skeletons and Real Data
                        setTimeout(() => {
                            this.calendar.render();
                        }, 10);
                    },
                    
                    // Custom rendering for days
                    dayCellContent: (info) => {
                        const date = info.date;
                        const dateStr = date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0') + '-' + String(date.getDate()).padStart(2, '0');
                        
                        // 1. SKELETON LOADING STATE
                        if (this.isFetching) {
                            return { 
                                html: `
                                    <div class="flex flex-col h-full w-full min-h-[80px] p-1 animate-pulse">
                                        <div class="h-4 w-5 bg-gray-200 rounded self-end mb-auto mt-1 mr-1"></div>
                                        <div class="h-6 w-full bg-gray-100 rounded mt-2"></div>
                                    </div>
                                ` 
                            };
                        }

                        // 2. REAL DATA STATE
                        let html = `
                            <div class="flex flex-col h-full w-full min-h-[80px]">
                                <div class="text-right text-gray-700 font-medium text-sm p-1.5">${info.dayNumberText}</div>
                                <div class="flex-1 flex flex-col justify-end p-1">
                        `;
                        
                        if (this.bookings[dateStr]) {
                            const b = this.bookings[dateStr];
                            html += `
                                    <div class="booking-label w-full m-0">
                                        <div class="truncate font-bold">${b.guest}</div>
                                        <div class="flex items-center justify-between opacity-90 text-[10px]">
                                            <span>👤 ${b.pax}</span>
                                            <span>Tour</span>
                                        </div>
                                    </div>
                            `;
                        } else if (this.blockedDates.includes(dateStr)) {
                            html += `<div class="blocked-label w-full m-0">Đã chặn</div>`;
                        }
                        
                        html += `
                                </div>
                            </div>
                        `;
                        return { html: html };
                    },
                    
                    dayCellDidMount: (info) => {
                        const date = info.date;
                        const dateStr = date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0') + '-' + String(date.getDate()).padStart(2, '0');
                        const cell = info.el;
                        
                        cell.classList.remove('fc-blocked-day', 'fc-booked-day', 'fc-available-day');
                        
                        if (this.isFetching) {
                            // Don't add hover effects or titles while loading
                            return;
                        }

                        if (this.bookings[dateStr]) {
                            cell.classList.add('fc-booked-day');
                            cell.title = `Booking: ${this.bookings[dateStr].title}\nKhách: ${this.bookings[dateStr].guest}\nSố người: ${this.bookings[dateStr].pax}`;
                        } else if (this.blockedDates.includes(dateStr)) {
                            cell.classList.add('fc-blocked-day');
                            cell.title = "Bạn đã chặn ngày này. Click để bỏ chặn.";
                        } else {
                            cell.classList.add('fc-available-day');
                            cell.title = "Ngày trống. Click để chặn.";
                        }
                    },
                    
                    // Handle clicking a date
                    dateClick: (info) => {
                        const dateStr = info.dateStr;
                        
                        if (this.bookings[dateStr]) {
                            showToast('warning', 'Ngày này đã có tour, không thể chặn!');
                            return;
                        }
                        
                        this.toggleDate(dateStr);
                    },
                    
                    // Handle changing months
                    datesSet: (info) => {
                        const midDate = new Date((info.start.getTime() + info.end.getTime()) / 2);
                        this.currentMonth = midDate.getMonth() + 1;
                        this.daysInMonth = new Date(midDate.getFullYear(), midDate.getMonth() + 1, 0).getDate();
                    }
                });
                
                this.calendar.render();
            },
            
            toggleDate(dateStr) {
                const index = this.blockedDates.indexOf(dateStr);
                if (index > -1) {
                    this.blockedDates.splice(index, 1);
                } else {
                    this.blockedDates.push(dateStr);
                }
                
                this.checkChanges();
                this.calendar.render(); // Re-render to update dayCellContent
            },
            
            clearAllBlocked() {
                if (this.blockedDates.length === 0) return;
                if (confirm('Bạn chắc chắn muốn bỏ chặn tất cả các ngày trong tháng?')) {
                    this.blockedDates = [];
                    this.checkChanges();
                    this.calendar.render(); 
                }
            },
            
            blockWeekends() {
                if (confirm('Chặn tất cả Thứ 7 và Chủ Nhật đang hiển thị trên lịch?')) {
                    const view = this.calendar.view;
                    const start = view.activeStart;
                    const end = view.activeEnd;
                    
                    let curr = new Date(start);
                    while (curr < end) {
                        if (curr.getDay() === 0 || curr.getDay() === 6) { // 0 = Sun, 6 = Sat
                            const dateStr = curr.toISOString().split('T')[0];
                            if (!this.bookings[dateStr] && !this.blockedDates.includes(dateStr)) {
                                this.blockedDates.push(dateStr);
                            }
                        }
                        curr.setDate(curr.getDate() + 1);
                    }
                    this.checkChanges();
                    this.calendar.render();
                }
            },

            checkChanges() {
                const sortedCurrent = [...this.blockedDates].sort().join(',');
                const sortedOriginal = [...this.originalBlockedDates].sort().join(',');
                this.hasChanges = sortedCurrent !== sortedOriginal;
            },
            
            discardChanges() {
                this.blockedDates = [...this.originalBlockedDates];
                this.hasChanges = false;
                this.calendar.render();
            },
            
            async saveChanges() {
                this.isSaving = true;
                
                try {
                    const view = this.calendar.view;
                    const startStr = view.activeStart.getFullYear() + '-' + String(view.activeStart.getMonth() + 1).padStart(2, '0') + '-' + String(view.activeStart.getDate()).padStart(2, '0');
                    const endStr = view.activeEnd.getFullYear() + '-' + String(view.activeEnd.getMonth() + 1).padStart(2, '0') + '-' + String(view.activeEnd.getDate()).padStart(2, '0');
                    
                    const res = await fetch('/Guide/SaveBlockedDates', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            rangeStart: startStr,
                            rangeEnd: endStr,
                            blockedDates: this.blockedDates
                        })
                    });
                    
                    if (!res.ok) {
                        throw new Error('Lỗi cập nhật dữ liệu');
                    }
                    
                    this.originalBlockedDates = [...this.blockedDates];
                    this.hasChanges = false;
                    showToast('success', 'Đã cập nhật lịch rảnh thành công!');
                } catch (error) {
                    console.error(error);
                    showToast('error', 'Cập nhật thất bại. Vui lòng thử lại.');
                } finally {
                    this.isSaving = false;
                }
            },
            
            get bookedDatesCount() {
                return Object.keys(this.bookings).length;
            },
            
            getAvailableDays() {
                return this.daysInMonth - this.blockedDates.length - this.bookedDatesCount;
            },
            
            getTotalRevenue() {
                return Object.values(this.bookings).reduce((sum, b) => sum + b.revenue, 0);
            },
            
            formatCurrency(amount) {
                return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
            },
            
            sortedBlockedDates() {
                return [...this.blockedDates].sort();
            },
            
            formatDate(dateStr) {
                const d = new Date(dateStr);
                const days = ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'];
                return `${days[d.getDay()]}, ${d.getDate()}/${d.getMonth()+1}`;
            },
            
            getUpcomingBookings() {
                const today = new Date();
                const todayStr = today.getFullYear() + '-' + String(today.getMonth() + 1).padStart(2, '0') + '-' + String(today.getDate()).padStart(2, '0');
                
                return Object.keys(this.bookings)
                    .filter(date => date >= todayStr)
                    .sort()
                    .map(date => ({ date: date, ...this.bookings[date] }))
                    .slice(0, 5);
            }
        }
    }
</script>

<div x-data="calendarManager()" x-init="initCalendar()" class="flex flex-col">
    <!-- KPI Bar -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4">
        <div class="bg-white rounded-xl p-3 shadow-sm border border-gray-100 flex items-center gap-3 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center text-green-500 shrink-0">
                <span class="material-symbols-outlined text-[20px]">event_available</span>
            </div>
            <div>
                <p class="text-[11px] text-gray-500 font-bold mb-0.5 uppercase tracking-wider">Ngày sẵn sàng</p>
                <h3 class="text-xl font-black text-gray-900" x-text="getAvailableDays()"></h3>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-3 shadow-sm border border-gray-100 flex items-center gap-3 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center text-red-500 shrink-0">
                <span class="material-symbols-outlined text-[20px]">event_busy</span>
            </div>
            <div>
                <p class="text-[11px] text-gray-500 font-bold mb-0.5 uppercase tracking-wider">Đã chặn</p>
                <h3 class="text-xl font-black text-gray-900" x-text="blockedDates.length"></h3>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-3 shadow-sm border border-gray-100 flex items-center gap-3 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-500 shrink-0">
                <span class="material-symbols-outlined text-[20px]">tour</span>
            </div>
            <div>
                <p class="text-[11px] text-gray-500 font-bold mb-0.5 uppercase tracking-wider">Đã có tour</p>
                <h3 class="text-xl font-black text-gray-900" x-text="bookedDatesCount"></h3>
            </div>
        </div>
        
        <div class="bg-white rounded-xl p-3 shadow-sm border border-gray-100 flex items-center gap-3 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 rounded-full bg-orange-50 flex items-center justify-center text-primary shrink-0">
                <span class="material-symbols-outlined text-[20px]">payments</span>
            </div>
            <div>
                <p class="text-[11px] text-gray-500 font-bold mb-0.5 uppercase tracking-wider">Dự kiến thu</p>
                <h3 class="text-lg font-black text-gray-900" x-text="formatCurrency(getTotalRevenue())"></h3>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 xl:grid-cols-4 gap-4 flex-1">
        
        <!-- Left: Calendar Area -->
        <div class="xl:col-span-3 flex flex-col gap-4">
            <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex-1">
                <!-- Legend -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-3 px-3 py-2 bg-gray-50 rounded-lg border border-gray-100 gap-3">
                    <div class="flex flex-wrap gap-4">
                        <div class="flex items-center gap-2">
                            <div class="w-4 h-4 rounded-md bg-white border border-gray-300"></div>
                            <span class="text-sm font-medium text-gray-700">Sẵn sàng (Click để chặn)</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-4 h-4 rounded-md bg-red-100 border border-red-200"></div>
                            <span class="text-sm font-medium text-gray-700">Đã chặn (Click để bỏ chặn)</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-4 h-4 rounded-md bg-blue-50 border border-blue-200"></div>
                            <span class="text-sm font-medium text-gray-700">Đã có booking</span>
                        </div>
                    </div>
                    
                    <button @@click="clearAllBlocked()" class="px-3 py-1.5 bg-red-50 hover:bg-red-100 text-red-600 rounded-lg text-sm font-bold transition-colors border border-red-100 shadow-sm flex items-center gap-2 sm:ml-auto w-fit">
                        <span class="material-symbols-outlined text-[16px]">delete_sweep</span> Bỏ chặn tất cả
                    </button>
                </div>

                <!-- FullCalendar Container -->
                <div id="calendar" class="flex-1"></div>
            </div>
        </div>

        <!-- Right: Sidebar -->
        <div class="xl:col-span-1 space-y-4 h-full">
            <!-- Tabs Sidebar -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col h-full">
                <div class="flex border-b border-gray-100">
                    <button @@click="activeTab = 'stats'" 
                            :class="activeTab === 'stats' ? 'border-primary text-primary bg-orange-50/50' : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50'"
                            class="flex-1 py-4 text-sm font-bold border-b-2 transition-all flex flex-col items-center justify-center gap-1">
                        <span class="material-symbols-outlined text-[20px]">event_busy</span>
                        Ngày đã chặn
                    </button>
                    <button @@click="activeTab = 'upcoming'" 
                            :class="activeTab === 'upcoming' ? 'border-primary text-primary bg-orange-50/50' : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50'"
                            class="flex-1 py-4 text-sm font-bold border-b-2 transition-all flex flex-col items-center justify-center gap-1">
                        <span class="material-symbols-outlined text-[20px]">tour</span>
                        Tour sắp tới
                    </button>
                </div>
                
                <!-- Tab Content: Blocked Dates -->
                <div x-show="activeTab === 'stats'" class="flex-1 flex flex-col overflow-hidden">
                    <div class="p-4 bg-gray-50 border-b border-gray-100">
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-gray-500 font-medium">Tổng cộng trong tháng</span>
                            <span class="font-bold text-gray-900 bg-white px-3 py-1 rounded-full border border-gray-200 shadow-sm"><span x-text="blockedDates.length"></span> ngày</span>
                        </div>
                    </div>
                    <div class="overflow-y-auto p-0 flex-1">
                        <template x-if="blockedDates.length === 0">
                            <div class="text-center py-12 px-4">
                                <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3">
                                    <span class="material-symbols-outlined text-gray-300 text-[32px]">event_available</span>
                                </div>
                                <p class="text-gray-500 text-sm">Bạn chưa chặn ngày nào.<br>Click vào lịch để chặn.</p>
                            </div>
                        </template>
                        
                        <ul class="divide-y divide-gray-50">
                            <template x-for="date in sortedBlockedDates()" :key="date">
                                <li class="p-4 flex justify-between items-center hover:bg-gray-50 group transition-colors cursor-default">
                                    <div class="flex items-center gap-3">
                                        <div class="w-2 h-2 rounded-full bg-red-400 shadow-[0_0_8px_rgba(248,113,113,0.6)]"></div>
                                        <span class="text-sm font-bold text-gray-700" x-text="formatDate(date)"></span>
                                    </div>
                                    <button @@click="toggleDate(date)" class="text-gray-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all p-1.5 rounded-md hover:bg-red-50" title="Bỏ chặn">
                                        <span class="material-symbols-outlined text-[18px] block">close</span>
                                    </button>
                                </li>
                            </template>
                        </ul>
                    </div>
                </div>
                
                <!-- Tab Content: Upcoming Bookings -->
                <div x-show="activeTab === 'upcoming'" class="flex-1 overflow-y-auto p-0" style="display: none;">
                    <template x-if="getUpcomingBookings().length === 0">
                        <div class="text-center py-12 px-4">
                            <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3">
                                <span class="material-symbols-outlined text-gray-300 text-[32px]">tour</span>
                            </div>
                            <p class="text-gray-500 text-sm">Chưa có booking nào sắp tới.</p>
                        </div>
                    </template>
                    
                    <ul class="divide-y divide-gray-100 p-2 space-y-2">
                        <template x-for="booking in getUpcomingBookings()" :key="booking.date">
                            <li class="p-4 rounded-xl hover:bg-blue-50/50 transition-colors border border-transparent hover:border-blue-100 cursor-pointer">
                                <div class="text-xs font-bold text-primary mb-2 flex items-center gap-1 bg-orange-50 w-fit px-2 py-1 rounded-md">
                                    <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                                    <span x-text="formatDate(booking.date)"></span>
                                </div>
                                <h4 class="font-bold text-gray-900 text-sm mb-2" x-text="booking.title"></h4>
                                <div class="flex items-center gap-4 text-xs text-gray-500 mb-3 bg-gray-50 p-2 rounded-lg">
                                    <span class="flex items-center gap-1 font-medium"><span class="material-symbols-outlined text-[14px]">person</span> <span x-text="booking.guest"></span></span>
                                    <span class="flex items-center gap-1 font-medium"><span class="material-symbols-outlined text-[14px]">group</span> <span x-text="booking.pax + ' pax'"></span></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs text-gray-400">Doanh thu</span>
                                    <span class="text-sm font-bold text-green-600" x-text="formatCurrency(booking.revenue)"></span>
                                </div>
                            </li>
                        </template>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Unsaved Changes Sticky Banner -->
    <div x-show="hasChanges" x-transition.opacity
         class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-[0_-10px_30px_rgba(0,0,0,0.05)] z-50 p-4 transform transition-all duration-300">
        <div class="max-w-7xl mx-auto flex items-center justify-between px-[280px]">
            <div class="flex items-center gap-3 bg-amber-50 px-4 py-2 rounded-lg border border-amber-100">
                <span class="material-symbols-outlined text-amber-500 animate-pulse">info</span>
                <p class="font-bold text-amber-800 text-sm">Bạn có thay đổi lịch rảnh chưa được lưu.</p>
            </div>
            <div class="flex gap-3">
                <button @@click="discardChanges()" class="px-6 py-2.5 rounded-xl font-bold text-gray-600 hover:bg-gray-100 transition-colors">
                    Hủy bỏ
                </button>
                <button @@click="saveChanges()" class="px-8 py-2.5 rounded-xl font-bold bg-primary text-white hover:bg-primary/90 transition-colors shadow-lg shadow-primary/30 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]" x-show="!isSaving">save</span>
                    <span class="material-symbols-outlined text-[20px] animate-spin" x-show="isSaving">autorenew</span>
                    <span x-text="isSaving ? 'Đang lưu...' : 'Lưu Thay Đổi Lịch'"></span>
                </button>
            </div>
        </div>
    </div>
</div>
