@{
    ViewData["Title"] = "Calendar Management";
    ViewData["ActivePage"] = "Calendar";
    Layout = "_GuideLayout";
}

<!-- FullCalendar CSS & Script -->
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js'></script>
<style>
    /* FullCalendar Overrides (Minimalist) */
    .fc-toolbar-title { font-size: 1.25rem !important; font-weight: 700 !important; color: #1f2937 !important; }
    .fc-button-primary { background-color: #FF6B35 !important; border-color: #FF6B35 !important; }
    .fc-button-primary:hover { background-color: #E55A2B !important; border-color: #E55A2B !important; }
    .fc-button-active { background-color: #E55A2B !important; }
    .fc-day-today { background-color: transparent !important; }
    .fc-daygrid-day-number { color: #4b5563 !important; font-weight: 600 !important; padding: 8px !important; text-decoration: none !important;}
    
    /* Past days */
    .fc-day-past { background-color: #f8fafc !important; }
    .fc-day-past .fc-daygrid-day-number { color: #94a3b8 !important; }
    
    /* Hover effects for available future days */
    .fc-day-future:not(.fc-blocked-day):not(.fc-booked-day) { cursor: pointer; transition: background-color 0.2s; }
    .fc-day-future:not(.fc-blocked-day):not(.fc-booked-day):hover { background-color: #f1f5f9 !important; }

    /* Compact booking chips */
    .booking-chip { width: 100%; border: 1px solid transparent; border-radius: 8px; padding: 5px 7px; text-align: left; transition: transform .15s ease, box-shadow .15s ease; }
    .booking-chip:hover, .booking-chip:focus-visible { transform: translateY(-1px); box-shadow: 0 4px 10px rgba(15, 23, 42, .12); outline: none; }
    .booking-chip-confirmed { background: #eff6ff; border-color: #bfdbfe; color: #1d4ed8; }
    .booking-chip-pending { background: #fff7ed; border-color: #fed7aa; color: #c2410c; }
    .booking-chip-completed { background: #f1f5f9; border-color: #e2e8f0; color: #64748b; }
    .booking-more-chip { width: 100%; border-radius: 7px; padding: 3px 6px; background: #f8fafc; color: #475569; font-size: 10px; font-weight: 700; text-align: center; }
    .fc-available-day { cursor: pointer; transition: all 0.2s; }
    .fc-available-day:hover { background-color: #f3f4f6 !important; }
    
    .fc-scrollgrid { border-color: #f3f4f6 !important; border-radius: 12px; overflow: hidden; }
    .fc-daygrid-day-frame { padding: 0 !important; min-height: 118px !important; position: relative !important; }
    .fc-daygrid-day-top { display: flex !important; flex-direction: column !important; height: 100% !important; opacity: 1 !important; z-index: 2; }
    .fc-daygrid-day-events { display: none !important; }
    
    .blocked-label { width: 100%; background: #f1f5f9; border: 1px dashed #cbd5e1; color: #64748b; padding: 5px 8px; border-radius: 7px; font-size: 0.75rem; margin-top: 4px; font-weight: 600; text-align: center; }
    .blocked-label:hover, .blocked-label:focus-visible { border-color: #94a3b8; background: #e2e8f0; color: #475569; outline: none; }
</style>

<script>
    function calendarManager() {
        return {
            activeTab: 'stats', // 'stats' or 'upcoming'
            calendar: null,
            currentMonth: new Date().getMonth() + 1,
            currentYear: new Date().getFullYear(),
            daysInMonth: new Date(new Date().getFullYear(), new Date().getMonth() + 1, 0).getDate(),
            
            // Mock data from server -> REMOVED, now fetched dynamically
            originalBlockedDates: [],
            originalBlockedDateDetails: {},
            bookingsByDate: {},
            blockedDateDetails: {},
            
            // Current state
            blockedDates: [],
            hasChanges: false,
            isSaving: false,
            isFetching: true, // Track API loading state for skeleton
            loadError: null,
            calendarDisplayMode: window.matchMedia('(max-width: 767px)').matches ? 'agenda' : 'month',
            availabilityEditorOpen: false,
            availabilityDate: null,
            availabilityReason: '',
            
            // Navigation guard state
            showLeaveModal: false,
            pendingNavigationUrl: null,
            selectedDate: null,
            selectedDayBookings: [],
            selectedBooking: null,
            isDetailsOpen: false,
            _linkClickHandler: null,
            _beforeUnloadHandler: null,
            _turboBeforeCacheHandler: null,
            _fetchAbortController: null,
            _lastFocusedElement: null,
            _availabilityResetTimer: null,

            initCalendar(attempt = 0) {
                if (typeof FullCalendar === 'undefined') {
                    if (attempt >= 20) {
                        this.isFetching = false;
                        this.loadError = 'The calendar could not be initialized. Please check your connection and try again.';
                        return;
                    }
                    setTimeout(() => this.initCalendar(attempt + 1), 50);
                    return;
                }

                this.blockedDates = [...this.originalBlockedDates];
                
                // Keep named handlers so Turbo/Alpine can clean them up when this page leaves the DOM.
                this._linkClickHandler = (e) => {
                    if (!this.hasChanges) return;
                    const link = e.target.closest('a[href]');
                    if (!link) return;
                    const href = link.getAttribute('href');
                    // Ignore anchors, javascript: links, and same-page links
                    if (!href || href.startsWith('#') || href.startsWith('javascript:')) return;
                    e.preventDefault();
                    e.stopPropagation();
                    this.pendingNavigationUrl = href;
                    this.showLeaveModal = true;
                };
                document.addEventListener('click', this._linkClickHandler);
                
                // Also handle browser back/forward & tab close
                this._beforeUnloadHandler = (e) => {
                    if (this.hasChanges) {
                        e.preventDefault();
                        e.returnValue = '';
                    }
                };
                window.addEventListener('beforeunload', this._beforeUnloadHandler);
                this._turboBeforeCacheHandler = () => this.destroy();
                document.addEventListener('turbo:before-cache', this._turboBeforeCacheHandler, { once: true });
                
                const calendarEl = document.getElementById('calendar');
                
                this.calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    locale: 'en',
                    customButtons: {
                        previousMonth: {
                            text: '‹',
                            hint: 'Previous month',
                            click: () => this.navigateCalendar('prev')
                        },
                        nextMonth: {
                            text: '›',
                            hint: 'Next month',
                            click: () => this.navigateCalendar('next')
                        },
                        todaySafe: {
                            text: 'Today',
                            hint: 'Go to current month',
                            click: () => this.navigateCalendar('today')
                        }
                    },
                    headerToolbar: {
                        left: 'previousMonth,nextMonth todaySafe',
                        center: 'title',
                        right: '' 
                    },
                    buttonText: {
                        today: 'Today',
                    },
                    firstDay: 1, // Start on Monday
                    height: 'auto', // Removes internal scrollbar completely
                    contentHeight: 'auto',
                    fixedWeekCount: false,
                    
                    // Fetch data dynamically based on view range
                    events: async (fetchInfo, successCallback, failureCallback) => {
                        try {
                            const startStr = fetchInfo.startStr.split('T')[0];
                            const endStr = fetchInfo.endStr.split('T')[0];
                            
                            this._fetchAbortController?.abort();
                            this._fetchAbortController = new AbortController();
                            const res = await fetch(`/Guide/GetCalendarData?start=${startStr}&end=${endStr}`, {
                                signal: this._fetchAbortController.signal
                            });
                            const data = await res.json();
                            if (!res.ok) throw new Error(data.message || 'Failed to load calendar data.');
                            
                            this.loadError = null;
                            // Update Alpine state
                            this.originalBlockedDates = data.blockedDates.map(d => d.date);
                            this.blockedDates = [...this.originalBlockedDates];
                            this.originalBlockedDateDetails = Object.fromEntries(
                                data.blockedDates.map(d => [d.date, { ...d }])
                            );
                            this.blockedDateDetails = this.cloneBlockedDetails(this.originalBlockedDateDetails);
                            
                            this.bookingsByDate = {};
                            data.bookings.forEach(b => {
                                const booking = {
                                    id: b.bookingId,
                                    date: b.bookingDate,
                                    startTime: b.startTime,
                                    endTime: b.endTime,
                                    travelerId: b.travelerId,
                                    guest: b.guestName,
                                    travelerAvatarUrl: b.travelerAvatarUrl,
                                    guestCount: b.guestCount,
                                    revenue: b.guideEarnings,
                                    title: b.packageTitle,
                                    packageId: b.packageId,
                                    coverImageUrl: b.coverImageUrl,
                                    meetingPoint: b.meetingPoint,
                                    travelerNotes: b.travelerNotes,
                                    status: b.status
                                };
                                this.bookingsByDate[b.bookingDate] ||= [];
                                this.bookingsByDate[b.bookingDate].push(booking);
                            });
                            Object.values(this.bookingsByDate).forEach(items =>
                                items.sort((a, b) => (a.startTime || '').localeCompare(b.startTime || ''))
                            );
                            
                            // Let FullCalendar know we're done
                            successCallback([]);
                        } catch (error) {
                            if (error.name === 'AbortError') return;
                            console.error('Error fetching calendar data:', error);
                            this.loadError = error.message || 'Failed to load calendar data.';
                            showToast('error', error.message || 'Failed to load calendar data.');
                            failureCallback(error);
                        }
                    },
                    
                    // Triggered when fetch starts/stops
                    loading: (isLoading) => {
                        this.isFetching = isLoading;
                        if (!isLoading) {
                            requestAnimationFrame(() => this.calendar?.render());
                        }
                    },
                    
                    // Custom rendering for days
                    dayCellContent: (info) => this.renderDayCell(info),
                    
                    dayCellDidMount: (info) => {
                        const date = info.date;
                        const dateStr = date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0') + '-' + String(date.getDate()).padStart(2, '0');
                        const cell = info.el;
                        
                        cell.classList.remove('fc-blocked-day', 'fc-booked-day', 'fc-available-day');
                        
                        cell.removeAttribute('title');
                        cell.removeAttribute('tabindex');
                        cell.removeAttribute('role');

                        if (this.isFetching) return;

                        const dayBookings = this.bookingsByDate[dateStr] || [];
                        if (dayBookings.length > 0) {
                            cell.classList.add('fc-booked-day');
                            cell.setAttribute('aria-label', `${this.formatLongDate(dateStr)}. ${dayBookings.length} ${dayBookings.length === 1 ? 'booking' : 'bookings'}.`);
                        } else if (this.blockedDates.includes(dateStr)) {
                            cell.classList.add('fc-blocked-day');
                            this.makeAvailabilityCellAccessible(cell, dateStr, 'Unavailable. Press Enter to manage availability.');
                        } else if (date < new Date().setHours(0,0,0,0)) {
                            cell.style.cursor = 'not-allowed';
                            cell.setAttribute('aria-label', `${this.formatLongDate(dateStr)}. Past date.`);
                        } else {
                            cell.classList.add('fc-available-day');
                            this.makeAvailabilityCellAccessible(cell, dateStr, 'Available. Press Enter to mark unavailable.');
                        }
                    },
                    
                    // Handle clicking a date
                    dateClick: (info) => {
                        const dateStr = info.dateStr;
                        
                        const dayBookings = this.bookingsByDate[dateStr] || [];
                        if (dayBookings.length > 0) {
                            this.openDayDetails(dateStr);
                            return;
                        }

                        if (info.date < new Date().setHours(0, 0, 0, 0)) return;
                        
                        this.openAvailabilityEditor(dateStr, info.jsEvent);
                    },
                    
                    // Handle changing months
                    datesSet: (info) => {
                        const midDate = new Date((info.start.getTime() + info.end.getTime()) / 2);
                        this.currentMonth = midDate.getMonth() + 1;
                        this.currentYear = midDate.getFullYear();
                        this.daysInMonth = new Date(midDate.getFullYear(), midDate.getMonth() + 1, 0).getDate();
                        this.closeAvailabilityEditor(false);
                    }
                });
                
                this.calendar.render();
            },

            renderDayCell(info) {
                const dateStr = this.toLocalDateString(info.date);
                const root = document.createElement('div');
                root.className = 'flex min-h-[108px] h-full w-full flex-col';

                if (this.isFetching) {
                    root.classList.add('animate-pulse', 'p-1');
                    const numberSkeleton = document.createElement('div');
                    numberSkeleton.className = 'h-4 w-5 self-end rounded bg-gray-200 mt-1 mr-1';
                    const cardSkeleton = document.createElement('div');
                    cardSkeleton.className = 'mt-auto h-10 w-full rounded-lg bg-gray-100';
                    root.append(numberSkeleton, cardSkeleton);
                    return { domNodes: [root] };
                }

                const dateHeader = document.createElement('div');
                dateHeader.className = 'flex justify-end p-1.5 text-sm font-semibold text-gray-700';
                const dateNumber = document.createElement('span');
                dateNumber.textContent = info.date.getDate().toString();
                if (info.isToday) {
                    dateNumber.className = 'flex h-7 w-7 items-center justify-center rounded-full bg-primary text-xs font-extrabold text-white shadow-[0_3px_10px_rgba(255,107,53,0.35)]';
                }
                dateHeader.appendChild(dateNumber);
                root.appendChild(dateHeader);

                const content = document.createElement('div');
                content.className = 'mt-auto flex flex-col gap-1 p-1';
                const dayBookings = this.bookingsByDate[dateStr] || [];

                dayBookings.slice(0, 2).forEach(booking => {
                    const chip = document.createElement('button');
                    chip.type = 'button';
                    chip.className = `booking-chip ${this.bookingChipClass(booking.status)}`;
                    chip.setAttribute('aria-label', `${booking.startTime || 'Tour'} ${booking.title}, ${this.statusLabel(booking.status)}`);
                    chip.addEventListener('click', event => {
                        event.preventDefault();
                        event.stopPropagation();
                        this.openDayDetails(dateStr, booking.id);
                    });

                    const primary = document.createElement('span');
                    primary.className = 'flex items-center gap-1 text-[11px] font-bold leading-tight';
                    const time = document.createElement('span');
                    time.className = 'shrink-0 tabular-nums';
                    time.textContent = booking.startTime || 'Tour';
                    const title = document.createElement('span');
                    title.className = 'truncate';
                    title.textContent = booking.title;
                    primary.append(time, title);

                    const meta = document.createElement('span');
                    meta.className = 'mt-1 block truncate text-[9px] font-semibold opacity-75';
                    meta.textContent = `${booking.guestCount} ${booking.guestCount === 1 ? 'guest' : 'guests'} · ${this.statusLabel(booking.status)}`;
                    chip.append(primary, meta);
                    content.appendChild(chip);
                });

                if (dayBookings.length > 2) {
                    const moreButton = document.createElement('button');
                    moreButton.type = 'button';
                    moreButton.className = 'booking-more-chip';
                    moreButton.textContent = `+${dayBookings.length - 2} more`;
                    moreButton.addEventListener('click', event => {
                        event.preventDefault();
                        event.stopPropagation();
                        this.openDayDetails(dateStr);
                    });
                    content.appendChild(moreButton);
                } else if (dayBookings.length === 0 && this.blockedDates.includes(dateStr)) {
                    const blocked = document.createElement('button');
                    blocked.type = 'button';
                    blocked.className = 'blocked-label';
                    blocked.textContent = 'Blocked';
                    blocked.setAttribute('aria-label', `${this.formatLongDate(dateStr)} is unavailable. Manage availability.`);
                    blocked.addEventListener('click', event => {
                        event.preventDefault();
                        event.stopPropagation();
                        this.openAvailabilityEditor(dateStr, event);
                    });
                    content.appendChild(blocked);
                }

                root.appendChild(content);
                return { domNodes: [root] };
            },

            makeAvailabilityCellAccessible(cell, dateStr, stateLabel) {
                cell.setAttribute('tabindex', '0');
                cell.setAttribute('role', 'button');
                cell.setAttribute('aria-label', `${this.formatLongDate(dateStr)}. ${stateLabel}`);
                cell.addEventListener('keydown', event => {
                    if (event.key !== 'Enter' && event.key !== ' ') return;
                    if (event.target.closest('button, a')) return;
                    event.preventDefault();
                    this.openAvailabilityEditor(dateStr, event);
                });
            },

            bookingChipClass(status) {
                if (status === 'pending') return 'booking-chip-pending';
                if (status === 'completed') return 'booking-chip-completed';
                return 'booking-chip-confirmed';
            },

            statusLabel(status) {
                const labels = {
                    pending: 'Pending',
                    confirmed: 'Confirmed',
                    completed: 'Completed'
                };
                return labels[status] || 'Booking';
            },

            statusBadgeClass(status) {
                if (status === 'pending') return 'border-amber-200 bg-amber-50 text-amber-700';
                if (status === 'completed') return 'border-slate-200 bg-slate-100 text-slate-600';
                return 'border-blue-200 bg-blue-50 text-blue-700';
            },

            openDayDetails(dateStr, bookingId = null) {
                const bookings = this.bookingsByDate[dateStr] || [];
                if (bookings.length === 0) return;

                this._lastFocusedElement = document.activeElement;
                this.closeAvailabilityEditor(false);
                this.selectedDate = dateStr;
                this.selectedDayBookings = bookings;
                this.selectedBooking = bookings.find(booking => booking.id === bookingId) || bookings[0];
                this.isDetailsOpen = true;
                document.body.style.overflow = 'hidden';
                setTimeout(() => document.querySelector('[data-booking-drawer-close]')?.focus(), 0);
            },

            openBookingDetails(booking) {
                if (!booking) return;
                this.openDayDetails(booking.date, booking.id);
            },

            selectBooking(booking) {
                this.selectedBooking = booking;
            },

            closeBookingDetails() {
                this.isDetailsOpen = false;
                document.body.style.overflow = '';
                this._lastFocusedElement?.focus?.();
                setTimeout(() => {
                    this.selectedDate = null;
                    this.selectedDayBookings = [];
                    this.selectedBooking = null;
                }, 200);
            },

            navigateCalendar(action) {
                if (this.hasChanges) {
                    const shouldDiscard = confirm('Discard unsaved availability changes and change months?');
                    if (!shouldDiscard) return;
                    this.discardChanges();
                }

                this.closeBookingDetails();
                if (action === 'prev') this.calendar.prev();
                if (action === 'next') this.calendar.next();
                if (action === 'today') this.calendar.today();
            },

            setCalendarDisplayMode(mode) {
                this.calendarDisplayMode = mode;
                if (mode === 'month') {
                    setTimeout(() => this.calendar?.updateSize(), 0);
                }
            },

            retryCalendarData() {
                this.loadError = null;
                this.isFetching = true;
                if (this.calendar) {
                    this.calendar.refetchEvents();
                } else {
                    this.initCalendar();
                }
            },

            toLocalDateString(date) {
                return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
            },

            parseLocalDate(dateStr) {
                const [year, month, day] = dateStr.split('-').map(Number);
                return new Date(year, month - 1, day);
            },

            openAvailabilityEditor(dateStr, event = null) {
                const dayBookings = this.bookingsByDate[dateStr] || [];
                if (dayBookings.length > 0) {
                    this.openDayDetails(dateStr);
                    return;
                }

                if (this.parseLocalDate(dateStr) < new Date().setHours(0, 0, 0, 0)) return;
                clearTimeout(this._availabilityResetTimer);
                this._lastFocusedElement = event?.currentTarget || document.activeElement;
                this.availabilityDate = dateStr;
                this.availabilityReason = this.blockedDateDetails[dateStr]?.reason || '';
                this.availabilityEditorOpen = true;
                document.body.style.overflow = 'hidden';
                setTimeout(() => document.querySelector('[data-availability-reason]')?.focus(), 0);
            },

            closeAvailabilityEditor(restoreFocus = true) {
                if (!this.availabilityEditorOpen) return;
                this.availabilityEditorOpen = false;
                if (!this.isDetailsOpen) document.body.style.overflow = '';
                if (restoreFocus) this._lastFocusedElement?.focus?.();
                this._availabilityResetTimer = setTimeout(() => {
                    this.availabilityDate = null;
                    this.availabilityReason = '';
                }, 150);
            },

            finishAvailabilityEdit(date) {
                this.closeAvailabilityEditor(false);
                this.calendar?.render();
                setTimeout(() => {
                    const target = this.calendarDisplayMode === 'agenda'
                        ? document.querySelector(`[data-agenda-date="${date}"] button:not([style*="display: none"])`)
                        : document.querySelector(`.fc-daygrid-day[data-date="${date}"]`);
                    target?.focus?.();
                }, 0);
            },

            saveAvailabilityEditor() {
                if (!this.availabilityDate) return;
                const date = this.availabilityDate;
                if (!this.blockedDates.includes(date)) this.blockedDates.push(date);
                this.blockedDateDetails[date] = {
                    ...(this.blockedDateDetails[date] || {}),
                    date,
                    reason: this.normalizedReason(this.availabilityReason)
                };
                this.checkChanges();
                this.finishAvailabilityEdit(date);
            },

            makeDateAvailable() {
                if (!this.availabilityDate) return;
                const date = this.availabilityDate;
                this.blockedDates = this.blockedDates.filter(item => item !== date);
                delete this.blockedDateDetails[date];
                this.checkChanges();
                this.finishAvailabilityEdit(date);
            },
            
            clearAllBlocked() {
                if (this.currentMonthBlockedDates().length === 0) return;
                if (confirm('Remove all blocked dates in this month?')) {
                    this.currentMonthBlockedDates().forEach(date => delete this.blockedDateDetails[date]);
                    this.blockedDates = this.blockedDates.filter(date => !this.isInCurrentMonth(date));
                    this.checkChanges();
                    this.calendar.render(); 
                }
            },
            
            blockWeekends() {
                if (confirm('Block all visible Saturdays and Sundays?')) {
                    const view = this.calendar.view;
                    const start = view.activeStart;
                    const end = view.activeEnd;
                    
                    let curr = new Date(start);
                    while (curr < end) {
                        if (curr.getDay() === 0 || curr.getDay() === 6) { // 0 = Sun, 6 = Sat
                            const dateStr = this.toLocalDateString(curr);
                            if (!(this.bookingsByDate[dateStr] || []).length && !this.blockedDates.includes(dateStr)) {
                                this.blockedDates.push(dateStr);
                                this.blockedDateDetails[dateStr] = { date: dateStr, reason: 'Weekend' };
                            }
                        }
                        curr.setDate(curr.getDate() + 1);
                    }
                    this.checkChanges();
                    this.calendar.render();
                }
            },

            checkChanges() {
                const delta = this.computeAvailabilityDelta();
                this.hasChanges = delta.addedDates.length > 0 || delta.removedDates.length > 0;
            },

            normalizedReason(value) {
                const reason = (value || '').trim();
                return reason || null;
            },

            cloneBlockedDetails(details) {
                return Object.fromEntries(
                    Object.entries(details || {}).map(([date, detail]) => [date, { ...detail }])
                );
            },

            computeAvailabilityDelta() {
                const original = new Set(this.originalBlockedDates);
                const current = new Set(this.blockedDates);
                const addedDates = [];

                current.forEach(date => {
                    const currentReason = this.normalizedReason(this.blockedDateDetails[date]?.reason);
                    const originalReason = this.normalizedReason(this.originalBlockedDateDetails[date]?.reason);
                    if (!original.has(date) || currentReason !== originalReason) {
                        addedDates.push({ date, reason: currentReason });
                    }
                });

                const removedDates = [...original].filter(date => !current.has(date));
                return {
                    addedDates: addedDates.sort((a, b) => a.date.localeCompare(b.date)),
                    removedDates: removedDates.sort()
                };
            },
            
            discardChanges() {
                this.blockedDates = [...this.originalBlockedDates];
                this.blockedDateDetails = this.cloneBlockedDetails(this.originalBlockedDateDetails);
                this.hasChanges = false;
                this.calendar?.render();
            },
            
            confirmLeave() {
                // User chose to leave without saving
                this.hasChanges = false; // prevent beforeunload from firing
                if (this.pendingNavigationUrl) {
                    window.location.href = this.pendingNavigationUrl;
                }
                this.showLeaveModal = false;
            },
            
            async saveAndLeave() {
                const saved = await this.saveChanges();
                if (saved && this.pendingNavigationUrl) {
                    window.location.href = this.pendingNavigationUrl;
                }
            },
            
            async saveChanges() {
                if (this.isSaving) return false;
                this.isSaving = true;
                
                try {
                    const view = this.calendar.view;
                    const startStr = view.activeStart.getFullYear() + '-' + String(view.activeStart.getMonth() + 1).padStart(2, '0') + '-' + String(view.activeStart.getDate()).padStart(2, '0');
                    const endStr = view.activeEnd.getFullYear() + '-' + String(view.activeEnd.getMonth() + 1).padStart(2, '0') + '-' + String(view.activeEnd.getDate()).padStart(2, '0');
                    
                    const delta = this.computeAvailabilityDelta();
                    const res = await fetch('/Guide/SaveBlockedDates', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            rangeStart: startStr,
                            rangeEnd: endStr,
                            addedDates: delta.addedDates,
                            removedDates: delta.removedDates
                        })
                    });
                    
                    const result = await res.json();
                    if (!res.ok) throw new Error(result.message || 'Failed to update calendar data.');

                    this.originalBlockedDates = result.blockedDates.map(date => date.date);
                    this.blockedDates = [...this.originalBlockedDates];
                    this.originalBlockedDateDetails = Object.fromEntries(
                        result.blockedDates.map(date => [date.date, { ...date }])
                    );
                    this.blockedDateDetails = this.cloneBlockedDetails(this.originalBlockedDateDetails);
                    this.hasChanges = false;
                    this.calendar.render();

                    if (result.conflictingDates?.length) {
                        const count = result.conflictingDates.length;
                        showToast('warning', `${count} ${count === 1 ? 'date was' : 'dates were'} not blocked because a booking now exists.`);
                    } else {
                        showToast('success', 'Availability calendar updated successfully.');
                    }
                    return true;
                } catch (error) {
                    console.error(error);
                    showToast('error', error.message || 'Update failed. Please try again.');
                    return false;
                } finally {
                    this.isSaving = false;
                }
            },

            get bookedDatesCount() {
                return this.currentMonthBookings().length;
            },

            getAvailableDays() {
                const unavailableDates = new Set([
                    ...this.currentMonthBlockedDates(),
                    ...Object.keys(this.bookingsByDate).filter(date => this.isInCurrentMonth(date))
                ]);
                return Math.max(0, this.daysInMonth - unavailableDates.size);
            },

            getTotalRevenue() {
                return this.currentMonthBookings()
                    .filter(booking => booking.status === 'confirmed' || booking.status === 'completed')
                    .reduce((sum, booking) => sum + booking.revenue, 0);
            },
            
            formatCurrency(amount) {
                return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
            },
            
            sortedBlockedDates() {
                return this.currentMonthBlockedDates().sort();
            },

            formatDate(dateStr) {
                return new Intl.DateTimeFormat('en-US', {
                    weekday: 'short',
                    month: 'short',
                    day: 'numeric'
                }).format(this.parseLocalDate(dateStr));
            },

            formatLongDate(dateStr) {
                if (!dateStr) return '';
                return new Intl.DateTimeFormat('en-US', {
                    weekday: 'long',
                    month: 'long',
                    day: 'numeric',
                    year: 'numeric'
                }).format(this.parseLocalDate(dateStr));
            },

            isInCurrentMonth(dateStr) {
                const date = this.parseLocalDate(dateStr);
                return date.getFullYear() === this.currentYear && date.getMonth() + 1 === this.currentMonth;
            },

            currentMonthBlockedDates() {
                return this.blockedDates.filter(date => this.isInCurrentMonth(date));
            },

            currentMonthBookings() {
                return Object.entries(this.bookingsByDate)
                    .filter(([date]) => this.isInCurrentMonth(date))
                    .flatMap(([, bookings]) => bookings);
            },

            currentMonthLabel() {
                return new Intl.DateTimeFormat('en-US', {
                    month: 'long',
                    year: 'numeric'
                }).format(new Date(this.currentYear, this.currentMonth - 1, 1));
            },

            isPastDate(dateStr) {
                return this.parseLocalDate(dateStr) < new Date().setHours(0, 0, 0, 0);
            },

            agendaDays() {
                const days = [];
                for (let day = 1; day <= this.daysInMonth; day++) {
                    const date = new Date(this.currentYear, this.currentMonth - 1, day);
                    const dateStr = this.toLocalDateString(date);
                    days.push({
                        date: dateStr,
                        dayNumber: day,
                        weekday: new Intl.DateTimeFormat('en-US', { weekday: 'short' }).format(date),
                        bookings: this.bookingsByDate[dateStr] || [],
                        isBlocked: this.blockedDates.includes(dateStr),
                        reason: this.blockedDateDetails[dateStr]?.reason || '',
                        isPast: this.isPastDate(dateStr),
                        isToday: dateStr === this.toLocalDateString(new Date())
                    });
                }
                return days;
            },

            get changeCount() {
                const delta = this.computeAvailabilityDelta();
                return delta.addedDates.length + delta.removedDates.length;
            },

            getUpcomingBookings() {
                const today = new Date();
                const todayStr = today.getFullYear() + '-' + String(today.getMonth() + 1).padStart(2, '0') + '-' + String(today.getDate()).padStart(2, '0');
                
                return Object.values(this.bookingsByDate)
                    .flat()
                    .filter(booking => booking.date >= todayStr &&
                        (booking.status === 'pending' || booking.status === 'confirmed'))
                    .sort((a, b) => `${a.date}T${a.startTime}`.localeCompare(`${b.date}T${b.startTime}`))
                    .slice(0, 8);
            },

            destroy() {
                this._fetchAbortController?.abort();
                clearTimeout(this._availabilityResetTimer);
                this.availabilityEditorOpen = false;
                this.isDetailsOpen = false;
                if (this._linkClickHandler) document.removeEventListener('click', this._linkClickHandler);
                if (this._beforeUnloadHandler) window.removeEventListener('beforeunload', this._beforeUnloadHandler);
                if (this._turboBeforeCacheHandler) document.removeEventListener('turbo:before-cache', this._turboBeforeCacheHandler);
                if (this.calendar) {
                    this.calendar.destroy();
                    this.calendar = null;
                }
                document.body.style.overflow = '';
            }
        }
    }
</script>

