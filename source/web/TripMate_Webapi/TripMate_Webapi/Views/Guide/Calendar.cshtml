                                <span class="material-symbols-outlined text-gray-300 text-[32px]">tour</span>
                            </div>
                            <p class="text-gray-500 text-sm">No upcoming bookings.</p>
                        </div>
                    </template>
                    
                    <ul class="divide-y divide-gray-100 p-2 space-y-2">
                        <template x-for="booking in getUpcomingBookings()" :key="booking.id">
                            <li @@click="openBookingDetails(booking)"
                                @@keydown.enter.prevent="openBookingDetails(booking)"
                                tabindex="0"
                                class="cursor-pointer rounded-xl border border-transparent p-4 transition-colors hover:border-blue-100 hover:bg-blue-50/50 focus:border-blue-200 focus:bg-blue-50/50 focus:outline-none">
                                <div class="mb-2 flex items-center justify-between gap-2">
                                    <div class="flex w-fit items-center gap-1 rounded-md bg-orange-50 px-2 py-1 text-xs font-bold text-primary">
                                        <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                                        <span x-text="formatDate(booking.date)"></span>
                                    </div>
                                    <span class="rounded-full border px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider"
                                          :class="statusBadgeClass(booking.status)"
                                          x-text="statusLabel(booking.status)"></span>
                                </div>
                                <h4 class="font-bold text-gray-900 text-sm mb-2" x-text="booking.title"></h4>
                                <div class="mb-3 grid grid-cols-2 gap-2 rounded-lg bg-gray-50 p-2 text-xs text-gray-500">
                                    <span class="flex min-w-0 items-center gap-1 font-medium"><span class="material-symbols-outlined text-[14px]">schedule</span> <span x-text="booking.startTime || 'Time TBD'"></span></span>
                                    <span class="flex items-center gap-1 font-medium"><span class="material-symbols-outlined text-[14px]">group</span> <span x-text="booking.guestCount + (booking.guestCount === 1 ? ' guest' : ' guests')"></span></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="truncate pr-2 text-xs text-gray-400" x-text="booking.guest"></span>
                                    <span class="text-sm font-bold text-green-600" x-text="formatCurrency(booking.revenue)"></span>
                                </div>
                            </li>
                        </template>
                    </ul>
                </div>
                
                <!-- (Save bar — see top slim banner) -->
            </div>
        </div>
    </div>

