                                <li class="p-4 flex justify-between items-center gap-3 hover:bg-gray-50 transition-colors">
                                    <div class="flex min-w-0 items-center gap-3">
                                        <div class="w-2 h-2 rounded-full bg-red-400 shadow-[0_0_8px_rgba(248,113,113,0.6)]"></div>
                                        <div class="min-w-0">
                                            <span class="block text-sm font-bold text-gray-700" x-text="formatDate(date)"></span>
                                            <span class="block truncate text-[11px] text-gray-400" x-text="blockedDateDetails[date]?.reason || 'No reason added'"></span>
                                        </div>
                                    </div>
                                    <button type="button" @@click="openAvailabilityEditor(date, $event)"
                                            class="shrink-0 rounded-lg border border-gray-200 px-2.5 py-1.5 text-xs font-bold text-gray-500 transition-colors hover:border-orange-200 hover:bg-orange-50 hover:text-primary"
                                            :aria-label="`Manage availability for ${formatLongDate(date)}`">
