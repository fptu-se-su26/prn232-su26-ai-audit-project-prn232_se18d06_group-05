@{
    ViewData["Title"] = "Thông Báo";
    ViewData["ActivePage"] = "Notifications";
    Layout = "_GuideLayout";
    
    var notifications = ViewBag.Notifications as IEnumerable<dynamic>;
}

<!-- JSON data cho AlpineJS -->
<script>
    window.initialNotifications = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(notifications));
</script>

<div class="max-w-4xl mx-auto" x-data="notificationsApp()">
    
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-1">Thông Báo</h2>
            <p class="text-gray-500 text-sm">Cập nhật mới nhất về booking, thanh toán và hệ thống.</p>
        </div>
        <div class="flex items-center gap-3">
            <button @@click="markAllAsRead" class="text-primary hover:text-primary-dark font-bold text-sm transition-colors">
                Đánh dấu tất cả đã đọc
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="flex overflow-x-auto hide-scrollbar gap-2 mb-6 pb-2">
        <button @@click="filter = 'all'" :class="filter === 'all' ? 'bg-gray-900 text-white shadow-sm' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200'" class="px-5 py-2 rounded-full text-sm font-bold transition-all whitespace-nowrap">
            Tất cả
        </button>
        <button @@click="filter = 'booking'" :class="filter === 'booking' ? 'bg-gray-900 text-white shadow-sm' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200'" class="px-5 py-2 rounded-full text-sm font-bold transition-all whitespace-nowrap">
            Booking
        </button>
        <button @@click="filter = 'payment'" :class="filter === 'payment' ? 'bg-gray-900 text-white shadow-sm' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200'" class="px-5 py-2 rounded-full text-sm font-bold transition-all whitespace-nowrap">
            Thanh toán
        </button>
        <button @@click="filter = 'system'" :class="filter === 'system' ? 'bg-gray-900 text-white shadow-sm' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200'" class="px-5 py-2 rounded-full text-sm font-bold transition-all whitespace-nowrap">
            Hệ thống
        </button>
    </div>

    <!-- Notifications List -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        
        <template x-if="filteredNotifications.length === 0">
            <div class="p-12 text-center">
                <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
                    <span class="material-symbols-outlined text-[32px]">notifications_off</span>
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Không có thông báo nào</h3>
                <p class="text-gray-500 text-sm">Chúng tôi sẽ thông báo cho bạn khi có booking mới!</p>
            </div>
        </template>

        <div class="divide-y divide-gray-100">
            <template x-for="n in filteredNotifications" :key="n.Id">
                <div class="p-5 flex gap-4 transition-colors hover:bg-gray-50 relative group cursor-pointer"
                     :class="!n.IsRead ? 'bg-blue-50/30' : ''"
                     @@click="markAsRead(n.Id)">
                    
                    <!-- Unread Indicator -->
                    <div x-show="!n.IsRead" class="absolute left-0 top-0 bottom-0 w-1 bg-primary rounded-r-md"></div>
                    
                    <!-- Icon based on Type -->
                    <div class="flex-shrink-0 mt-1 relative">
                        <div class="w-12 h-12 rounded-full flex items-center justify-center"
                             :class="{
                                'bg-amber-100 text-amber-600': n.Type === 'booking_new' || n.Type === 'review',
                                'bg-green-100 text-green-600': n.Type === 'payment' || n.Type === 'booking_confirmed',
                                'bg-gray-100 text-gray-600': n.Type === 'booking_completed',
                                'bg-red-100 text-red-600': n.Type === 'booking_cancelled',
                                'bg-blue-100 text-blue-600': n.Type === 'admin' || n.Type === 'message'
                             }">
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'booking_new'">notifications_active</span>
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'booking_confirmed'">check_circle</span>
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'booking_completed'">done_all</span>
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'booking_cancelled'">cancel</span>
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'payment'">payments</span>
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'review'" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'admin'">verified</span>
                            <span class="material-symbols-outlined text-[24px]" x-show="n.Type === 'message'">chat</span>
                        </div>
                        <div x-show="!n.IsRead" class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-primary rounded-full border-2 border-white"></div>
                    </div>
                    
                    <!-- Content -->
                    <div class="flex-grow min-w-0">
                        <h4 class="text-sm font-bold text-gray-900 mb-1" :class="!n.IsRead ? 'text-gray-900' : 'text-gray-700'" x-text="n.Title"></h4>
                        <p class="text-sm text-gray-500 mb-2 line-clamp-2" x-text="n.Message"></p>
                        <div class="flex items-center gap-3">
                            <span class="text-[11px] font-bold text-gray-400" x-text="n.Time"></span>
                            
                            <!-- Actions (Optional based on type) -->
                            <template x-if="n.Type === 'booking_new'">
                                <a href="/Guide/Bookings" class="text-[11px] font-bold text-primary hover:underline" @@click.stop>Xem booking →</a>
                            </template>
                            <template x-if="n.Type === 'payment'">
                                <a href="/Guide/Earnings" class="text-[11px] font-bold text-primary hover:underline" @@click.stop>Xem ví →</a>
                            </template>
                            <template x-if="n.Type === 'review'">
                                <a href="/Guide/Profile" class="text-[11px] font-bold text-primary hover:underline" @@click.stop>Xem hồ sơ →</a>
                            </template>
                        </div>
                    </div>
                    
                    <!-- Delete btn (appears on hover) -->
                    <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                        <button @@click.stop="deleteNotification(n.Id)" class="w-8 h-8 rounded-full flex items-center justify-center text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors" title="Xóa thông báo">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                    </div>
                </div>
            </template>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function notificationsApp() {
            return {
                notifications: window.initialNotifications || [],
                filter: 'all', // all, booking, payment, system

                get filteredNotifications() {
                    return this.notifications.filter(n => {
                        if (this.filter === 'all') return true;
                        if (this.filter === 'booking') return n.Type.startsWith('booking_');
                        if (this.filter === 'payment') return n.Type === 'payment';
                        if (this.filter === 'system') return n.Type === 'admin' || n.Type === 'review';
                        return true;
                    });
                },

                markAsRead(id) {
                    const n = this.notifications.find(x => x.Id === id);
                    if (n && !n.IsRead) {
                        n.IsRead = true;
                        // update counter in sidebar (not implemented in this mock but logic applies)
                    }
                },

                markAllAsRead() {
                    this.notifications.forEach(n => n.IsRead = true);
                    showToast('success', 'Đã đánh dấu tất cả là đã đọc.');
                },

                deleteNotification(id) {
                    this.notifications = this.notifications.filter(n => n.Id !== id);
                    showToast('info', 'Đã xóa thông báo.');
                }
            }
        }
    </script>
}
