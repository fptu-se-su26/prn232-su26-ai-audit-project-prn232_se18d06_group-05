@model TripMate_Webapi.Controllers.GuideDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "_GuideLayout";
}

<!-- Header Section -->
<div class="flex justify-between items-end mb-8">
    <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Xin chào, @Model.GuideName! 👋</h2>
        <p class="text-gray-600">Hôm nay là @DateTime.Now.ToString("dd/MM/yyyy"). Chúc bạn một ngày làm việc hiệu quả!</p>
    </div>
    <div class="flex gap-4">
        <div class="bg-white border border-gray-200 px-4 py-2 rounded-lg flex items-center gap-2 text-gray-600 shadow-sm">
            <span class="material-symbols-outlined text-primary">calendar_today</span>
            <span class="text-sm font-medium">@Model.DateRange</span>
        </div>
        <button class="bg-white text-gray-900 px-6 py-2 rounded-lg font-medium hover:bg-gray-100 transition-colors border border-gray-200 shadow-sm flex items-center gap-2">
            <span class="material-symbols-outlined">download</span> Báo cáo
        </button>
    </div>
</div>

<!-- Metrics Grid -->
<div class="grid grid-cols-12 gap-6 mb-8">
    <!-- Total Earnings Card -->
    <div class="col-span-12 lg:col-span-6 bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-sm font-medium text-gray-500 mb-2 uppercase tracking-wider">Tổng thu nhập tháng này</p>
                <h3 class="text-4xl font-bold text-gray-900 mb-2">₫@Model.TotalEarnings.ToString("N0")</h3>
                <p class="text-green-600 text-sm font-medium flex items-center gap-1 bg-green-50 w-max px-2 py-1 rounded-md">
                    <span class="material-symbols-outlined text-[16px]">trending_up</span>
                    +@Model.EarningsGrowth% so với tháng trước
                </p>
            </div>
            <div class="w-14 h-14 rounded-full bg-orange-100 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-[28px]">payments</span>
            </div>
        </div>
    </div>

    <!-- Active Tours -->
    <div class="col-span-12 md:col-span-6 lg:col-span-3 bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 mb-4">
            <span class="material-symbols-outlined">tour</span>
        </div>
        <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Tours Hoạt Động</p>
        <h3 class="text-3xl font-bold text-gray-900 mt-1">@Model.ActiveTours</h3>
        <p class="text-xs mt-2 text-gray-500">Đang hiển thị trên app</p>
    </div>

    <!-- Total Bookings -->
    <div class="col-span-12 md:col-span-6 lg:col-span-3 bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center text-green-600 mb-4">
            <span class="material-symbols-outlined">calendar_month</span>
        </div>
        <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Tổng Bookings</p>
        <h3 class="text-3xl font-bold text-gray-900 mt-1">@Model.TotalBookings</h3>
        <div class="mt-3 w-full bg-gray-100 rounded-full h-1.5">
            <div class="bg-green-500 h-1.5 rounded-full" style="width: @Model.BookingProgress%"></div>
        </div>
        <p class="text-xs mt-2 text-gray-500">Đạt @Model.BookingProgress% mục tiêu tháng</p>
    </div>
</div>

<div class="grid grid-cols-12 gap-8">
    <!-- Recent Bookings List -->
    <section class="col-span-12 lg:col-span-8">
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
            <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <h4 class="text-lg font-bold text-gray-900">Bookings Gần Đây</h4>
                <a href="/Guide/Bookings" class="text-sm font-medium text-primary hover:text-primary-dark flex items-center gap-1">
                    Xem tất cả <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                </a>
            </div>
            <div class="p-0">
                @if (Model.RecentBookings != null && Model.RecentBookings.Any())
                {
                    @foreach (var booking in Model.RecentBookings)
                    {
                        <div class="flex items-center px-6 py-4 border-b border-gray-50 hover:bg-gray-50/50 transition-colors">
                            <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center flex-shrink-0 text-primary">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </div>
                            <div class="ml-4 flex-grow">
                                <p class="font-bold text-gray-900 text-sm">@booking.TravelerName</p>
                                <p class="text-xs text-gray-500 mt-0.5">@booking.TourName</p>
                            </div>
                            <div class="hidden md:block px-6">
                                <p class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Ngày đi</p>
                                <p class="text-sm font-medium text-gray-800">@booking.Date</p>
                            </div>
                            <div class="hidden md:block px-6">
                                <p class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Thu về</p>
                                <p class="text-sm font-bold text-green-600">₫@booking.Amount.ToString("N0")</p>
                            </div>
                            <div class="pl-4">
                                @if (booking.Status == "Confirmed")
                                {
                                    <span class="px-2.5 py-1 bg-green-50 text-green-700 rounded-lg text-xs font-bold border border-green-100">Đã xác nhận</span>
                                }
                                else if (booking.Status == "Pending")
                                {
                                    <span class="px-2.5 py-1 bg-amber-50 text-amber-700 rounded-lg text-xs font-bold border border-amber-100">Chờ duyệt</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 bg-gray-50 text-gray-700 rounded-lg text-xs font-bold border border-gray-200">@booking.Status</span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-12 text-gray-500 flex flex-col items-center">
                        <span class="material-symbols-outlined text-4xl text-gray-300 mb-2">inbox</span>
                        <p>Chưa có booking nào gần đây</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Recent Activity Timeline -->
    <aside class="col-span-12 lg:col-span-4">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 sticky top-24">
            <h4 class="text-lg font-bold text-gray-900 mb-6">Hoạt động mới nhất</h4>
            <div class="space-y-6 relative">
                <div class="absolute left-[15px] top-2 bottom-2 w-0.5 bg-gray-100"></div>

                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="relative flex gap-4">
                        <div class="w-8 h-8 rounded-full @activity.IconBgClass flex items-center justify-center @activity.IconTextClass z-10 shadow-sm ring-4 ring-white">
                            <span class="material-symbols-outlined text-[16px]">@activity.Icon</span>
                        </div>
                        <div>
                            <p class="font-medium text-gray-900 text-sm">@activity.Title</p>
                            <p class="text-xs text-gray-500 mt-0.5">@activity.Description</p>
                            <p class="text-[11px] font-medium text-gray-400 mt-1">@activity.TimeAgo</p>
                        </div>
                    </div>
                }
            </div>

            <!-- Quick Action -->
            <div class="mt-8 pt-6 border-t border-gray-100">
                <button class="w-full bg-primary hover:bg-primary-dark text-white rounded-xl py-3 font-medium transition-colors flex justify-center items-center gap-2 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">add</span> Tạo Tour Mới
                </button>
            </div>
        </div>
    </aside>
</div>
