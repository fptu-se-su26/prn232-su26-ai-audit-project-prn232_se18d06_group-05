@model TripMate_WebAPI.DTOs.GuideDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "_GuideLayout";

    // Serialize sparkline data for Chart.js
    var sparklineJson = System.Text.Json.JsonSerializer.Serialize(Model.EarningsSparkline ?? new List<decimal>());
    var currentMonth = DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("vi-VN"));
}

@section Styles {
<style>
    @@keyframes countUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .stat-value { animation: countUp 0.5s ease-out forwards; }

    @@keyframes shimmer {
        0%   { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }
    .hero-gradient {
        background: linear-gradient(135deg, #fff7f4 0%, #fff 50%, #f0f9ff 100%);
    }
    .kpi-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 24px -8px rgba(0,0,0,0.10);
    }
    .pending-banner {
        background: linear-gradient(90deg, #fff7ed, #ffedd5);
        border-left: 4px solid #FF6B35;
    }
    .sparkline-wrap { position: relative; }
    .booking-row { transition: background 0.15s ease; }
    .booking-row:hover { background: #fff7f4; }
    .status-dot {
        width: 8px; height: 8px; border-radius: 50%; display: inline-block;
    }
    .upcoming-card { transition: background 0.15s ease; }
    .upcoming-card:hover { background: #f9fafb; }
</style>
}

@* ── PENDING URGENT BANNER ─────────────────────────────────────────── *@
@if (Model.PendingBookingsCount > 0)
{
    <div class="pending-banner rounded-2xl px-5 py-4 mb-6 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-primary text-[20px]">notification_important</span>
            </div>
            <div>
                <p class="font-bold text-gray-900 text-sm">
                    Bạn có <span class="text-primary">@Model.PendingBookingsCount booking</span> đang chờ xác nhận!
                </p>
                <p class="text-xs text-gray-500 mt-0.5">Khách hàng đang chờ phản hồi từ bạn. Hãy xác nhận sớm để tăng tỉ lệ chấp nhận.</p>
            </div>
        </div>
        <a href="/Guide/Bookings?tab=Pending" class="flex-shrink-0 bg-primary hover:bg-primary-dark text-white text-sm font-bold px-5 py-2.5 rounded-xl transition-colors shadow-sm flex items-center gap-1.5">
            Xem ngay <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
        </a>
    </div>
}

@* ── HERO HEADER ─────────────────────────────────────────────────────── *@
<div class="hero-gradient rounded-3xl border border-gray-100 shadow-sm p-6 mb-6 flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div class="flex items-center gap-5">
        <div class="relative flex-shrink-0">
            <img src="@Model.AvatarUrl" alt="avatar"
                 class="w-16 h-16 rounded-2xl object-cover border-2 border-white shadow-md"
                 onerror="this.src='/images/AVATAR.png'">
            @if (Model.IsVerified)
            {
                <div class="absolute -bottom-1 -right-1 w-5 h-5 bg-blue-500 rounded-full flex items-center justify-center shadow border-2 border-white" title="Đã xác minh">
                    <span class="material-symbols-outlined text-white text-[12px]" style="font-variation-settings:'FILL' 1">verified</span>
                </div>
            }
        </div>
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Xin chào, @Model.GuideName! 👋</h2>
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-1.5">
                <span class="text-sm text-gray-500 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px] text-gray-400">location_on</span>
                    @Model.Location
                </span>
                <span class="text-sm text-amber-500 flex items-center gap-1 font-semibold">
                    <span class="material-symbols-outlined text-[14px]" style="font-variation-settings:'FILL' 1">star</span>
                    @Model.AverageRating.ToString("0.0") <span class="text-gray-400 font-normal">(@Model.ReviewsCount đánh giá)</span>
                </span>
                <span class="text-xs text-gray-400">Hôm nay, @DateTime.Now.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0">
        <div class="bg-white/80 backdrop-blur border border-gray-200 px-4 py-2.5 rounded-xl flex items-center gap-2 text-gray-600 shadow-sm text-sm font-medium">
            <span class="material-symbols-outlined text-primary text-[18px]">calendar_today</span>
            @currentMonth
        </div>
        <a href="/Guide/CreateTour" class="bg-primary hover:bg-primary-dark text-white px-5 py-2.5 rounded-xl font-bold transition-colors shadow-sm flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined text-[18px]">add</span> Tạo Tour
        </a>
    </div>
</div>

@* ── 4 KPI CARDS ────────────────────────────────────────────────────── *@
<div class="grid grid-cols-2 xl:grid-cols-4 gap-4 mb-6">

    @* Card 1: Thu nhập *@
    <div class="kpi-card col-span-2 xl:col-span-1 bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-[20px]">payments</span>
            </div>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-green-50 text-green-700 flex items-center gap-0.5">
                <span class="material-symbols-outlined text-[13px]">trending_up</span>
                +@Model.EarningsGrowth%
            </span>
        </div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Thu nhập tháng này</p>
        <p class="text-2xl font-black text-gray-900 stat-value">₫@Model.TotalEarnings.ToString("N0")</p>
        <p class="text-xs text-gray-400 mt-1">so với tháng trước</p>
    </div>

    @* Card 2: Bookings *@
    <div class="kpi-card bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-600 text-[20px]">event_note</span>
            </div>
            @if (Model.PendingBookingsCount > 0)
            {
                <span class="text-xs font-bold px-2.5 py-1 rounded-full bg-amber-50 text-amber-700">@Model.PendingBookingsCount chờ</span>
            }
        </div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Tổng Bookings</p>
        <p class="text-2xl font-black text-gray-900 stat-value">@Model.TotalBookings</p>
        <p class="text-xs text-gray-400 mt-1">booking tháng này</p>
    </div>

    @* Card 3: Tours *@
    <div class="kpi-card bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-purple-600 text-[20px]">tour</span>
            </div>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-purple-50 text-purple-700">Live</span>
        </div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Tours Hoạt Động</p>
        <p class="text-2xl font-black text-gray-900 stat-value">@Model.ActiveTours</p>
        <p class="text-xs text-gray-400 mt-1">đang hiển thị trên app</p>
    </div>

    @* Card 4: Rating *@
    <div class="kpi-card bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-amber-500 text-[20px]" style="font-variation-settings:'FILL' 1">star</span>
            </div>
        </div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Đánh Giá TB</p>
        <p class="text-2xl font-black text-gray-900 stat-value">@Model.AverageRating.ToString("0.0")</p>
        <p class="text-xs text-gray-400 mt-1">@Model.ReviewsCount lượt đánh giá</p>
    </div>
</div>

@* ── MAIN CONTENT GRID ───────────────────────────────────────────────── *@
<div class="grid grid-cols-12 gap-6">

    @* ── LEFT COLUMN (8/12) ──────────────────────────────────────────── *@
    <div class="col-span-12 lg:col-span-8 flex flex-col gap-6">

        @* Sparkline Earnings Chart *@
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
            <div class="flex items-center justify-between mb-5">
                <div>
                    <h4 class="text-base font-bold text-gray-900">Thu Nhập Năm Nay</h4>
                    <p class="text-xs text-gray-400 mt-0.5">Năm 2026</p>
                </div>
                <div class="text-right">
                    <p class="text-xl font-black text-gray-900">₫@Model.TotalEarnings.ToString("N0")</p>
                    <p class="text-xs text-green-600 font-semibold flex items-center gap-0.5 justify-end">
                        <span class="material-symbols-outlined text-[13px]">trending_up</span>
                        +@Model.EarningsGrowth% so tháng trước
                    </p>
                </div>
            </div>
            <div class="sparkline-wrap" style="height: 250px;">
                <canvas id="earningsChart"></canvas>
            </div>
        </div>

        @* Recent Bookings *@
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <div>
                    <h4 class="text-base font-bold text-gray-900">Bookings Gần Đây</h4>
                    <p class="text-xs text-gray-400 mt-0.5">@Model.RecentBookings.Count booking mới nhất</p>
                </div>
                <a href="/Guide/Bookings" class="text-sm font-semibold text-primary hover:text-primary-dark flex items-center gap-1 transition-colors">
                    Xem tất cả <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                </a>
            </div>

            @if (Model.RecentBookings != null && Model.RecentBookings.Any())
            {
                <div class="divide-y divide-gray-50">
                    @foreach (var booking in Model.RecentBookings)
                    {
                        <div class="booking-row flex items-center px-6 py-4 gap-4">
                            @* Avatar *@
                            <img src="@booking.TravelerAvatar" alt="@booking.TravelerName"
                                 class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-gray-100"
                                 onerror="this.onerror=null;this.src='/images/AVATAR.png'">

                            @* Name + Tour *@
                            <div class="flex-grow min-w-0">
                                <p class="font-bold text-gray-900 text-sm truncate">@booking.TravelerName</p>
                                <p class="text-xs text-gray-400 truncate mt-0.5 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px]">route</span>
                                    @booking.TourName
                                </p>
                            </div>

                            @* Date + Time *@
                            <div class="hidden sm:block flex-shrink-0 text-right">
                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Ngày đi</p>
                                <p class="text-sm font-medium text-gray-800 mt-0.5">@booking.Date</p>
                                <p class="text-xs text-gray-400">@booking.Time · @booking.Guests khách</p>
                            </div>

                            @* Amount *@
                            <div class="hidden md:block flex-shrink-0 text-right w-28">
                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Thu về</p>
                                <p class="text-sm font-bold text-green-600 mt-0.5">₫@booking.Amount.ToString("N0")</p>
                            </div>

                            @* Status *@
                            <div class="flex-shrink-0">
                                @if (booking.Status == "Confirmed")
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-50 text-green-700 rounded-lg text-xs font-bold border border-green-100">
                                        <span class="status-dot bg-green-500"></span>Đã xác nhận
                                    </span>
                                }
                                else if (booking.Status == "Pending")
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-50 text-amber-700 rounded-lg text-xs font-bold border border-amber-100">
                                        <span class="status-dot bg-amber-500"></span>Chờ duyệt
                                    </span>
                                }
                                else
                                {
                                    <span class="px-3 py-1.5 bg-gray-50 text-gray-600 rounded-lg text-xs font-bold border border-gray-200">@booking.Status</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12 text-gray-400 flex flex-col items-center gap-2">
                    <span class="material-symbols-outlined text-5xl text-gray-200">inbox</span>
                    <p class="font-medium">Chưa có booking nào gần đây</p>
                    <p class="text-xs text-gray-300">Khi có khách đặt tour, chúng sẽ xuất hiện ở đây</p>
                </div>
            }
        </div>

    </div>

    @* ── RIGHT COLUMN (4/12) ─────────────────────────────────────────── *@
    <div class="col-span-12 lg:col-span-4 flex flex-col gap-6">

        @* Quick Stats *@
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
            <h4 class="text-base font-bold text-gray-900 mb-4">Thống kê nhanh</h4>
            <div class="space-y-4">
                @* Acceptance Rate *@
                <div>
                    <div class="flex justify-between items-center mb-1.5">
                        <span class="text-xs font-medium text-gray-500 flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[14px] text-green-500">check_circle</span>
                            Tỉ lệ chấp nhận
                        </span>
                        <span class="text-sm font-bold text-gray-900">@Model.AcceptanceRate%</span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-2">
                        <div class="bg-green-500 h-2 rounded-full transition-all" style="width: @Model.AcceptanceRate%"></div>
                    </div>
                </div>

                @* Response Time *@
                <div class="flex items-center justify-between py-3 border-t border-gray-50">
                    <span class="text-xs font-medium text-gray-500 flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-[14px] text-blue-500">schedule</span>
                        Thời gian phản hồi
                    </span>
                    <span class="text-sm font-bold text-gray-900">~@Model.ResponseTimeMinutes phút</span>
                </div>

                @* Profile Views *@
                <div class="flex items-center justify-between py-3 border-t border-gray-50">
                    <span class="text-xs font-medium text-gray-500 flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-[14px] text-purple-500">visibility</span>
                        Lượt xem profile
                    </span>
                    <span class="text-sm font-bold text-gray-900">@Model.ProfileViewsThisMonth</span>
                </div>
            </div>
        </div>

        @* Upcoming Schedule *@
        @if (Model.UpcomingSchedule != null && Model.UpcomingSchedule.Any())
        {
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
                <div class="flex justify-between items-center mb-4">
                    <h4 class="text-base font-bold text-gray-900">Lịch Sắp Tới</h4>
                    <a href="/Guide/Calendar" class="text-xs text-primary font-semibold hover:underline">Xem lịch</a>
                </div>
                <div class="space-y-2">
                    @foreach (var item in Model.UpcomingSchedule)
                    {
                        <div class="upcoming-card rounded-xl px-4 py-3 border border-gray-100">
                            <div class="flex items-start justify-between gap-2">
                                <div class="min-w-0">
                                    <p class="text-sm font-bold text-gray-900 truncate">@item.TourName</p>
                                    <p class="text-xs text-gray-400 mt-0.5 truncate">@item.TravelerName · @item.Guests khách</p>
                                </div>
                                <div class="text-right flex-shrink-0">
                                    <p class="text-xs font-bold text-primary">@item.Date</p>
                                    <p class="text-xs text-gray-400">@item.Time</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* Activity Feed *@
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
            <h4 class="text-base font-bold text-gray-900 mb-5">Hoạt Động Gần Đây</h4>
            <div class="space-y-5 relative">
                <div class="absolute left-[15px] top-1 bottom-1 w-px bg-gray-100"></div>
                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="relative flex gap-4">
                        <div class="w-8 h-8 rounded-full @activity.IconBgClass flex items-center justify-center @activity.IconTextClass z-10 shadow-sm ring-4 ring-white flex-shrink-0">
                            <span class="material-symbols-outlined text-[15px]">@activity.Icon</span>
                        </div>
                        <div class="min-w-0">
                            <p class="font-semibold text-gray-900 text-sm">@activity.Title</p>
                            <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">@activity.Description</p>
                            <p class="text-[11px] font-medium text-gray-300 mt-1">@activity.TimeAgo</p>
                        </div>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener("turbo:load", function() {
            const canvas = document.getElementById('earningsChart');
            if (!canvas) return; // Prevent errors if navigating away
            
            // Check if Chart is loaded, if not, wait a bit
            if (typeof Chart === 'undefined') {
                setTimeout(initChart, 100);
                return;
            }
            initChart();

            function initChart() {
                const sparklineData = @Html.Raw(sparklineJson);
                const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                
                const maxVal = Math.ceil(Math.max(...sparklineData) / 10000000) * 10000000; 

                const ctx = canvas.getContext('2d');

                const gradient = ctx.createLinearGradient(0, 0, 0, 250);
                gradient.addColorStop(0, 'rgba(255, 107, 53, 0.15)'); 
                gradient.addColorStop(1, 'rgba(255, 107, 53, 0.00)');

                const barGradient = ctx.createLinearGradient(0, 0, 0, 250);
                barGradient.addColorStop(0, 'rgba(255, 107, 53, 0.05)');
                barGradient.addColorStop(1, 'rgba(255, 107, 53, 0.0)');

                const activeColumnGradient = ctx.createLinearGradient(0, 0, 0, 250);
                activeColumnGradient.addColorStop(0, 'rgba(255, 107, 53, 0.2)');
                activeColumnGradient.addColorStop(1, 'rgba(255, 107, 53, 0.02)');

                const glowPlugin = {
                    id: 'glowPlugin',
                    beforeDatasetsDraw: (chart) => {
                        const ctx = chart.ctx;
                        ctx.save();
                        ctx.shadowColor = 'rgba(255, 107, 53, 0.4)';
                        ctx.shadowBlur = 15;
                        ctx.shadowOffsetX = 0;
                        ctx.shadowOffsetY = 8;
                    },
                    afterDatasetsDraw: (chart) => {
                        chart.ctx.restore();
                    }
                };

                // Destroy existing chart if turbo reloaded
                if (window.myEarningsChart) {
                    window.myEarningsChart.destroy();
                }

                window.myEarningsChart = new Chart(ctx, {
                    type: 'line',
                    plugins: [glowPlugin],
                    data: {
                        labels: months,
                        datasets: [
                            {
                                type: 'line',
                                label: 'Thu nhập',
                                data: sparklineData,
                                fill: true,
                                backgroundColor: gradient,
                                borderColor: '#FF6B35', 
                                borderWidth: 3.5,
                                tension: 0.45,
                                pointRadius: 0,
                                pointHoverRadius: 8,
                                pointBackgroundColor: '#FF6B35',
                                pointBorderColor: '#fff',
                                pointBorderWidth: 3,
                                order: 1
                            },
                            {
                                type: 'bar',
                                label: 'Background',
                                data: sparklineData, 
                                backgroundColor: barGradient,
                                hoverBackgroundColor: activeColumnGradient,
                                borderRadius: 8,
                                barPercentage: 0.5,
                                categoryPercentage: 1.0,
                                order: 2,
                                tooltip: false
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'transparent',
                                titleColor: 'transparent',
                                bodyColor: '#1f2937',
                                bodyFont: { weight: '900', size: 14, family: "'Inter', sans-serif" },
                                displayColors: false,
                                boxShadow: 'none',
                                yAlign: 'bottom',
                                caretSize: 0,
                                padding: 10,
                                filter: function(tooltipItem) {
                                    return tooltipItem.datasetIndex === 0;
                                },
                                callbacks: {
                                    title: () => null,
                                    label: (item) => {
                                        const val = item.raw;
                                        return (val / 1000000).toFixed(0) + 'M';
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false, drawBorder: false },
                                border: { display: false },
                                ticks: {
                                    color: '#9ca3af',
                                    font: { size: 12, family: "'Inter', sans-serif" },
                                    padding: 15
                                }
                            },
                            y: {
                                beginAtZero: true,
                                max: maxVal,
                                grid: { 
                                    color: '#f3f4f6', 
                                    tickLength: 0,
                                    borderDash: [5, 5]
                                },
                                border: { display: false },
                                ticks: {
                                    color: '#d1d5db',
                                    font: { size: 12, family: "'Inter', sans-serif" },
                                    padding: 20,
                                    stepSize: maxVal / 5,
                                    callback: v => v === 0 ? '0' : (v / 1000000)
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}

