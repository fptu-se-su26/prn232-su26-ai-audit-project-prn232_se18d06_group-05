@{
    ViewData["Title"] = "Create a New Experience Package";
    ViewData["ActivePage"] = "MyTours";
    Layout = "_GuideLayout";
}

@section Styles {
    <meta name="turbo-cache-control" content="no-cache">
}

<div class="min-h-screen pb-10" x-data="tourWizardApp()">
    
    <!-- Top Thin Stepper -->
    <div class="fixed top-0 left-0 right-0 h-1 bg-gray-200 z-[60]">
        <div class="h-full bg-primary transition-all duration-500 ease-out" :style="`width: ${(step / 4) * 100}%`"></div>
    </div>

    <!-- Header Section -->
    <div class="max-w-2xl mx-auto pt-6 px-4 sm:px-0 mb-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <a href="/Guide/MyTours" class="w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            </a>
            <div>
                <h2 class="text-xl font-bold text-gray-900">@(ViewBag.IsEdit == true ? "Edit Experience Package" : "Create a New Experience Package")</h2>
            </div>
        </div>
        <button type="button" class="text-xs font-semibold text-gray-600 hover:text-gray-900 underline underline-offset-4 transition-colors">
            Save and Exit
        </button>
    </div>

    <!-- Main Form Container -->
    <div class="max-w-2xl mx-auto px-4 sm:px-0">
        <form @@submit.prevent="submitForm">
            
            <!-- STEP 1: THÔNG TIN CƠ BẢN & VỊ TRÍ -->
            <div x-show="step === 1" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Start with the basics</h3>
                <p class="text-sm text-gray-500 mb-6">Help travelers understand the experience you offer.</p>
                
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">Experience Package Name <span class="text-red-500">*</span></label>
                        <input type="text" x-model="formData.name" placeholder="Example: Explore Hoi An Ancient Town at Night"
                               class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 mb-1.5">Estimated Duration <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input type="number" x-model="formData.duration" min="0.5" step="0.5"
                                       class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-500">hours</span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 mb-1.5">Maximum Group Size <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input type="number" x-model="formData.maxGuests" min="1"
                                       class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-500">people</span>
                            </div>
                        </div>
                    </div>

                    <hr class="border-gray-200" />
                    
                    <div>
                        <h4 class="text-base font-bold text-gray-900 mb-1">Meeting Point</h4>
                        <p class="text-gray-500 text-xs mb-4">Where you will meet travelers to begin the experience.</p>
                        
                        <div class="grid grid-cols-1 gap-5">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">City <span class="text-red-500">*</span></label>
                                <select x-model="formData.city" class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm appearance-none cursor-pointer">
                                    <option value="" disabled>-- Select a city or province --</option>
                                    <option value="Hà Nội">Hanoi</option>
                                    <option value="TP Hồ Chí Minh">Ho Chi Minh City</option>
                                    <option value="Đà Nẵng">Da Nang</option>
                                    <option value="Hội An">Quang Nam (Hoi An)</option>
                                    <option value="Khác">Other</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Specific Address <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[18px]">location_on</span>
                                    <input type="text" x-model="formData.meetingPoint" placeholder="Enter the meeting address..."
                                           class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl py-2.5 pl-10 pr-4 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 2: LỊCH TRÌNH & CHI TIẾT -->
            <div x-show="step === 2" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Itinerary Details</h3>
                <p class="text-sm text-gray-500 mb-6">A clear itinerary helps travelers decide whether to book.</p>
                
                <div class="space-y-8">
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">Overview <span class="text-red-500">*</span></label>
                        <textarea x-model="formData.description" rows="4"
                                  placeholder="Tell travelers what makes this experience special..."
                                  class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm resize-none"></textarea>
                    </div>

                    <!-- Timeline Builder Modern -->
                    <div>
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900">Detailed Itinerary</label>
                                <p class="text-xs text-gray-500 mt-0.5">Add the key moments of the experience.</p>
                            </div>
                        </div>
                        
                        <div class="ml-2 mt-2">
                            <div class="relative">
                                <!-- Vertical Line -->
                                <div class="absolute left-2.5 top-4 bottom-4 w-0.5 bg-gray-200"></div>

                                <div class="space-y-4 relative z-10">
                                    <template x-for="(item, index) in formData.timeline" :key="index">
                                        <div class="relative flex items-start gap-4">
                                            <!-- Timeline Dot -->
                                            <div class="relative z-10 w-5 h-5 mt-2 rounded-full border-4 border-white bg-primary shadow-sm flex-shrink-0"></div>
                                            
                                            <!-- Inputs -->
                                            <div class="flex-grow flex flex-col sm:flex-row gap-2 bg-white p-2.5 rounded-xl border border-gray-200 shadow-sm hover:border-gray-300 transition-colors">
                                                <input type="time" x-model="item.time" class="w-28 bg-transparent border-none text-gray-900 text-sm font-semibold focus:ring-0 px-2 outline-none">
                                                <div class="hidden sm:block w-px bg-gray-200 my-1"></div>
                                                <input type="text" x-model="item.activity" placeholder="Activity (example: Breakfast)" class="flex-grow bg-transparent border-none text-gray-700 text-sm focus:ring-0 px-2 outline-none">
                                                
                                                <button type="button" @@click="removeTimelineItem(index)" class="p-1.5 text-gray-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors flex-shrink-0">
                                                    <span class="material-symbols-outlined text-[18px]">close</span>
                                                </button>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </div>

                            <button type="button" @@click="addTimelineItem()" class="mt-4 relative z-10 flex items-center gap-1.5 text-xs font-bold text-gray-700 hover:text-primary transition-colors bg-white border border-dashed border-gray-300 px-4 py-2 rounded-xl hover:border-primary hover:bg-orange-50">
                                <span class="material-symbols-outlined text-[16px]">add</span> Add Timeline Item
                            </button>
                        </div>
                    </div>

                    <hr class="border-gray-200" />

                    <!-- Selectable Cards for Languages -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Languages <span class="text-red-500">*</span></label>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                            <template x-for="lang in [{ value: 'Tiếng Việt', label: 'Vietnamese' }, { value: 'English', label: 'English' }, { value: '한국어', label: 'Korean' }, { value: '中文', label: 'Chinese' }]" :key="lang.value">
                                <label class="relative flex items-center justify-center px-3 py-3 cursor-pointer rounded-xl border transition-all duration-200"
                                       :class="formData.languages.includes(lang.value) ? 'border-primary bg-orange-50' : 'border-gray-200 bg-white hover:border-gray-300'">
                                    <input type="checkbox" :value="lang.value" x-model="formData.languages" class="sr-only">
                                    <span class="font-semibold text-sm" :class="formData.languages.includes(lang.value) ? 'text-primary' : 'text-gray-700'" x-text="lang.label"></span>
                                    
                                    <!-- Check Icon Overlay -->
                                    <div x-show="formData.languages.includes(lang.value)" class="absolute top-1.5 right-1.5 w-4 h-4 bg-primary text-white rounded-full flex items-center justify-center">
                                        <span class="material-symbols-outlined text-[12px]">check</span>
                                    </div>
                                </label>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 3: HÌNH ẢNH (MEDIA) -->
            <div x-show="step === 3" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Add Tour Photos</h3>
                <p class="text-sm text-gray-500 mb-6">High-quality photos help your experience stand out.</p>
                
                <div class="space-y-6">
                    <!-- Cover Image -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Cover Image <span class="text-red-500">*</span></label>
                        <div class="relative border-2 border-dashed border-gray-300 rounded-2xl h-48 flex flex-col items-center justify-center bg-gray-50 hover:bg-orange-50/50 hover:border-primary transition-colors cursor-pointer group overflow-hidden" onclick="document.getElementById('coverImageInput').click()">
                            <input type="file" id="coverImageInput" accept="image/jpeg, image/png" class="hidden" @@change="handleCoverImage" />
                            <template x-if="coverImagePreview">
                                <img :src="coverImagePreview" class="absolute inset-0 w-full h-full object-cover z-0" />
                            </template>
                            <div class="text-center z-10 transition-transform group-hover:-translate-y-1" :class="{'bg-black/40 p-4 rounded-xl backdrop-blur-sm': coverImagePreview}">
                                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm mx-auto mb-2 text-gray-400 group-hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-[24px]">add_photo_alternate</span>
                                </div>
                                <p class="text-sm font-bold" :class="coverImagePreview ? 'text-white' : 'text-gray-900'" x-text="coverImagePreview ? 'Change cover image' : 'Drag and drop a cover image or browse'"></p>
                                <p class="text-xs mt-1" :class="coverImagePreview ? 'text-gray-200' : 'text-gray-500'">JPG or PNG (Maximum 5 MB)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Gallery -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <label class="block text-sm font-semibold text-gray-900">Additional Photos</label>
                            <span class="text-xs font-medium text-gray-500">Up to 5 photos</span>
                        </div>
                        <div class="grid grid-cols-3 md:grid-cols-5 gap-3">
                            <input type="file" id="galleryInput" accept="image/jpeg, image/png" multiple class="hidden" @@change="handleGalleryImages" />
                            
                            <!-- Add button -->
                            <div x-show="galleryPreviews.length < 5" class="border-2 border-dashed border-gray-300 rounded-xl aspect-square flex flex-col items-center justify-center bg-white hover:bg-gray-50 hover:border-gray-400 transition-colors cursor-pointer group" onclick="document.getElementById('galleryInput').click()">
                                <span class="material-symbols-outlined text-[24px] text-gray-400 group-hover:text-gray-600">add</span>
                            </div>
                            
                            <!-- Real previews -->
                            <template x-for="(preview, index) in galleryPreviews" :key="index">
                                <div class="relative border border-gray-200 rounded-xl aspect-square overflow-hidden group">
                                    <img :src="preview" class="w-full h-full object-cover" />
                                    <button type="button" @@click.stop="removeGalleryImage(index)" class="absolute top-1 right-1 bg-red-500 text-white rounded-full p-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined text-[14px]">close</span>
                                    </button>
                                </div>
                            </template>
                            
                            <!-- Mock slots -->
                            <template x-for="i in Math.max(0, 4 - galleryPreviews.length)">
                                <div class="border border-gray-100 rounded-xl aspect-square bg-gray-50/50 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-gray-200 text-[24px]">image</span>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 4: ĐỊNH GIÁ & DỊCH VỤ -->
            <div x-show="step === 4" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Experience Pricing</h3>
                <p class="text-sm text-gray-500 mb-6">Set your price and select the services included.</p>
                
                <div class="space-y-8">
                    <!-- Pricing Container -->
                    <div class="bg-gray-50 rounded-2xl p-5 border border-gray-200">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Base Price / Session <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <input type="text" :value="formatCurrencyValue(formData.pricePerSession)" @@input="formData.pricePerSession = parseCurrencyValue($event.target.value)"
                                           class="w-full bg-white border border-gray-300 text-gray-900 text-base font-bold rounded-xl px-4 py-2.5 pl-10 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 font-bold text-base">₫</span>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Additional Guest Fee</label>
                                <div class="relative">
                                    <input type="text" :value="formatCurrencyValue(formData.pricePerGuest)" @@input="formData.pricePerGuest = parseCurrencyValue($event.target.value)"
                                           class="w-full bg-white border border-gray-300 text-gray-900 text-base font-bold rounded-xl px-4 py-2.5 pl-10 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 font-bold text-base">₫</span>
                                </div>
                                <p class="text-[11px] text-gray-500 mt-1.5">Applied to each guest above the base group size.</p>
                            </div>
                        </div>

                        <!-- Real-time Earnings Calculator -->
                        <div class="mt-5 bg-white rounded-xl p-4 border border-gray-200 shadow-sm">
                            <h4 class="text-xs font-bold text-gray-900 mb-3 uppercase tracking-wide">Estimated Earnings</h4>
                            <div class="flex justify-between items-center text-sm mb-2 text-gray-600">
                                <span>Base price</span>
                                <span class="font-medium" x-text="formatCurrency(formData.pricePerSession)"></span>
                            </div>
                            <div class="flex justify-between items-center text-sm mb-3 text-gray-600">
                                <span>Platform fee (15%)</span>
                                <span class="font-medium text-red-500" x-text="'- ' + formatCurrency(platformFee())"></span>
                            </div>
                            <div class="border-t border-gray-200 pt-3 flex justify-between items-center">
                                <span class="font-bold text-gray-900 text-sm">Your payout / session</span>
                                <span class="text-lg font-black text-green-600" x-text="formatCurrency(netEarnings())"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Included Services as Selectable Cards -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Included Services</label>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-3">
                            <template x-for="service in availableServices" :key="service.id">
                                <label class="relative flex items-center p-3 cursor-pointer rounded-xl border transition-all duration-200"
                                       :class="formData.includedServices.includes(service.id) ? 'border-primary bg-orange-50' : 'border-gray-200 bg-white hover:border-gray-300'">
                                    <input type="checkbox" :value="service.id" x-model="formData.includedServices" class="sr-only">
                                    <span class="material-symbols-outlined mr-2 text-[18px] text-gray-400" :class="formData.includedServices.includes(service.id) ? 'text-primary' : ''" x-text="service.icon"></span>
                                    <span class="font-semibold text-xs" :class="formData.includedServices.includes(service.id) ? 'text-primary' : 'text-gray-700'" x-text="service.name"></span>
                                </label>
                            </template>
                        </div>
                        <!-- Add Custom Service -->
                        <div class="flex items-center gap-2 mt-2">
                            <input type="text" x-model="customServiceInput" @@keydown.enter.prevent="addCustomService()" 
                                   placeholder="Or enter another service..."
                                   class="flex-grow bg-white border border-gray-300 text-sm rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                            <button type="button" @@click="addCustomService()" 
                                    class="px-5 py-2.5 bg-gray-100 text-gray-700 border border-gray-200 hover:bg-gray-200 hover:border-gray-300 font-bold text-sm rounded-xl transition-all shadow-sm">
                                Add
                            </button>
                        </div>
                    </div>

                    <!-- Tags -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Tags</label>
                        <div class="flex flex-wrap gap-2 p-2.5 bg-white border border-gray-300 rounded-xl min-h-[50px] shadow-sm focus-within:ring-4 focus-within:ring-primary/20 focus-within:border-primary transition-all">
                            <template x-for="tag in formData.tags" :key="tag">
                                <span class="flex items-center gap-1 bg-gray-100 text-gray-700 px-2.5 py-1 rounded-md text-xs font-medium">
                                    <span x-text="'#' + tag"></span>
                                    <button type="button" @@click="removeTag(tag)" class="text-gray-400 hover:text-red-500 focus:outline-none"><span class="material-symbols-outlined text-[14px]">close</span></button>
                                </span>
                            </template>
                            <input type="text" x-model="tagInput" @@keydown.enter.prevent="addTag()" :disabled="formData.tags.length >= 5" 
                                   placeholder="Type a tag and press Enter..."
                                   class="bg-transparent border-none focus:ring-0 text-sm flex-grow outline-none placeholder-gray-400 disabled:opacity-50">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Massive Spacer to guarantee scrolling past the pill -->
            <div class="h-48 w-full mt-10"></div>
        </form>
    </div>

    <!-- Floating Action Pill -->
    <!-- Solid white background prevents text collision. Floating center aligned. -->
    <div class="fixed bottom-8 left-0 right-0 lg:left-64 z-50 flex justify-center pointer-events-none">
        <div class="bg-white border border-gray-200 shadow-[0_10px_40px_rgba(0,0,0,0.1)] rounded-full p-2 flex items-center pointer-events-auto">
            
            <!-- Back Button -->
            <button type="button" @@click="prevStep()" x-show="step > 1"
                    class="px-5 py-2.5 rounded-full text-sm font-bold text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-all flex items-center gap-1.5 mr-1">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back
            </button>
            
            <div class="w-px h-6 bg-gray-200 mx-1" x-show="step > 1"></div>
            
            <!-- Next Button -->
            <button type="button" @@click="nextStep()" x-show="step < 4"
                    class="ml-1 px-8 py-2.5 rounded-full text-sm font-bold text-white bg-gray-900 hover:bg-black transition-all shadow-md flex items-center gap-2">
                Continue <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </button>
            
            <!-- Submit Button -->
            <button type="button" @@click="submitForm()" x-show="step === 4" :disabled="isSubmitting" style="display: none;"
                    class="ml-1 px-8 py-2.5 rounded-full text-sm font-bold text-white bg-primary hover:bg-primary-dark transition-all shadow-md flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px] animate-spin" x-show="isSubmitting" style="display: none;">autorenew</span>
                <span x-text="isSubmitting ? 'Publishing...' : 'Finish & Publish'"></span>
            </button>
            
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function tourWizardApp() {
            return {
                step: 1,
                isSubmitting: false,
                isEdit: @(ViewBag.IsEdit == true ? "true" : "false"),
                tagInput: '',
                customServiceInput: '',
                
                coverImagePreview: null,
                coverImageFile: null,
                galleryPreviews: [],
                galleryFiles: [],
                
                handleCoverImage(e) {
                    const file = e.target.files[0];
                    if (file) {
                        this.coverImageFile = file;
                        this.coverImagePreview = URL.createObjectURL(file);
                    }
                },
                
                handleGalleryImages(e) {
                    const files = Array.from(e.target.files);
                    const remainingSlots = 5 - this.galleryFiles.length;
                    const filesToAdd = files.slice(0, remainingSlots);
                    
                    filesToAdd.forEach(file => {
                        this.galleryFiles.push(file);
                        this.galleryPreviews.push(URL.createObjectURL(file));
                    });
                    
                    e.target.value = '';
                },
                
                removeGalleryImage(index) {
                    this.galleryFiles.splice(index, 1);
                    this.galleryPreviews.splice(index, 1);
                },
                
                availableServices: [
                    { id: 'scooter', name: 'Transportation', icon: 'two_wheeler' },
                    { id: 'meal', name: 'Meal', icon: 'restaurant' },
                    { id: 'drink', name: 'Drinks', icon: 'local_cafe' },
                    { id: 'ticket', name: 'Admission Tickets', icon: 'local_activity' },
                    { id: 'photo', name: 'Photography', icon: 'photo_camera' }
                ],
                
                formData: {
                    id: '', name: '', duration: 4, maxGuests: 5, city: '', meetingPoint: '',
                    description: '', timeline: [{time: '', activity: ''}], languages: ['Tiếng Việt', 'English'],
                    pricePerSession: 1000000, pricePerGuest: 0, includedServices: ['scooter'], tags: ['explore']
                },

                init() {
                    if (this.isEdit) {
                        try {
                            const tourData = @Html.Raw(ViewBag.TourData ?? "null");
                            if (tourData) {
                                this.formData.id = tourData.id;
                                this.formData.name = tourData.title;
                                this.formData.duration = tourData.durationHours;
                                this.formData.maxGuests = tourData.maxGroupSize;
                                this.formData.city = tourData.city;
                                this.formData.meetingPoint = tourData.meetingPoint;
                                this.formData.description = tourData.description;
                                this.formData.pricePerSession = tourData.pricePerSession;
                                this.formData.pricePerGuest = tourData.pricePerPerson || 0;
                                this.formData.timeline = tourData.timelineJson || [{time: '', activity: ''}];
                                this.formData.languages = tourData.languages || [];
                                const loadedServices = tourData.includedItems || [];
                                this.formData.includedServices = [];
                                
                                loadedServices.forEach(svcName => {
                                    const existing = this.availableServices.find(s => s.name === svcName);
                                    if (existing) {
                                        this.formData.includedServices.push(existing.id);
                                    } else {
                                        const customId = 'custom_' + Math.random().toString(36).substr(2, 9);
                                        this.availableServices.push({ id: customId, name: svcName, icon: 'star' });
                                        this.formData.includedServices.push(customId);
                                    }
                                });
                                this.formData.tags = tourData.tags || [];
                                if (tourData.coverImageUrl) {
                                    this.coverImagePreview = tourData.coverImageUrl;
                                }
                                if (tourData.galleryImageUrls && tourData.galleryImageUrls.length > 0) {
                                    this.galleryPreviews = [...tourData.galleryImageUrls];
                                }
                            }
                        } catch(e) {
                            console.error("Failed to parse edit data", e);
                        }
                    }
                },

                nextStep() {
                    if (this.step === 1) {
                        if (!this.formData.name || !this.formData.city || !this.formData.meetingPoint) {
                            showToast('error', 'Please enter the package name, city, and meeting point.');
                            return;
                        }
                        
                        // Lọc bỏ các mốc thời gian trống hoàn toàn (cả giờ và hoạt động đều rỗng)
                        this.formData.timeline = this.formData.timeline.filter(t => t.time.trim() !== '' || t.activity.trim() !== '');
                        
                        // Validate Timeline (nếu có mốc thời gian bị điền thiếu 1 trong 2)
                        for (let i = 0; i < this.formData.timeline.length; i++) {
                            if (!this.formData.timeline[i].time || !this.formData.timeline[i].activity) {
                                showToast('error', 'Please enter both the time and activity for every timeline item.');
                                return;
                            }
                        }
                        
                        // Sort Timeline by time automatically
                        this.formData.timeline.sort((a, b) => a.time.localeCompare(b.time));
                    }
                    
                    if (this.step < 4) this.step++;
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                },
                
                prevStep() {
                    if (this.step > 1) this.step--;
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                },

                addTimelineItem() {
                    this.formData.timeline.push({ time: '', activity: '' });
                },
                removeTimelineItem(index) {
                    this.formData.timeline.splice(index, 1);
                },

                platformFee() { return this.formData.pricePerSession * 0.15; },
                netEarnings() { return this.formData.pricePerSession - this.platformFee(); },
                formatCurrency(val) { return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val || 0); },

                addCustomService() {
                    const name = this.customServiceInput.trim();
                    if (name) {
                        const id = 'custom_' + Date.now();
                        // Add to available services with a generic star icon
                        this.availableServices.push({ id: id, name: name, icon: 'star' });
                        // Automatically select it
                        this.formData.includedServices.push(id);
                        this.customServiceInput = '';
                    }
                },

                addTag() {
                    const tag = this.tagInput.trim().toLowerCase().replace(/[^\p{L}\p{N}\s-]/gu, '').replace(/\s+/g, '-');
                    if (tag && this.formData.tags.length < 5 && !this.formData.tags.includes(tag)) {
                        this.formData.tags.push(tag);
                    }
                    this.tagInput = '';
                },
                removeTag(tagToRemove) {
                    this.formData.tags = this.formData.tags.filter(tag => tag !== tagToRemove);
                },

                formatCurrencyValue(val) {
                    if (!val && val !== 0) return '';
                    return val.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
                },
                
                parseCurrencyValue(val) {
                    if (!val) return 0;
                    return parseInt(val.toString().replace(/,/g, '')) || 0;
                },

                async submitForm() {
                    if (this.step === 1 && (!this.formData.name || !this.formData.city || !this.formData.meetingPoint)) {
                        showToast('error', 'Please enter the package name, city, and meeting point.');
                        return;
                    }

                    this.isSubmitting = true;
                    
                    try {
                        const formData = new FormData();
                        if (this.isEdit) formData.append("Id", this.formData.id);
                        formData.append("Title", this.formData.name);
                        formData.append("City", this.formData.city);
                        formData.append("MeetingPoint", this.formData.meetingPoint);
                        formData.append("Description", this.formData.description);
                        formData.append("DurationHours", this.formData.duration);
                        formData.append("PricePerSession", this.formData.pricePerSession);
                        formData.append("PricePerGuest", this.formData.pricePerGuest);
                        formData.append("MaxGroupSize", this.formData.maxGuests);
                        
                        const selectedServiceNames = this.formData.includedServices.map(id => {
                            const svc = this.availableServices.find(s => s.id === id);
                            return svc ? svc.name : id;
                        });
                        formData.append("IncludedServices", JSON.stringify(selectedServiceNames));
                        formData.append("Languages", JSON.stringify(this.formData.languages));
                        formData.append("Tags", JSON.stringify(this.formData.tags));
                        formData.append("TimelineJson", JSON.stringify(this.formData.timeline));

                        if (this.coverImageFile) {
                            formData.append("CoverImage", this.coverImageFile);
                        }
                        
                        this.galleryFiles.forEach((file) => {
                            formData.append("GalleryImages", file);
                        });

                        const response = await fetch('/Guide/CreateTour', {
                            method: 'POST',
                            body: formData
                        });

                        const result = await response.json();

                        if (result.success) {
                            showToast('success', result.message || 'Your experience package has been published.');
                            setTimeout(() => { 
                                if (window.Turbo) Turbo.visit('/Guide/MyTours');
                                else window.location.href = '/Guide/MyTours';
                            }, 1500);
                        } else {
                            showToast('error', result.message || 'An error occurred while saving.');
                        }
                    } catch (error) {
                        showToast('error', 'System error. Please try again later.');
                        console.error(error);
                    } finally {
                        this.isSubmitting = false;
                    }
                }
            }
        }
    </script>
}
