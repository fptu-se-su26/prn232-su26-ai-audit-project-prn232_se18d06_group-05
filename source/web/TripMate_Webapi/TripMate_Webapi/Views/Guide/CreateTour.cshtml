@{
    ViewData["Title"] = "Create a New Experience Package";
    ViewData["ActivePage"] = "MyTours";
    ViewData["TurboVisitControl"] = "reload";
    ViewData["TurboCacheControl"] = "no-cache";
    Layout = "_GuideLayout";
}

<div class="min-h-screen pb-10" x-data="tourWizardApp()">
    
    <!-- Top Thin Stepper -->
    <div class="fixed top-0 left-0 right-0 h-1 bg-gray-200 z-[60]">
        <div class="h-full bg-primary transition-all duration-500 ease-out" :style="`width: ${(step / 4) * 100}%`"></div>
    </div>

    <!-- Header Section -->
    <div class="max-w-7xl mx-auto pt-6 px-4 mb-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <a href="/Guide/MyTours" class="w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            </a>
            <div>
                <h2 class="text-xl font-bold text-gray-900">@(ViewBag.IsEdit == true ? "Edit Experience Package" : "Create a New Experience Package")</h2>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <span class="hidden text-xs font-semibold sm:inline" :class="saveState === 'error' ? 'text-red-600' : 'text-slate-400'" x-text="saveStatusLabel"></span>
            <button x-show="publicationStatus === 'draft'" type="button" @@click="saveDraft(true)" :disabled="isSavingDraft" class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-bold text-slate-700 hover:border-orange-200 hover:bg-orange-50 disabled:opacity-50">
                <span x-text="isSavingDraft ? 'Saving…' : 'Save draft'"></span>
            </button>
            <button type="button" @@click="cancelEditing()" class="text-xs font-semibold text-gray-600 hover:text-gray-900 underline underline-offset-4 transition-colors">Cancel</button>
        </div>
    </div>

    <nav class="mx-auto mb-8 max-w-7xl px-4" aria-label="Tour creation progress">
        <ol class="grid grid-cols-4 gap-2">
            <template x-for="wizardStep in wizardSteps" :key="wizardStep.id">
                <li>
                    <button type="button" @@click="wizardStep.id < step && (step = wizardStep.id)"
                            :disabled="wizardStep.id > step"
                            :aria-current="step === wizardStep.id ? 'step' : null"
                            class="flex w-full flex-col items-center gap-1 rounded-xl px-1 py-2 text-center transition-colors disabled:cursor-default"
                            :class="step === wizardStep.id ? 'bg-orange-50 text-primary' : (wizardStep.id < step ? 'text-green-600 hover:bg-green-50' : 'text-gray-400')">
                        <span class="flex h-7 w-7 items-center justify-center rounded-full border text-xs font-black"
                              :class="step === wizardStep.id ? 'border-primary bg-primary text-white' : (wizardStep.id < step ? 'border-green-500 bg-green-500 text-white' : 'border-gray-200 bg-white')"
                              x-text="wizardStep.id < step ? '✓' : wizardStep.id"></span>
                        <span class="hidden text-[11px] font-bold sm:block" x-text="wizardStep.label"></span>
                    </button>
                </li>
            </template>
        </ol>
    </nav>

    <!-- Main Form Container -->
    <div class="mx-auto grid max-w-7xl items-start gap-6 px-4 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form @@submit.prevent="submitForm" class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm">
            <div class="p-5 sm:p-7">
            <div x-show="validationMessage" class="mb-5 flex items-start gap-3 rounded-xl border border-red-100 bg-red-50 p-4 text-sm text-red-700" role="alert" style="display:none"><span class="material-symbols-outlined text-[20px]">error</span><div><p class="font-bold">Review this step</p><p x-text="validationMessage"></p></div></div>
            
            <!-- STEP 1: BASICS AND LOCATION -->
            <div x-show="step === 1" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Start with the basics</h3>
                <p class="text-sm text-gray-500 mb-6">Help travelers understand the experience you offer.</p>
                
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">Experience Package Name <span class="text-red-500">*</span></label>
                        <input type="text" x-model="formData.name" x-ref="tourName" maxlength="120" placeholder="Example: Explore Hoi An Ancient Town at Night"
                               :aria-invalid="validationField === 'name'" class="w-full text-sm bg-white border text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm" :class="validationField === 'name' ? 'border-red-400' : 'border-gray-300'">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 mb-1.5">Estimated Duration <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input type="number" x-model="formData.duration" min="0.5" step="0.5"
                                       class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-500">hours</span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 mb-1.5">Maximum Group Size <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input type="number" x-model="formData.maxGuests" min="1"
                                       class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-500">people</span>
                            </div>
                        </div>
                    </div>

                    <hr class="border-gray-200" />
                    
                    <div>
                        <h4 class="text-base font-bold text-gray-900 mb-1">Meeting Point</h4>
                        <p class="text-gray-500 text-xs mb-4">Where you will meet travelers to begin the experience.</p>
                        
                        <div class="grid grid-cols-1 gap-5">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">City <span class="text-red-500">*</span></label>
                                <select x-model="formData.city" class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm appearance-none cursor-pointer">
                                    <option value="" disabled>-- Select a city or province --</option>
                                    <option value="Hanoi">Hanoi</option>
                                    <option value="Ho Chi Minh City">Ho Chi Minh City</option>
                                    <option value="Da Nang">Da Nang</option>
                                    <option value="Quang Nam">Quang Nam (Hoi An)</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Specific Address <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[18px]">location_on</span>
                                    <input type="text" x-model="formData.meetingPoint" placeholder="Enter the meeting address..."
                                           class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl py-2.5 pl-10 pr-4 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 2: ITINERARY AND DETAILS -->
            <div x-show="step === 2" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Itinerary Details</h3>
                <p class="text-sm text-gray-500 mb-6">A clear itinerary helps travelers decide whether to book.</p>
                
                <div class="space-y-8">
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">Overview <span class="text-red-500">*</span></label>
                        <textarea x-model="formData.description" rows="4"
                                  placeholder="Tell travelers what makes this experience special..."
                                  class="w-full text-sm bg-white border border-gray-300 text-gray-900 rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm resize-none"></textarea>
                    </div>

                    <!-- Timeline Builder Modern -->
                    <div>
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900">Detailed Itinerary</label>
                                <p class="text-xs text-gray-500 mt-0.5">Add the key moments of the experience.</p>
                            </div>
                        </div>
                        
                        <div class="ml-2 mt-2">
                            <div class="relative">
                                <!-- Vertical Line -->
                                <div class="absolute left-2.5 top-4 bottom-4 w-0.5 bg-gray-200"></div>

                                <div class="space-y-4 relative z-10">
                                    <template x-for="(item, index) in formData.timeline" :key="index">
                                        <div class="relative flex items-start gap-4">
                                            <!-- Timeline Dot -->
                                            <div class="relative z-10 w-5 h-5 mt-2 rounded-full border-4 border-white bg-primary shadow-sm flex-shrink-0"></div>
                                            
                                            <!-- Inputs -->
                                            <div class="flex-grow flex flex-col sm:flex-row gap-2 bg-white p-2.5 rounded-xl border border-gray-200 shadow-sm hover:border-gray-300 transition-colors">
                                                <input type="time" x-model="item.time" class="w-28 bg-transparent border-none text-gray-900 text-sm font-semibold focus:ring-0 px-2 outline-none">
                                                <div class="hidden sm:block w-px bg-gray-200 my-1"></div>
                                                <input type="text" x-model="item.activity" placeholder="Activity (example: Breakfast)" class="flex-grow bg-transparent border-none text-gray-700 text-sm focus:ring-0 px-2 outline-none">
                                                
                                                <button type="button" @@click="removeTimelineItem(index)" class="p-1.5 text-gray-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors flex-shrink-0">
                                                    <span class="material-symbols-outlined text-[18px]">close</span>
                                                </button>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </div>

                            <button type="button" @@click="addTimelineItem()" class="mt-4 relative z-10 flex items-center gap-1.5 text-xs font-bold text-gray-700 hover:text-primary transition-colors bg-white border border-dashed border-gray-300 px-4 py-2 rounded-xl hover:border-primary hover:bg-orange-50">
                                <span class="material-symbols-outlined text-[16px]">add</span> Add Timeline Item
                            </button>
                        </div>
                    </div>

                    <hr class="border-gray-200" />

                    <!-- Selectable Cards for Languages -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Languages <span class="text-red-500">*</span></label>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                            <template x-for="lang in [{ value: 'Vietnamese', label: 'Vietnamese' }, { value: 'English', label: 'English' }, { value: 'Korean', label: 'Korean' }, { value: 'Chinese', label: 'Chinese' }]" :key="lang.value">
                                <label class="relative flex items-center justify-center px-3 py-3 cursor-pointer rounded-xl border transition-all duration-200"
                                       :class="formData.languages.includes(lang.value) ? 'border-primary bg-orange-50' : 'border-gray-200 bg-white hover:border-gray-300'">
                                    <input type="checkbox" :value="lang.value" x-model="formData.languages" class="sr-only">
                                    <span class="font-semibold text-sm" :class="formData.languages.includes(lang.value) ? 'text-primary' : 'text-gray-700'" x-text="lang.label"></span>
                                    
                                    <!-- Check Icon Overlay -->
                                    <div x-show="formData.languages.includes(lang.value)" class="absolute top-1.5 right-1.5 w-4 h-4 bg-primary text-white rounded-full flex items-center justify-center">
                                        <span class="material-symbols-outlined text-[12px]">check</span>
                                    </div>
                                </label>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 3: MEDIA -->
            <div x-show="step === 3" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Add Tour Photos</h3>
                <p class="text-sm text-gray-500 mb-6">High-quality photos help your experience stand out.</p>
                
                <div class="space-y-6">
                    <!-- Cover Image -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Cover Image <span class="text-red-500">*</span></label>
                            <div class="relative border-2 border-dashed border-gray-300 rounded-2xl h-48 flex flex-col items-center justify-center bg-gray-50 hover:bg-orange-50/50 hover:border-primary transition-colors cursor-pointer group overflow-hidden"
                                 role="button" tabindex="0" aria-label="Choose a cover image"
                                 @@click="document.getElementById('coverImageInput').click()"
                                 @@keydown.enter.prevent="document.getElementById('coverImageInput').click()"
                                 @@keydown.space.prevent="document.getElementById('coverImageInput').click()">
                            <input type="file" id="coverImageInput" accept="image/jpeg, image/png" class="hidden" @@change="handleCoverImage" />
                            <template x-if="coverImagePreview">
                                <img :src="coverImagePreview" alt="Tour cover preview" @@error="!coverImageFile && (coverImagePreview = null)" class="absolute inset-0 w-full h-full object-cover z-0" />
                            </template>
                            <div class="text-center z-10 transition-transform group-hover:-translate-y-1" :class="{'bg-black/40 p-4 rounded-xl backdrop-blur-sm': coverImagePreview}">
                                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm mx-auto mb-2 text-gray-400 group-hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-[24px]">add_photo_alternate</span>
                                </div>
                                <p class="text-sm font-bold" :class="coverImagePreview ? 'text-white' : 'text-gray-900'" x-text="coverImagePreview ? 'Change cover image' : 'Choose a cover image'"></p>
                                <p class="text-xs mt-1" :class="coverImagePreview ? 'text-gray-200' : 'text-gray-500'">JPG or PNG (Maximum 5 MB)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Gallery -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <label class="block text-sm font-semibold text-gray-900">Additional Photos</label>
                            <span class="text-xs font-medium text-gray-500">Up to 5 photos</span>
                        </div>
                        <div class="grid grid-cols-3 md:grid-cols-5 gap-3">
                            <input type="file" id="galleryInput" accept="image/jpeg, image/png" multiple class="hidden" @@change="handleGalleryImages" />
                            
                            <!-- Add button -->
                            <button type="button" x-show="galleryItems.length < 5" @@click="document.getElementById('galleryInput').click()" @@dragover.prevent="isDraggingGallery=true" @@dragleave.prevent="isDraggingGallery=false" @@drop.prevent="handleGalleryDrop($event)"
                                    class="border-2 border-dashed border-gray-300 rounded-xl aspect-square flex flex-col items-center justify-center bg-white hover:bg-gray-50 hover:border-gray-400 transition-colors cursor-pointer group"
                                    :class="isDraggingGallery ? 'border-primary bg-orange-50' : ''" aria-label="Add or drop gallery photos">
                                <span class="material-symbols-outlined text-[24px] text-gray-400 group-hover:text-gray-600">add</span>
                                <span class="mt-1 hidden text-[9px] font-bold text-slate-400 sm:block">Drop files</span>
                            </button>
                            
                            <!-- Real previews -->
                            <template x-for="(item, index) in galleryItems" :key="item.id">
                                <div class="relative border border-gray-200 rounded-xl aspect-square overflow-hidden group">
                                    <img :src="item.preview" alt="Tour gallery preview" class="w-full h-full object-cover" />
                                    <button type="button" @@click.stop="removeGalleryImage(index)" aria-label="Remove gallery photo"
                                            class="absolute top-1 right-1 bg-red-500 text-white rounded-full p-1 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined text-[14px]">close</span>
                                    </button>
                                    <div class="absolute bottom-1 left-1 flex gap-1 opacity-100 sm:opacity-0 sm:group-hover:opacity-100">
                                        <button type="button" @@click.stop="moveGalleryImage(index,-1)" :disabled="index===0" class="flex h-6 w-6 items-center justify-center rounded-full bg-white/90 text-slate-700 disabled:opacity-30" aria-label="Move photo left"><span class="material-symbols-outlined text-[14px]">arrow_back</span></button>
                                        <button type="button" @@click.stop="moveGalleryImage(index,1)" :disabled="index===galleryItems.length-1" class="flex h-6 w-6 items-center justify-center rounded-full bg-white/90 text-slate-700 disabled:opacity-30" aria-label="Move photo right"><span class="material-symbols-outlined text-[14px]">arrow_forward</span></button>
                                    </div>
                                </div>
                            </template>
                            
                            <!-- Mock slots -->
                            <template x-for="i in Math.max(0, 4 - galleryItems.length)">
                                <div class="border border-gray-100 rounded-xl aspect-square bg-gray-50/50 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-gray-200 text-[24px]">image</span>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 4: PRICING AND SERVICES -->
            <div x-show="step === 4" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Experience Pricing</h3>
                <p class="text-sm text-gray-500 mb-6">Set your price and select the services included.</p>
                
                <div class="space-y-8">
                    <!-- Pricing Container -->
                    <div class="bg-gray-50 rounded-2xl p-5 border border-gray-200">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Base Price / Session <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <input type="text" :value="formatCurrencyValue(formData.pricePerSession)" @@input="formData.pricePerSession = parseCurrencyValue($event.target.value)"
                                           class="w-full bg-white border border-gray-300 text-gray-900 text-base font-bold rounded-xl px-4 py-2.5 pl-10 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 font-bold text-base">₫</span>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Guests Included in Base Price <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <input type="number" x-model.number="formData.includedGuests" min="1" :max="formData.maxGuests"
                                           class="w-full bg-white border border-gray-300 text-gray-900 text-base font-bold rounded-xl px-4 py-2.5 pr-20 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-500">guests</span>
                                </div>
                                <p class="text-[11px] text-gray-500 mt-1.5">The base price covers this many travelers.</p>
                            </div>
                        </div>

                        <div class="mt-5">
                            <label class="block text-sm font-semibold text-gray-900 mb-1.5">Additional Guest Fee</label>
                            <div class="relative">
                                <input type="text" :value="formatCurrencyValue(formData.additionalGuestFee)" @@input="formData.additionalGuestFee = parseCurrencyValue($event.target.value)"
                                       class="w-full bg-white border border-gray-300 text-gray-900 text-base font-bold rounded-xl px-4 py-2.5 pl-10 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 font-bold text-base">₫</span>
                            </div>
                            <p class="text-[11px] text-gray-500 mt-1.5"
                               x-text="formData.maxGuests > formData.includedGuests ? `Charged for each guest from number ${Number(formData.includedGuests) + 1}, up to ${formData.maxGuests} guests.` : 'No additional guest can be added at the current maximum group size.'"></p>
                        </div>

                        <!-- Real-time Earnings Calculator -->
                        <div class="mt-5 bg-white rounded-xl p-4 border border-gray-200 shadow-sm">
                            <h4 class="text-xs font-bold text-gray-900 mb-3 uppercase tracking-wide">Estimated Earnings</h4>
                            <div class="flex justify-between items-center text-sm mb-2 text-gray-600">
                                <span>Base tour price</span>
                                <span class="font-medium" x-text="formatCurrency(formData.pricePerSession)"></span>
                            </div>
                            <div class="flex justify-between items-center text-sm mb-3 text-gray-600">
                                <span>Full group total (<span x-text="formData.maxGuests"></span> guests)</span>
                                <span class="font-medium" x-text="formatCurrency(fullCapacityTotal())"></span>
                            </div>
                            <div class="flex justify-between items-center text-sm mb-3 text-gray-600">
                                <span>Platform fee (15%)</span>
                                <span class="font-medium text-red-500" x-text="'- ' + formatCurrency(platformFee(fullCapacityTotal()))"></span>
                            </div>
                            <div class="border-t border-gray-200 pt-3 flex justify-between items-center">
                                <span class="font-bold text-gray-900 text-sm">Your payout at full capacity</span>
                                <span class="text-lg font-black text-green-600" x-text="formatCurrency(netEarnings(fullCapacityTotal()))"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Included Services as Selectable Cards -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Included Services</label>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-3">
                            <template x-for="service in availableServices" :key="service.id">
                                <label class="relative flex items-center p-3 cursor-pointer rounded-xl border transition-all duration-200"
                                       :class="formData.includedServices.includes(service.id) ? 'border-primary bg-orange-50' : 'border-gray-200 bg-white hover:border-gray-300'">
                                    <input type="checkbox" :value="service.id" x-model="formData.includedServices" class="sr-only">
                                    <span class="material-symbols-outlined mr-2 text-[18px] text-gray-400" :class="formData.includedServices.includes(service.id) ? 'text-primary' : ''" x-text="service.icon"></span>
                                    <span class="font-semibold text-xs" :class="formData.includedServices.includes(service.id) ? 'text-primary' : 'text-gray-700'" x-text="service.name"></span>
                                </label>
                            </template>
                        </div>
                        <!-- Add Custom Service -->
                        <div class="flex items-center gap-2 mt-2">
                            <input type="text" x-model="customServiceInput" @@keydown.enter.prevent="addCustomService()" 
                                   placeholder="Or enter another service..."
                                   class="flex-grow bg-white border border-gray-300 text-sm rounded-xl px-4 py-2.5 focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all shadow-sm">
                            <button type="button" @@click="addCustomService()" 
                                    class="px-5 py-2.5 bg-gray-100 text-gray-700 border border-gray-200 hover:bg-gray-200 hover:border-gray-300 font-bold text-sm rounded-xl transition-all shadow-sm">
                                Add
                            </button>
                        </div>
                    </div>

                    <!-- Tags -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-2">Tags</label>
                        <div class="flex flex-wrap gap-2 p-2.5 bg-white border border-gray-300 rounded-xl min-h-[50px] shadow-sm focus-within:ring-4 focus-within:ring-primary/20 focus-within:border-primary transition-all">
                            <template x-for="tag in formData.tags" :key="tag">
                                <span class="flex items-center gap-1 bg-gray-100 text-gray-700 px-2.5 py-1 rounded-md text-xs font-medium">
                                    <span x-text="'#' + tag"></span>
                                    <button type="button" @@click="removeTag(tag)" class="text-gray-400 hover:text-red-500 focus:outline-none"><span class="material-symbols-outlined text-[14px]">close</span></button>
                                </span>
                            </template>
                            <input type="text" x-model="tagInput" @@keydown.enter.prevent="addTag()" :disabled="formData.tags.length >= 5" 
                                   placeholder="Type a tag and press Enter..."
                                   class="bg-transparent border-none focus:ring-0 text-sm flex-grow outline-none placeholder-gray-400 disabled:opacity-50">
                        </div>
                    </div>
                </div>
            </div>

            </div>
            <footer class="sticky bottom-0 z-20 flex items-center justify-between gap-3 border-t border-slate-100 bg-white/95 p-4 backdrop-blur sm:px-7">
            <button type="button" @@click="prevStep()" x-show="step > 1"
                    class="inline-flex items-center gap-1.5 rounded-xl px-4 py-2.5 text-sm font-bold text-gray-600 transition hover:bg-gray-100 hover:text-gray-900">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back
            </button>
            <span x-show="step === 1" class="text-xs font-semibold text-slate-400"><span x-text="completionScore"></span>% complete</span>
            <div class="ml-auto flex items-center gap-2">
            <button type="button" @@click="nextStep()" x-show="step < 4"
                    class="inline-flex items-center gap-2 rounded-xl bg-gray-900 px-6 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-black">
                Continue <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </button>
            <button type="button" @@click="submitForm()" x-show="step === 4" :disabled="isSubmitting" style="display: none;"
                    class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-primary-dark disabled:opacity-60">
                <span class="material-symbols-outlined text-[18px] animate-spin" x-show="isSubmitting" style="display: none;">autorenew</span>
                <span x-text="isSubmitting ? 'Saving...' : (isEdit ? 'Save Changes' : 'Finish & Publish')"></span>
            </button>
            </div>
            </footer>
        </form>

        <aside class="space-y-4 lg:sticky lg:top-24">
            <section class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm" aria-label="Traveler preview">
                <div class="relative h-44 bg-gradient-to-br from-orange-100 via-amber-50 to-slate-200">
                    <img x-show="coverImagePreview" :src="coverImagePreview" alt="Tour cover preview" class="h-full w-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent"></div>
                    <span class="absolute left-4 top-4 rounded-full bg-white/90 px-2.5 py-1 text-[10px] font-black uppercase text-slate-600" x-text="publicationStatus"></span>
                    <div class="absolute bottom-4 left-4 right-4 text-white"><p class="text-[10px] font-bold uppercase tracking-wider" x-text="formData.city || 'Destination'"></p><h3 class="mt-1 line-clamp-2 text-lg font-black" x-text="formData.name || 'Your experience title'"></h3></div>
                </div>
                <div class="space-y-4 p-5"><div class="flex gap-3 text-xs font-semibold text-slate-500"><span x-text="`${formData.duration || 0} hours`"></span><span x-text="`Up to ${formData.maxGuests || 0} guests`"></span></div><p class="line-clamp-3 text-sm leading-6 text-slate-500" x-text="formData.description || 'Your description will appear here as travelers browse the experience.'"></p><div class="border-t border-slate-100 pt-4"><p class="text-lg font-black text-primary" x-text="formatCurrency(formData.pricePerSession)"></p><p class="text-[10px] font-semibold text-slate-400" x-text="`Per tour · Includes ${formData.includedGuests} guest${Number(formData.includedGuests) === 1 ? '' : 's'}`"></p></div></div>
            </section>
            <section class="rounded-2xl border border-slate-100 bg-white p-5 shadow-sm">
                <div class="flex items-center justify-between"><h3 class="text-sm font-black text-slate-900">Publish checklist</h3><span class="text-sm font-black" :class="completionScore === 100 ? 'text-green-600' : 'text-primary'" x-text="`${completionScore}%`"></span></div>
                <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-100"><div class="h-full rounded-full bg-primary transition-all" :style="`width:${completionScore}%`"></div></div>
                <ul class="mt-4 space-y-2"><template x-for="item in completionItems" :key="item.label"><li class="flex items-center gap-2 text-xs font-semibold" :class="item.complete ? 'text-slate-600' : 'text-slate-400'"><span class="material-symbols-outlined text-[17px]" :class="item.complete ? 'text-green-500' : 'text-slate-300'" x-text="item.complete ? 'check_circle' : 'radio_button_unchecked'"></span><span x-text="item.label"></span></li></template></ul>
            </section>
            <p class="px-2 text-center text-[11px] leading-5 text-slate-400">Preview updates as you type. New drafts autosave text details; selected files are uploaded when you publish.</p>
        </aside>
    </div>

    <div x-show="showCancelModal" @@keydown.escape.window="showCancelModal = false"
         class="fixed inset-0 z-[90] flex items-center justify-center p-4" style="display: none;"
         role="dialog" aria-modal="true" aria-labelledby="cancel-tour-editor-title">
        <div class="absolute inset-0 bg-slate-950/45 backdrop-blur-[1px]" @@click="showCancelModal = false"></div>
        <div class="relative w-full max-w-sm overflow-hidden rounded-2xl bg-white shadow-2xl">
            <div class="p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-amber-50 text-amber-600">
                    <span class="material-symbols-outlined">warning</span>
                </div>
                <h3 id="cancel-tour-editor-title" class="text-lg font-bold text-gray-900">Leave the tour editor?</h3>
                <p class="mt-1 text-sm leading-relaxed text-gray-500" x-text="publicationStatus === 'draft' ? 'Your server-saved draft will remain in My Tours. Any changes still waiting to sync, including selected files, may be lost.' : 'Changes saved only on this device will be discarded.'"></p>
            </div>
            <div class="flex justify-end gap-2 border-t border-gray-100 bg-gray-50 p-4">
                <button type="button" @@click="showCancelModal = false" class="rounded-xl px-4 py-2.5 text-sm font-bold text-gray-600 hover:bg-gray-100">Keep editing</button>
                <button type="button" @@click="confirmCancel()" class="rounded-xl bg-red-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-red-700">Leave editor</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function tourWizardApp() {
            return {
                step: 1,
                isSubmitting: false,
                isEdit: @(ViewBag.IsEdit == true ? "true" : "false"),
                publicationStatus: '@(ViewBag.IsEdit == true ? "hidden" : "draft")',
                showCancelModal: false,
                isSavingDraft: false,
                isDraggingGallery: false,
                hasUnsavedChanges: false,
                allowNavigation: false,
                saveState: 'idle',
                lastSavedAt: null,
                autosaveTimer: null,
                validationMessage: '',
                validationField: '',
                wizardSteps: [
                    { id: 1, label: 'Basics' },
                    { id: 2, label: 'Experience' },
                    { id: 3, label: 'Photos' },
                    { id: 4, label: 'Pricing' }
                ],
                tagInput: '',
                customServiceInput: '',
                
                coverImagePreview: null,
                coverImageFile: null,
                galleryItems: [],
                
                handleCoverImage(e) {
                    const file = e.target.files[0];
                    if (!file) return;
                    if (!this.validateImageFile(file)) {
                        e.target.value = '';
                        return;
                    }
                    if (this.coverImageFile && this.coverImagePreview?.startsWith('blob:')) {
                        URL.revokeObjectURL(this.coverImagePreview);
                    }
                    this.coverImageFile = file;
                    this.coverImagePreview = URL.createObjectURL(file);
                },
                
                handleGalleryImages(e) {
                    this.addGalleryFiles(Array.from(e.target.files));
                    e.target.value = '';
                },
                
                removeGalleryImage(index) {
                    const item = this.galleryItems[index];
                    if (item?.file && item.preview?.startsWith('blob:')) URL.revokeObjectURL(item.preview);
                    this.galleryItems.splice(index, 1);
                },

                handleGalleryDrop(event) {
                    this.isDraggingGallery = false;
                    this.addGalleryFiles(Array.from(event.dataTransfer?.files || []));
                },
                addGalleryFiles(files) {
                    const validFiles = files.filter(file => this.validateImageFile(file));
                    const remainingSlots = 5 - this.galleryItems.length;
                    validFiles.slice(0, remainingSlots).forEach((file, index) => this.galleryItems.push({
                        id: `new_${Date.now()}_${index}`, preview: URL.createObjectURL(file), existingUrl: null, file
                    }));
                    if (validFiles.length > remainingSlots) showToast('warning', 'You can add up to five gallery images.');
                },
                moveGalleryImage(index, offset) {
                    const target = index + offset;
                    if (target < 0 || target >= this.galleryItems.length) return;
                    const items = [...this.galleryItems];
                    [items[index], items[target]] = [items[target], items[index]];
                    this.galleryItems = items;
                },

                validateImageFile(file) {
                    if (!['image/jpeg', 'image/png'].includes(file.type)) {
                        showToast('error', 'Images must be JPG or PNG files.');
                        return false;
                    }
                    if (file.size > 5 * 1024 * 1024) {
                        showToast('error', 'Each image must be smaller than 5 MB.');
                        return false;
                    }
                    return true;
                },
                
                availableServices: [
                    { id: 'scooter', name: 'Transportation', icon: 'two_wheeler' },
                    { id: 'meal', name: 'Meal', icon: 'restaurant' },
                    { id: 'drink', name: 'Drinks', icon: 'local_cafe' },
                    { id: 'ticket', name: 'Admission Tickets', icon: 'local_activity' },
                    { id: 'photo', name: 'Photography', icon: 'photo_camera' }
                ],
                
                formData: {
                    id: '', name: '', duration: 4, maxGuests: 5, city: '', meetingPoint: '',
                    description: '', timeline: [{time: '', activity: ''}], languages: ['Vietnamese', 'English'],
                    pricePerSession: 1000000, includedGuests: 1, additionalGuestFee: 0,
                    includedServices: ['scooter'], tags: ['explore']
                },

                get completionItems() {
                    return [
                        { label: 'Tour name and destination', complete: (this.formData.name || '').trim().length >= 5 && !!this.formData.city && !!(this.formData.meetingPoint || '').trim() },
                        { label: 'Description and language', complete: (this.formData.description || '').trim().length >= 20 && this.formData.languages.length > 0 },
                        { label: 'Complete itinerary', complete: this.formData.timeline.some(item => item.time && item.activity) },
                        { label: 'Cover photo', complete: !!this.coverImagePreview },
                        { label: 'Valid capacity and pricing', complete: Number(this.formData.pricePerSession) > 0 && Number(this.formData.includedGuests) >= 1 && Number(this.formData.maxGuests) >= Number(this.formData.includedGuests) }
                    ];
                },
                get completionScore() { return Math.round(this.completionItems.filter(item => item.complete).length * 100 / this.completionItems.length); },
                get saveStatusLabel() {
                    if (this.saveState === 'saving') return 'Saving draft…';
                    if (this.saveState === 'error') return 'Autosave failed';
                    if (this.lastSavedAt) return `${this.publicationStatus === 'draft' ? 'Draft saved' : 'Saved locally'} ${this.relativeSavedTime()}`;
                    return this.hasUnsavedChanges ? 'Unsaved changes' : 'All changes saved';
                },

                init() {
                    if (this.isEdit) {
                        try {
                            const tourData = @Html.Raw(ViewBag.TourData ?? "null");
                            if (tourData) {
                                this.formData.id = tourData.id;
                                this.publicationStatus = tourData.publicationStatus || 'hidden';
                                this.formData.name = tourData.title;
                                this.formData.duration = tourData.durationHours;
                                this.formData.maxGuests = tourData.maxGroupSize;
                                const cityAliases = { 'Hà Nội': 'Hanoi', 'TP Hồ Chí Minh': 'Ho Chi Minh City', 'Đà Nẵng': 'Da Nang', 'Hội An': 'Quang Nam', 'Khác': 'Other' };
                                this.formData.city = cityAliases[tourData.city] || tourData.city;
                                this.formData.meetingPoint = tourData.meetingPoint;
                                this.formData.description = tourData.description;
                                this.formData.pricePerSession = tourData.pricePerSession;
                                this.formData.includedGuests = tourData.includedGuestCount || 1;
                                this.formData.additionalGuestFee = tourData.additionalGuestFee || 0;
                                this.formData.timeline = tourData.timelineJson || [{time: '', activity: ''}];
                                const languageAliases = { 'Tiếng Việt': 'Vietnamese', '한국어': 'Korean', '中文': 'Chinese' };
                                this.formData.languages = (tourData.languages || []).map(language => languageAliases[language] || language);
                                const loadedServices = tourData.includedItems || [];
                                this.formData.includedServices = [];
                                
                                loadedServices.forEach(svcName => {
                                    const existing = this.availableServices.find(s => s.name === svcName);
                                    if (existing) {
                                        this.formData.includedServices.push(existing.id);
                                    } else {
                                        const customId = 'custom_' + Math.random().toString(36).substr(2, 9);
                                        this.availableServices.push({ id: customId, name: svcName, icon: 'star' });
                                        this.formData.includedServices.push(customId);
                                    }
                                });
                                this.formData.tags = tourData.tags || [];
                                if (tourData.coverImageUrl) {
                                    this.coverImagePreview = tourData.coverImageUrl;
                                }
                                if (tourData.galleryImageUrls && tourData.galleryImageUrls.length > 0) {
                                    this.galleryItems = tourData.galleryImageUrls.map((url, index) => ({
                                        id: `existing_${index}`,
                                        preview: url,
                                        existingUrl: url,
                                        file: null
                                    }));
                                }
                            }
                        } catch(e) {
                            console.error("Failed to parse edit data", e);
                        }
                    }
                    this.restoreLocalDraft();
                    this.$nextTick(() => {
                        this.$watch('formData', () => this.queueAutosave());
                        this.$watch('coverImagePreview', () => this.markUnsaved());
                        this.$watch('galleryItems', () => this.markUnsaved());
                    });
                    window.addEventListener('beforeunload', event => {
                        if (!this.hasUnsavedChanges || this.allowNavigation) return;
                        event.preventDefault(); event.returnValue = '';
                    });
                    document.addEventListener('turbo:before-visit', event => {
                        if (!this.hasUnsavedChanges || this.allowNavigation) return;
                        event.preventDefault(); this.showCancelModal = true;
                    });
                },

                localStorageKey() { return `tripmate-tour-editor:${this.formData.id || 'new'}`; },
                restoreLocalDraft() {
                    try {
                        const raw = localStorage.getItem(this.localStorageKey());
                        if (!raw) return;
                        const saved = JSON.parse(raw);
                        if (!saved?.formData) return;
                        this.formData = { ...this.formData, ...saved.formData };
                        this.lastSavedAt = saved.savedAt ? new Date(saved.savedAt) : null;
                        showToast('info', 'Recovered your locally saved changes.');
                    } catch { localStorage.removeItem(this.localStorageKey()); }
                },
                persistLocalDraft() {
                    const savedAt = new Date().toISOString();
                    localStorage.setItem(this.localStorageKey(), JSON.stringify({ formData: JSON.parse(JSON.stringify(this.formData)), savedAt }));
                    this.lastSavedAt = new Date(savedAt);
                },
                markUnsaved() { this.hasUnsavedChanges = true; this.persistLocalDraft(); },
                queueAutosave() {
                    this.markUnsaved(); clearTimeout(this.autosaveTimer);
                    if (this.publicationStatus === 'draft') this.autosaveTimer = setTimeout(() => this.saveDraft(false), 1200);
                },
                relativeSavedTime() {
                    if (!this.lastSavedAt) return '';
                    const seconds = Math.max(0, Math.round((Date.now() - new Date(this.lastSavedAt).getTime()) / 1000));
                    return seconds < 10 ? 'just now' : seconds < 60 ? `${seconds}s ago` : `${Math.floor(seconds / 60)}m ago`;
                },
                selectedServiceNames() { return this.formData.includedServices.map(id => this.availableServices.find(service => service.id === id)?.name || id); },
                async saveDraft(notify = false) {
                    if (this.publicationStatus !== 'draft' || this.isSavingDraft) return;
                    this.isSavingDraft = true; this.saveState = 'saving';
                    try {
                        const response = await fetch('/Guide/SaveTourDraft', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({
                            id: this.formData.id || null, title: this.formData.name, city: this.formData.city, meetingPoint: this.formData.meetingPoint,
                            description: this.formData.description, durationHours: Number(this.formData.duration || 4), pricePerSession: Number(this.formData.pricePerSession || 0),
                            pricePerGuest: Number(this.formData.additionalGuestFee || 0), includedGuestCount: Number(this.formData.includedGuests || 1), maxGroupSize: Number(this.formData.maxGuests || 1),
                            includedServices: this.selectedServiceNames(), languages: this.formData.languages, tags: this.formData.tags, timeline: this.formData.timeline
                        }) });
                        const result = await response.json();
                        if (!response.ok || !result.success) throw new Error(result.message || 'The draft could not be saved.');
                        const oldKey = this.localStorageKey();
                        this.formData.id = result.data.id; this.isEdit = true; this.lastSavedAt = new Date(result.data.savedAt || Date.now()); this.saveState = 'saved'; this.hasUnsavedChanges = false;
                        if (oldKey !== this.localStorageKey()) {
                            localStorage.removeItem(oldKey); this.persistLocalDraft(); this.hasUnsavedChanges = false;
                            history.replaceState({}, '', `/Guide/CreateTour?id=${encodeURIComponent(this.formData.id)}`);
                        }
                        if (notify) showToast('success', 'Draft saved. Photos will upload when you publish.');
                    } catch (error) { this.saveState = 'error'; if (notify) showToast('error', error.message || 'The draft could not be saved.'); }
                    finally { this.isSavingDraft = false; }
                },

                nextStep() {
                    if (!this.validateStep(this.step)) return;
                    if (this.step === 2) {
                        this.formData.timeline = this.formData.timeline.filter(t => t.time.trim() !== '' || t.activity.trim() !== '');
                        this.formData.timeline.sort((a, b) => a.time.localeCompare(b.time));
                    }
                    
                    if (this.step < 4) this.step++;
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                },
                
                prevStep() {
                    if (this.step > 1) this.step--;
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                },

                addTimelineItem() {
                    this.formData.timeline.push({ time: '', activity: '' });
                },
                removeTimelineItem(index) {
                    this.formData.timeline.splice(index, 1);
                },

                fullCapacityTotal() {
                    const extraGuests = Math.max(0, Number(this.formData.maxGuests) - Number(this.formData.includedGuests));
                    return Number(this.formData.pricePerSession || 0) + extraGuests * Number(this.formData.additionalGuestFee || 0);
                },
                platformFee(total) { return Number(total || 0) * 0.15; },
                netEarnings(total) { return Number(total || 0) - this.platformFee(total); },
                formatCurrency(val) { return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val || 0); },

                validateStep(step, notify = true) {
                    let message = '';
                    let field = '';
                    if (step === 1) {
                        if ((this.formData.name || '').trim().length < 5) { message = 'Enter an experience name with at least 5 characters.'; field = 'name'; }
                        else if (!this.formData.city) { message = 'Select a city or province.'; field = 'city'; }
                        else if (!(this.formData.meetingPoint || '').trim()) { message = 'Enter a specific meeting address.'; field = 'meetingPoint'; }
                        else if (Number(this.formData.duration) < 0.5) { message = 'Duration must be at least 0.5 hours.'; field = 'duration'; }
                        else if (Number(this.formData.maxGuests) < 1) { message = 'Maximum group size must be at least one.'; field = 'maxGuests'; }
                    } else if (step === 2) {
                        if ((this.formData.description || '').trim().length < 20) message = 'Write an overview with at least 20 characters.';
                        else if (!this.formData.languages.length) message = 'Select at least one language.';
                        else if (!this.formData.timeline.some(item => item.time && item.activity)) message = 'Add at least one complete itinerary item.';
                        else if (this.formData.timeline.some(item =>
                            (item.time || item.activity) && (!item.time || !item.activity))) {
                            message = 'Enter both the time and activity for every itinerary item.';
                        }
                    } else if (step === 3) {
                        if (!this.coverImagePreview) message = 'Add a cover image before publishing.';
                    } else if (step === 4) {
                        if (Number(this.formData.pricePerSession) <= 0) message = 'Enter a base tour price greater than zero.';
                        else if (Number(this.formData.includedGuests) < 1) message = 'The base price must include at least one guest.';
                        else if (Number(this.formData.includedGuests) > Number(this.formData.maxGuests)) message = 'Included guests cannot exceed the maximum group size.';
                        else if (Number(this.formData.additionalGuestFee) < 0) message = 'Additional guest fee cannot be negative.';
                    }

                    if (notify) {
                        this.validationMessage = message;
                        this.validationField = field;
                        if (message) {
                            showToast('error', message);
                            this.$nextTick(() => (field === 'name' ? this.$refs.tourName : this.$el.querySelector('[aria-invalid="true"]'))?.focus());
                        }
                    }
                    return !message;
                },

                cancelEditing() {
                    this.showCancelModal = true;
                },

                confirmCancel() {
                    this.showCancelModal = false;
                    localStorage.removeItem(this.localStorageKey());
                    this.allowNavigation = true;
                    if (window.Turbo) Turbo.visit('/Guide/MyTours');
                    else window.location.href = '/Guide/MyTours';
                },

                addCustomService() {
                    const name = this.customServiceInput.trim();
                    if (name) {
                        const id = 'custom_' + Date.now();
                        // Add to available services with a generic star icon
                        this.availableServices.push({ id: id, name: name, icon: 'star' });
                        // Automatically select it
                        this.formData.includedServices.push(id);
                        this.customServiceInput = '';
                    }
                },

                addTag() {
                    const tag = this.tagInput.trim().toLowerCase().replace(/[^\p{L}\p{N}\s-]/gu, '').replace(/\s+/g, '-');
                    if (tag && this.formData.tags.length < 5 && !this.formData.tags.includes(tag)) {
                        this.formData.tags.push(tag);
                    }
                    this.tagInput = '';
                },
                removeTag(tagToRemove) {
                    this.formData.tags = this.formData.tags.filter(tag => tag !== tagToRemove);
                },

                formatCurrencyValue(val) {
                    if (!val && val !== 0) return '';
                    return val.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
                },
                
                parseCurrencyValue(val) {
                    if (!val) return 0;
                    return parseInt(val.toString().replace(/,/g, '')) || 0;
                },

                async submitForm() {
                    if (this.isSubmitting) return;
                    for (let targetStep = 1; targetStep <= 4; targetStep++) {
                        if (!this.validateStep(targetStep, false)) {
                            this.step = targetStep;
                            this.validateStep(targetStep, true);
                            window.scrollTo({ top: 0, behavior: 'smooth' });
                            return;
                        }
                    }

                    this.isSubmitting = true;
                    
                    try {
                        const formData = new FormData();
                        if (this.formData.id) formData.append("Id", this.formData.id);
                        formData.append("Title", this.formData.name);
                        formData.append("City", this.formData.city);
                        formData.append("MeetingPoint", this.formData.meetingPoint);
                        formData.append("Description", this.formData.description);
                        formData.append("DurationHours", this.formData.duration);
                        formData.append("PricePerSession", this.formData.pricePerSession);
                        formData.append("PricePerGuest", this.formData.additionalGuestFee);
                        formData.append("IncludedGuestCount", this.formData.includedGuests);
                        formData.append("MaxGroupSize", this.formData.maxGuests);
                        
                        formData.append("IncludedServices", JSON.stringify(this.selectedServiceNames()));
                        formData.append("Languages", JSON.stringify(this.formData.languages));
                        formData.append("Tags", JSON.stringify(this.formData.tags));
                        formData.append("TimelineJson", JSON.stringify(this.formData.timeline));
                        formData.append("RetainedGalleryImages", JSON.stringify(
                            this.galleryItems.filter(item => item.existingUrl).map(item => item.existingUrl)
                        ));

                        if (this.coverImageFile) {
                            formData.append("CoverImage", this.coverImageFile);
                        }
                        
                        this.galleryItems.filter(item => item.file).forEach((item) => {
                            formData.append("GalleryImages", item.file);
                        });

                        const response = await fetch('/Guide/CreateTour', {
                            method: 'POST',
                            body: formData
                        });

                        const result = await response.json();

                        if (result.success) {
                            localStorage.removeItem(this.localStorageKey());
                            this.hasUnsavedChanges = false;
                            this.allowNavigation = true;
                            showToast('success', result.message || (this.isEdit ? 'Your changes have been saved.' : 'Your experience package has been published.'));
                            setTimeout(() => { 
                                if (window.Turbo) Turbo.visit('/Guide/MyTours');
                                else window.location.href = '/Guide/MyTours';
                            }, 1500);
                        } else {
                            showToast('error', result.message || 'An error occurred while saving.');
                        }
                    } catch (error) {
                        showToast('error', 'System error. Please try again later.');
                        console.error(error);
                    } finally {
                        this.isSubmitting = false;
                    }
                }
            }
        }
    </script>
}
