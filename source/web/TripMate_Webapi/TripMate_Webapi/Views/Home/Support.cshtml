@{
    ViewData["Title"] = "Support";
    Layout = "~/Views/Shared/_LandingLayout.cshtml";
}

<div class="bg-brand-cream text-brand-dark min-h-screen">
    <!-- Header Section -->
    <section class="py-20 px-8 md:px-16 max-w-[800px] mx-auto text-center">
        <span class="text-brand-orange font-bold text-xs tracking-[0.2em] uppercase mb-4 block">WE ARE HERE FOR YOU</span>
        <h1 class="font-serif-custom text-5xl md:text-6xl font-semibold leading-tight mb-8">
            How can we help?
        </h1>
        
        <!-- Search Box -->
        <div class="relative max-w-xl mx-auto">
            <input type="text" placeholder="Search for articles, guides, or FAQ..." class="w-full bg-white border border-outline-variant/50 rounded-full px-8 py-4 text-brand-dark shadow-sm focus:ring-2 focus:ring-brand-orange focus:border-transparent outline-none">
            <button class="absolute right-2 top-2 bottom-2 bg-brand-orange text-white px-6 rounded-full font-bold hover:bg-brand-dark transition-colors">
                Search
            </button>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-16 px-8 md:px-16 max-w-[1000px] mx-auto">
        <h2 class="text-3xl font-serif-custom font-bold mb-10 border-b border-cream-dark pb-4">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-cream-dark">
                <h3 class="text-xl font-bold mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-brand-orange" style="font-variation-settings: 'FILL' 1;">verified</span>
                    How are guides verified?
                </h3>
                <p class="text-brand-dark/70 leading-relaxed">
                    Every TripMate guide goes through a rigorous 3-step verification process including identity checks, in-person interviews, and a trial tour. We ensure they not only have deep local knowledge but also the storytelling skills to make your trip unforgettable.
                </p>
            </div>

            <div class="bg-white p-8 rounded-2xl shadow-sm border border-cream-dark">
                <h3 class="text-xl font-bold mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-brand-orange" style="font-variation-settings: 'FILL' 1;">payments</span>
                    Are payments secure?
                </h3>
                <p class="text-brand-dark/70 leading-relaxed">
                    Yes. All payments are securely processed through our encrypted gateway. Your funds are held securely and only released to the guide after a successful tour, ensuring 100% peace of mind.
                </p>
            </div>

            <div class="bg-white p-8 rounded-2xl shadow-sm border border-cream-dark">
                <h3 class="text-xl font-bold mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-brand-orange" style="font-variation-settings: 'FILL' 1;">cancel</span>
                    What is the cancellation policy?
                </h3>
                <p class="text-brand-dark/70 leading-relaxed">
                    You can cancel for a full refund up to 48 hours before your scheduled tour. For cancellations within 48 hours, a 50% fee applies to compensate our guides for their reserved time.
                </p>
            </div>
        </div>

        <!-- Contact Support -->
        <div class="mt-20 bg-[#1a1511] text-white rounded-3xl p-12 text-center relative overflow-hidden">
            <div class="relative z-10">
                <h3 class="text-3xl font-serif-custom mb-4">Still need help?</h3>
                <p class="text-white/70 mb-8 max-w-lg mx-auto">Our dedicated support team in Vietnam is available 24/7 to assist you with any questions or emergencies.</p>
                <div class="flex justify-center gap-6">
                    <a href="mailto:support@tripmate.vn" class="bg-white text-brand-dark px-8 py-3 rounded-full font-bold hover:bg-brand-orange hover:text-white transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined">mail</span> Email Us
                    </a>
                    <button class="border border-white/30 text-white px-8 py-3 rounded-full font-bold hover:bg-white/10 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined">chat</span> Live Chat
                    </button>
                </div>
            </div>
        </div>
    </section>
</div>
