@model TripMate_Webapi.Controllers.HomeViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Cinematic Hero Section -->
<section class="relative h-[800px] w-full overflow-hidden">
    <div class="absolute inset-0">
        <img alt="Vietnam landscape" class="w-full h-full object-cover" 
             src="https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=1920"/>
        <div class="absolute inset-0 hero-gradient"></div>
    </div>
    <div class="relative h-full flex flex-col items-center justify-center px-12 max-w-[1440px] mx-auto text-center">
        <h1 class="text-7xl font-extrabold text-white mb-8 drop-shadow-2xl">
            Khám Phá Việt Nam
        </h1>
        <!-- Search Bar -->
        <div class="glass-search w-full max-w-4xl p-2 rounded-xl flex items-center shadow-2xl mt-8 border border-white/20">
            <div class="flex-1 px-6 border-r border-outline-variant/30 text-left">
                <label class="block text-xs font-bold text-on-surface-variant mb-1">ĐỊA ĐIỂM</label>
                <input class="w-full bg-transparent border-none p-0 text-on-surface focus:ring-0 placeholder:text-outline/60" 
                       placeholder="Bạn muốn đi đâu?" type="text"/>
            </div>
            <div class="flex-1 px-6 border-r border-outline-variant/30 text-left">
                <label class="block text-xs font-bold text-on-surface-variant mb-1">NGÀY</label>
                <input class="w-full bg-transparent border-none p-0 text-on-surface focus:ring-0 placeholder:text-outline/60" 
                       placeholder="Chọn ngày" type="text"/>
            </div>
            <div class="flex-1 px-6 text-left">
                <label class="block text-xs font-bold text-on-surface-variant mb-1">KHÁCH</label>
                <input class="w-full bg-transparent border-none p-0 text-on-surface focus:ring-0 placeholder:text-outline/60" 
                       placeholder="Số người" type="text"/>
            </div>
            <button class="bg-primary hover:bg-primary/90 text-on-primary w-14 h-14 rounded-lg flex items-center justify-center transition-all shadow-lg">
                <span class="material-symbols-outlined">search</span>
            </button>
        </div>
    </div>
</section>

<!-- Category Section -->
<section class="py-12 px-12 max-w-[1440px] mx-auto border-b border-surface-variant">
    <div class="flex items-center justify-center gap-8 overflow-x-auto">
        <div class="flex flex-col items-center gap-2 cursor-pointer border-b-2 border-primary pb-3 px-4">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">beach_access</span>
            <span class="text-sm font-bold text-on-surface">Biển</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer opacity-60 hover:opacity-100 transition-opacity px-4 pb-3">
            <span class="material-symbols-outlined text-on-surface-variant">landscape</span>
            <span class="text-sm font-semibold text-on-surface-variant">Núi</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer opacity-60 hover:opacity-100 transition-opacity px-4 pb-3">
            <span class="material-symbols-outlined text-on-surface-variant">apartment</span>
            <span class="text-sm font-semibold text-on-surface-variant">Thành phố</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer opacity-60 hover:opacity-100 transition-opacity px-4 pb-3">
            <span class="material-symbols-outlined text-on-surface-variant">castle</span>
            <span class="text-sm font-semibold text-on-surface-variant">Lịch sử</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer opacity-60 hover:opacity-100 transition-opacity px-4 pb-3">
            <span class="material-symbols-outlined text-on-surface-variant">restaurant</span>
            <span class="text-sm font-semibold text-on-surface-variant">Ẩm thực</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer opacity-60 hover:opacity-100 transition-opacity px-4 pb-3">
            <span class="material-symbols-outlined text-on-surface-variant">spa</span>
            <span class="text-sm font-semibold text-on-surface-variant">Nghỉ dưỡng</span>
        </div>
    </div>
</section>

<!-- Top Journeys Section -->
<section class="py-16 px-12 max-w-[1440px] mx-auto">
    <div class="flex justify-between items-end mb-8">
        <div>
            <h2 class="text-5xl font-bold text-on-surface mb-2">Tour Nổi Bật</h2>
            <p class="text-lg text-on-surface-variant">Những trải nghiệm được lựa chọn kỹ lưỡng cho bạn.</p>
        </div>
        <button class="text-primary text-sm font-bold flex items-center gap-2 hover:gap-3 transition-all group">
            Xem tất cả <span class="material-symbols-outlined">arrow_forward</span>
        </button>
    </div>
    <div class="grid grid-cols-12 gap-8">
        @if (Model.FeaturedTours != null && Model.FeaturedTours.Any())
        {
            var firstTour = Model.FeaturedTours.First();
            <!-- Large Card -->
            <div class="col-span-8 relative h-[500px] rounded-xl overflow-hidden group cursor-pointer tonal-elevation">
                <img alt="@firstTour.Title" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" 
                     src="@(firstTour.Images?.FirstOrDefault() ?? "https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?w=1200")"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>
                <div class="absolute bottom-0 left-0 p-8">
                    <span class="bg-primary text-on-primary text-xs px-4 py-1.5 rounded-full mb-3 inline-block font-bold shadow-lg">PHỔ BIẾN</span>
                    <h3 class="text-4xl font-bold text-white mb-1">@firstTour.Title</h3>
                    <p class="text-white/90 text-lg">@firstTour.Location</p>
                </div>
            </div>

            @if (Model.FeaturedTours.Count > 1)
            {
                var secondTour = Model.FeaturedTours[1];
                <!-- Vertical Card -->
                <div class="col-span-4 relative h-[500px] rounded-xl overflow-hidden group cursor-pointer tonal-elevation">
                    <img alt="@secondTour.Title" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" 
                         src="@(secondTour.Images?.FirstOrDefault() ?? "https://images.unsplash.com/photo-1555400038-63f5ba517a47?w=800")"/>
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>
                    <div class="absolute bottom-0 left-0 p-8">
                        <h3 class="text-3xl font-bold text-white mb-1">@secondTour.Title</h3>
                        <p class="text-white/90">@secondTour.Location</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-span-12 text-center py-12 text-on-surface-variant">
                Chưa có tour nào
            </div>
        }
    </div>
</section>

<!-- Curated Stays Section -->
<section class="py-16 bg-surface-variant">
    <div class="px-12 max-w-[1440px] mx-auto">
        <div class="flex justify-between items-end mb-8">
            <div>
                <h2 class="text-5xl font-bold text-on-surface mb-2">Tour Được Tuyển Chọn</h2>
                <p class="text-lg text-on-surface-variant">Những tour được đánh giá cao nhất.</p>
            </div>
        </div>
        <div class="grid grid-cols-4 gap-8">
            @if (Model.CuratedStays != null && Model.CuratedStays.Any())
            {
                @foreach (var tour in Model.CuratedStays)
                {
                    <div class="bg-surface rounded-xl overflow-hidden tonal-elevation group cursor-pointer hover:-translate-y-2 transition-all duration-500">
                        <div class="h-64 relative overflow-hidden">
                            <img alt="@tour.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                                 src="@(tour.Images?.FirstOrDefault() ?? "https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=800")"/>
                            <button class="absolute top-4 right-4 bg-black/20 hover:bg-primary backdrop-blur-md p-2.5 rounded-full transition-all">
                                <span class="material-symbols-outlined text-white">favorite</span>
                            </button>
                        </div>
                        <div class="p-6">
                            <div class="flex justify-between items-start mb-2">
                                <h4 class="text-xl font-bold text-on-surface">@tour.Title</h4>
                                <div class="flex items-center gap-1 bg-primary-container px-2 py-0.5 rounded-md">
                                    <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                                    <span class="text-sm font-bold text-on-primary-container">@tour.Rating.ToString("F1")</span>
                                </div>
                            </div>
                            <p class="text-on-surface-variant mb-6">@tour.Location</p>
                            <div class="flex justify-between items-center pt-5 border-t border-outline-variant/30">
                                <p class="text-on-surface">
                                    <span class="text-2xl font-extrabold text-primary">@tour.Price.ToString("N0")₫</span>
                                    <span class="text-on-surface-variant font-medium">/ người</span>
                                </p>
                                <span class="material-symbols-outlined text-primary font-bold">arrow_forward</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-4 text-center py-12 text-on-surface-variant">
                    Chưa có tour nào
                </div>
            }
        </div>
    </div>
</section>
