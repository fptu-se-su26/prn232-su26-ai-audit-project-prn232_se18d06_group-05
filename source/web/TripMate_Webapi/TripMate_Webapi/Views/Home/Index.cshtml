@model TripMate_Webapi.Controllers.HomeViewModel
@{
    ViewData["Title"] = "TripMate - Authentic Local Experiences";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-surface min-h-screen font-sans" x-data="travelerHome()">
    
    <!-- Hero Section with AI & Trust Combined -->
    <section class="relative min-h-[600px] flex items-center overflow-hidden py-24">
        <!-- Background Image with Parallax effect -->
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1504457047772-27faf1c00561?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Vietnam Landscape" class="w-full h-full object-cover animate-ken-burns" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/40"></div>
        </div>

        <div class="relative z-10 w-full max-w-[1440px] mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Left: AI Matchmaker -->
            <div class="flex flex-col items-start text-left">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-6 animate-fade-in-up shadow-lg">
                    <span class="material-symbols-outlined text-primary text-sm animate-pulse">auto_awesome</span>
                    <span class="text-white text-sm font-bold tracking-wide uppercase">TripMate AI Matchmaker</span>
                </div>
                
                <h1 class="text-6xl md:text-7xl font-extrabold text-white mb-6 leading-tight drop-shadow-2xl animate-fade-in-up animation-delay-100 tracking-tighter">
                    Find your soulmate<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-orange-400">Local Guide.</span>
                </h1>
                <p class="text-white/90 text-xl mb-10 max-w-xl font-medium drop-shadow-md animate-fade-in-up animation-delay-200 leading-relaxed">
                    Stop endlessly browsing. Take a 2-minute survey and let our AI pair you with local experts who perfectly match your travel vibe.
                </p>

                <a href="/Survey/Index" class="bg-primary hover:bg-primary/90 text-white px-10 py-5 rounded-full flex items-center justify-center font-bold text-lg transition-all duration-300 shadow-[0_10px_40px_rgba(255,122,0,0.4)] hover:shadow-[0_15px_50px_rgba(255,122,0,0.6)] hover:-translate-y-2 animate-fade-in-up animation-delay-300">
                    <span class="material-symbols-outlined mr-2">magic_button</span> Try AI Matchmaker
                </a>
            </div>

            <!-- Right: Trust & Security -->
            <div class="animate-fade-in-up animation-delay-300">
                <div class="bg-white/10 backdrop-blur-md border border-white/20 p-8 md:p-10 rounded-3xl text-white shadow-2xl">
                    <h3 class="text-2xl font-bold mb-8 flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary">shield_locked</span> Why TripMate?
                    </h3>
                    <ul class="space-y-8">
                        <li class="flex items-start gap-5">
                            <div class="w-12 h-12 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center flex-shrink-0 border border-green-500/30">
                                <span class="material-symbols-outlined">verified_user</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-xl mb-1">100% Verified Locals</h4>
                                <p class="text-white/80 leading-relaxed">Strict identity verification, background checks, and interviews for your safety.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-5">
                            <div class="w-12 h-12 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center flex-shrink-0 border border-blue-500/30">
                                <span class="material-symbols-outlined">gpp_good</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-xl mb-1">Secure Escrow Payments</h4>
                                <p class="text-white/80 leading-relaxed">Your money is held safely in escrow until your tour is successfully completed.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-5">
                            <div class="w-12 h-12 rounded-full bg-purple-500/20 text-purple-400 flex items-center justify-center flex-shrink-0 border border-purple-500/30">
                                <span class="material-symbols-outlined">draw</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-xl mb-1">Custom Itineraries</h4>
                                <p class="text-white/80 leading-relaxed">No rigid schedules. Co-create the perfect trip directly via chat with your guide.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- AI Survey Call to Action (The core USP) -->
    <section class="py-12 bg-white">
        <div class="max-w-[1200px] mx-auto px-6">
            <div class="flex justify-between items-end mb-10 border-b border-outline-variant/20 pb-4">
                <div>
                    <h2 class="text-3xl font-extrabold text-on-surface mb-2">Meet Popular Local Experts</h2>
                    <p class="text-on-surface-variant text-lg">Highly rated guides ready to show you their world.</p>
                </div>
                <a href="/Home/Explore" class="hidden md:flex text-primary font-bold items-center gap-1 hover:underline bg-primary/5 px-4 py-2 rounded-lg transition-colors hover:bg-primary/10">
                    See all guides <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @if (Model != null && Model.PopularGuides != null && Model.PopularGuides.Any())
                {
                    foreach (var guide in Model.PopularGuides)
                    {
                        <a href="/Traveler/GuideProfile/@guide.Id" class="bg-surface rounded-2xl overflow-hidden shadow-sm border border-outline-variant/30 group hover:shadow-xl transition-all duration-300 relative flex flex-col hover:-translate-y-1">
                            <button @@click.prevent="toggleSave('@guide.Id')" class="absolute top-3 right-3 z-10 w-10 h-10 rounded-full bg-white/80 backdrop-blur-md flex items-center justify-center hover:bg-white transition-colors shadow-sm">
                                <span class="material-symbols-outlined" :class="savedGuides.includes('@guide.Id') ? 'text-red-500 fill-current' : 'text-gray-400'">favorite</span>
                            </button>
                            <div class="h-56 overflow-hidden relative">
                                <img src="@(string.IsNullOrEmpty(guide.CoverPhotoUrl) ? "/images/halong.jpg" : guide.CoverPhotoUrl)" alt="Cover" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
                                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                                
                                <!-- Floating Avatar -->
                                <div class="absolute top-4 left-4 z-10 w-14 h-14 rounded-full border-2 border-white overflow-hidden shadow-lg">
                                    <img src="@(string.IsNullOrEmpty(guide.Profile?.AvatarUrl) ? "/images/default_avatar.png" : guide.Profile.AvatarUrl)" alt="@guide.Profile?.FullName" class="w-full h-full object-cover"/>
                                </div>
                                
                                <div class="absolute bottom-0 left-0 right-0 p-4 pt-12 z-10">
                                    <h3 class="text-xl font-bold text-white mb-1">@(guide.Profile?.FullName ?? "Unknown Guide")</h3>
                                    <p class="text-sm text-white/90 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">location_on</span> @guide.CityArea</p>
                                </div>
                            </div>
                            <div class="p-5 flex-1 flex flex-col">
                                <div class="flex justify-between items-center mb-3">
                                    <div class="flex items-center gap-1 text-sm font-bold text-on-surface">
                                        <span class="material-symbols-outlined text-[18px] text-yellow-500 fill-current">star</span> @(guide.AverageRating?.ToString("0.0") ?? "0.0") <span class="text-on-surface-variant font-normal">(@(guide.TotalReviews ?? 0))</span>
                                    </div>
                                    <div class="text-primary font-bold bg-primary/10 px-2 py-1 rounded text-sm">₫@(guide.PricePerHour?.ToString("#,##0") ?? "0")/h</div>
                                </div>
                                <p class="text-sm text-on-surface-variant italic mb-4 line-clamp-2">"@guide.Bio"</p>
                                <div class="flex flex-wrap gap-2 mt-auto">
                                    @if (guide.Specialties != null)
                                    {
                                        foreach (var spec in guide.Specialties.Take(2))
                                        {
                                            <span class="px-2 py-1 bg-surface-variant text-on-surface-variant text-[10px] rounded font-semibold uppercase tracking-wider">@spec</span>
                                        }
                                    }
                                </div>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="col-span-full text-center text-on-surface-variant py-10">
                        No popular guides available at the moment.
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Featured Tours Section -->
    <section class="py-16 bg-white">
        <div class="max-w-[1200px] mx-auto px-6">
            <div class="flex justify-between items-end mb-10 border-b border-outline-variant/20 pb-4">
                <div>
                    <h2 class="text-3xl font-extrabold text-on-surface mb-2">Popular Tours</h2>
                    <p class="text-on-surface-variant text-lg">Handcrafted experiences by local experts.</p>
                </div>
                <a href="/Home/Tours" class="hidden md:flex text-primary font-bold items-center gap-1 hover:underline bg-primary/5 px-4 py-2 rounded-lg transition-colors hover:bg-primary/10">
                    Browse all tours <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                @if (Model?.AllTours != null && Model.AllTours.Any())
                {
                    foreach (var tour in Model.AllTours.Take(4))
                    {
                        var guideName = tour.GuideProfile?.Profile?.FullName ?? "Local Guide";
                        var guideCover = tour.GuideProfile?.CoverPhotoUrl ?? "";
                        var guideAvatar = tour.GuideProfile?.Profile?.AvatarUrl ?? "";
                        var guideCity = tour.GuideProfile?.CityArea ?? "Vietnam";
                        var guideProfileId = tour.GuideProfileId ?? "";

                        <div style="cursor: pointer;" @@click="openTourModal('@System.Web.HttpUtility.JavaScriptStringEncode(tour.Id ?? "")', '@System.Web.HttpUtility.JavaScriptStringEncode(tour.Title ?? "")', `@System.Web.HttpUtility.JavaScriptStringEncode(tour.Description ?? "")`, @tour.DurationHours, @tour.PricePerSession, @(tour.PricePerPerson ?? 0), @tour.MaxGroupSize, '@System.Web.HttpUtility.JavaScriptStringEncode(string.Join(",", tour.IncludedItems ?? new List<string>()))', '@System.Web.HttpUtility.JavaScriptStringEncode(guideName)', '@System.Web.HttpUtility.JavaScriptStringEncode(guideAvatar)', '@System.Web.HttpUtility.JavaScriptStringEncode(guideProfileId)')" class="bg-surface rounded-2xl overflow-hidden shadow-sm border border-outline-variant/30 group hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col">
                            <div class="h-44 overflow-hidden relative">
                                @if (!string.IsNullOrEmpty(guideCover))
                                {
                                    <img src="@guideCover" alt="@tour.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
                                }
                                else
                                {
                                    <div class="w-full h-full bg-gradient-to-br from-primary-container to-surface-variant flex items-center justify-center">
                                        <span class="material-symbols-outlined text-5xl text-primary/30">landscape</span>
                                    </div>
                                }
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-2 py-0.5 rounded-full text-[11px] font-bold text-primary">
                                    @tour.DurationHours hrs
                                </div>
                                <div class="absolute bottom-3 left-3 flex items-center gap-2 z-10" @@click.stop="window.location.href='/Traveler/GuideProfile/@guideProfileId'">
                                    <div class="w-7 h-7 rounded-full border border-white overflow-hidden bg-gray-200">
                                        @if (!string.IsNullOrEmpty(guideAvatar))
                                        {
                                            <img src="@guideAvatar" class="w-full h-full object-cover" />
                                        }
                                    </div>
                                    <span class="text-white text-xs font-bold drop-shadow hover:underline">@guideName</span>
                                </div>
                            </div>
                            <div class="p-4 flex-1 flex flex-col">
                                <h3 class="font-bold text-on-surface mb-1 line-clamp-1 group-hover:text-primary transition-colors">@tour.Title</h3>
                                <p class="text-on-surface-variant text-xs line-clamp-2 mb-3">@tour.Description</p>
                                <div class="mt-auto flex items-center justify-between">
                                    <span class="text-primary font-bold text-sm">
                                        @(tour.PricePerSession > 0 ? string.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:C0}", tour.PricePerSession) : "Contact")
                                    </span>
                                    <span class="text-xs text-on-surface-variant flex items-center gap-0.5"><span class="material-symbols-outlined text-[12px]">location_on</span> @guideCity</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-span-full text-center text-on-surface-variant py-10">
                        No tours available at the moment.
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Popular Destinations Section -->
    <section class="py-16 px-6 max-w-[1200px] mx-auto">
        <div class="flex justify-between items-end mb-10 border-b border-outline-variant/20 pb-4">
            <div>
                <h2 class="text-3xl font-extrabold text-on-surface mb-2">Explore Destinations</h2>
                <p class="text-on-surface-variant text-lg">Top spots for private, tailored tours.</p>
            </div>
            <a href="/Home/Destinations" class="hidden md:flex text-primary font-bold items-center gap-1 hover:underline bg-primary/5 px-4 py-2 rounded-lg transition-colors hover:bg-primary/10">
                View all destinations <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Destination Card 1 -->
            <a href="/Home/Explore?destination=Ha Long Bay, Vietnam" class="group relative rounded-2xl overflow-hidden aspect-square shadow-md hover:shadow-xl transition-all">
                <img src="/images/halong.jpg" alt="Ha Long Bay" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-6 left-6 right-6">
                    <h3 class="text-2xl font-bold text-white mb-1">Ha Long Bay</h3>
                    <p class="text-white/80 text-sm font-medium">120+ Guides</p>
                </div>
            </a>

            <!-- Destination Card 2 -->
            <a href="/Home/Explore?destination=Hoi An, Vietnam" class="group relative rounded-2xl overflow-hidden aspect-square shadow-md hover:shadow-xl transition-all">
                <img src="/images/hoian.png" alt="Hoi An" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-6 left-6 right-6">
                    <h3 class="text-2xl font-bold text-white mb-1">Hoi An</h3>
                    <p class="text-white/80 text-sm font-medium">85+ Guides</p>
                </div>
            </a>
            
            <!-- Destination Card 3 -->
            <a href="/Home/Explore?destination=Sapa, Vietnam" class="group relative rounded-2xl overflow-hidden aspect-square shadow-md hover:shadow-xl transition-all">
                <img src="/images/sapa.png" alt="Sapa" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-6 left-6 right-6">
                    <h3 class="text-2xl font-bold text-white mb-1">Sapa</h3>
                    <p class="text-white/80 text-sm font-medium">94+ Guides</p>
                </div>
            </a>
            
            <!-- Destination Card 4 -->
            <a href="/Home/Explore?destination=Phu Quoc, Vietnam" class="group relative rounded-2xl overflow-hidden aspect-square shadow-md hover:shadow-xl transition-all">
                <img src="/images/phuquoc_new.png" alt="Phu Quoc" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-6 left-6 right-6">
                    <h3 class="text-2xl font-bold text-white mb-1">Phu Quoc</h3>
                    <p class="text-white/80 text-sm font-medium">60+ Guides</p>
                </div>
            </a>
        </div>
        <div class="text-center mt-8 md:hidden">
            <a href="/Home/Destinations" class="text-primary font-bold hover:underline">View all destinations →</a>
        </div>
    </section>

    <!-- How it works -->
    <section id="how-it-works" class="py-20 bg-primary-container text-on-primary-container relative overflow-hidden">
        <div class="max-w-[1200px] mx-auto px-6 relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-extrabold mb-4">How TripMate Works</h2>
                <p class="text-lg opacity-80 max-w-2xl mx-auto">Your personalized journey starts with a simple conversation.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="text-center flex flex-col items-center">
                    <div class="w-16 h-16 rounded-2xl bg-primary text-white flex items-center justify-center text-2xl font-bold mb-6 shadow-lg shadow-primary/30">1</div>
                    <h3 class="text-xl font-bold mb-3">AI Survey</h3>
                    <p class="opacity-80 text-sm">Tell us your vibes and preferences in a quick 2-minute test.</p>
                </div>
                <div class="text-center flex flex-col items-center">
                    <div class="w-16 h-16 rounded-2xl bg-white text-primary flex items-center justify-center text-2xl font-bold mb-6 shadow-lg">2</div>
                    <h3 class="text-xl font-bold mb-3">Get Matched</h3>
                    <p class="opacity-80 text-sm">Our AI connects you with highly compatible local experts.</p>
                </div>
                <div class="text-center flex flex-col items-center">
                    <div class="w-16 h-16 rounded-2xl bg-white text-primary flex items-center justify-center text-2xl font-bold mb-6 shadow-lg">3</div>
                    <h3 class="text-xl font-bold mb-3">Customize</h3>
                    <p class="opacity-80 text-sm">Chat with your guide and co-create your perfect schedule.</p>
                </div>
                <div class="text-center flex flex-col items-center">
                    <div class="w-16 h-16 rounded-2xl bg-white text-primary flex items-center justify-center text-2xl font-bold mb-6 shadow-lg">4</div>
                    <h3 class="text-xl font-bold mb-3">Travel</h3>
                    <p class="opacity-80 text-sm">Experience the destination authentically and securely.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Recent Bookings / Reviews -->
    <section class="py-20 bg-surface">
        <div class="max-w-[1200px] mx-auto px-6">
            <h2 class="text-3xl font-extrabold text-center text-on-surface mb-16">Traveler Stories</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Review 1 -->
                <div class="bg-white rounded-3xl shadow-lg border border-outline-variant/20 p-8 relative pt-12 mt-8">
                    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" class="w-20 h-20 rounded-full border-4 border-white absolute -top-10 left-8 object-cover shadow-md" />
                    <div class="flex text-yellow-500 mb-4">
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                    </div>
                    <p class="text-on-surface-variant text-base italic mb-6 leading-relaxed">"Mai was an incredible guide! The AI matched us perfectly based on our love for street food. She took us to the best Banh Mi spot that no tourist knows about."</p>
                    <div>
                        <p class="text-on-surface font-bold">Sarah Jenkins</p>
                        <p class="text-sm text-primary font-medium">Traveled to Hoi An</p>
                    </div>
                </div>

                <!-- Review 2 -->
                <div class="bg-white rounded-3xl shadow-lg border border-outline-variant/20 p-8 relative pt-12 mt-8 md:-translate-y-8">
                    <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" class="w-20 h-20 rounded-full border-4 border-white absolute -top-10 left-8 object-cover shadow-md" />
                    <div class="flex text-yellow-500 mb-4">
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                    </div>
                    <p class="text-on-surface-variant text-base italic mb-6 leading-relaxed">"Minh organized a private boat for us in Phu Quoc. The snorkeling was out of this world. TripMate made finding a trustworthy guide so easy."</p>
                    <div>
                        <p class="text-on-surface font-bold">David Chen</p>
                        <p class="text-sm text-primary font-medium">Traveled to Phu Quoc</p>
                    </div>
                </div>

                <!-- Review 3 -->
                <div class="bg-white rounded-3xl shadow-lg border border-outline-variant/20 p-8 relative pt-12 mt-8">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" class="w-20 h-20 rounded-full border-4 border-white absolute -top-10 left-8 object-cover shadow-md" />
                    <div class="flex text-yellow-500 mb-4">
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star</i>
                        <i class="material-symbols-outlined fill-current">star_half</i>
                    </div>
                    <p class="text-on-surface-variant text-base italic mb-6 leading-relaxed">"Tuan was so patient during our trek in Sapa. He shared amazing stories about the local tribes. A truly authentic experience."</p>
                    <div>
                        <p class="text-on-surface font-bold">Jessica Alba</p>
                        <p class="text-sm text-primary font-medium">Traveled to Sapa</p>
                    </div>
                </div>
            </div>
        </div>
        </div>
    </section>

    <!-- Tour Detail Modal -->
    <div x-show="showModal" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center p-4" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <!-- Background Overlay -->
        <div x-show="showModal" x-transition:enter="ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 bg-black/60 backdrop-blur-sm" @@click="showModal = false"></div>

            <!-- Modal Panel -->
            <div x-show="showModal" 
                 x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100" 
                 x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95" 
                 class="relative bg-surface rounded-3xl text-left overflow-hidden shadow-2xl transform transition-all max-w-2xl w-full max-h-[90vh] overflow-y-auto border border-white/20 z-10">
                
                <!-- Modal Header -->
                <div class="bg-primary/5 px-6 py-4 md:px-8 md:py-6 border-b border-outline-variant/30 flex justify-between items-start">
                    <div>
                        <h2 class="text-2xl md:text-3xl font-extrabold text-on-surface" x-text="modal.title"></h2>
                    </div>
                    <button @@click="showModal = false" class="text-on-surface-variant hover:text-red-500 transition-colors bg-white rounded-full p-1 shadow-sm border border-outline-variant/20">
                        <span class="material-symbols-outlined block">close</span>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6 md:p-8 space-y-6">
                    <div class="flex flex-wrap gap-4">
                        <div class="flex items-center gap-2 bg-primary-container/50 px-4 py-2 rounded-xl">
                            <span class="material-symbols-outlined text-primary text-sm">schedule</span>
                            <span class="font-bold text-sm" x-text="modal.duration + ' hours'"></span>
                        </div>
                        <div class="flex items-center gap-2 bg-surface-variant px-4 py-2 rounded-xl">
                            <span class="material-symbols-outlined text-on-surface-variant text-sm">group</span>
                            <span class="font-bold text-sm" x-text="'Max ' + modal.maxGroup + ' people'"></span>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-lg font-bold text-on-surface mb-3 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-xl">route</span> Tour Description
                        </h3>
                        <p class="text-on-surface-variant leading-relaxed whitespace-pre-line" x-text="modal.description"></p>
                    </div>

                    <div x-show="modal.includedItems.length > 0">
                        <h3 class="text-lg font-bold text-on-surface mb-3 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-xl">check_circle</span> What's Included
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                            <template x-for="item in modal.includedItems" :key="item">
                                <div class="flex items-center gap-2 bg-green-50 border border-green-100 px-3 py-2 rounded-lg">
                                    <span class="material-symbols-outlined text-green-600 text-sm">check</span>
                                    <span class="text-sm text-green-800 font-medium" x-text="item"></span>
                                </div>
                            </template>
                        </div>
                    </div>

                    <!-- Guide Info -->
                    <a :href="'/Traveler/GuideProfile/' + modal.guideId" class="bg-surface-variant/50 rounded-2xl p-5 flex items-center gap-4 hover:bg-surface-variant transition-colors group/guide">
                        <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-primary/20 shrink-0 bg-gray-100">
                            <img x-show="modal.guideAvatar" :src="modal.guideAvatar" class="w-full h-full object-cover" />
                            <span x-show="!modal.guideAvatar" class="material-symbols-outlined text-3xl text-gray-400 mt-2 block text-center">person</span>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-on-surface-variant">Created by</p>
                            <p class="font-bold text-on-surface text-lg group-hover/guide:text-primary transition-colors" x-text="modal.guideName"></p>
                        </div>
                        <span class="material-symbols-outlined text-on-surface-variant group-hover/guide:text-primary transition-colors">arrow_forward</span>
                    </a>

                    <!-- Price & Book -->
                    <div class="bg-white border-2 border-primary/30 rounded-2xl p-6 flex items-center justify-between">
                        <div>
                            <p class="text-sm text-on-surface-variant">Price</p>
                            <p class="text-3xl font-extrabold text-primary" x-text="modal.priceLabel"></p>
                        </div>
                        <button @@click="bookTour(modal.id, modal.guideId)"
                                class="bg-primary hover:bg-primary/90 text-white px-8 py-4 rounded-xl font-bold text-lg flex items-center gap-2 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">
                            <span class="material-symbols-outlined">lock</span>
                            Book This Tour
                        </button>
                    </div>
                </div>
        </div>
    </div>
</div>

<style>
    @@keyframes ken-burns {
        0% { transform: scale(1); }
        100% { transform: scale(1.05); }
    }
    .animate-ken-burns {
        animation: ken-burns 20s ease-in-out infinite alternate;
    }
    
    @@keyframes fade-in-up {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
        opacity: 0;
    }
    .animation-delay-100 { animation-delay: 100ms; }
    .animation-delay-200 { animation-delay: 200ms; }
    .animation-delay-300 { animation-delay: 300ms; }
</style>

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('travelerHome', () => ({
            savedGuides: [], 
            showModal: false,
            bookingInProgress: false,
            modal: {
                id: '', title: '', description: '', duration: 0,
                pricePerSession: 0, pricePerPerson: 0, maxGroup: 6,
                includedItems: [], priceLabel: '',
                guideName: '', guideAvatar: '', guideId: ''
            },

            toggleSave(id) {
                if(this.savedGuides.includes(id)) {
                    this.savedGuides = this.savedGuides.filter(g => g !== id);
                } else {
                    this.savedGuides.push(id);
                }
            },

            openTourModal(id, title, description, duration, pricePerSession, pricePerPerson, maxGroup, includedItemsStr, guideName, guideAvatar, guideId) {
                this.modal.id = id;
                this.modal.title = title;
                this.modal.description = description;
                this.modal.duration = duration;
                this.modal.pricePerSession = pricePerSession;
                this.modal.pricePerPerson = pricePerPerson;
                this.modal.maxGroup = maxGroup;
                this.modal.includedItems = includedItemsStr ? includedItemsStr.split(',').map(s => s.trim()).filter(s => s) : [];
                this.modal.guideName = guideName || 'Local Guide';
                this.modal.guideAvatar = guideAvatar || '';
                this.modal.guideId = guideId || '';

                const fmt = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 });
                this.modal.priceLabel = pricePerSession > 0
                    ? fmt.format(pricePerSession) + '/session'
                    : (pricePerPerson > 0 ? fmt.format(pricePerPerson) + '/person' : 'Contact');

                this.showModal = true;
            },

            async bookTour(packageId, guideId) {
                const token = localStorage.getItem('accessToken');
                if (!token) {
                    window.location.href = '/Auth/Login?returnUrl=' + encodeURIComponent(window.location.href);
                    return;
                }
                if (this.bookingInProgress) return;
                this.bookingInProgress = true;

                try {
                    const formData = new FormData();
                    formData.append('guideId', guideId);
                    formData.append('packageId', packageId);
                    formData.append('date', new Date(Date.now() + 7 * 86400000).toISOString().split('T')[0]);
                    formData.append('guests', '1');

                    const res = await fetch('/Traveler/BookTour', {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token },
                        body: formData
                    });

                    if (res.ok) {
                        const data = await res.json();
                        if (data.paymentUrl) {
                            window.location.href = data.paymentUrl;
                            return;
                        }
                    } else if (res.status === 400) {
                        const errorData = await res.json();
                        Swal.fire({ title: 'Notice', text: errorData.error || 'Booking failed.', icon: 'info', customClass: { popup: 'swal-top-fix' } });
                    } else {
                        Swal.fire({ title: 'Error', text: 'Booking failed. Please try again.', icon: 'error', customClass: { popup: 'swal-top-fix' } });
                    }
                } catch(err) {
                    console.error('BookTour error:', err);
                    Swal.fire({ title: 'Error', text: 'Connection error. Please try again.', icon: 'error', customClass: { popup: 'swal-top-fix' } });
                } finally {
                    this.bookingInProgress = false;
                }
            }
        }))
    })
</script>
