@model TripMate_Webapi.Controllers.HomeViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Cinematic Hero Section (Matching Focus) -->
<section class="relative h-[800px] w-full overflow-hidden">
    <div class="absolute inset-0">
        <img alt="Vietnam landscape" class="w-full h-full object-cover" 
             src="https://images.unsplash.com/photo-1528127269322-539801943592?w=1920"/>
        <div class="absolute inset-0 hero-gradient"></div>
    </div>
    <div class="relative h-full flex flex-col items-center justify-center px-12 max-w-[1440px] mx-auto text-center">
        <h1 class="text-7xl font-extrabold text-white mb-6 drop-shadow-2xl">
            Find Your Local Soulmate
        </h1>
        <p class="text-2xl text-white/90 mb-12 max-w-2xl font-medium drop-shadow-md">
            No rigid itineraries. Discover local culture your own way with the perfect companion tailored just for you.
        </p>
        
        <!-- Call to Action: Start Survey -->
        <a href="/Survey" class="bg-primary hover:bg-primary/90 text-on-primary px-10 py-5 rounded-full text-xl font-bold flex items-center gap-3 transition-all shadow-2xl hover:scale-105">
            <span class="material-symbols-outlined text-3xl">magic_button</span>
            Find My Guide Now
        </a>
    </div>
</section>

<!-- How it works Section -->
<section class="py-20 px-12 max-w-[1440px] mx-auto bg-surface">
    <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-on-surface mb-4">3 Simple Steps</h2>
        <p class="text-lg text-on-surface-variant">To find your ideal travel companion.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-center flex flex-col items-center">
            <div class="w-24 h-24 bg-primary-container text-primary rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-5xl">quiz</span>
            </div>
            <h3 class="text-2xl font-bold mb-3">1. Take the Quiz</h3>
            <p class="text-on-surface-variant">Share your interests, travel style, and expectations.</p>
        </div>
        <div class="text-center flex flex-col items-center">
            <div class="w-24 h-24 bg-primary-container text-primary rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-5xl">person_search</span>
            </div>
            <h3 class="text-2xl font-bold mb-3">2. Smart Matching</h3>
            <p class="text-on-surface-variant">Our algorithm analyzes and suggests the best-fit Guides (80%+ match).</p>
        </div>
        <div class="text-center flex flex-col items-center">
            <div class="w-24 h-24 bg-primary-container text-primary rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-5xl">handshake</span>
            </div>
            <h3 class="text-2xl font-bold mb-3">3. Connect & Start</h3>
            <p class="text-on-surface-variant">Chat directly, schedule, and enjoy your trip.</p>
        </div>
    </div>
</section>

<!-- Top Guides Section -->
<section class="py-16 px-12 max-w-[1440px] mx-auto">
    <div class="flex justify-between items-end mb-12">
        <div>
            <h2 class="text-5xl font-bold text-on-surface mb-2">Featured Top Guides</h2>
            <p class="text-lg text-on-surface-variant">The most loved companions of the month.</p>
        </div>
        <button class="text-primary text-sm font-bold flex items-center gap-2 hover:gap-3 transition-all group">
            View all <span class="material-symbols-outlined">arrow_forward</span>
        </button>
    </div>
    
    <div class="grid grid-cols-4 gap-8">
        <!-- Mock Guide Cards -->
        @for(int i = 1; i <= 4; i++)
        {
            <div class="bg-surface rounded-xl overflow-hidden tonal-elevation group cursor-pointer hover:-translate-y-2 transition-all duration-500 border border-outline-variant/30">
                <div class="h-64 relative overflow-hidden bg-gray-200">
                    <!-- Avatar Placeholder -->
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="material-symbols-outlined text-6xl text-gray-400">face</span>
                    </div>
                    <button class="absolute top-4 right-4 bg-white/50 hover:bg-white backdrop-blur-md p-2.5 rounded-full transition-all text-gray-600 hover:text-red-500">
                        <span class="material-symbols-outlined">favorite</span>
                    </button>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h4 class="text-xl font-bold text-on-surface">Local Guide @i</h4>
                        <div class="flex items-center gap-1 bg-primary-container px-2 py-0.5 rounded-md">
                            <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="text-sm font-bold text-on-primary-container">4.9</span>
                        </div>
                    </div>
                    <p class="text-on-surface-variant mb-4 flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm text-red-500">location_on</span>
                        Hanoi, VN
                    </p>
                    <div class="flex gap-2 mb-6 flex-wrap">
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded">Culture</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded">Food</span>
                    </div>
                    <div class="flex justify-between items-center pt-5 border-t border-outline-variant/30">
                        <p class="text-on-surface">
                            <span class="text-xl font-extrabold text-primary">500,000₫</span>
                            <span class="text-on-surface-variant text-sm">/ day</span>
                        </p>
                        <button class="text-primary font-bold text-sm hover:underline">View Profile</button>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
