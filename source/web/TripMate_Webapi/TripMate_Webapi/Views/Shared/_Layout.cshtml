<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - TripMate</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="/notifications.js"></script>
    <script src="/chat-realtime.js"></script>
    <script src="/message-badge.js"></script>
    
    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.3/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.3/dist/sweetalert2.all.min.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#ff7a00",
                        "on-primary": "#ffffff",
                        "primary-container": "#ffebd9",
                        "on-primary-container": "#331800",
                        secondary: "#705d4e",
                        "on-secondary": "#ffffff",
                        surface: "#fbf9f8",
                        "on-surface": "#1f1b18",
                        "surface-variant": "#f0ebe8",
                        "on-surface-variant": "#4f453e",
                        outline: "#81756c",
                        "outline-variant": "#d3c4b9",
                        background: "#fbf9f8",
                        "on-background": "#1f1b18"
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        /* End of custom layout styles */
        .tonal-elevation {
            box-shadow: 0 12px 30px -10px rgba(255, 122, 0, 0.12), 0 4px 10px -5px rgba(0, 0, 0, 0.04);
        }
        .glass-search {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
        }
        /* Smooth Page Transition */
        .page-enter {
            animation: pageFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }
        @@keyframes pageFadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        /* Global scrollbar styling for smoothness */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f0ebe8; }
        ::-webkit-scrollbar-thumb { background: #d3c4b9; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff7a00; }
    </style>
</head>
@* in Views/Shared/_Layout.cshtml, before </body> *@
@RenderSection("Scripts", required: false)
<body class="bg-background text-on-background page-enter" data-requires-auth="@(ViewBag.RequiresAuth == true ? "true" : "false")">
    <!-- TopNavBar -->
    <header class="sticky top-0 w-full z-50 bg-surface/80 backdrop-blur-md shadow-sm border-b border-outline-variant/30">
        <div class="flex justify-between items-center h-20 px-12 max-w-[1440px] mx-auto">
            <div class="flex items-center gap-8">
                <a href="/" class="flex items-center gap-3">
                    <img alt="TripMate Logo" class="h-10 w-10 rounded-full object-cover" src="/images/AVATAR.png"/>
                    <span class="text-2xl font-extrabold tracking-tight text-on-surface">TRIPMATE</span>
                </a>
            </div>
            <nav id="mainNav" class="hidden md:flex items-center gap-6 text-sm font-bold flex-1 ml-8">
                <!-- Search Bar in Header -->
                <form action="/Home/Explore" method="get" class="relative group hidden lg:flex bg-white rounded-full border border-outline-variant/30 items-center transition-all focus-within:ring-2 focus-within:ring-primary focus-within:border-primary shadow-sm hover:shadow-md">
                    <div class="flex items-center px-4 py-2 relative">
                        <span class="material-symbols-outlined text-on-surface-variant text-lg mr-2">search</span>
                        <input type="text" id="destination-input" name="search" autocomplete="off" placeholder="Guides, tours, keywords..." class="bg-transparent text-on-surface text-sm w-48 focus:outline-none border-none p-0 placeholder-on-surface-variant/70">
                        <div id="autocomplete-dropdown" class="absolute top-[120%] left-0 w-80 bg-white border border-outline-variant/30 rounded-xl shadow-xl hidden z-[100] max-h-72 overflow-y-auto">
                        </div>
                    </div>
                    <button type="submit" class="bg-primary hover:bg-primary/90 text-white px-6 py-2 h-full font-bold transition-all shadow-md rounded-r-full">Search</button>
                </form>

                <a class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-orange-500 hover:opacity-80 transition-opacity flex items-center gap-1 whitespace-nowrap" href="/Survey/Index">
                    <span class="material-symbols-outlined text-[18px] text-primary">auto_awesome</span>
                    AI Matchmaker
                </a>
                <a class="text-on-surface-variant hover:text-primary transition-colors flex items-center gap-1 whitespace-nowrap" href="/Traveler/CreateTripRequest">
                    <span class="material-symbols-outlined text-[18px]">add_circle</span>
                    Post a Trip Request
                </a>
            </nav>
            <div id="headerTools" class="flex items-center gap-6">
                <a class="text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap font-bold" href="/Home/BecomeAGuide">Become a guide</a>
                
                <div class="flex items-center gap-4">
                    <div class="relative flex items-center justify-center" x-data="notificationDropdown()" x-show="isLoggedIn" style="display: none;">
                        <button @@click="toggleDropdown()" class="text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center relative">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">notifications</span>
                            <span x-show="unreadCount > 0" class="absolute -top-1.5 -right-1.5 bg-red-500 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full" x-text="unreadCount > 99 ? '99+' : unreadCount" style="display: none;"></span>
                        </button>
                        
                        <!-- Dropdown -->
                        <div x-show="isOpen" @@click.outside="closeDropdown()" style="display: none;" class="absolute right-0 top-full mt-4 w-[350px] bg-white rounded-3xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.2)] border border-outline-variant/30 z-50 overflow-hidden" x-transition.opacity.scale.95>
                            <div class="p-4 border-b border-outline-variant/30 flex justify-between items-center bg-surface">
                                <h3 class="font-bold text-on-surface text-lg">Notifications</h3>
                                <button x-show="unreadCount > 0" @@click="markAllAsRead()" class="text-xs bg-primary-container text-primary px-2 py-1 rounded-full font-bold hover:bg-primary hover:text-white transition-colors">Mark all read</button>
                            </div>
                            <div class="max-h-96 overflow-y-auto">
                                <div x-show="isLoading" class="p-8 text-center">
                                    <div class="w-6 h-6 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto"></div>
                                </div>
                                <template x-if="!isLoading && notifications.length === 0">
                                    <div class="p-10 text-center text-on-surface-variant flex flex-col items-center">
                                        <div class="w-16 h-16 bg-surface-variant rounded-full flex items-center justify-center mb-3">
                                            <span class="material-symbols-outlined text-3xl">notifications_paused</span>
                                        </div>
                                        <p class="font-bold text-on-surface">You're all caught up!</p>
                                        <p class="text-sm">No new notifications right now.</p>
                                    </div>
                                </template>
                                <template x-for="notif in notifications" :key="notif.id">
                                    <div @@click="handleNotificationClick(notif)" 
                                         class="p-4 border-b border-outline-variant/20 hover:bg-surface-variant transition-colors cursor-pointer flex gap-4 items-start"
                                         :class="!notif.isRead ? 'bg-primary/5' : ''">
                                        <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 mt-0.5" 
                                             :class="getIconClass(notif.type)">
                                            <span class="material-symbols-outlined text-[18px]" x-text="getIcon(notif.type)"></span>
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm font-bold text-on-surface mb-1" x-text="notif.title"></p>
                                            <p class="text-sm text-on-surface-variant mb-2 line-clamp-2 leading-relaxed" x-text="notif.message"></p>
                                            <p class="text-xs text-on-surface-variant/80 font-medium" x-text="formatDate(notif.createdAt)"></p>
                                        </div>
                                        <div x-show="!notif.isRead" class="w-2 h-2 bg-primary rounded-full mt-2 shrink-0"></div>
                                    </div>
                                </template>
                            </div>
                            <div class="p-3 bg-surface border-t border-outline-variant/30 text-center">
                                <a href="#" class="text-sm font-bold text-primary hover:underline">View all notifications</a>
                            </div>
                        </div>
                    </div>
                    <div id="savedContainer" class="flex items-center justify-center"></div>
                    <div id="userSection" class="ml-2">
                        <!-- Will be populated by JavaScript -->
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer (hidden on auth pages) -->
    @{
        var pageTitle = ViewData["Title"]?.ToString() ?? "";
        var isAuthPage = pageTitle == "Đăng nhập" || pageTitle == "Đăng ký" || pageTitle == "Đặt lại mật khẩu";
    }
    <footer class="w-full mt-16 bg-surface-variant border-t border-outline-variant/50 @(isAuthPage ? "hidden" : "")">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 px-12 py-16 max-w-[1440px] mx-auto">
            <div class="col-span-1">
                <div class="flex items-center gap-3 mb-4">
                    <img alt="TripMate Logo" class="h-8 w-8 rounded-full object-cover" src="/images/AVATAR.png"/>
                    <span class="text-xl font-extrabold text-on-surface">TRIPMATE</span>
                </div>
                <p class="text-on-surface-variant leading-relaxed font-medium">
                    Explore Vietnam your way with dedicated local guides.
                </p>
            </div>
            <div class="flex flex-col gap-3">
                <h5 class="text-sm font-bold text-on-surface tracking-widest uppercase">Explore</h5>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">Destinations</a>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">Experiences</a>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">Local Guides</a>
            </div>
            <div class="flex flex-col gap-3">
                <h5 class="text-sm font-bold text-on-surface tracking-widest uppercase">Company</h5>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">About Us</a>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">Careers</a>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">Contact</a>
            </div>
            <div class="flex flex-col gap-3">
                <h5 class="text-sm font-bold text-on-surface tracking-widest uppercase">Legal</h5>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="/Home/PrivacyPolicy">Privacy Policy</a>
                <a class="text-on-surface-variant hover:text-primary transition-colors" href="/Home/TermsOfService">Terms of Service</a>
            </div>
        </div>
        <div class="px-12 py-6 border-t border-outline-variant/20 max-w-[1440px] mx-auto text-center">
            <span class="text-sm text-on-surface-variant font-bold tracking-widest uppercase">
                © 2026 TRIPMATE. EXPLORE VIETNAM YOUR WAY.
            </span>
        </div>
    </footer>

    <script>
        // Check authentication and display user section
        function checkAuth() {
            const token = localStorage.getItem('accessToken') || localStorage.getItem('jwt_token');
            const userEmail = localStorage.getItem('userEmail');
            const userRole = localStorage.getItem('userRole');
            const userAvatarUrl = localStorage.getItem('userAvatarUrl');
            const userSection = document.getElementById('userSection');

            if (token && userEmail) {
                // User is logged in
                const atChar = String.fromCharCode(64); // at symbol
                const atIndex = userEmail.indexOf(atChar);
                const storedName = localStorage.getItem('userName');
                const displayName = storedName || (atIndex > 0 ? userEmail.substring(0, atIndex) : userEmail);
                
                const avatarContent = userAvatarUrl 
                    ? `<img src="${userAvatarUrl}" class="w-full h-full object-cover rounded-full" alt="${displayName}"/>`
                    : `<div class="w-full h-full flex items-center justify-center text-primary font-bold">${displayName.substring(0, 1).toUpperCase()}</div>`;

                userSection.innerHTML = `
                    <div class="relative group">
                        <button class="flex items-center gap-3 hover:bg-primary-container px-4 py-2 rounded-full transition-all">
                            <span class="text-sm font-medium text-on-surface">${displayName}</span>
                            <div class="h-10 w-10 rounded-full overflow-hidden border-2 border-primary/20 bg-primary-container flex items-center justify-center">
                                ${avatarContent}
                            </div>
                        </button>
                        <!-- Dropdown Menu -->
                        <div class="absolute right-0 top-full mt-2 w-56 bg-surface rounded-xl shadow-2xl border border-outline-variant/30 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                            <a href="${userRole === 'guide' ? '/Guide/Dashboard' : '/Traveler/Dashboard'}" class="block p-4 border-b border-outline-variant/30 hover:bg-surface-variant transition-colors">
                                <p class="font-bold text-on-surface">${displayName}</p>
                                <p class="text-xs text-on-surface-variant">${userEmail}</p>
                                <span class="inline-block mt-2 px-3 py-1 bg-primary-container text-primary text-xs font-bold rounded-full capitalize">
                                    ${userRole || 'traveler'}
                                </span>
                            </a>
                            <div class="p-2">
                                ${userRole === 'traveler' ? `
                                <a href="/Traveler/Trips" class="flex items-center gap-3 px-4 py-3 hover:bg-primary-container rounded-lg transition-all text-on-surface">
                                    <span class="material-symbols-outlined text-on-surface-variant">calendar_month</span>
                                    <span class="font-medium">My Trips</span>
                                </a>
                                <a href="/Traveler/Messages" class="flex items-center gap-3 px-4 py-3 hover:bg-primary-container rounded-lg transition-all text-on-surface">
                                    <span class="material-symbols-outlined text-on-surface-variant">chat</span>
                                    <span class="font-medium">Messages</span>
                                </a>
                                ` : ''}
                                ${userRole === 'guide' ? `
                                <a href="/Guide/Dashboard" class="flex items-center gap-3 px-4 py-3 hover:bg-primary-container rounded-lg transition-all text-on-surface">
                                    <span class="material-symbols-outlined text-on-surface-variant">dashboard</span>
                                    <span class="font-medium">Guide Dashboard</span>
                                </a>
                                ` : ''}
                                ${userRole === 'guide' ? `
                                <a href="/Guide/Profile" class="flex items-center gap-3 px-4 py-3 hover:bg-primary-container rounded-lg transition-all text-on-surface">
                                    <span class="material-symbols-outlined text-on-surface-variant">person</span>
                                    <span class="font-medium">Profile</span>
                                </a>
                                <a href="/Guide/Profile" class="flex items-center gap-3 px-4 py-3 hover:bg-primary-container rounded-lg transition-all text-on-surface">
                                    <span class="material-symbols-outlined text-on-surface-variant">settings</span>
                                    <span class="font-medium">Settings</span>
                                </a>
                                ` : `
                                <a href="/Traveler/Settings" class="flex items-center gap-3 px-4 py-3 hover:bg-primary-container rounded-lg transition-all text-on-surface">
                                    <span class="material-symbols-outlined text-on-surface-variant">manage_accounts</span>
                                    <span class="font-medium">Profile & Setting</span>
                                </a>
                                `}
                                <button onclick="logout()" class="w-full flex items-center gap-3 px-4 py-3 hover:bg-red-50 rounded-lg transition-all text-red-600 font-medium">
                                    <span class="material-symbols-outlined">logout</span>
                                    <span>Logout</span>
                                </button>
                            </div>
                        </div>
                    </div>
                `;

                // Optionally adjust Main Nav based on role
                if(userRole === 'traveler') {
                    // Inject Saved Guides link in header tools
                    if(!document.getElementById('savedGuidesLink')) {
                        const savedGuides = document.createElement('a');
                        savedGuides.id = 'savedGuidesLink';
                        savedGuides.className = 'flex items-center justify-center text-on-surface-variant hover:text-primary transition-colors';
                        savedGuides.href = '/Traveler/Saved';
                        savedGuides.innerHTML = '<span class="material-symbols-outlined" style="font-variation-settings: \\\'FILL\\\' 0;">favorite</span>';
                        
                        const container = document.getElementById('savedContainer');
                        if (container) container.appendChild(savedGuides);
                    }
                }
            } else {
                // User is not logged in
                userSection.innerHTML = `
                    <a href="/Auth/Login" class="px-6 py-2 bg-primary text-on-primary rounded-lg font-medium hover:bg-primary/90 transition-all">
                        Login
                    </a>
                `;
            }
        }

        // Logout function
        function logout() {
            // Clear all localStorage
            localStorage.removeItem('accessToken');
            localStorage.removeItem('refreshToken');
            localStorage.removeItem('userEmail');
            localStorage.removeItem('userId');
            localStorage.removeItem('userRole');
            localStorage.removeItem('surveyCompleted');
            localStorage.removeItem('personalityProfile');
            
            // Redirect to login
            window.location.href = '/Auth/Login';
        }

        // Run on page load
        checkAuth();

        // ── M1: Auth Guard cho các Traveler pages ──────────────────────────
        // Server set ViewBag.RequiresAuth = true trong Controller
        // JS đọc flag này từ data attribute và redirect nếu chưa login
        (function() {
            const requiresAuth = document.body.dataset.requiresAuth === 'true';
            if (!requiresAuth) return;

            const token = localStorage.getItem('accessToken');
            const userId = localStorage.getItem('userId');

            if (!token || !userId) {
                // Lưu URL hiện tại để sau login quay về
                localStorage.setItem('redirectAfterLogin', window.location.href);
                // Redirect về Login
                window.location.replace('/Auth/Login?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search));
            }
        })();

        // Initialize smart local fuzzy search
        document.addEventListener('DOMContentLoaded', function() {
            // City alias map: canonical DB value → all search aliases
            const CITY_DATA = [
                { value: 'Hanoi',     label: 'Hanoi',     aliases: ['hanoi','ha noi','hà nội','ha nội','hn'] },
                { value: 'Danang',    label: 'Da Nang',   aliases: ['danang','da nang','đà nẵng','da nẵng','đà nang','dn'] },
                { value: 'Hoi An',    label: 'Hoi An',    aliases: ['hoian','hoi an','hội an','hoi-an'] },
                { value: 'Ho Chi Minh', label: 'Ho Chi Minh City', aliases: ['hcm','ho chi minh','hcmc','saigon','sài gòn','sai gon','sg'] },
                { value: 'Sapa',      label: 'Sapa',      aliases: ['sapa','sa pa','sả pa'] },
                { value: 'Nha Trang', label: 'Nha Trang', aliases: ['nhatrang','nha trang','nt'] },
                { value: 'Da Lat',    label: 'Da Lat',    aliases: ['dalat','da lat','đà lạt','da lạt'] },
                { value: 'Hue',       label: 'Hue',       aliases: ['hue','huế','thua thien','thừa thiên'] },
                { value: 'Phu Quoc',  label: 'Phu Quoc',  aliases: ['phuquoc','phu quoc','phú quốc'] },
                { value: 'Ha Long',   label: 'Ha Long Bay', aliases: ['halong','ha long','hạ long','vịnh hạ long'] },
            ];

            const TOUR_KEYWORDS = [
                { label: '🍜 Street Food Tours',   value: 'street food' },
                { label: '📸 Photography Tours',   value: 'photography' },
                { label: '🏯 Culture & History',   value: 'culture' },
                { label: '🌿 Adventure & Trekking', value: 'adventure' },
                { label: '🛵 Motorbike Tours',      value: 'motorbike' },
            ];

            const destInput = document.getElementById('destination-input');
            const dropdown = document.getElementById('autocomplete-dropdown');

            function normalize(str) {
                return str.toLowerCase().trim()
                    .replace(/[áàảãạăắặẳẵặâấầẩẫậ]/g, 'a')
                    .replace(/[éèẻẽẹêếềểễệ]/g, 'e')
                    .replace(/[íìỉĩị]/g, 'i')
                    .replace(/[óòỏõọôốồổỗộơớờởỡợ]/g, 'o')
                    .replace(/[úùủũụưứừửữự]/g, 'u')
                    .replace(/[ýỳỷỹỵ]/g, 'y')
                    .replace(/[đ]/g, 'd');
            }

            function renderDropdown(query) {
                const norm = normalize(query);
                dropdown.innerHTML = '';

                if (norm.length < 1) {
                    dropdown.classList.add('hidden');
                    return;
                }

                let cityResults = CITY_DATA.filter(c =>
                    c.aliases.some(a => normalize(a).includes(norm)) ||
                    normalize(c.label).includes(norm)
                ).slice(0, 5);

                let tourResults = TOUR_KEYWORDS.filter(t =>
                    normalize(t.value).includes(norm) || normalize(t.label).includes(norm)
                ).slice(0, 3);

                if (cityResults.length === 0 && tourResults.length === 0) {
                    // Generic suggestion
                    cityResults = CITY_DATA.slice(0, 4);
                }

                if (cityResults.length > 0) {
                    const header = document.createElement('div');
                    header.className = 'px-4 py-2 text-xs font-bold text-on-surface-variant uppercase tracking-wider bg-surface-variant/50';
                    header.textContent = '📍 Destinations';
                    dropdown.appendChild(header);

                    cityResults.forEach(item => {
                        const div = document.createElement('div');
                        div.className = 'px-4 py-3 hover:bg-primary-container/40 cursor-pointer text-sm text-on-surface flex items-center gap-3 transition-colors';
                        div.innerHTML = `<span class="material-symbols-outlined text-primary text-sm shrink-0">location_on</span><div><span class="font-bold">${item.label}</span><span class="text-xs text-on-surface-variant ml-1">Vietnam</span></div>`;
                        div.addEventListener('click', () => {
                            destInput.value = item.value;
                            dropdown.classList.add('hidden');
                            destInput.closest('form').submit();
                        });
                        dropdown.appendChild(div);
                    });
                }

                if (tourResults.length > 0) {
                    const header2 = document.createElement('div');
                    header2.className = 'px-4 py-2 text-xs font-bold text-on-surface-variant uppercase tracking-wider bg-surface-variant/50 border-t border-outline-variant/20';
                    header2.textContent = '🎯 Experiences';
                    dropdown.appendChild(header2);

                    tourResults.forEach(item => {
                        const div = document.createElement('div');
                        div.className = 'px-4 py-3 hover:bg-primary-container/40 cursor-pointer text-sm text-on-surface flex items-center gap-3 transition-colors';
                        div.innerHTML = `<span class="material-symbols-outlined text-on-surface-variant text-sm shrink-0">explore</span><span class="font-medium">${item.label}</span>`;
                        div.addEventListener('click', () => {
                            destInput.value = item.value;
                            dropdown.classList.add('hidden');
                            destInput.closest('form').submit();
                        });
                        dropdown.appendChild(div);
                    });
                }

                dropdown.classList.remove('hidden');
            }

            if (destInput && dropdown) {
                destInput.addEventListener('input', function() {
                    renderDropdown(this.value.trim());
                });
                destInput.addEventListener('focus', function() {
                    if (this.value.trim().length > 0) renderDropdown(this.value.trim());
                });
                document.addEventListener('click', function(e) {
                    if (!destInput.contains(e.target) && !dropdown.contains(e.target)) {
                        dropdown.classList.add('hidden');
                    }
                });
                destInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') { dropdown.classList.add('hidden'); }
                });
            }
        });

        document.addEventListener('alpine:init', () => {
            Alpine.data('notificationDropdown', () => ({
                isLoggedIn: false,
                isOpen: false,
                isLoading: false,
                unreadCount: 0,
                notifications: [],
                token: localStorage.getItem('accessToken'),

                init() {
                    if (this.token) {
                        this.isLoggedIn = true;
                        this.fetchUnreadCount();
                        // Poll every 30 seconds
                        setInterval(() => this.fetchUnreadCount(), 30000);
                    }
                },

                toggleDropdown() {
                    this.isOpen = !this.isOpen;
                    if (this.isOpen && this.notifications.length === 0) {
                        this.fetchNotifications();
                    }
                },

                closeDropdown() {
                    this.isOpen = false;
                },

                async fetchUnreadCount() {
                    try {
                        const res = await fetch('/Notification/GetUnreadCount', {
                            headers: { 'Authorization': 'Bearer ' + this.token }
                        });
                        if (res.ok) {
                            const data = await res.json();
                            if (data.success) this.unreadCount = data.count;
                        }
                    } catch (e) { console.error('Error fetching unread count', e); }
                },

                async fetchNotifications() {
                    this.isLoading = true;
                    try {
                        const res = await fetch('/Notification/GetMyNotifications', {
                            headers: { 'Authorization': 'Bearer ' + this.token }
                        });
                        if (res.ok) {
                            const data = await res.json();
                            if (data.success) {
                                this.notifications = data.notifications;
                                this.unreadCount = this.notifications.filter(n => !n.isRead).length;
                            }
                        }
                    } catch (e) { console.error('Error fetching notifications', e); }
                    finally { this.isLoading = false; }
                },

                async markAllAsRead() {
                    try {
                        await fetch('/Notification/MarkAllAsRead', {
                            method: 'POST',
                            headers: { 'Authorization': 'Bearer ' + this.token }
                        });
                        this.notifications.forEach(n => n.isRead = true);
                        this.unreadCount = 0;
                    } catch (e) { console.error('Error marking all as read', e); }
                },

                async handleNotificationClick(notif) {
                    if (!notif.isRead) {
                        try {
                            await fetch(`/Notification/MarkAsRead?id=${notif.id}`, {
                                method: 'POST',
                                headers: { 'Authorization': 'Bearer ' + this.token }
                            });
                            notif.isRead = true;
                            this.unreadCount = Math.max(0, this.unreadCount - 1);
                        } catch (e) { console.error('Error marking as read', e); }
                    }
                    if (notif.linkUrl) {
                        window.location.href = notif.linkUrl;
                    }
                    this.closeDropdown();
                },

                getIcon(type) {
                    const icons = {
                        'booking_request': 'event_available',
                        'booking_confirmed': 'check_circle',
                        'booking_cancelled': 'cancel',
                        'new_review': 'star',
                        'system': 'info'
                    };
                    return icons[type] || 'notifications';
                },

                getIconClass(type) {
                    const classes = {
                        'booking_request': 'bg-blue-100 text-blue-600',
                        'booking_confirmed': 'bg-green-100 text-green-600',
                        'booking_cancelled': 'bg-red-100 text-red-600',
                        'new_review': 'bg-yellow-100 text-yellow-600',
                        'system': 'bg-gray-100 text-gray-600'
                    };
                    return classes[type] || 'bg-primary-container text-primary';
                },

                formatDate(dateString) {
                    const date = new Date(dateString);
                    const now = new Date();
                    const diff = Math.floor((now - date) / 1000);
                    
                    if (diff < 60) return 'Just now';
                    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
                    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
                    if (diff < 604800) return `${Math.floor(diff/86400)}d ago`;
                    
                    return date.toLocaleDateString();
                }
            }));
        });

        document.addEventListener('DOMContentLoaded', () => {
            const dateInputs = document.querySelectorAll('.date-picker');
            if (dateInputs.length > 0) {
                flatpickr(dateInputs, {
                    mode: "range",
                    minDate: "today",
                    dateFormat: "Y-m-d",
                    altInput: true,
                    altFormat: "M j, Y",
                });
            }
        });
    </script>
</body>
</html>
