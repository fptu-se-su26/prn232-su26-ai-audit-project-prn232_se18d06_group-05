<!DOCTYPE html>
<html lang="vi">
@using System.Security.Claims
@inject TripMate_Webapi.Repositories.IGuideRepository GuideRepo
@inject TripMate_Webapi.Repositories.IBookingRepository BookingRepo
@{
    int pendingBookingsCount = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrEmpty(userId))
        {
            var profile = await GuideRepo.GetGuideProfileByUserIdAsync(userId);
            if (profile != null)
            {
                pendingBookingsCount = await BookingRepo.GetPendingBookingsCountAsync(profile.Id);
            }
        }
    }
}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] | TripMate Guide Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet">
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/@@alpinejs/collapse@3.x.x/dist/cdn.min.js" data-turbo-track="reload"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" data-turbo-track="reload"></script>
    
    <!-- Hotwire Turbo -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/@@hotwired/turbo@8.0.4/dist/turbo.es2017-esm.js" data-turbo-track="reload"></script>
    
    <script data-turbo-track="reload">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#FF6B35',
                        'primary-dark': '#E55A2B',
                        secondary: '#004E89',
                        accent: '#F7B801',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.5);
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="bg-gray-50 text-gray-900 antialiased">
    <!-- Side Navigation Bar -->
    <aside class="fixed left-0 top-0 h-screen w-[280px] bg-white border-r border-gray-200 flex flex-col py-6 px-4 z-50 overflow-y-auto">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 mb-6 px-2 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white font-bold shadow-sm">
                <span class="material-symbols-outlined text-[20px]">flight_takeoff</span>
            </div>
            <h1 class="text-xl font-bold text-gray-900 tracking-tight">TripMate</h1>
        </a>

        <!-- Menu Section -->
        <div class="mb-2 px-2 mt-4">
            <p class="text-xs font-semibold text-gray-500 mb-3">Menu</p>
        </div>
        
        <nav class="flex flex-col gap-1 mb-6">
            <a href="/Guide/Dashboard" class="@(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all group">
                <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">grid_view</span>
                <span>Dashboard</span>
            </a>
            
            <a href="/Guide/Bookings" class="@(ViewData["ActivePage"]?.ToString() == "Bookings" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center justify-between px-3 py-2.5 rounded-xl transition-all group">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Bookings" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">bar_chart</span>
                    <span>Bookings</span>
                </div>
                @if (pendingBookingsCount > 0)
                {
                    <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full shadow-sm">@pendingBookingsCount</span>
                }
            </a>

            <a href="/Guide/Calendar" class="@(ViewData["ActivePage"]?.ToString() == "Calendar" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all group">
                <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Calendar" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">calendar_month</span>
                <span>Calendar</span>
            </a>

            <a href="/Guide/MyTours" class="@(ViewData["ActivePage"]?.ToString() == "MyTours" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all group">
                <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "MyTours" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">task_alt</span>
                <span>My Tours</span>
            </a>

            <a href="/Guide/Messages" class="@(ViewData["ActivePage"]?.ToString() == "Messages" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all group">
                <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Messages" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">person_outline</span>
                <span>Messages</span>
            </a>

            <a href="/Guide/Notifications" class="@(ViewData["ActivePage"]?.ToString() == "Notifications" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center justify-between px-3 py-2.5 rounded-xl transition-all group">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Notifications" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">notifications_none</span>
                    <span>Notifications</span>
                </div>
                <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full shadow-sm">21</span>
            </a>
        </nav>

        <!-- Divider -->
        <hr class="border-gray-200 mx-2 mb-6">

        <!-- Finance & Settings Section -->
        <nav class="flex flex-col gap-1 mb-auto">
            <a href="/Guide/Profile" class="@(ViewData["ActivePage"]?.ToString() == "Profile" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all group">
                <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Profile" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">settings</span>
                <span>Profile Setting</span>
            </a>

            <a href="/Guide/Earnings" class="@(ViewData["ActivePage"]?.ToString() == "Earnings" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all group">
                <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Earnings" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">flag</span>
                <span>Earnings Report</span>
            </a>

            <a href="/Guide/Support" class="@(ViewData["ActivePage"]?.ToString() == "Support" ? "bg-orange-100 text-primary font-bold" : "hover:bg-orange-50 text-gray-600 hover:text-primary font-medium") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all group">
                <span class="material-symbols-outlined @(ViewData["ActivePage"]?.ToString() == "Support" ? "text-primary" : "text-gray-400 group-hover:text-primary") text-[22px]">error_outline</span>
                <span>Support</span>
            </a>
        </nav>

        <!-- Group Section (Account) -->
        <div class="mt-6" x-data="{ userMenuOpen: false }">
            <p class="text-xs font-semibold text-gray-500 mb-3 px-2">Account</p>
            <div class="relative">
                <button @@click="userMenuOpen = !userMenuOpen" @@click.outside="userMenuOpen = false" class="w-full flex items-center justify-between px-3 py-2.5 hover:bg-gray-100/70 rounded-xl transition-all group focus:outline-none">
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-green-500 shadow-sm"></div>
                        <span class="text-sm font-medium text-gray-700">Guide User</span>
                    </div>
                    <span class="material-symbols-outlined text-gray-400 group-hover:text-gray-600 text-[20px] transition-transform duration-200" :class="{'rotate-90': userMenuOpen}">chevron_right</span>
                </button>
                
                <!-- Dropdown -->
                <div x-show="userMenuOpen" x-transition.opacity.duration.200ms style="display: none;" class="absolute bottom-full left-0 w-full mb-2 bg-white border border-gray-200 shadow-xl rounded-xl overflow-hidden py-1 z-50">
                    <a href="/Guide/Profile" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 font-medium">
                        <span class="material-symbols-outlined text-[18px]">person</span> Hồ sơ của tôi
                    </a>
                    <button onclick="logout()" class="w-full text-left flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 font-medium">
                        <span class="material-symbols-outlined text-[18px]">logout</span> Đăng xuất
                    </button>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="ml-[280px] min-h-screen flex flex-col bg-gray-50">
        <!-- TOPBAR -->
        <header class="sticky top-0 bg-white/80 backdrop-blur-md border-b border-gray-200 shadow-sm z-40 px-8 py-4 flex justify-between items-center">
            <h2 class="text-xl font-bold text-gray-800">@ViewData["Title"]</h2>
            <div class="flex items-center gap-6">
                <!-- Search -->
                <div class="relative hidden md:block w-64">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[20px]">search</span>
                    <input type="text" placeholder="Tìm kiếm booking, tour..." class="w-full bg-gray-100 text-sm text-gray-700 placeholder-gray-400 border-none rounded-full py-2 pl-10 pr-4 focus:ring-2 focus:ring-primary/50 outline-none transition-all">
                </div>
                
                <!-- Notification Bell -->
                <a href="/Guide/Notifications" class="relative text-gray-500 hover:text-primary transition-colors focus:outline-none">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border-2 border-white shadow-sm"></span>
                </a>
                
                <!-- Avatar -->
                <a href="/Guide/Profile" class="w-9 h-9 rounded-full overflow-hidden border-2 border-white shadow-sm ring-1 ring-gray-200 cursor-pointer hover:ring-primary transition-all">
                    <img src="/images/AVATAR.png" alt="Avatar" class="w-full h-full object-cover">
                </a>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <div class="flex-1 p-8">
            @RenderBody()
        </div>
    </main>

    <script>
        // Global Toast Notification function
        function showToast(type, message, title = null, duration = 4000) {
            // Ensure toast container exists
            let container = document.getElementById('toast-container');
            if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                container.className = 'fixed top-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none';
                document.body.appendChild(container);
            }

            const config = {
                success: { color: 'bg-[#00B232]', defaultTitle: 'Thành công' },
                error:   { color: 'bg-[#FF0000]', defaultTitle: 'Đã xảy ra lỗi' },
                warning: { color: 'bg-[#FFB800]', defaultTitle: 'Hành động yêu cầu' },
                info:    { color: 'bg-[#2E77F2]', defaultTitle: 'Bạn có biết?' },
            };
            
            const currentConfig = config[type] || config.info;
            const displayTitle = title || currentConfig.defaultTitle;
            
            const toast = document.createElement('div');
            toast.className = `relative flex items-center w-80 bg-white rounded-lg shadow-[0_4px_12px_rgba(0,0,0,0.08)] border border-gray-100 overflow-hidden transform transition-all duration-300 translate-x-10 opacity-0 pointer-events-auto`;
            
            toast.innerHTML = `
                <div class="absolute left-0 top-0 bottom-0 w-1.5 ${currentConfig.color}"></div>
                <div class="flex-1 py-3 px-4 pl-6">
                    <h4 class="text-[15px] font-bold text-gray-900 leading-tight">${displayTitle}</h4>
                    <p class="text-[13px] text-gray-500 mt-1 leading-snug">${message}</p>
                </div>
                <button class="px-4 text-gray-400 hover:text-gray-700 transition-colors focus:outline-none" onclick="this.closest('.relative').style.opacity='0'; setTimeout(() => this.closest('.relative').remove(), 300)">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            `;
            
            // Append
            container.appendChild(toast);
            
            // Animate in
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    toast.classList.remove('translate-x-10', 'opacity-0');
                });
            });
            
            // Animate out
            setTimeout(() => { 
                toast.classList.add('opacity-0', 'translate-x-10'); 
                setTimeout(() => toast.remove(), 300); 
            }, duration);
        }

        // Logout function
        function logout() {
            if (confirm('Bạn có chắc muốn đăng xuất?')) {
                localStorage.removeItem('accessToken');
                localStorage.removeItem('refreshToken');
                localStorage.removeItem('userEmail');
                localStorage.removeItem('userId');
                localStorage.removeItem('userRole');
                window.location.href = '/Auth/Login';
            }
        }
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
