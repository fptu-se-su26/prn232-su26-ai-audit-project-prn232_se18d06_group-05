@model TripMate_Webapi.Controllers.GuideApprovalsViewModel
@using TripMate_WebAPI.Services
@{
    ViewData["Title"] = "Guide Approvals";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TripMate | Guide Approvals</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#FF6B35',
                        'primary-dark': '#E55A2B',
                        secondary: '#004E89',
                        accent: '#F7B801',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Side Navigation Bar (Same as Dashboard) -->
    <aside class="fixed left-0 top-0 h-screen w-[280px] bg-white border-r border-gray-200 flex flex-col py-8 pr-4 z-50">
        <div class="px-6 mb-10">
            <div class="flex items-center gap-3 mb-2">
                <img src="/images/logo.svg" alt="TripMate" class="w-10 h-10">
                <h1 class="text-2xl font-bold text-primary">TripMate</h1>
            </div>
            <p class="text-sm text-gray-600">Admin Portal</p>
        </div>

        <nav class="flex-grow flex flex-col gap-1">
            <a class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a class="flex items-center gap-4 px-6 py-3 bg-orange-100 text-primary border-l-4 border-primary rounded-r-full my-1 font-medium transition-all duration-200 relative" href="/Admin/GuideApprovals">
                <span class="material-symbols-outlined">badge</span>
                <span>Guide Approvals</span>
                @if (Model.PendingCount > 0)
                {
                    <span class="absolute top-1 right-2 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">@Model.PendingCount</span>
                }
            </a>
            <a class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="#">
                <span class="material-symbols-outlined">calendar_month</span>
                <span>Bookings</span>
            </a>
            <a class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="#">
                <span class="material-symbols-outlined">tour</span>
                <span>Tours</span>
            </a>
            <a class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="#">
                <span class="material-symbols-outlined">group</span>
                <span>Guides</span>
            </a>
            <a class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="#">
                <span class="material-symbols-outlined">insights</span>
                <span>Analytics</span>
            </a>
        </nav>

        <div class="px-4 mt-auto">
            <div class="mt-6 flex flex-col gap-1">
                <a class="flex items-center gap-4 px-6 py-2 text-gray-600 hover:bg-gray-100 rounded-r-full font-medium" href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Settings</span>
                </a>
                <a class="flex items-center gap-4 px-6 py-2 text-gray-600 hover:bg-gray-100 rounded-r-full font-medium" href="/">
                    <span class="material-symbols-outlined">home</span>
                    <span>Back to Home</span>
                </a>
                <button onclick="logout()" class="flex items-center gap-4 px-6 py-2 text-red-600 hover:bg-red-50 rounded-r-full font-medium transition-all">
                    <span class="material-symbols-outlined">logout</span>
                    <span>Đăng xuất</span>
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="ml-[280px] min-h-screen p-12 bg-gray-50">
        <!-- Header Section -->
        <header class="flex justify-between items-end mb-12">
            <div>
                <h2 class="text-5xl font-bold text-gray-900 mb-2">Guide Approvals</h2>
                <p class="text-lg text-gray-600">Review and approve guide applications</p>
            </div>
            <div class="flex gap-4">
                <span class="bg-orange-100 text-primary px-6 py-3 rounded-lg font-bold text-lg">
                    @Model.PendingCount Pending
                </span>
            </div>
        </header>

        <!-- Applications Grid -->
        <div class="grid grid-cols-1 gap-6">
            @if (Model.PendingApplications != null && Model.PendingApplications.Any())
            {
                @foreach (var application in Model.PendingApplications)
                {
                    <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all">
                        <div class="flex items-start gap-6">
                            <!-- Avatar -->
                            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center text-white text-2xl font-bold flex-shrink-0">
                                @(application.Full_Name?.Substring(0, 1).ToUpper() ?? "G")
                            </div>

                            <!-- Info -->
                            <div class="flex-grow">
                                <div class="flex items-start justify-between mb-4">
                                    <div>
                                        <h3 class="text-2xl font-bold text-gray-900 mb-1">@application.Full_Name</h3>
                                        <p class="text-gray-600 flex items-center gap-2">
                                            <span class="material-symbols-outlined text-sm">mail</span>
                                            @application.Email
                                        </p>
                                        <p class="text-gray-600 flex items-center gap-2 mt-1">
                                            <span class="material-symbols-outlined text-sm">phone</span>
                                            @application.Phone_Number
                                        </p>
                                    </div>
                                    <span class="bg-yellow-100 text-yellow-700 px-4 py-2 rounded-full text-sm font-medium">
                                        Pending Review
                                    </span>
                                </div>

                                <!-- Quick Info Grid -->
                                <div class="grid grid-cols-4 gap-4 mb-6">
                                    <div class="bg-gray-50 rounded-lg p-4">
                                        <p class="text-xs text-gray-600 mb-1">Experience</p>
                                        <p class="font-bold text-gray-900">@application.Experience</p>
                                    </div>
                                    <div class="bg-gray-50 rounded-lg p-4">
                                        <p class="text-xs text-gray-600 mb-1">Specialization</p>
                                        <p class="font-bold text-gray-900">@application.Specialization</p>
                                    </div>
                                    <div class="bg-gray-50 rounded-lg p-4">
                                        <p class="text-xs text-gray-600 mb-1">Languages</p>
                                        <p class="font-bold text-gray-900">@(application.Languages ?? "N/A")</p>
                                    </div>
                                    <div class="bg-gray-50 rounded-lg p-4">
                                        <p class="text-xs text-gray-600 mb-1">Applied</p>
                                        <p class="font-bold text-gray-900">@application.Created_At?.ToString("MMM dd, yyyy")</p>
                                    </div>
                                </div>

                                <!-- Bio Preview -->
                                @if (!string.IsNullOrEmpty(application.Bio))
                                {
                                    <div class="mb-6">
                                        <p class="text-sm text-gray-600 mb-2 font-medium">Bio:</p>
                                        <p class="text-gray-700 line-clamp-2">@application.Bio</p>
                                    </div>
                                }

                                <!-- Actions -->
                                <div class="flex gap-3">
                                    <button onclick="viewDetails('@application.Id')" class="flex-1 px-6 py-3 bg-gray-100 text-gray-900 rounded-lg font-medium hover:bg-gray-200 transition-all flex items-center justify-center gap-2">
                                        <span class="material-symbols-outlined">visibility</span>
                                        View Details
                                    </button>
                                    <button onclick="showRejectModal('@application.Id', '@application.Full_Name')" class="px-6 py-3 bg-red-50 text-red-600 rounded-lg font-medium hover:bg-red-100 transition-all flex items-center gap-2">
                                        <span class="material-symbols-outlined">close</span>
                                        Reject
                                    </button>
                                    <button onclick="showApproveModal('@application.Id', '@application.Full_Name')" class="px-8 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-all flex items-center gap-2 shadow-md">
                                        <span class="material-symbols-outlined">check_circle</span>
                                        Approve
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="bg-white rounded-2xl p-16 text-center">
                    <span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">check_circle</span>
                    <h3 class="text-2xl font-bold text-gray-900 mb-2">All Caught Up!</h3>
                    <p class="text-gray-600">No pending guide applications at the moment.</p>
                </div>
            }
        </div>
    </main>

    <!-- Approve Modal -->
    <div id="approveModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-2xl max-w-md w-full p-8 shadow-2xl">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-4xl text-green-600">check_circle</span>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Approve Guide</h3>
                <p class="text-gray-600">Are you sure you want to approve <span id="approveName" class="font-bold"></span>?</p>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Admin Comment (Optional)</label>
                <textarea id="approveComment" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" placeholder="Add a note for the guide..."></textarea>
            </div>

            <div class="flex gap-3">
                <button onclick="closeApproveModal()" class="flex-1 px-6 py-3 bg-gray-100 text-gray-900 rounded-lg font-medium hover:bg-gray-200 transition-all">
                    Cancel
                </button>
                <button onclick="confirmApprove()" class="flex-1 px-6 py-3 bg-green-600 text-white rounded-lg font-medium hover:bg-green-700 transition-all">
                    Approve
                </button>
            </div>
        </div>
    </div>

    <!-- Reject Modal -->
    <div id="rejectModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-2xl max-w-md w-full p-8 shadow-2xl">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-4xl text-red-600">cancel</span>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Reject Application</h3>
                <p class="text-gray-600">Please provide a reason for rejecting <span id="rejectName" class="font-bold"></span></p>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Reason (Required)</label>
                <textarea id="rejectReason" rows="4" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500" placeholder="Explain why this application is being rejected..."></textarea>
            </div>

            <div class="flex gap-3">
                <button onclick="closeRejectModal()" class="flex-1 px-6 py-3 bg-gray-100 text-gray-900 rounded-lg font-medium hover:bg-gray-200 transition-all">
                    Cancel
                </button>
                <button onclick="confirmReject()" class="flex-1 px-6 py-3 bg-red-600 text-white rounded-lg font-medium hover:bg-red-700 transition-all">
                    Reject
                </button>
            </div>
        </div>
    </div>

    <script>
        let currentGuideId = '';

        // Logout function
        function logout() {
            if (confirm('Bạn có chắc muốn đăng xuất?')) {
                localStorage.removeItem('accessToken');
                localStorage.removeItem('refreshToken');
                localStorage.removeItem('userEmail');
                localStorage.removeItem('userId');
                localStorage.removeItem('userRole');
                localStorage.removeItem('surveyCompleted');
                localStorage.removeItem('personalityProfile');
                window.location.href = '/Auth/Login';
            }
        }

        // Show Approve Modal
        function showApproveModal(guideId, guideName) {
            currentGuideId = guideId;
            document.getElementById('approveName').textContent = guideName;
            document.getElementById('approveComment').value = '';
            document.getElementById('approveModal').classList.remove('hidden');
        }

        // Close Approve Modal
        function closeApproveModal() {
            document.getElementById('approveModal').classList.add('hidden');
            currentGuideId = '';
        }

        // Confirm Approve
        async function confirmApprove() {
            const comment = document.getElementById('approveComment').value;

            try {
                const response = await fetch('/Admin/ApproveGuide', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        guideId: currentGuideId,
                        comment: comment
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert(data.message || 'Có lỗi xảy ra');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi phê duyệt');
            }

            closeApproveModal();
        }

        // Show Reject Modal
        function showRejectModal(guideId, guideName) {
            currentGuideId = guideId;
            document.getElementById('rejectName').textContent = guideName;
            document.getElementById('rejectReason').value = '';
            document.getElementById('rejectModal').classList.remove('hidden');
        }

        // Close Reject Modal
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            currentGuideId = '';
        }

        // Confirm Reject
        async function confirmReject() {
            const reason = document.getElementById('rejectReason').value.trim();

            if (!reason) {
                alert('Vui lòng nhập lý do từ chối');
                return;
            }

            try {
                const response = await fetch('/Admin/RejectGuide', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        guideId: currentGuideId,
                        comment: reason
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert(data.message || 'Có lỗi xảy ra');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi từ chối');
            }

            closeRejectModal();
        }

        // View Details (redirect to detail page)
        function viewDetails(guideId) {
            window.location.href = `/Admin/GuideDetail/${guideId}`;
        }

        // Close modals on ESC key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeApproveModal();
                closeRejectModal();
            }
        });
    </script>
</body>
</html>
