@model TripMate_Webapi.Controllers.GuideApprovalsViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Guide Approvals";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TripMate | Guide Approvals</title>
    <script>
        // Front-end JWT and role authorization check
        (function() {
            const token = localStorage.getItem('accessToken');
            const role = localStorage.getItem('userRole');
            const email = localStorage.getItem('userEmail');
            
            if (!token || (role !== 'admin' && email !== 'admin@tripmate.com')) {
                window.location.href = '/Auth/Login';
            }
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#FF6B35',
                        'primary-dark': '#E55A2B',
                        secondary: '#004E89',
                        accent: '#F7B801',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.5);
        }
    </style>
</head>
<body class="bg-gray-50 flex" x-data="{
    applications: @Html.Raw(JsonSerializer.Serialize(Model.PendingApplications)),
    selectedId: '@(Model.PendingApplications.FirstOrDefault()?.Id ?? "")',
    approveComment: '',
    rejectReason: '',
    showApproveModal: false,
    showRejectModal: false,
    
    getSelectedApp() {
        return this.applications.find(a => a.id === this.selectedId);
    },
    
    async verifyGuide() {
        if (!this.selectedId) return;
        try {
            const res = await fetch(`/api/admin/guides/${this.selectedId}/verify`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
                },
                body: JSON.stringify({ Comment: this.approveComment })
            });
            const data = await res.json();
            if (res.ok) {
                alert(data.message);
                window.location.reload();
            } else {
                alert(data.message || 'Error approving guide');
            }
        } catch (err) {
            console.error(err);
            alert('An error occurred');
        }
        this.showApproveModal = false;
    },
    
    async rejectGuide() {
        if (!this.selectedId) return;
        if (!this.rejectReason.trim()) {
            alert('Please enter rejection reason');
            return;
        }
        try {
            const res = await fetch(`/api/admin/guides/${this.selectedId}/reject`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
                },
                body: JSON.stringify({ Comment: this.rejectReason })
            });
            const data = await res.json();
            if (res.ok) {
                alert(data.message);
                window.location.reload();
            } else {
                alert(data.message || 'Error rejecting guide');
            }
        } catch (err) {
            console.error(err);
            alert('An error occurred');
        }
        this.showRejectModal = false;
    },

    logout() {
        if (confirm('Are you sure you want to log out?')) {
            localStorage.removeItem('accessToken');
            localStorage.removeItem('refreshToken');
            localStorage.removeItem('userEmail');
            localStorage.removeItem('userId');
            localStorage.removeItem('userRole');
            window.location.href = '/Auth/Login';
        }
    }
}">

    <!-- Side Navigation Bar -->
    <aside class="fixed left-0 top-0 h-screen w-[280px] bg-white border-r border-gray-200 flex flex-col py-8 pr-4 z-50">
        <div class="px-6 mb-10">
            <div class="flex items-center gap-3 mb-2">
                <img src="/images/logo.svg" alt="TripMate" class="w-10 h-10">
                <h1 class="text-2xl font-bold text-primary">TripMate</h1>
            </div>
            <p class="text-sm text-gray-600">Admin Portal</p>
        </div>

        <nav class="flex-grow flex flex-col gap-1">
            <a id="nav-dashboard" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a id="nav-approvals" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200 relative" href="/Admin/GuideApprovals">
                <span class="material-symbols-outlined">badge</span>
                <span>Guide Approvals</span>
                <span id="guideBadge" class="hidden absolute top-2 right-4 w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                <span id="guideCount" class="hidden absolute top-1 right-2 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"></span>
            </a>
            <a id="nav-escrow" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Escrow">
                <span class="material-symbols-outlined">payments</span>
                <span>Escrow & Finance</span>
            </a>
            <a id="nav-moderation" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Moderation">
                <span class="material-symbols-outlined">gavel</span>
                <span>Content & Disputes</span>
            </a>
            <a id="nav-guides" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Guides">
                <span class="material-symbols-outlined">group</span>
                <span>Guides</span>
            </a>
            <a id="nav-analytics" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Analytics">
                <span class="material-symbols-outlined">insights</span>
                <span>Analytics</span>
            </a>
        </nav>

        <div class="px-4 mt-auto">
            <div class="mt-6 px-4 py-4 flex items-center gap-3 border-t border-gray-200">
                <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">person</span>
                </div>
                <div class="flex-1">
                    <p id="sidebarAdminName" class="font-medium text-gray-900">Admin User</p>
                    <p id="sidebarAdminRole" class="text-xs text-gray-500">Super Admin</p>
                </div>
                <button onclick="logout()" class="p-2 hover:bg-red-50 rounded-lg transition-all group" title="Logout">
                    <span class="material-symbols-outlined text-gray-400 group-hover:text-red-600">logout</span>
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Workspace Split-Pane Layout -->
    <main class="ml-[280px] w-[calc(100%-280px)] min-h-screen flex bg-gray-50">
        
        <!-- Left Side: FIFO Applications Queue -->
        <section class="w-1/3 border-r border-gray-200 bg-white flex flex-col h-screen overflow-hidden">
            <div class="p-6 border-b border-gray-200 bg-white">
                <h2 class="text-2xl font-bold text-gray-900 mb-1">Queue Pipeline</h2>
                <p class="text-sm text-gray-500">FIFO Queue (First In, First Out)</p>
            </div>

            <div class="flex-grow overflow-y-auto divide-y divide-gray-100">
                <template x-for="(app, index) in applications" :key="app.id">
                    <div :class="selectedId === app.id ? 'bg-orange-50/70 border-l-4 border-primary' : 'hover:bg-gray-50'" 
                         class="p-5 cursor-pointer transition-all duration-200 relative flex flex-col gap-2"
                         @@click="selectedId = app.id">
                        
                        <div class="flex justify-between items-start">
                            <span class="font-bold text-gray-900" x-text="app.full_name"></span>
                            <span class="text-xs text-orange-600 font-semibold bg-orange-100 px-2 py-0.5 rounded-full" x-text="'#' + (index + 1)"></span>
                        </div>
                        <div class="text-sm text-gray-600" x-text="app.email"></div>
                        <div class="text-xs text-gray-400 mt-1 flex justify-between items-center">
                            <span x-text="app.specialization"></span>
                            <span x-text="new Date(app.created_at).toLocaleDateString('en-US')"></span>
                        </div>
                    </div>
                </template>

                <template x-if="applications.length === 0">
                    <div class="text-center py-20 text-gray-500">
                        <span class="material-symbols-outlined text-5xl mb-3 block">check_circle</span>
                        <p class="font-medium text-lg">Queue is empty</p>
                    </div>
                </template>
            </div>
        </section>

        <!-- Right Side: Details Comparison Panel & PDF Viewer -->
        <section class="w-2/3 flex flex-col h-screen overflow-hidden bg-gray-50">
            <template x-if="getSelectedApp()">
                <div class="flex flex-col h-full overflow-hidden" x-data="{ activeTab: 'details' }">
                    <!-- Top Action Bar -->
                    <div class="p-6 border-b border-gray-200 bg-white flex justify-between items-center shadow-sm">
                        <div>
                            <h3 class="text-2xl font-bold text-gray-900" x-text="getSelectedApp().full_name"></h3>
                            <p class="text-sm text-gray-500" x-text="'Applied: ' + new Date(getSelectedApp().created_at).toLocaleString()"></p>
                        </div>
                        <div class="flex gap-3">
                            <button @@click="showRejectModal = true" class="px-6 py-2.5 bg-red-50 text-red-600 font-semibold rounded-lg hover:bg-red-100 transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">close</span>
                                Reject
                            </button>
                            <button @@click="showApproveModal = true" class="px-6 py-2.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark shadow-md transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">verified</span>
                                Verify Guide
                            </button>
                        </div>
                    </div>

                    <!-- Split Panel Content -->
                    <div class="flex-grow flex overflow-hidden">
                        <!-- Info Panel -->
                        <div class="w-1/2 p-8 overflow-y-auto flex flex-col gap-6 bg-white border-r border-gray-200">
                            <div>
                                <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Contact Information</h4>
                                <div class="space-y-3 bg-gray-50 rounded-xl p-4">
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500">Email</span>
                                        <span class="font-medium text-gray-900" x-text="getSelectedApp().email"></span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500">Phone Number</span>
                                        <span class="font-medium text-gray-900" x-text="getSelectedApp().phone_number || 'Not provided'"></span>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Specialization & Skills</h4>
                                <div class="space-y-3 bg-gray-50 rounded-xl p-4">
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500">Specialization</span>
                                        <span class="font-medium text-gray-900" x-text="getSelectedApp().specialization"></span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500">Languages</span>
                                        <span class="font-medium text-gray-900" x-text="getSelectedApp().languages || 'None'"></span>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Biography (Bio)</h4>
                                <p class="text-gray-700 bg-gray-50 rounded-xl p-4 text-sm leading-relaxed" x-text="getSelectedApp().bio || 'No biography provided'"></p>
                            </div>
                        </div>

                        <!-- PDF Certificate Panel -->
                        <div class="w-1/2 flex flex-col h-full bg-gray-100">
                            <div class="px-6 py-4 bg-gray-200 border-b border-gray-300 flex justify-between items-center">
                                <span class="font-bold text-gray-700 text-sm flex items-center gap-2">
                                    <span class="material-symbols-outlined text-sm">description</span>
                                    Verification Document (ID/Passport)
                                </span>
                                <a :href="getSelectedApp().certificate_path" target="_blank" class="text-primary hover:underline text-xs font-bold flex items-center gap-1">
                                    Open in new tab
                                    <span class="material-symbols-outlined text-xs">open_in_new</span>
                                </a>
                            </div>
                            <div class="flex-grow relative">
                                <template x-if="getSelectedApp().certificate_path">
                                    <iframe :src="getSelectedApp().certificate_path" class="w-full h-full border-none"></iframe>
                                </template>
                                <template x-if="!getSelectedApp().certificate_path">
                                    <div class="w-full h-full flex flex-col items-center justify-center text-gray-400 p-8 text-center">
                                        <span class="material-symbols-outlined text-5xl mb-2">no_documents</span>
                                        <p class="text-sm">No attachment or failed to load document.</p>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>
            </template>

            <template x-if="!getSelectedApp()">
                <div class="flex-grow flex flex-col items-center justify-center text-gray-400 bg-white">
                    <span class="material-symbols-outlined text-7xl mb-4 text-gray-200">safety_check</span>
                    <h3 class="text-2xl font-bold text-gray-800">Select a Local Guide</h3>
                    <p class="text-sm text-gray-500 mt-1">Select from queue to compare details and review.</p>
                </div>
            </template>
        </section>
    </main>

    <!-- Approve Modal -->
    <div x-show="showApproveModal" class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4" x-cloak>
        <div class="bg-white rounded-2xl max-w-md w-full p-8 shadow-2xl animate-in fade-in zoom-in-95 duration-200">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-4xl text-green-600 font-bold">verified</span>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Approve Guide</h3>
                <p class="text-sm text-gray-600">Are you sure you want to approve and verify this guide profile?</p>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Comments (Optional)</label>
                <textarea x-model="approveComment" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary text-sm" placeholder="Send a welcome note or comment..."></textarea>
            </div>

            <div class="flex gap-3">
                <button @@click="showApproveModal = false" class="flex-1 px-6 py-3 bg-gray-100 text-gray-900 rounded-xl font-semibold hover:bg-gray-200 transition-all text-sm">
                    Cancel
                </button>
                <button @@click="verifyGuide()" class="flex-1 px-6 py-3 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700 transition-all text-sm shadow-md">
                    Verify
                </button>
            </div>
        </div>
    </div>

    <!-- Reject Modal -->
    <div x-show="showRejectModal" class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4" x-cloak>
        <div class="bg-white rounded-2xl max-w-md w-full p-8 shadow-2xl animate-in fade-in zoom-in-95 duration-200">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-4xl text-red-600 font-bold">cancel</span>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Reject Application</h3>
                <p class="text-sm text-gray-600">Please provide a clear rejection reason to send to the guide.</p>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Rejection Reason (Required)</label>
                <textarea x-model="rejectReason" rows="4" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 text-sm" placeholder="Example: Document is blurry, missing photo ID..."></textarea>
            </div>

            <div class="flex gap-3">
                <button @@click="showRejectModal = false" class="flex-1 px-6 py-3 bg-gray-100 text-gray-900 rounded-xl font-semibold hover:bg-gray-200 transition-all text-sm">
                    Cancel
                </button>
                <button @@click="rejectGuide()" class="flex-1 px-6 py-3 bg-red-600 text-white rounded-xl font-semibold hover:bg-red-700 transition-all text-sm shadow-md">
                    Reject
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Set active tab styling dynamically based on path
            const path = window.location.pathname;
            let activeEl = null;
            if (path.includes("/Admin/Dashboard") || path === "/Admin" || path === "/admin") {
                activeEl = document.getElementById("nav-dashboard");
            } else if (path.includes("/Admin/GuideApprovals")) {
                activeEl = document.getElementById("nav-approvals");
            } else if (path.includes("/Admin/Escrow")) {
                activeEl = document.getElementById("nav-escrow");
            } else if (path.includes("/Admin/Moderation")) {
                activeEl = document.getElementById("nav-moderation");
            } else if (path.includes("/Admin/Guides")) {
                activeEl = document.getElementById("nav-guides");
            } else if (path.includes("/Admin/Analytics")) {
                activeEl = document.getElementById("nav-analytics");
            }
            
            if (activeEl) {
                activeEl.className = "flex items-center gap-4 px-6 py-3 bg-orange-100 text-primary border-l-4 border-primary rounded-r-full my-1 font-medium transition-all duration-200";
            }

            // Render Admin User Profile info
            const email = localStorage.getItem("userEmail");
            const role = localStorage.getItem("userRole");
            if (email) {
                const nameEl = document.getElementById("sidebarAdminName");
                if (nameEl) nameEl.textContent = email.split('@@')[0];
            }
            if (role) {
                const roleEl = document.getElementById("sidebarAdminRole");
                if (roleEl) roleEl.textContent = role === "admin" ? "Super Admin" : role;
            }

            // Load pending guide count and update badge
            async function loadPendingGuideCount() {
                try {
                    const response = await fetch('/Admin/GetPendingCount');
                    const data = await response.json();
                    
                    if (data.count > 0) {
                        const badge = document.getElementById('guideBadge');
                        const countBadge = document.getElementById('guideCount');
                        
                        if (badge) badge.classList.remove('hidden');
                        if (countBadge) {
                            countBadge.classList.remove('hidden');
                            countBadge.textContent = data.count;
                        }
                    }
                } catch (error) {
                    console.error('Error loading pending count:', error);
                }
            }

            loadPendingGuideCount();
            setInterval(loadPendingGuideCount, 30000);
        });

        // Logout function
        window.logout = function() {
            if (confirm('Are you sure you want to log out?')) {
                localStorage.removeItem('accessToken');
                localStorage.removeItem('refreshToken');
                localStorage.removeItem('userEmail');
                localStorage.removeItem('userId');
                localStorage.removeItem('userRole');
                window.location.href = '/Auth/Login';
            }
        }

        // Show development toast
        window.showDevelopmentToast = function(event, featureName) {
            event.preventDefault();
            const toast = document.createElement("div");
            toast.className = "fixed top-6 right-6 z-[100] bg-gray-900 text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 border border-gray-800 transform translate-y-2 opacity-0 transition-all duration-300";
            toast.innerHTML = `
                <span class="material-symbols-outlined text-amber-500 animate-bounce">construction</span>
                <div>
                    <p class="font-bold text-sm">Feature ${featureName}</p>
                    <p class="text-xs text-gray-400">Under development and coming soon!</p>
                </div>
            `;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove("translate-y-2", "opacity-0");
            }, 10);
            setTimeout(() => {
                toast.classList.add("translate-y-2", "opacity-0");
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 3000);
        }
    </script>
</body>
</html>
