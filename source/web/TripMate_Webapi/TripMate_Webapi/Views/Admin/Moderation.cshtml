@{
    ViewData["Title"] = "Content & Disputes Moderation";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TripMate | Content & Disputes</title>
    <script>
        // Front-end JWT and role authorization check
        (function() {
            const token = localStorage.getItem('accessToken');
            const role = localStorage.getItem('userRole');
            const email = localStorage.getItem('userEmail');
            
            if (!token || (role !== 'admin' && email !== 'admin@tripmate.com' && email !== 'admin2@tripmate.com')) {
                window.location.href = '/Auth/Login';
            }
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#FF6B35',
                        'primary-dark': '#E55A2B',
                        secondary: '#004E89',
                        accent: '#F7B801',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.5);
        }
    </style>
</head>
<body class="bg-gray-50 flex" x-data="{
    activeTab: 'reviews',
    users: [],
    reviews: [],
    disputes: [],
    chatLogs: [],
    searchBookingId: '',
    showModerateModal: false,
    moderateReviewId: '',
    moderateAdminNote: '',

    async loadUsers() {
        const res = await fetch('/api/admin/users', {
            headers: { 'Authorization': `Bearer ${localStorage.getItem('accessToken')}` }
        });
        if (res.ok) this.users = await res.json();
    },

    async loadReviews() {
        const res = await fetch('/api/admin/reviews', {
            headers: { 'Authorization': `Bearer ${localStorage.getItem('accessToken')}` }
        });
        if (res.ok) this.reviews = await res.json();
    },

    async loadDisputes() {
        const res = await fetch('/api/admin/bookings', {
            headers: { 'Authorization': `Bearer ${localStorage.getItem('accessToken')}` }
        });
        if (res.ok) {
            const all = await res.json();
            // Filter bookings with status cancelled (3) or having cancel_reason
            this.disputes = all.filter(b => b.status === 3 || b.cancel_reason);
        }
    },

    async toggleUserStatus(id, isActive) {
        if (!confirm(`Are you sure you want to ${isActive ? 'activate' : 'suspend'} this account?`)) return;
        const res = await fetch(`/api/admin/users/${id}/toggle-status`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
            },
            body: JSON.stringify({ isActive: isActive })
        });
        const data = await res.json();
        alert(data.message);
        if (res.ok) this.loadUsers();
    },

    async changeUserRole(id, role) {
        if (!role) return;
        if (!confirm(`Are you sure you want to force change this user's role to '${role}'?`)) return;
        const res = await fetch(`/api/admin/users/${id}/role`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
            },
            body: JSON.stringify({ role: role })
        });
        const data = await res.json();
        alert(data.message);
        if (res.ok) this.loadUsers();
    },

    openModerateReview(id) {
        this.moderateReviewId = id;
        this.moderateAdminNote = '';
        this.showModerateModal = true;
    },

    async submitModerateReview() {
        if (!this.moderateAdminNote.trim()) return alert('Please enter a reason to hide the review');
        const res = await fetch(`/api/admin/reviews/${this.moderateReviewId}/moderate`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
            },
            body: JSON.stringify({ adminNote: this.moderateAdminNote })
        });
        const data = await res.json();
        alert(data.message);
        if (res.ok) {
            this.showModerateModal = false;
            this.loadReviews();
        }
    },

    async handleCancelRequest(id, approve) {
        const actionText = approve ? 'approve cancellation' : 'reject cancellation';
        if (!confirm(`Are you sure you want to ${actionText} this booking?`)) return;

        const res = await fetch(`/api/admin/bookings/${id}/cancel-approve`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
            },
            body: JSON.stringify({ approve: approve })
        });
        const data = await res.json();
        alert(data.message);
        if (res.ok) this.loadDisputes();
    },

    async loadChatLogs() {
        if (!this.searchBookingId.trim()) return alert('Please enter a Booking ID');
        const res = await fetch(`/api/admin/chat/logs?bookingId=${this.searchBookingId}`, {
            headers: { 'Authorization': `Bearer ${localStorage.getItem('accessToken')}` }
        });
        if (res.ok) {
            this.chatLogs = await res.json();
        } else {
            alert('No conversation found for this Booking ID');
            this.chatLogs = [];
        }
    },

    logout() {
        if (confirm('Are you sure you want to log out?')) {
            localStorage.removeItem('accessToken');
            localStorage.removeItem('refreshToken');
            localStorage.removeItem('userEmail');
            localStorage.removeItem('userId');
            localStorage.removeItem('userRole');
            window.location.href = '/Auth/Login';
        }
    },

    init() {
        this.loadReviews();
        this.loadDisputes();
    }
}">

    <!-- Side Navigation Bar -->
    <aside class="fixed left-0 top-0 h-screen w-[280px] bg-white border-r border-gray-200 flex flex-col py-8 pr-4 z-50">
        <div class="px-6 mb-10">
            <div class="flex items-center gap-3 mb-2">
                <img src="/images/logo.svg" alt="TripMate" class="w-10 h-10">
                <h1 class="text-2xl font-bold text-primary">TripMate</h1>
            </div>
            <p class="text-sm text-gray-600">Admin Portal</p>
        </div>

        <nav class="flex-grow flex flex-col gap-1">
            <a id="nav-dashboard" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a id="nav-approvals" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200 relative" href="/Admin/GuideApprovals">
                <span class="material-symbols-outlined">badge</span>
                <span>Guide Approvals</span>
                <span id="guideBadge" class="hidden absolute top-2 right-4 w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                <span id="guideCount" class="hidden absolute top-1 right-2 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"></span>
            </a>
            <a id="nav-escrow" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Escrow">
                <span class="material-symbols-outlined">payments</span>
                <span>Escrow & Finance</span>
            </a>
            <a id="nav-moderation" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Moderation">
                <span class="material-symbols-outlined">gavel</span>
                <span>Content & Disputes</span>
            </a>
            <a id="nav-guides" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Guides">
                <span class="material-symbols-outlined">assignment_ind</span>
                <span>Guides</span>
            </a>
            <a id="nav-users" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Users">
                <span class="material-symbols-outlined">group</span>
                <span>Users</span>
            </a>
            <a id="nav-bookings" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Bookings">
                <span class="material-symbols-outlined">explore</span>
                <span>Bookings</span>
            </a>
            <a id="nav-analytics" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Analytics">
                <span class="material-symbols-outlined">insights</span>
                <span>Analytics</span>
            </a>
        </nav>

        <div class="px-4 mt-auto">
            <div class="mt-6 px-4 py-4 flex items-center gap-3 border-t border-gray-200">
                <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">person</span>
                </div>
                <div class="flex-1">
                    <p id="sidebarAdminName" class="font-medium text-gray-900">Admin User</p>
                    <p id="sidebarAdminRole" class="text-xs text-gray-500">Super Admin</p>
                </div>
                <button onclick="logout()" class="p-2 hover:bg-red-50 rounded-lg transition-all group" title="Logout">
                    <span class="material-symbols-outlined text-gray-400 group-hover:text-red-600">logout</span>
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="ml-[280px] w-[calc(100%-280px)] min-h-screen p-12 bg-gray-50 flex flex-col gap-8">
        <!-- Header -->
        <header>
            <h2 class="text-5xl font-bold text-gray-900 mb-2">Content & Disputes</h2>
            <p class="text-lg text-gray-600">Moderate content, resolve booking disputes, view chat logs, manage user accounts, and review reports.</p>
        </header>

        <div class="flex gap-4 border-b border-gray-200 pb-4">
            <button @@click="activeTab = 'reviews'" :class="activeTab === 'reviews' ? 'bg-primary text-white font-bold' : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'" class="px-6 py-2.5 rounded-lg shadow-sm transition-all text-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">reviews</span>
                Review Moderation
            </button>
            <button @@click="activeTab = 'disputes'" :class="activeTab === 'disputes' ? 'bg-primary text-white font-bold' : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'" class="px-6 py-2.5 rounded-lg shadow-sm transition-all text-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">dangerous</span>
                Dispute Queue
            </button>
            <button @@click="activeTab = 'chat'" :class="activeTab === 'chat' ? 'bg-primary text-white font-bold' : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'" class="px-6 py-2.5 rounded-lg shadow-sm transition-all text-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">chat</span>
                Chat Log Viewer
            </button>
        </div>


        <!-- TAB CONTENT: Review Moderation -->
        <div x-show="activeTab === 'reviews'" class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden" x-cloak>
            <div class="px-8 py-5 border-b border-gray-200">
                <h3 class="text-xl font-bold text-gray-900">Review Moderation</h3>
                <p class="text-xs text-gray-500 mt-1">View and hide reviews violating community standards.</p>
            </div>
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 text-xs font-bold uppercase tracking-wider border-b border-gray-200">
                        <th class="py-4 px-6">Reviewer</th>
                        <th class="py-4 px-6">Rating</th>
                        <th class="py-4 px-6">Comment Content</th>
                        <th class="py-4 px-6 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm">
                    <template x-for="r in reviews" :key="r.id">
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-6">
                                <p class="font-bold text-gray-900" x-text="r.profiles?.full_name || 'N/A'"></p>
                                <p class="text-xs text-gray-400" x-text="r.profiles?.email || ''"></p>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex text-amber-400">
                                    <template x-for="i in r.rating">
                                        <span class="material-symbols-outlined text-sm">star</span>
                                    </template>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-gray-700" x-text="r.comment || '(No comment)'"></td>
                            <td class="py-4 px-6 text-center">
                                <button :disabled="r.comment && (r.comment.includes('[Review hidden') || r.comment.includes('[Đánh giá bị ẩn'))" 
                                        @@click="openModerateReview(r.id)"
                                        :class="r.comment && (r.comment.includes('[Review hidden') || r.comment.includes('[Đánh giá bị ẩn')) ? 'bg-gray-100 text-gray-400 cursor-not-allowed' : 'bg-red-50 text-red-600 hover:bg-red-100'"
                                        class="px-4 py-1.5 rounded-lg font-bold text-xs transition-all">
                                    Hide Review
                                </button>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>

        <!-- TAB CONTENT: Dispute Queue -->
        <div x-show="activeTab === 'disputes'" class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden" x-cloak>
            <div class="px-8 py-5 border-b border-gray-200">
                <h3 class="text-xl font-bold text-gray-900">Tour Cancellation & Dispute Requests</h3>
                <p class="text-xs text-gray-500 mt-1">Approve refunds or resolve cancellation requests after confirmation.</p>
            </div>
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 text-xs font-bold uppercase tracking-wider border-b border-gray-200">
                        <th class="py-4 px-6">Booking ID</th>
                        <th class="py-4 px-6">Tour Info</th>
                        <th class="py-4 px-6">Cancel Reason</th>
                        <th class="py-4 px-6 text-right">Total Amount</th>
                        <th class="py-4 px-6 text-center">Status</th>
                        <th class="py-4 px-6 text-center">Dispute Resolution</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm">
                    <template x-for="d in disputes" :key="d.id">
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-6 font-mono text-xs text-gray-500" x-text="d.id"></td>
                            <td class="py-4 px-6">
                                <p class="font-bold text-gray-900" x-text="d.experience_packages?.title || 'Original Tour'"></p>
                                <p class="text-xs text-gray-400" x-text="'Guide: ' + (d.experience_packages?.guide_profiles?.profiles?.full_name || 'N/A')"></p>
                            </td>
                            <td class="py-4 px-6 text-red-600 font-semibold" x-text="d.cancel_reason || 'No reason provided'"></td>
                            <td class="py-4 px-6 text-right font-bold text-gray-900" x-text="d.total_amount.toLocaleString('vi-VN') + '₫'"></td>
                            <td class="py-4 px-6 text-center">
                                <span :class="d.status === 3 ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800'" class="px-2 py-0.5 rounded text-xs font-bold" x-text="d.status === 3 ? 'Cancel Request' : 'Other'"></span>
                            </td>
                            <td class="py-4 px-6 text-center">
                                <div class="flex justify-center gap-2">
                                    <button @@click="handleCancelRequest(d.id, true)" class="px-3 py-1 bg-green-600 text-white rounded font-bold text-xs hover:bg-green-700 transition-all flex items-center gap-1">
                                        <span class="material-symbols-outlined text-xs">done</span> Approve Cancel
                                    </button>
                                    <button @@click="handleCancelRequest(d.id, false)" class="px-3 py-1 bg-gray-500 text-white rounded font-bold text-xs hover:bg-gray-600 transition-all flex items-center gap-1">
                                        <span class="material-symbols-outlined text-xs">close</span> Reject
                                    </button>
                                </div>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>

        <!-- TAB CONTENT: Chat Log Viewer -->
        <div x-show="activeTab === 'chat'" class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 flex flex-col gap-6" x-cloak>
            <div>
                <h3 class="text-xl font-bold text-gray-900">Chat Log Viewer</h3>
                <p class="text-xs text-gray-500 mt-1">Access chat history for bookings reported for policy violations.</p>
            </div>

            <!-- Search Bar -->
            <div class="flex gap-3 max-w-lg">
                <input type="text" x-model="searchBookingId" class="flex-grow px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary text-sm font-mono" placeholder="Enter Booking ID to check...">
                <button @@click="loadChatLogs()" class="px-6 py-2.5 bg-primary text-white font-bold rounded-xl hover:bg-primary-dark shadow-sm transition-all flex items-center gap-2 text-sm">
                    <span class="material-symbols-outlined text-sm">search</span>
                    Retrieve
                </button>
            </div>

            <!-- Chat Transcript -->
            <div class="border border-gray-200 rounded-xl bg-gray-50 h-[450px] flex flex-col overflow-hidden">
                <div class="px-6 py-3 bg-gray-100 border-b border-gray-200 flex justify-between items-center text-xs font-bold text-gray-500 uppercase">
                    <span>Conversation Content</span>
                    <span x-text="chatLogs.length + ' messages'"></span>
                </div>

                <div class="flex-grow p-6 overflow-y-auto flex flex-col gap-4">
                    <template x-for="m in chatLogs" :key="m.id">
                        <div :class="m.sender_id === chatLogs[0].sender_id ? 'items-start' : 'items-end'" class="flex flex-col gap-1 max-w-[70%] self-start" :style="m.sender_id !== chatLogs[0].sender_id ? 'align-self: flex-end;' : ''">
                            <span class="text-xs text-gray-500 font-bold" x-text="m.sender?.full_name || 'Member'"></span>
                            <div :class="m.sender_id === chatLogs[0].sender_id ? 'bg-white text-gray-800 border-gray-200' : 'bg-primary text-white border-transparent'" class="px-4 py-2.5 rounded-2xl border text-sm shadow-sm leading-relaxed" x-text="m.message_text"></div>
                            <span class="text-[10px] text-gray-400 mt-0.5" x-text="new Date(m.sent_at).toLocaleString('en-US')"></span>
                        </div>
                    </template>

                    <template x-if="chatLogs.length === 0">
                        <div class="w-full h-full flex flex-col items-center justify-center text-gray-400 p-8 text-center">
                            <span class="material-symbols-outlined text-5xl mb-2">forum</span>
                            <p class="text-sm">No conversation data yet. Please enter a Booking ID and click 'Retrieve'.</p>
                        </div>
                    </template>
                </div>
            </div>
        </div>
    </main>

    <!-- Review Moderation Modal -->
    <div x-show="showModerateModal" class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4" x-cloak>
        <div class="bg-white rounded-2xl max-w-md w-full p-8 shadow-2xl animate-in fade-in zoom-in-95 duration-200">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-4xl text-red-600 font-bold">hide</span>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Hide Review</h3>
                <p class="text-sm text-gray-600">This review content will be replaced by a moderation notice.</p>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Reason to hide review (Required)</label>
                <textarea x-model="moderateAdminNote" rows="3" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 text-sm" placeholder="Example: Offensive language, harassment..."></textarea>
            </div>

            <div class="flex gap-3">
                <button @@click="showModerateModal = false" class="flex-1 px-6 py-3 bg-gray-100 text-gray-900 rounded-xl font-semibold hover:bg-gray-200 transition-all text-sm">
                    Cancel
                </button>
                <button @@click="submitModerateReview()" class="flex-1 px-6 py-3 bg-red-600 text-white rounded-xl font-semibold hover:bg-red-700 transition-all text-sm shadow-md">
                    Hide Now
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Set active tab styling dynamically based on path
            const path = window.location.pathname;
            let activeEl = null;
            if (path.includes("/Admin/Dashboard") || path === "/Admin" || path === "/admin") {
                activeEl = document.getElementById("nav-dashboard");
            } else if (path.includes("/Admin/GuideApprovals")) {
                activeEl = document.getElementById("nav-approvals");
            } else if (path.includes("/Admin/Escrow")) {
                activeEl = document.getElementById("nav-escrow");
            } else if (path.includes("/Admin/Moderation")) {
                activeEl = document.getElementById("nav-moderation");
            } else if (path.includes("/Admin/Guides")) {
                activeEl = document.getElementById("nav-guides");
            } else if (path.includes("/Admin/Users")) {
                activeEl = document.getElementById("nav-users");
            } else if (path.includes("/Admin/Bookings")) {
                activeEl = document.getElementById("nav-bookings");
            } else if (path.includes("/Admin/Analytics")) {
                activeEl = document.getElementById("nav-analytics");
            }
            
            if (activeEl) {
                activeEl.className = "flex items-center gap-4 px-6 py-3 bg-orange-100 text-primary border-l-4 border-primary rounded-r-full my-1 font-medium transition-all duration-200";
            }

            // Render Admin User Profile info
            const email = localStorage.getItem("userEmail");
            const role = localStorage.getItem("userRole");
            if (email) {
                const nameEl = document.getElementById("sidebarAdminName");
                if (nameEl) nameEl.textContent = email.split('@@')[0];
            }
            if (role) {
                const roleEl = document.getElementById("sidebarAdminRole");
                if (roleEl) roleEl.textContent = role === "admin" ? "Super Admin" : role;
            }

            // Load pending guide count and update badge
            async function loadPendingGuideCount() {
                try {
                    const response = await fetch('/Admin/GetPendingCount');
                    const data = await response.json();
                    
                    if (data.count > 0) {
                        const badge = document.getElementById('guideBadge');
                        const countBadge = document.getElementById('guideCount');
                        
                        if (badge) badge.classList.remove('hidden');
                        if (countBadge) {
                            countBadge.classList.remove('hidden');
                            countBadge.textContent = data.count;
                        }
                    }
                } catch (error) {
                    console.error('Error loading pending count:', error);
                }
            }

            loadPendingGuideCount();
            setInterval(loadPendingGuideCount, 30000);
        });

        // Logout function
        window.logout = function() {
            if (confirm('Are you sure you want to log out?')) {
                localStorage.removeItem('accessToken');
                localStorage.removeItem('refreshToken');
                localStorage.removeItem('userEmail');
                localStorage.removeItem('userId');
                localStorage.removeItem('userRole');
                window.location.href = '/Auth/Login';
            }
        }

        // Show development toast
        window.showDevelopmentToast = function(event, featureName) {
            event.preventDefault();
            const toast = document.createElement("div");
            toast.className = "fixed top-6 right-6 z-[100] bg-gray-900 text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 border border-gray-800 transform translate-y-2 opacity-0 transition-all duration-300";
            toast.innerHTML = `
                <span class="material-symbols-outlined text-amber-500 animate-bounce">construction</span>
                <div>
                    <p class="font-bold text-sm">Feature ${featureName}</p>
                    <p class="text-xs text-gray-400">Under development and coming soon!</p>
                </div>
            `;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove("translate-y-2", "opacity-0");
            }, 10);
            setTimeout(() => {
                toast.classList.add("translate-y-2", "opacity-0");
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 3000);
        }
    </script>
</body>
</html>
