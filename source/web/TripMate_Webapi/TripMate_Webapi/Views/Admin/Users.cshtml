@model List<TripMate_WebAPI.DTOs.Auth.ProfileRow>
@using System.Text.Json
@{
    ViewData["Title"] = "User Management";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TripMate | User Management</title>
    <script>
        // Front-end JWT and role authorization check
        (function() {
            const token = localStorage.getItem('accessToken');
            const role = localStorage.getItem('userRole');
            const email = localStorage.getItem('userEmail');
            
            if (!token || (role !== 'admin' && email !== 'admin@tripmate.com' && email !== 'admin2@tripmate.com')) {
                window.location.href = '/Auth/Login';
            }
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#FF6B35',
                        'primary-dark': '#E55A2B',
                        secondary: '#004E89',
                        accent: '#F7B801',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.5);
        }
        [x-cloak] { display: none !important; }
    </style>
    <script id="users-data" type="application/json">
        @Html.Raw(JsonSerializer.Serialize(Model))
    </script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('usersComponent', (initialUsers) => ({
                users: initialUsers,
                search: '',
                roleFilter: '',
                statusFilter: '',
                
                get filteredUsers() {
                    return this.users.filter(u => {
                        const name = (u.full_name || '').toLowerCase();
                        const email = (u.email || '').toLowerCase();
                        const searchKeyword = this.search.toLowerCase();
                        const matchesSearch = name.includes(searchKeyword) || email.includes(searchKeyword);
                        
                        const matchesRole = this.roleFilter === '' || u.role === this.roleFilter;
                        const matchesStatus = this.statusFilter === '' || 
                                              (this.statusFilter === 'active' && u.is_active) || 
                                              (this.statusFilter === 'suspended' && !u.is_active);
                        
                        return matchesSearch && matchesRole && matchesStatus;
                    });
                },

                showConfirmModal: false,
                confirmUser: null,
                confirmNextState: false,
                isProcessing: false,

                openConfirmModal(u) {
                    this.confirmUser = u;
                    this.confirmNextState = !u.is_active;
                    this.showConfirmModal = true;
                },

                async confirmToggleStatus() {
                    if (!this.confirmUser || this.isProcessing) return;
                    this.isProcessing = true;
                    const u = this.confirmUser;
                    const nextState = this.confirmNextState;

                    try {
                        const res = await fetch(`/api/admin/users/${u.id}/toggle-status`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
                            },
                            body: JSON.stringify({ isActive: nextState })
                        });
                        const data = await res.json();
                        if (res.ok) {
                            u.is_active = nextState;
                            this.showConfirmModal = false;
                        } else {
                            alert(data.message || 'Lỗi khi cập nhật trạng thái');
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Đã xảy ra lỗi khi cập nhật trạng thái.');
                    } finally {
                        this.isProcessing = false;
                    }
                },

                async exportCSV() {
                    try {
                        const res = await fetch('/api/admin/users/export', {
                            headers: {
                                'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
                            }
                        });
                        if (!res.ok) throw new Error('Export failed');
                        
                        const blob = await res.blob();
                        const url = window.URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url;
                        a.download = `users_export_${new Date().toISOString().slice(0,10)}.csv`;
                        document.body.appendChild(a);
                        a.click();
                        a.remove();
                    } catch (err) {
                        alert('Error exporting users: ' + err.message);
                    }
                }
            }));
        });
    </script>
</head>
<body class="bg-gray-50 flex" x-data="usersComponent(JSON.parse(document.getElementById('users-data').textContent))">

    <!-- Side Navigation Bar -->
    <aside class="fixed left-0 top-0 h-screen w-[280px] bg-white border-r border-gray-200 flex flex-col py-8 pr-4 z-50">
        <div class="px-6 mb-10">
            <div class="flex items-center gap-3 mb-2">
                <img src="/images/AVATAR.png" alt="TripMate Logo" class="h-10 w-10 rounded-full object-cover">
                <h1 class="text-2xl font-bold text-primary">TripMate</h1>
            </div>
            <p class="text-sm text-gray-600">Admin Portal</p>
        </div>

        <nav class="flex-grow flex flex-col gap-1">
            <a id="nav-dashboard" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a id="nav-approvals" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200 relative" href="/Admin/GuideApprovals">
                <span class="material-symbols-outlined">badge</span>
                <span>Guide Approvals</span>
                <span id="guideBadge" class="hidden absolute top-2 right-4 w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                <span id="guideCount" class="hidden absolute top-1 right-2 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"></span>
            </a>
            <a id="nav-escrow" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Escrow">
                <span class="material-symbols-outlined">payments</span>
                <span>Escrow & Finance</span>
            </a>
            <a id="nav-moderation" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Moderation">
                <span class="material-symbols-outlined">gavel</span>
                <span>Content & Disputes</span>
            </a>
            <a id="nav-guides" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Guides">
                <span class="material-symbols-outlined">assignment_ind</span>
                <span>Guides</span>
            </a>
            <a id="nav-users" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Users">
                <span class="material-symbols-outlined">group</span>
                <span>Users</span>
            </a>
            <a id="nav-bookings" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Bookings">
                <span class="material-symbols-outlined">explore</span>
                <span>Bookings</span>
            </a>
            <a id="nav-analytics" class="flex items-center gap-4 px-6 py-3 text-gray-600 hover:bg-gray-100 rounded-r-full my-1 font-medium transition-all duration-200" href="/Admin/Analytics">
                <span class="material-symbols-outlined">insights</span>
                <span>Analytics</span>
            </a>
        </nav>

        <div class="px-4 mt-auto">
            <div class="mt-6 px-4 py-4 flex items-center gap-3 border-t border-gray-200">
                <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">person</span>
                </div>
                <div class="flex-1">
                    <p id="sidebarAdminName" class="font-medium text-gray-900">Admin User</p>
                    <p id="sidebarAdminRole" class="text-xs text-gray-500">Super Admin</p>
                </div>
                <button onclick="logout()" class="p-2 hover:bg-red-50 rounded-lg transition-all group" title="Logout">
                    <span class="material-symbols-outlined text-gray-400 group-hover:text-red-600">logout</span>
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="ml-[280px] w-[calc(100%-280px)] min-h-screen p-12 bg-gray-50">
        <!-- Header -->
        <header class="flex justify-between items-end mb-10">
            <div>
                <h2 class="text-5xl font-bold text-gray-900 mb-2">User Directory</h2>
                <p class="text-lg text-gray-600">Manage all registered accounts, view basic information, and suspend/activate users.</p>
            </div>
            <div>
                <button @@click="exportCSV()" class="bg-white text-gray-900 px-6 py-3 rounded-lg font-bold border border-gray-200 hover:bg-gray-100 shadow-sm transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">download</span>
                    Export Users (CSV)
                </button>
            </div>
        </header>

        <!-- Controls Toolbar (Search & Filter) -->
        <div class="glass-panel p-6 rounded-2xl mb-8 flex flex-col md:flex-row justify-between items-stretch md:items-center gap-4 shadow-sm">
            <div class="flex-1 relative">
                <span class="material-symbols-outlined absolute left-4 top-3 text-gray-400">search</span>
                <input type="text" x-model="search" placeholder="Search by name or email..." 
                       class="w-full pl-12 pr-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary text-sm transition-all outline-none">
            </div>
            
            <div class="flex flex-wrap gap-3">
                <select x-model="roleFilter" class="px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary text-sm outline-none transition-all">
                    <option value="">-- All Roles --</option>
                    <option value="traveler">Traveler</option>
                    <option value="guide">Guide</option>
                    <option value="admin">Admin</option>
                </select>

                <select x-model="statusFilter" class="px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary text-sm outline-none transition-all">
                    <option value="">-- All Statuses --</option>
                    <option value="active">Active</option>
                    <option value="suspended">Suspended</option>
                </select>
            </div>
        </div>

        <!-- Table Card -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="px-8 py-5 border-b border-gray-200 flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-900">User List</h3>
                <span class="bg-orange-50 text-primary border border-orange-200 px-3 py-1 rounded-full text-xs font-semibold" x-text="`${filteredUsers.length} users`"></span>
            </div>

            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 text-xs font-bold uppercase tracking-wider border-b border-gray-200">
                        <th class="py-4 px-6">User / Email</th>
                        <th class="py-4 px-6">Phone Number</th>
                        <th class="py-4 px-6">Role</th>
                        <th class="py-4 px-6 text-center">Status</th>
                        <th class="py-4 px-6 text-center">Registered Date</th>
                        <th class="py-4 px-6 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm">
                    <template x-for="u in filteredUsers" :key="u.id">
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <!-- Name & Email -->
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-primary font-bold overflow-hidden">
                                        <template x-if="u.avatar_url">
                                            <img :src="u.avatar_url" class="w-full h-full object-cover">
                                        </template>
                                        <template x-if="!u.avatar_url">
                                            <span x-text="u.full_name ? u.full_name[0] : 'U'"></span>
                                        </template>
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-900" x-text="u.full_name || 'N/A'"></p>
                                        <p class="text-xs text-gray-400" x-text="u.email || 'N/A'"></p>
                                    </div>
                                </div>
                            </td>
                            
                            <!-- Phone -->
                            <td class="py-4 px-6">
                                <span class="font-medium text-gray-900" x-text="u.phone_number || 'N/A'"></span>
                            </td>

                            <!-- Role -->
                            <td class="py-4 px-6">
                                <span class="px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider"
                                      :class="{
                                          'bg-blue-50 text-blue-700 border border-blue-200': u.role === 'admin',
                                          'bg-purple-50 text-purple-700 border border-purple-200': u.role === 'guide',
                                          'bg-gray-50 text-gray-700 border border-gray-200': u.role === 'traveler'
                                      }"
                                      x-text="u.role">
                                </span>
                            </td>

                            <!-- Status -->
                            <td class="py-4 px-6 text-center">
                                <span class="px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider"
                                      :class="{
                                          'bg-green-50 text-green-700 border border-green-200': u.is_active,
                                          'bg-red-50 text-red-700 border border-red-200': !u.is_active
                                      }"
                                      x-text="u.is_active ? 'Active' : 'Suspended'">
                                </span>
                            </td>

                            <!-- Registered Date -->
                            <td class="py-4 px-6 text-center font-medium text-gray-600">
                                <span x-text="new Date(u.created_at).toLocaleDateString('en-US')"></span>
                            </td>

                            <!-- Actions -->
                            <td class="py-4 px-6 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <template x-if="!u.is_active">
                                        <button @@click="openConfirmModal(u)" class="px-3 py-1.5 bg-green-50 hover:bg-green-100 text-green-600 rounded-lg text-xs font-semibold border border-green-200 transition-all">
                                            Unlock
                                        </button>
                                    </template>
                                    <template x-if="u.is_active">
                                        <button @@click="openConfirmModal(u)" class="px-3 py-1.5 bg-red-50 hover:bg-red-100 text-red-600 rounded-lg text-xs font-semibold border border-red-200 transition-all">
                                            Suspend
                                        </button>
                                    </template>
                                </div>
                              </td>
                        </tr>
                    </template>

                    <template x-if="filteredUsers.length === 0">
                        <tr>
                            <td colspan="6" class="text-center py-16 text-gray-500">
                                <span class="material-symbols-outlined text-4xl block mb-2 text-gray-400">group_off</span>
                                No users found.
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Custom Confirmation Modal -->
    <div x-show="showConfirmModal" class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4" x-cloak x-transition.opacity>
        <div class="bg-white rounded-2xl max-w-md w-full p-8 shadow-2xl transform transition-all duration-200" x-transition.scale.95>
            <div class="text-center mb-6">
                <div :class="confirmNextState ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600'" 
                     class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-4xl font-bold" x-text="confirmNextState ? 'lock_open' : 'block'"></span>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2" x-text="confirmNextState ? 'Mở khóa tài khoản' : 'Khóa tài khoản'"></h3>
                <p class="text-sm text-gray-600">
                    Bạn có chắc chắn muốn <span class="font-semibold text-gray-900" x-text="confirmNextState ? 'kích hoạt lại' : 'tạm khóa'"></span> tài khoản của người dùng 
                    <span class="font-bold text-gray-900" x-text="confirmUser ? confirmUser.full_name : ''"></span>?
                </p>
            </div>

            <div class="flex gap-3">
                <button @@click="showConfirmModal = false" class="flex-1 px-5 py-3 bg-gray-100 text-gray-700 rounded-xl font-semibold hover:bg-gray-200 transition-all text-sm">
                    Hủy bỏ
                </button>
                <button @@click="confirmToggleStatus()" :disabled="isProcessing"
                        :class="confirmNextState ? 'bg-green-600 hover:bg-green-700 text-white' : 'bg-red-600 hover:bg-red-700 text-white'"
                        class="flex-1 px-5 py-3 rounded-xl font-semibold transition-all text-sm flex items-center justify-center gap-2 shadow-md">
                    <span x-show="isProcessing" class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
                    <span x-text="confirmNextState ? 'Kích hoạt' : 'Khóa tài khoản'"></span>
                </button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Set active tab styling dynamically based on path
            const activeEl = document.getElementById("nav-users");
            if (activeEl) {
                activeEl.className = "flex items-center gap-4 px-6 py-3 bg-orange-100 text-primary border-l-4 border-primary rounded-r-full my-1 font-medium transition-all duration-200";
            }

            // Render Admin User Profile info
            const email = localStorage.getItem("userEmail");
            const role = localStorage.getItem("userRole");
            if (email) {
                const nameEl = document.getElementById("sidebarAdminName");
                if (nameEl) nameEl.textContent = email.split('@@')[0];
            }
            if (role) {
                const roleEl = document.getElementById("sidebarAdminRole");
                if (roleEl) roleEl.textContent = role === "admin" ? "Super Admin" : role;
            }

            // Load pending guide count
            async function loadPendingGuideCount() {
                try {
                    const response = await fetch('/Admin/GetPendingCount');
                    const data = await response.json();
                    
                    if (data.count > 0) {
                        const badge = document.getElementById('guideBadge');
                        const countBadge = document.getElementById('guideCount');
                        
                        if (badge) badge.classList.remove('hidden');
                        if (countBadge) {
                            countBadge.classList.remove('hidden');
                            countBadge.textContent = data.count;
                        }
                    }
                } catch (error) {
                    console.error('Error loading pending count:', error);
                }
            }

            loadPendingGuideCount();
            setInterval(loadPendingGuideCount, 30000);
        });

        // Logout
        window.logout = function() {
            if (confirm('Are you sure you want to log out?')) {
                localStorage.removeItem('accessToken');
                localStorage.removeItem('refreshToken');
                localStorage.removeItem('userEmail');
                localStorage.removeItem('userId');
                localStorage.removeItem('userRole');
                window.location.href = '/Auth/Login';
            }
        }
    </script>
</body>
</html>
