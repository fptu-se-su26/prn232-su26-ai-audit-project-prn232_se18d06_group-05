@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="min-h-screen flex items-center justify-center py-16 px-4 bg-gradient-to-br from-primary/5 via-surface to-primary-container/20">
    <div class="w-full max-w-md">
        <!-- Glass Card -->
        <div class="bg-surface/80 backdrop-blur-xl rounded-2xl shadow-2xl border border-outline-variant/30 overflow-hidden">
            <!-- Header -->
            <div class="bg-gradient-to-r from-primary to-primary/80 p-8 text-center">
                <div class="flex justify-center mb-4">
                    <img alt="TripMate Logo" class="h-16 w-16 rounded-full object-cover border-4 border-white/30"
                        src="/images/AVATAR.png" />
                </div>
                <h1 class="text-3xl font-extrabold text-white mb-2">Đặt lại mật khẩu</h1>
                <p class="text-white/90">Tạo mật khẩu mới cho tài khoản của bạn</p>
            </div>

            <!-- Form -->
            <div class="p-8">
                <form id="resetPasswordForm" class="space-y-6">
                    <input type="hidden" id="email" value="@ViewBag.Email" />
                    <input type="hidden" id="token" value="@ViewBag.Token" />

                    <!-- New Password -->
                    <div class="relative">
                        <label class="block text-sm font-bold text-on-surface-variant mb-2 tracking-wide">MẬT KHẨU MỚI</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
                            <input type="password" id="newPassword" required
                                class="w-full pl-12 pr-12 py-3 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface placeholder:text-on-surface-variant/50"
                                placeholder="Nhập mật khẩu mới" />
                            <button type="button" onclick="togglePassword('newPassword', 'toggleIcon1')"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors">
                                <span class="material-symbols-outlined" id="toggleIcon1">visibility</span>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="relative">
                        <label class="block text-sm font-bold text-on-surface-variant mb-2 tracking-wide">XÁC NHẬN MẬT KHẨU</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
                            <input type="password" id="confirmPassword" required
                                class="w-full pl-12 pr-12 py-3 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface placeholder:text-on-surface-variant/50"
                                placeholder="Nhập lại mật khẩu mới" />
                            <button type="button" onclick="togglePassword('confirmPassword', 'toggleIcon2')"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors">
                                <span class="material-symbols-outlined" id="toggleIcon2">visibility</span>
                            </button>
                        </div>
                    </div>

                    <!-- Error Message -->
                    <div id="errorMessage" class="hidden bg-red-50 border-l-4 border-red-500 p-4 rounded-lg">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-red-500">error</span>
                            <p class="text-sm text-red-700 font-medium" id="errorText"></p>
                        </div>
                    </div>

                    <!-- Success Message -->
                    <div id="successMessage" class="hidden bg-green-50 border-l-4 border-green-500 p-4 rounded-lg">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-green-500">check_circle</span>
                            <p class="text-sm text-green-700 font-medium">Đặt lại mật khẩu thành công!</p>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" id="submitBtn"
                        class="w-full bg-primary hover:bg-primary/90 text-on-primary font-bold py-3 rounded-lg transition-all shadow-lg hover:shadow-xl flex items-center justify-center gap-2 group disabled:opacity-70 disabled:cursor-not-allowed">
                        <span>Đặt lại mật khẩu</span>
                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </button>
                </form>

                <!-- Back to Login Link -->
                <div class="mt-8 text-center">
                    <p class="text-on-surface-variant">
                        <a href="/Auth/Login" class="text-primary font-bold hover:underline">← Quay lại đăng nhập</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Loading Spinner -->
<link rel="stylesheet" href="/spinner.css">
<div id="loadingSpinner" class="spinner-overlay" style="display: none;">
    <div class="spinner-container">
        <svg class="pl" width="240" height="240" viewBox="0 0 240 240">
            <circle class="pl__ring pl__ring--a" cx="120" cy="120" r="105" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 660" stroke-dashoffset="-330" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--b" cx="120" cy="120" r="35" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 220" stroke-dashoffset="-110" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--c" cx="85" cy="120" r="70" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 440" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--d" cx="155" cy="120" r="70" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 440" stroke-linecap="round"></circle>
        </svg>
        <p class="spinner-text">Đang xử lý...</p>
    </div>
</div>

<script>
    // Toggle password visibility
    function togglePassword(inputId, iconId) {
        const passwordInput = document.getElementById(inputId);
        const toggleIcon = document.getElementById(iconId);

        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            toggleIcon.textContent = 'visibility_off';
        } else {
            passwordInput.type = 'password';
            toggleIcon.textContent = 'visibility';
        }
    }

    // Show/hide spinner
    function showSpinner() {
        document.getElementById('loadingSpinner').style.display = 'flex';
    }

    function hideSpinner() {
        document.getElementById('loadingSpinner').style.display = 'none';
    }

    // Show error message
    function showError(message) {
        const errorDiv = document.getElementById('errorMessage');
        const errorText = document.getElementById('errorText');
        const successDiv = document.getElementById('successMessage');
        
        successDiv.classList.add('hidden');
        errorText.textContent = message;
        errorDiv.classList.remove('hidden');

        // Auto hide after 5 seconds
        setTimeout(() => {
            errorDiv.classList.add('hidden');
        }, 5000);
    }

    // Show success message
    function showSuccess() {
        const errorDiv = document.getElementById('errorMessage');
        const successDiv = document.getElementById('successMessage');
        
        errorDiv.classList.add('hidden');
        successDiv.classList.remove('hidden');
    }

    // Check if tokens are provided in URL hash (from Supabase Auth)
    window.onload = function() {
        const hash = window.location.hash.substring(1);
        const params = new URLSearchParams(hash);
        const accessToken = params.get('access_token');
        const refreshToken = params.get('refresh_token') || '';
        
        if (accessToken) {
            document.getElementById('token').value = accessToken;
            document.getElementById('email').value = refreshToken; // using email hidden field for refresh_token temporarily
        } else {
            const email = document.getElementById('email').value;
            const token = document.getElementById('token').value;
            if (!email || !token) {
                showError('Link đặt lại mật khẩu không hợp lệ. Vui lòng yêu cầu link mới.');
            }
        }
    };

    // Handle form submission
    document.getElementById('resetPasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const email = document.getElementById('email').value;
        const token = document.getElementById('token').value;
        const newPassword = document.getElementById('newPassword').value;
        const confirmPassword = document.getElementById('confirmPassword').value;

        // Validate passwords
        if (newPassword.length < 6) {
            showError('Mật khẩu phải có ít nhất 6 ký tự');
            return;
        }

        if (newPassword !== confirmPassword) {
            showError('Mật khẩu xác nhận không khớp');
            return;
        }

        if (!email || !token) {
            showError('Thông tin đặt lại mật khẩu không hợp lệ');
            return;
        }

        const submitBtn = document.getElementById('submitBtn');
        submitBtn.disabled = true;
        showSpinner();

        try {
            const response = await fetch('/api/auth/reset-password', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    accessToken: token,
                    refreshToken: email,
                    newPassword: newPassword
                })
            });

            const data = await response.json();

            if (response.ok) {
                hideSpinner();
                showSuccess();
                submitBtn.innerHTML = '<span>Đang chuyển hướng...</span><span class="material-symbols-outlined animate-spin">sync</span>';
                
                // Redirect to login after 2 seconds
                setTimeout(() => {
                    window.location.href = '/Auth/Login';
                }, 2000);
            } else {
                hideSpinner();
                submitBtn.disabled = false;
                showError(data.message || 'Có lỗi xảy ra. Vui lòng thử lại.');
            }
        } catch (error) {
            hideSpinner();
            submitBtn.disabled = false;
            console.error('Reset password error:', error);
            showError('Có lỗi xảy ra. Vui lòng thử lại sau.');
        }
    });
</script>