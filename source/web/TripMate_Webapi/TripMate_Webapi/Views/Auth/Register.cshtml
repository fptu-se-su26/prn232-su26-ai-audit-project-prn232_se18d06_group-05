@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="min-h-screen flex items-center justify-center py-12 px-4 bg-gradient-to-br from-primary/5 via-surface to-primary-container/20">
    <div class="w-full max-w-4xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" id="registerGrid">
            <!-- Main Registration Form -->
            <div class="w-full">
                <div class="bg-surface/80 backdrop-blur-xl rounded-2xl shadow-2xl border border-outline-variant/30 overflow-hidden">
                    <!-- Header -->
                    <div class="bg-gradient-to-r from-primary to-primary/80 p-6 text-center">
                        <div class="flex justify-center mb-3">
                            <img alt="TripMate Logo" class="h-14 w-14 rounded-full object-cover border-4 border-white/30" src="/images/AVATAR.png"/>
                        </div>
                        <h1 class="text-2xl font-extrabold text-white mb-1">Tạo tài khoản mới</h1>
                        <p class="text-white/90 text-sm">Bắt đầu hành trình khám phá của bạn</p>
                    </div>

                    <!-- Form -->
                    <div class="p-6">
                        <form id="registerForm" class="space-y-4">
                            <!-- Full Name -->
                            <div class="relative">
                                <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">HỌ VÀ TÊN</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">person</span>
                                    <input type="text" id="fullName" required
                                        class="w-full pl-10 pr-4 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm placeholder:text-on-surface-variant/50"
                                        placeholder="Nguyễn Văn A" />
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="relative">
                                <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">EMAIL</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">email</span>
                                    <input type="email" id="email" required
                                        class="w-full pl-10 pr-4 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm placeholder:text-on-surface-variant/50"
                                        placeholder="your@email.com" />
                                </div>
                            </div>

                            <!-- Phone Number -->
                            <div class="relative">
                                <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">SỐ ĐIỆN THOẠI</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">phone</span>
                                    <input type="tel" id="phoneNumber" required pattern="[0-9]{10,11}"
                                        class="w-full pl-10 pr-4 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm placeholder:text-on-surface-variant/50"
                                        placeholder="0901234567" />
                                </div>
                                <p class="text-[11px] text-on-surface-variant mt-1 ml-1">10-11 chữ số</p>
                            </div>

                            <!-- Password -->
                            <div class="relative">
                                <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">MẬT KHẨU</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">lock</span>
                                    <input type="password" id="password" required minlength="6"
                                        class="w-full pl-10 pr-10 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm placeholder:text-on-surface-variant/50"
                                        placeholder="••••••••" />
                                </div>
                                <p class="text-[11px] text-on-surface-variant mt-1 ml-1">Tối thiểu 6 ký tự</p>
                            </div>

                            <!-- Confirm Password -->
                            <div class="relative">
                                <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">XÁC NHẬN MẬT KHẨU</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">lock_reset</span>
                                    <input type="password" id="confirmPassword" required minlength="6"
                                        class="w-full pl-10 pr-10 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm placeholder:text-on-surface-variant/50"
                                        placeholder="••••••••" />
                                </div>
                            </div>

                            <!-- Role Selection -->
                            <div class="relative">
                                <label class="block text-xs font-bold text-on-surface-variant mb-2 tracking-wide">VAI TRÒ</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <label class="relative cursor-pointer">
                                        <input type="radio" name="role" value="traveler" checked class="peer sr-only" onchange="toggleGuideForm()"/>
                                        <div class="p-3 bg-surface-variant border-2 border-outline-variant rounded-lg peer-checked:border-primary peer-checked:bg-primary-container transition-all">
                                            <div class="flex flex-col items-center gap-1">
                                                <span class="material-symbols-outlined text-xl text-on-surface-variant peer-checked:text-primary">luggage</span>
                                                <span class="text-xs font-bold text-on-surface">Du khách</span>
                                            </div>
                                        </div>
                                    </label>
                                    <label class="relative cursor-pointer">
                                        <input type="radio" name="role" value="guide" class="peer sr-only" onchange="toggleGuideForm()"/>
                                        <div class="p-3 bg-surface-variant border-2 border-outline-variant rounded-lg peer-checked:border-primary peer-checked:bg-primary-container transition-all">
                                            <div class="flex flex-col items-center gap-1">
                                                <span class="material-symbols-outlined text-xl text-on-surface-variant peer-checked:text-primary">badge</span>
                                                <span class="text-xs font-bold text-on-surface">Hướng dẫn viên</span>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <!-- Terms -->
                            <div class="flex items-start gap-2">
                                <input type="checkbox" id="terms" required class="mt-0.5 w-3.5 h-3.5 rounded border-outline-variant text-primary focus:ring-primary/20"/>
                                <label for="terms" class="text-xs text-on-surface-variant">
                                    Tôi đồng ý với <a href="/Home/TermsOfService" target="_blank" class="text-primary font-bold hover:underline">Điều khoản dịch vụ</a> và <a href="/Home/PrivacyPolicy" target="_blank" class="text-primary font-bold hover:underline">Chính sách bảo mật</a>
                                </label>
                            </div>

                            <!-- Error Message -->
                            <div id="errorMessage" class="hidden bg-red-50 border-l-4 border-red-500 p-3 rounded-lg">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-red-500 text-[18px]">error</span>
                                    <p class="text-xs text-red-700 font-medium" id="errorText"></p>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit"
                                class="w-full bg-primary hover:bg-primary/90 text-on-primary font-bold py-2.5 rounded-lg transition-all shadow-lg hover:shadow-xl flex items-center justify-center gap-2 group text-sm">
                                <span>Đăng ký</span>
                                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform text-[18px]">arrow_forward</span>
                            </button>
                        </form>

                        <!-- Login Link -->
                        <div class="mt-5 text-center">
                            <p class="text-on-surface-variant text-sm">
                                Đã có tài khoản?
                                <a href="/Auth/Login" class="text-primary font-bold hover:underline">Đăng nhập ngay</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Guide Additional Information Form — grid sibling, shown only when guide role selected -->
            <div id="guideForm" class="w-full hidden">
                <div class="bg-surface/80 backdrop-blur-xl rounded-2xl shadow-2xl border border-outline-variant/30 overflow-hidden">
                    <!-- Header -->
                    <div class="bg-gradient-to-r from-secondary to-secondary/80 p-5 text-center">
                        <div class="flex justify-center mb-2">
                            <span class="material-symbols-outlined text-3xl text-white">verified</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-white mb-1">Thông tin hướng dẫn viên</h2>
                        <p class="text-white/90 text-xs">Cung cấp thêm thông tin để xác minh</p>
                    </div>

                    <!-- Form -->
                    <div class="p-5 space-y-4">
                        <!-- Experience -->
                        <div class="relative">
                            <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">KINH NGHIỆM (NĂM)</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">work_history</span>
                                <select id="experience"
                                    class="w-full pl-10 pr-4 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm">
                                    <option value="">Chọn kinh nghiệm</option>
                                    <option value="0-1">Dưới 1 năm</option>
                                    <option value="1-3">1-3 năm</option>
                                    <option value="3-5">3-5 năm</option>
                                    <option value="5-10">5-10 năm</option>
                                    <option value="10+">Trên 10 năm</option>
                                </select>
                            </div>
                        </div>

                        <!-- Specialization -->
                        <div class="relative">
                            <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">CHUYÊN MÔN</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">category</span>
                                <select id="specialization"
                                    class="w-full pl-10 pr-4 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm">
                                    <option value="">Chọn chuyên môn</option>
                                    <option value="cultural">Du lịch văn hóa</option>
                                    <option value="adventure">Du lịch mạo hiểm</option>
                                    <option value="nature">Du lịch sinh thái</option>
                                    <option value="food">Du lịch ẩm thực</option>
                                    <option value="historical">Du lịch lịch sử</option>
                                    <option value="beach">Du lịch biển</option>
                                    <option value="mountain">Du lịch núi</option>
                                </select>
                            </div>
                        </div>

                        <!-- Languages -->
                        <div class="relative">
                            <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">NGÔN NGỮ</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">translate</span>
                                <input type="text" id="languages"
                                    class="w-full pl-10 pr-4 py-2.5 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm placeholder:text-on-surface-variant/50"
                                    placeholder="Tiếng Việt, English, 中文" />
                            </div>
                            <p class="text-[11px] text-on-surface-variant mt-1 ml-1">Các ngôn ngữ bạn có thể giao tiếp</p>
                        </div>

                        <!-- Certificate Upload -->
                        <div class="relative">
                            <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">CHỨNG CHỈ HƯỚNG DẪN VIÊN</label>
                            <div class="relative">
                                <input type="file" id="certificateFile" accept=".pdf" class="hidden" onchange="handleFileUpload(this)" />
                                <div id="uploadArea"
                                    class="w-full p-4 bg-surface-variant border-2 border-dashed border-outline-variant rounded-lg hover:border-primary transition-all cursor-pointer text-center"
                                    onclick="document.getElementById('certificateFile').click()">
                                    <span class="material-symbols-outlined text-3xl text-on-surface-variant mb-1 block">cloud_upload</span>
                                    <p class="text-on-surface font-medium text-sm mb-0.5">Nhấp để tải lên chứng chỉ</p>
                                    <p class="text-[11px] text-on-surface-variant">PDF, tối đa 10MB</p>
                                </div>
                            </div>
                            
                            <!-- File Preview -->
                            <div id="filePreview" class="hidden mt-3 p-3 bg-primary-container rounded-lg">
                                <div class="flex items-center gap-3">
                                    <span class="material-symbols-outlined text-xl text-primary flex-shrink-0">picture_as_pdf</span>
                                    <div class="flex-1 min-w-0">
                                        <p id="fileName" class="text-xs font-medium text-on-primary-container truncate"></p>
                                        <p id="fileSize" class="text-[11px] text-on-primary-container/70"></p>
                                    </div>
                                    <button type="button" onclick="removeFile()" class="flex-shrink-0 p-1 hover:bg-primary/20 rounded-full transition-colors">
                                        <span class="material-symbols-outlined text-primary text-[18px]">close</span>
                                    </button>
                                </div>
                                <div id="pdfThumbnail" class="mt-2 p-2 bg-surface rounded-lg border border-outline-variant/30">
                                    <div class="flex items-center justify-center h-24 bg-surface-variant rounded border-2 border-dashed border-outline-variant">
                                        <div class="text-center">
                                            <span class="material-symbols-outlined text-3xl text-on-surface-variant mb-1 block">description</span>
                                            <p class="text-xs text-on-surface-variant">PDF Preview</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Bio -->
                        <div class="relative">
                            <label class="block text-xs font-bold text-on-surface-variant mb-1.5 tracking-wide">GIỚI THIỆU BẢN THÂN</label>
                            <textarea id="bio" rows="3"
                                class="w-full p-3 bg-surface-variant border-2 border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-on-surface text-sm placeholder:text-on-surface-variant/50 resize-none"
                                placeholder="Chia sẻ về kinh nghiệm và đam mê của bạn..."></textarea>
                            <p class="text-[11px] text-on-surface-variant mt-1 ml-1">Tối đa 500 ký tự</p>
                        </div>

                        <!-- Verification Note -->
                        <div class="bg-blue-50 border-l-4 border-blue-500 p-3 rounded-lg">
                            <div class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-blue-500 mt-0.5 text-[18px]">info</span>
                                <div>
                                    <p class="text-xs text-blue-700 font-medium mb-0.5">Xác minh tài khoản</p>
                                    <p class="text-[11px] text-blue-600">
                                        Thông tin sẽ được xem xét trong 24-48 giờ. Bạn sẽ nhận email thông báo kết quả.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Loading Spinner -->
<link rel="stylesheet" href="/spinner.css">
<div id="loadingSpinner" class="spinner-overlay" style="display: none;">
    <div class="spinner-container">
        <svg class="pl" width="240" height="240" viewBox="0 0 240 240">
            <circle class="pl__ring pl__ring--a" cx="120" cy="120" r="105" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 660" stroke-dashoffset="-330" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--b" cx="120" cy="120" r="35" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 220" stroke-dashoffset="-110" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--c" cx="85" cy="120" r="70" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 440" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--d" cx="155" cy="120" r="70" fill="none" stroke="#000" stroke-width="20"
                stroke-dasharray="0 440" stroke-linecap="round"></circle>
        </svg>
        <p class="spinner-text">Đang tạo tài khoản...</p>
    </div>
</div>

<!-- Guide Pending Approval Screen -->
<div id="guidePendingScreen" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9998; justify-content:center; align-items:center;">
    <div style="background:white; border-radius:20px; max-width:480px; width:90%; padding:40px; text-align:center; box-shadow:0 25px 60px rgba(0,0,0,0.3);">
        <div style="width:80px; height:80px; background:linear-gradient(135deg,#FF6B35,#FF8C42); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 24px;">
            <span class="material-symbols-outlined" style="font-size:40px; color:white;">schedule</span>
        </div>
        <h2 style="color:#1a1a2e; font-size:24px; font-weight:800; margin-bottom:12px;">Đăng ký thành công!</h2>
        <p style="color:#FF6B35; font-size:16px; font-weight:700; margin-bottom:16px;">Tài khoản đang chờ phê duyệt</p>
        <p style="color:#555; font-size:14px; line-height:1.6; margin-bottom:28px;">
            Hồ sơ Hướng dẫn viên của bạn đã được gửi đến Admin TripMate.<br/>
            Chúng tôi sẽ xem xét và gửi kết quả qua email trong vòng <strong>24–48 giờ</strong>.
        </p>
        <div style="background:#fff8f5; border:1px solid #ffe0d0; border-radius:10px; padding:16px; margin-bottom:24px;">
            <p style="color:#FF6B35; font-size:13px; font-weight:600; margin:0;">📧 Kiểm tra email của bạn để nhận thông báo kết quả từ TripMate!</p>
        </div>
        <a href="/Auth/Login" style="display:inline-block; background:linear-gradient(135deg,#FF6B35,#FF8C42); color:white; padding:12px 32px; border-radius:10px; text-decoration:none; font-weight:700; font-size:15px;">Về trang đăng nhập</a>
    </div>
</div>

<script>
    // ponytail: toggle guide form as grid sibling — fixed layout bug
    function toggleGuideForm() {
        const guideForm = document.getElementById('guideForm');
        const grid = document.getElementById('registerGrid');
        const selectedRole = document.querySelector('input[name="role"]:checked').value;
        
        if (selectedRole === 'guide') {
            guideForm.classList.remove('hidden');
            guideForm.classList.add('animate-fade-in');
            // Ensure grid shows 2 columns on lg when guide form visible
            grid.classList.remove('lg:grid-cols-1');
            grid.classList.add('lg:grid-cols-2');
        } else {
            guideForm.classList.add('hidden');
            guideForm.classList.remove('animate-fade-in');
            // Single column when only traveler form
            grid.classList.remove('lg:grid-cols-2');
            grid.classList.add('lg:grid-cols-1');
        }
    }

    // ponytail: init — traveler is default, single column
    document.getElementById('registerGrid').classList.remove('lg:grid-cols-2');
    document.getElementById('registerGrid').classList.add('lg:grid-cols-1');

    function handleFileUpload(input) {
        const file = input.files[0];
        if (!file) return;
        if (file.type !== 'application/pdf') { alert('Vui lòng chọn file PDF!'); input.value = ''; return; }
        if (file.size > 10 * 1024 * 1024) { alert('File quá lớn! Vui lòng chọn file dưới 10MB.'); input.value = ''; return; }
        showFilePreview(file);
    }

    function showFilePreview(file) {
        document.getElementById('uploadArea').classList.add('hidden');
        document.getElementById('filePreview').classList.remove('hidden');
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = formatFileSize(file.size);
        generatePDFThumbnail(file);
    }

    function removeFile() {
        document.getElementById('certificateFile').value = '';
        document.getElementById('uploadArea').classList.remove('hidden');
        document.getElementById('filePreview').classList.add('hidden');
    }

    function formatFileSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }

    function generatePDFThumbnail(file) {
        document.getElementById('pdfThumbnail').innerHTML = `
            <div class="flex items-center justify-center h-24 bg-surface-variant rounded border-2 border-dashed border-outline-variant">
                <div class="text-center">
                    <span class="material-symbols-outlined text-3xl text-red-500 mb-1 block">picture_as_pdf</span>
                    <p class="text-xs font-medium text-on-surface">${file.name}</p>
                    <p class="text-[11px] text-on-surface-variant">${formatFileSize(file.size)}</p>
                </div>
            </div>
        `;
    }

    function togglePassword(fieldId) {
        const p = document.getElementById(fieldId);
        const icon = document.getElementById('toggleIcon' + fieldId.charAt(0).toUpperCase() + fieldId.slice(1));
        const isHidden = p.type === 'password';
        p.type = isHidden ? 'text' : 'password';
        icon.textContent = isHidden ? 'visibility_off' : 'visibility';
    }

    function showSpinner() { document.getElementById('loadingSpinner').style.display = 'flex'; }
    function hideSpinner() { document.getElementById('loadingSpinner').style.display = 'none'; }

    function showError(message) {
        const errorDiv = document.getElementById('errorMessage');
        document.getElementById('errorText').textContent = message;
        errorDiv.classList.remove('hidden');
        setTimeout(() => errorDiv.classList.add('hidden'), 5000);
    }

    document.getElementById('registerForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const fullName = document.getElementById('fullName').value;
        const email = document.getElementById('email').value;
        const phoneNumber = document.getElementById('phoneNumber').value;
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        const role = document.querySelector('input[name="role"]:checked').value;
        const terms = document.getElementById('terms').checked;

        if (password !== confirmPassword) { showError('Mật khẩu xác nhận không khớp!'); return; }
        if (!terms) { showError('Vui lòng đồng ý với điều khoản dịch vụ!'); return; }
        if (!/^[0-9]{10,11}$/.test(phoneNumber)) { showError('Số điện thoại không hợp lệ! Vui lòng nhập 10-11 chữ số.'); return; }

        if (role === 'guide') {
            if (!document.getElementById('experience').value) { showError('Vui lòng chọn kinh nghiệm làm việc!'); return; }
            if (!document.getElementById('specialization').value) { showError('Vui lòng chọn chuyên môn!'); return; }
            if (!document.getElementById('certificateFile').files[0]) { showError('Vui lòng tải lên chứng chỉ hướng dẫn viên!'); return; }
        }

        showSpinner();
        try {
            const formData = new FormData();
            formData.append('email', email);
            formData.append('password', password);
            formData.append('fullName', fullName);
            formData.append('phoneNumber', phoneNumber);
            formData.append('role', role);

            if (role === 'guide') {
                formData.append('experience', document.getElementById('experience').value);
                formData.append('specialization', document.getElementById('specialization').value);
                formData.append('languages', document.getElementById('languages').value);
                formData.append('bio', document.getElementById('bio').value);
                formData.append('certificate', document.getElementById('certificateFile').files[0]);
            }

            const response = await fetch('/api/auth/register', { method: 'POST', body: formData });
            const data = await response.json();

            if (response.ok) {
                hideSpinner();
                if (role === 'guide') {
                    document.getElementById('guidePendingScreen').style.display = 'flex';
                } else if (data.accessToken) {
                    localStorage.setItem('accessToken', data.accessToken);
                    localStorage.setItem('refreshToken', data.refreshToken || '');
                    localStorage.setItem('userEmail', data.user?.email || email);
                    localStorage.setItem('userId', data.user?.id || '');
                    localStorage.setItem('userRole', data.user?.role || role);
                    window.location.href = '/Survey/Personality';
                } else {
                    alert('Đăng ký thành công! Vui lòng đăng nhập.');
                    window.location.href = '/Auth/Login';
                }
            } else {
                hideSpinner();
                showError(data.message || 'Đăng ký thất bại. Vui lòng thử lại.');
            }
        } catch (error) {
            hideSpinner();
            console.error('Register error:', error);
            showError('Có lỗi xảy ra. Vui lòng thử lại sau.');
        }
    });
</script>

