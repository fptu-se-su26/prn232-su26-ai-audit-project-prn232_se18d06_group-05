@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-surface flex">
    
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-outline-variant/30 hidden md:flex flex-col sticky top-20 h-[calc(100vh-80px)]">
        <div class="p-8 flex flex-col items-center border-b border-outline-variant/30">
            <div class="w-20 h-20 rounded-full bg-primary-container text-primary flex items-center justify-center text-2xl font-bold mb-4 shadow-sm border border-primary/20">
                JD
            </div>
            <h3 class="font-bold text-on-surface text-lg">John Doe</h3>
            <span class="text-xs text-on-surface-variant bg-surface-variant px-3 py-1 rounded-full mt-2 font-medium">Traveler • ENFP</span>
        </div>
        
        <nav class="p-4 flex-1 space-y-2">
            <a href="/Traveler/Dashboard" class="flex items-center gap-4 px-6 py-3 text-on-surface-variant hover:bg-surface-variant hover:text-on-surface rounded-xl font-medium transition-all">
                <span class="material-symbols-outlined">dashboard</span>
                My Dashboard
            </a>
            <a href="/Traveler/SavedGuides" class="flex items-center gap-4 px-6 py-3 text-on-surface-variant hover:bg-surface-variant hover:text-on-surface rounded-xl font-medium transition-all">
                <span class="material-symbols-outlined">favorite</span>
                Saved Guides
            </a>
            <a href="/Traveler/Messages" class="flex items-center gap-4 px-6 py-3 bg-primary-container text-primary rounded-xl font-bold transition-all">
                <span class="material-symbols-outlined">chat</span>
                Messages
                <span class="ml-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full font-bold">2</span>
            </a>
            <a href="/Survey" class="flex items-center gap-4 px-6 py-3 text-on-surface-variant hover:bg-surface-variant hover:text-on-surface rounded-xl font-medium transition-all">
                <span class="material-symbols-outlined">travel_explore</span>
                New Trip
            </a>
        </nav>
    </aside>

    <!-- Main Content: Chat Interface -->
    <main class="flex-1 flex flex-col h-[calc(100vh-80px)] bg-white overflow-hidden">
        
        <div class="flex h-full">
            <!-- Chat List -->
            <div class="w-1/3 border-r border-outline-variant/30 flex flex-col">
                <div class="p-6 border-b border-outline-variant/30">
                    <h2 class="text-2xl font-bold text-on-surface mb-4">Messages</h2>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-3 text-on-surface-variant">search</span>
                        <input type="text" placeholder="Search conversations..." class="w-full bg-surface border-none rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary text-on-surface">
                    </div>
                </div>

                <div class="flex-1 overflow-y-auto">
                    <!-- Chat Item 1 (Active) -->
                    <div class="p-4 border-b border-outline-variant/30 hover:bg-surface-variant cursor-pointer transition-all bg-primary-container/20 border-l-4 border-l-primary flex gap-4 items-center">
                        <div class="relative">
                            <div class="w-14 h-14 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden shrink-0 border border-outline-variant/30">
                                <span class="material-symbols-outlined text-4xl text-gray-400">face_3</span>
                            </div>
                            <div class="absolute bottom-0 right-0 w-4 h-4 bg-green-500 rounded-full border-2 border-white"></div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-center mb-1">
                                <h4 class="font-bold text-on-surface truncate">Minh Anh</h4>
                                <span class="text-xs text-primary font-bold">10:42 AM</span>
                            </div>
                            <p class="text-sm text-on-surface-variant truncate font-bold text-primary">Sounds great! See you at the fountain.</p>
                        </div>
                        <div class="w-2 h-2 bg-primary rounded-full"></div>
                    </div>

                    <!-- Chat Item 2 -->
                    <div class="p-4 border-b border-outline-variant/30 hover:bg-surface-variant cursor-pointer transition-all flex gap-4 items-center opacity-70">
                        <div class="w-14 h-14 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden shrink-0 border border-outline-variant/30">
                            <span class="material-symbols-outlined text-4xl text-gray-400">face_4</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-center mb-1">
                                <h4 class="font-bold text-on-surface truncate">Tuan Kiet</h4>
                                <span class="text-xs text-on-surface-variant">Yesterday</span>
                            </div>
                            <p class="text-sm text-on-surface-variant truncate">Thank you for traveling with me!</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Chat Window -->
            <div class="flex-1 flex flex-col bg-surface">
                <!-- Chat Header -->
                <div class="p-6 bg-white border-b border-outline-variant/30 flex justify-between items-center shadow-sm z-10">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden shrink-0 border border-outline-variant/30">
                            <span class="material-symbols-outlined text-3xl text-gray-400">face_3</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-on-surface text-lg">Minh Anh</h3>
                            <p class="text-xs text-green-600 font-medium flex items-center gap-1">
                                <span class="w-2 h-2 bg-green-500 rounded-full inline-block"></span> Online
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <a href="/Traveler/BookingDetails/1" class="px-4 py-2 bg-primary-container text-primary rounded-lg text-sm font-bold hover:bg-primary hover:text-white transition-all">
                            View Booking
                        </a>
                        <button class="w-10 h-10 rounded-full hover:bg-surface-variant flex items-center justify-center text-on-surface-variant transition-all">
                            <span class="material-symbols-outlined">more_vert</span>
                        </button>
                    </div>
                </div>

                <!-- Chat Messages -->
                <div class="flex-1 overflow-y-auto p-6 space-y-6">
                    <div class="text-center text-xs text-on-surface-variant font-medium my-4">Today</div>
                    
                    <!-- Guide Message -->
                    <div class="flex gap-4 max-w-[80%]">
                        <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden shrink-0 mt-1">
                            <span class="material-symbols-outlined text-xl text-gray-400">face_3</span>
                        </div>
                        <div>
                            <div class="bg-white p-4 rounded-2xl rounded-tl-none shadow-sm border border-outline-variant/20 text-on-surface">
                                Hi John! I just accepted your booking for the Hanoi Art & Culture Walk. I'm so excited to show you around!
                            </div>
                            <span class="text-xs text-on-surface-variant mt-1 inline-block ml-1">10:30 AM</span>
                        </div>
                    </div>

                    <!-- Traveler Message -->
                    <div class="flex gap-4 max-w-[80%] ml-auto justify-end">
                        <div class="text-right">
                            <div class="bg-primary text-white p-4 rounded-2xl rounded-tr-none shadow-sm">
                                Awesome! I can't wait. Should we meet at the Hoan Kiem Lake fountain like the itinerary says?
                            </div>
                            <span class="text-xs text-on-surface-variant mt-1 inline-block mr-1">10:35 AM</span>
                        </div>
                    </div>

                    <!-- Guide Message -->
                    <div class="flex gap-4 max-w-[80%]">
                        <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden shrink-0 mt-1">
                            <span class="material-symbols-outlined text-xl text-gray-400">face_3</span>
                        </div>
                        <div>
                            <div class="bg-white p-4 rounded-2xl rounded-tl-none shadow-sm border border-outline-variant/20 text-on-surface">
                                Yes! I'll be wearing a yellow t-shirt and holding a small camera. 
                            </div>
                            <div class="bg-white p-4 rounded-2xl rounded-tl-none shadow-sm border border-outline-variant/20 text-on-surface mt-2">
                                Sounds great! See you at the fountain.
                            </div>
                            <span class="text-xs text-on-surface-variant mt-1 inline-block ml-1">10:42 AM</span>
                        </div>
                    </div>
                </div>

                <!-- Chat Input -->
                <div class="p-6 bg-white border-t border-outline-variant/30">
                    <div class="flex items-center gap-4 bg-surface rounded-full p-2 pr-4 border border-outline-variant/50 focus-within:border-primary focus-within:ring-1 focus-within:ring-primary transition-all">
                        <button class="w-10 h-10 rounded-full text-on-surface-variant hover:bg-surface-variant hover:text-primary flex items-center justify-center transition-all shrink-0">
                            <span class="material-symbols-outlined">add_circle</span>
                        </button>
                        <input type="text" placeholder="Type a message..." class="flex-1 bg-transparent border-none focus:ring-0 text-on-surface">
                        <button class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center hover:bg-primary/90 transition-all shrink-0 shadow-md">
                            <span class="material-symbols-outlined text-sm" style="margin-left: 2px;">send</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </main>
</div>
