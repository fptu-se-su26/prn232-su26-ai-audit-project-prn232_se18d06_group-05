@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-surface flex">
    
    <partial name="_TravelerSidebar" />

    <!-- Main Content: Chat Interface -->
    <main class="flex-1 flex flex-col h-[calc(100vh-80px)] bg-white overflow-hidden">
        
        <div class="flex h-full">
            <!-- Chat List -->
            <div class="w-1/3 border-r border-outline-variant/30 flex flex-col">
                <div class="p-6 border-b border-outline-variant/30">
                    <h2 class="text-2xl font-bold text-on-surface mb-4">Messages</h2>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-3 text-on-surface-variant">search</span>
                        <input type="text" placeholder="Search conversations..." class="w-full bg-surface border-none rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary text-on-surface">
                    </div>
                </div>

                <div class="flex-1 overflow-y-auto">
                    @if (ViewBag.Guides != null && ((List<TripMate_Webapi.Entities.GuideProfileEntity>)ViewBag.Guides).Any())
                    {
                        var guides = (List<TripMate_Webapi.Entities.GuideProfileEntity>)ViewBag.Guides;
                        foreach (var guide in guides)
                        {
                            <div class="p-4 border-b border-outline-variant/30 hover:bg-surface-variant cursor-pointer transition-all flex gap-4 items-center">
                                <div class="relative">
                                    <div class="w-14 h-14 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden shrink-0 border border-outline-variant/30">
                                        @if (!string.IsNullOrEmpty(guide.Profile?.AvatarUrl))
                                        {
                                            <img src="@guide.Profile.AvatarUrl" alt="@guide.Profile.FullName" class="w-full h-full object-cover"/>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-4xl text-gray-400">face_4</span>
                                        }
                                    </div>
                                    <div class="absolute bottom-0 right-0 w-4 h-4 bg-green-500 rounded-full border-2 border-white"></div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex justify-between items-center mb-1">
                                        <h4 class="font-bold text-on-surface truncate">@(guide.Profile?.FullName ?? "Guide")</h4>
                                        <span class="text-xs text-on-surface-variant">Recent</span>
                                    </div>
                                    <p class="text-sm text-on-surface-variant truncate">Click to view conversation</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-8 text-center text-on-surface-variant">
                            <span class="material-symbols-outlined text-4xl mb-2">chat_bubble_outline</span>
                            <p class="text-sm">You don't have any active conversations yet. Book a guide to start chatting!</p>
                            <a href="/Traveler/Trips" class="mt-4 inline-block bg-primary text-white px-4 py-2 rounded-lg text-sm font-bold">View My Trips</a>
                        </div>
                    }
                </div>
            </div>

            <!-- Chat Window -->
            <div class="flex-1 flex flex-col bg-surface items-center justify-center">
                <div class="text-center text-on-surface-variant">
                    <span class="material-symbols-outlined text-6xl mb-4 text-outline-variant">forum</span>
                    <h3 class="text-xl font-bold text-on-surface mb-2">Select a conversation</h3>
                    <p>Choose a guide from the list to view your messages or start chatting.</p>
                </div>
            </div>
        </div>

    </main>
</div>
