@model TripMate_Webapi.Entities.BookingEntity
@{
    ViewData["Title"] = "Booking Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-surface min-h-screen py-12 px-4">
    <div class="max-w-[1000px] mx-auto">
        <!-- Breadcrumbs & Header -->
        <div class="mb-8 flex items-center gap-4">
            <a href="/Traveler/Dashboard" class="w-10 h-10 rounded-full bg-white border border-outline-variant/50 flex items-center justify-center text-on-surface-variant hover:text-primary transition-all shadow-sm">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h1 class="text-3xl font-extrabold text-on-surface">@(Model.ExperiencePackage?.Title ?? "Custom Tour")</h1>
                <p class="text-on-surface-variant font-medium">Booking Reference: #@Model.Id?.Substring(0, 8).ToUpper()</p>
            </div>
            
            <div class="ml-auto flex items-center gap-2">
                @if (Model.Status == 0)
                {
                    <div class="bg-yellow-100 text-yellow-700 px-4 py-2 rounded-full text-sm font-bold border border-yellow-200 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">schedule</span> Pending
                    </div>
                }
                else if (Model.Status == 1)
                {
                    <div class="bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-bold border border-blue-200 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">check_circle</span> Approved
                    </div>
                }
                else
                {
                    <div class="bg-green-100 text-green-700 px-4 py-2 rounded-full text-sm font-bold border border-green-200 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">task_alt</span> Completed
                    </div>
                }
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Itinerary -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Overview Card -->
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 tonal-elevation">
                    <h2 class="text-2xl font-bold text-on-surface mb-6 border-b border-outline-variant/30 pb-4">Trip Overview</h2>
                    
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
                        <div>
                            <p class="text-xs font-bold text-on-surface-variant mb-1 uppercase tracking-wider">Date</p>
                            <p class="font-bold text-on-surface">@Model.BookingDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-on-surface-variant mb-1 uppercase tracking-wider">Time</p>
                            <p class="font-bold text-on-surface">@Model.StartTime.ToString("hh:mm tt")</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-on-surface-variant mb-1 uppercase tracking-wider">Guests</p>
                            <p class="font-bold text-on-surface">@Model.GuestCount People</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-on-surface-variant mb-1 uppercase tracking-wider">Location</p>
                            <p class="font-bold text-on-surface">@(Model.GuideProfile?.CityArea ?? "TBD")</p>
                        </div>
                    </div>

                    <div class="bg-primary-container/30 p-6 rounded-2xl flex items-start gap-4">
                        <div class="w-12 h-12 bg-primary text-white flex items-center justify-center rounded-full shrink-0">
                            <span class="material-symbols-outlined">location_on</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg text-on-surface mb-1">Meeting Point</h4>
                            <p class="text-on-surface-variant mb-2">Hoan Kiem Lake, Main Fountain Square</p>
                            <a href="#" class="text-primary font-bold text-sm hover:underline flex items-center gap-1">
                                View on Map <span class="material-symbols-outlined text-sm">open_in_new</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Itinerary Timeline -->
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 tonal-elevation">
                    <h2 class="text-2xl font-bold text-on-surface mb-8 border-b border-outline-variant/30 pb-4">Itinerary Details</h2>
                    
                    <div class="relative pl-8 border-l-2 border-primary/30 space-y-10">
                        <div class="relative">
                            <div class="absolute -left-[41px] w-5 h-5 rounded-full bg-primary border-4 border-white shadow-sm"></div>
                            <h3 class="text-xl font-bold text-on-surface mb-1">Tour Experience</h3>
                            <p class="text-sm font-bold text-primary mb-4">@Model.BookingDate.ToString("MMM dd") • @Model.StartTime.ToString("hh:mm tt")</p>
                            <div class="bg-surface-variant p-5 rounded-xl text-on-surface-variant space-y-2">
                                <p>@Model.ExperiencePackage?.Description</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Guide & Payment -->
            <div class="lg:col-span-1 space-y-8">
                <!-- Guide Profile Card -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-outline-variant/30 tonal-elevation text-center">
                    <div class="w-24 h-24 mx-auto rounded-full bg-gray-200 mb-4 overflow-hidden relative border-2 border-primary/20">
                        <img src="@(string.IsNullOrEmpty(Model.GuideProfile?.Profile?.AvatarUrl) ? "/images/default_avatar.png" : Model.GuideProfile.Profile.AvatarUrl)" alt="Guide" class="w-full h-full object-cover"/>
                    </div>
                    <h3 class="text-xl font-bold text-on-surface mb-1">@(Model.GuideProfile?.Profile?.FullName ?? "Unknown Guide")</h3>
                    <p class="text-sm text-primary font-bold mb-4">Your Local Expert</p>
                    
                    <div class="flex flex-col gap-3">
                        <button class="w-full bg-primary-container text-primary hover:bg-primary hover:text-white py-3 rounded-xl font-bold flex items-center justify-center gap-2 transition-all">
                            <span class="material-symbols-outlined">chat</span> Message Guide
                        </button>
                        <a href="/Guide/Profile/@Model.GuideProfile?.UserId" class="w-full border-2 border-outline-variant text-on-surface-variant hover:border-primary hover:text-primary py-3 rounded-xl font-bold flex items-center justify-center gap-2 transition-all">
                            <span class="material-symbols-outlined">person</span> View Profile
                        </a>
                    </div>
                </div>

                <!-- Payment Summary Card -->
                <div class="bg-white rounded-3xl p-8 shadow-2xl border-2 border-primary/20 sticky top-24">
                    <h3 class="text-xl font-bold text-on-surface mb-6">Payment Summary</h3>
                    
                    <div class="space-y-4 mb-6 border-b border-outline-variant/30 pb-6">
                        <div class="flex justify-between text-on-surface-variant">
                            <span>Subtotal (@Model.GuestCount Guests)</span>
                            <span class="font-medium text-on-surface">@((Model.TotalAmount - Model.PlatformFee).ToString("#,##0")) ₫</span>
                        </div>
                        <div class="flex justify-between text-on-surface-variant">
                            <span>Platform Fee</span>
                            <span class="font-medium text-on-surface">@(Model.PlatformFee.ToString("#,##0")) ₫</span>
                        </div>
                    </div>
                    
                    <div class="flex justify-between items-end mb-8">
                        <span class="font-bold text-on-surface">Total</span>
                        <span class="text-3xl font-extrabold text-primary">@(Model.TotalAmount.ToString("#,##0")) ₫</span>
                    </div>

                    @if (Model.Status != 2)
                    {
                        <a href="/Traveler/Checkout/@Model.Id" class="block w-full text-center bg-primary hover:bg-primary/90 text-white py-4 rounded-xl font-bold text-lg shadow-lg hover:-translate-y-1 transition-all flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined">lock</span> Proceed to Pay
                        </a>
                    }
                    else
                    {
                        <div class="block w-full text-center bg-green-500 text-white py-4 rounded-xl font-bold text-lg shadow-lg flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined">check_circle</span> Paid
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
