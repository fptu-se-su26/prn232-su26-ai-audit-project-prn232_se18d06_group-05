@model TripMate_Webapi.Entities.GuideProfileEntity
@{
    ViewData["Title"] = Model.Profile?.FullName ?? "Guide Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var packages = ViewBag.Packages as List<TripMate_WebAPI.Services.ExperiencePackageRow> ?? new();
    var reviews = ViewBag.Reviews as List<TripMate_Webapi.Entities.ReviewEntity> ?? new();
}

<div class="min-h-screen bg-surface" x-data="guideProfilePage()">
    <!-- Cover Photo -->
    <div class="w-full h-80 bg-gray-200 relative">
        @if (!string.IsNullOrEmpty(Model.CoverPhotoUrl))
        {
            <img src="@Model.CoverPhotoUrl" alt="Cover" class="w-full h-full object-cover" />
        }
        else
        {
            <div class="absolute inset-0 bg-gradient-to-br from-primary-container to-surface-variant flex items-center justify-center">
                <span class="material-symbols-outlined text-9xl text-primary/40">landscape</span>
            </div>
        }
    </div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-12 pb-24 relative -top-20">
        
        <div class="flex flex-col md:flex-row gap-8">
            <!-- Left Column: Guide Info -->
            <div class="w-full md:w-1/3">
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 text-center relative">
                    <!-- Avatar -->
                    <div class="w-32 h-32 mx-auto rounded-full overflow-hidden border-4 border-white shadow-md relative -top-16 mb-[-3rem] bg-gray-100">
                        @if (!string.IsNullOrEmpty(Model.Profile?.AvatarUrl))
                        {
                            <img src="@Model.Profile.AvatarUrl" alt="@Model.Profile.FullName" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-6xl text-gray-400 mt-6">person</span>
                        }
                    </div>

                    <h1 class="text-3xl font-bold text-on-surface mb-2">@Model.Profile?.FullName</h1>
                    <p class="text-primary font-medium flex items-center justify-center gap-1 mb-4">
                        <span class="material-symbols-outlined text-sm">location_on</span>
                        @(string.IsNullOrEmpty(Model.CityArea) ? "Vietnam" : Model.CityArea)
                    </p>

                    @if (Model.IsVerified == true)
                    {
                        <div class="inline-flex items-center gap-1 bg-green-50 text-green-700 px-3 py-1 rounded-full text-sm font-bold border border-green-100 mb-6">
                            <span class="material-symbols-outlined text-sm">verified</span> Verified Guide
                        </div>
                    }

                    <div class="flex justify-center gap-6 border-y border-outline-variant/30 py-4 mb-6">
                        <div class="text-center">
                            <div class="text-2xl font-bold text-on-surface flex items-center justify-center gap-1">
                                <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'FILL' 1;">star</span>
                                @(Model.AverageRating?.ToString("0.0") ?? "0.0")
                            </div>
                            <div class="text-xs text-on-surface-variant font-medium uppercase tracking-wider">Rating</div>
                        </div>
                        <div class="w-px bg-outline-variant/30"></div>
                        <div class="text-center">
                            <div class="text-2xl font-bold text-on-surface">@(Model.TotalReviews ?? 0)</div>
                            <div class="text-xs text-on-surface-variant font-medium uppercase tracking-wider">Reviews</div>
                        </div>
                    </div>

                    <!-- Book Now Primary CTA -->
                    <button @@click="startCustomBooking()"
                            class="w-full bg-primary hover:bg-primary/90 text-white py-4 rounded-xl font-bold transition-all mb-3 flex justify-center items-center gap-2 shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-lg">
                        <span class="material-symbols-outlined">lock</span>
                        Book Now — Escrow Payment
                    </button>
                    <p class="text-xs text-on-surface-variant mb-4 flex items-center justify-center gap-1">
                        <span class="material-symbols-outlined text-sm text-green-600">verified_user</span>
                        Money held securely until tour completion
                    </p>

                    <!-- Save Guide Button -->
                    <button @@click="toggleSaveGuide()"
                            class="w-full bg-surface-variant hover:bg-outline-variant/30 text-on-surface py-3 rounded-xl font-bold transition-all mb-4 flex justify-center items-center gap-2 border border-outline-variant/50">
                        <span class="material-symbols-outlined text-primary" :style="isSaved ? 'font-variation-settings: \'FILL\' 1;' : ''">favorite</span>
                        <span x-text="isSaved ? 'Saved to Favorites' : 'Save Guide'"></span>
                    </button>

                    <!-- Message (only visible if booking exists — hint text) -->
                    <div class="text-center text-xs text-on-surface-variant bg-surface-variant/50 rounded-lg p-3">
                        <span class="material-symbols-outlined text-sm align-middle">chat</span>
                        Messaging unlocks after booking & payment
                    </div>
                </div>

                <!-- Languages & Specialties -->
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 mt-8">
                    <h3 class="text-lg font-bold text-on-surface mb-4">Languages</h3>
                    <div class="flex flex-wrap gap-2 mb-8">
                        @if (Model.Languages != null && Model.Languages.Any())
                        {
                            foreach (var lang in Model.Languages)
                            {
                                <span class="bg-surface-variant text-on-surface-variant px-3 py-1.5 rounded-lg text-sm font-medium">@lang</span>
                            }
                        }
                        else
                        {
                            <span class="text-sm text-on-surface-variant">Vietnamese, English</span>
                        }
                    </div>

                    <h3 class="text-lg font-bold text-on-surface mb-4">Specialties</h3>
                    <div class="flex flex-wrap gap-2">
                        @if (Model.Specialties != null && Model.Specialties.Any())
                        {
                            foreach (var spec in Model.Specialties)
                            {
                                <span class="bg-surface-variant text-on-surface-variant px-3 py-1.5 rounded-lg text-sm font-medium">@spec</span>
                            }
                        }
                        else
                        {
                            <span class="text-sm text-on-surface-variant">General Tourism</span>
                        }
                    </div>
                </div>

                <!-- Price Info -->
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 mt-8">
                    <h3 class="text-lg font-bold text-on-surface mb-4">Pricing</h3>
                    <div class="flex items-center justify-between">
                        <span class="text-on-surface-variant">Hourly Rate</span>
                        <span class="text-2xl font-bold text-primary">@(Model.PricePerHour?.ToString("#,##0") ?? "0") ₫/hr</span>
                    </div>
                </div>
            </div>

            <!-- Right Column: Content -->
            <div class="w-full md:w-2/3 pt-8 md:pt-0">
                <!-- Bio -->
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 mb-8 mt-20 md:mt-0">
                    <h2 class="text-2xl font-bold text-on-surface mb-4">About Me</h2>
                    <p class="text-on-surface-variant leading-relaxed whitespace-pre-line">
                        @(string.IsNullOrEmpty(Model.Bio) ? "This guide hasn't added a bio yet. But they are ready to show you the best of the city!" : Model.Bio)
                    </p>
                </div>

                <!-- Experience Packages / Tours -->
                <h2 class="text-2xl font-bold text-on-surface mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">explore</span>
                    Experience Packages
                </h2>
                <div class="space-y-4 mb-12">
                    @if (packages.Any())
                    {
                        foreach (var pkg in packages)
                        {
                            <div class="bg-white rounded-3xl p-6 shadow-sm border border-outline-variant/30 flex flex-col md:flex-row md:items-center justify-between gap-6 hover:shadow-md transition-shadow cursor-pointer group"
                                 @@click="openTourModal('@System.Web.HttpUtility.JavaScriptStringEncode(pkg.Id ?? "")', '@System.Web.HttpUtility.JavaScriptStringEncode(pkg.Title ?? "")', `@System.Web.HttpUtility.JavaScriptStringEncode(pkg.Description ?? "")`, @pkg.DurationHours, @pkg.PricePerSession, @(pkg.PricePerPerson ?? 0), @pkg.MaxGroupSize, '@System.Web.HttpUtility.JavaScriptStringEncode(string.Join(",", pkg.IncludedItems ?? new List<string>()))')">
                                <div class="flex-1">
                                    <div class="flex justify-between items-start mb-2">
                                        <h3 class="text-xl font-bold text-on-surface group-hover:text-primary transition-colors">@pkg.Title</h3>
                                        <span class="bg-primary-container text-primary px-3 py-1 rounded-full text-xs font-bold whitespace-nowrap">@pkg.DurationHours hours</span>
                                    </div>
                                    <p class="text-on-surface-variant text-sm mb-4 line-clamp-2">@pkg.Description</p>
                                    <div class="flex flex-wrap gap-2">
                                        @if (pkg.IncludedItems != null)
                                        {
                                            foreach (var item in pkg.IncludedItems.Take(3))
                                            {
                                                <span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-1 rounded"><span class="material-symbols-outlined text-[12px] align-text-bottom">check</span> @item</span>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="md:w-48 shrink-0 flex flex-col items-end border-t md:border-t-0 md:border-l border-outline-variant/30 pt-4 md:pt-0 md:pl-6 text-right">
                                    <p class="text-sm text-on-surface-variant mb-1">From</p>
                                    <p class="text-2xl font-bold text-primary mb-4">
                                        @(pkg.PricePerSession > 0 ? string.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:C0}", pkg.PricePerSession) + "/session" : (pkg.PricePerPerson > 0 ? string.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:C0}", pkg.PricePerPerson) + "/person" : "Contact"))
                                    </p>
                                    <span class="text-primary font-bold text-sm flex items-center gap-1 group-hover:underline">
                                        View Details <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                                    </span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Fallback Package if Guide hasn't created one -->
                        <div class="bg-white rounded-3xl p-6 shadow-sm border border-outline-variant/30 flex flex-col md:flex-row md:items-center justify-between gap-6">
                            <div class="flex-1">
                                <h3 class="text-xl font-bold text-on-surface mb-2">Custom Itinerary</h3>
                                <p class="text-on-surface-variant text-sm mb-4">A personalized tour based on your preferences. Book this guide and discuss your dream trip!</p>
                            </div>
                            <div class="md:w-48 shrink-0 flex flex-col items-end border-t md:border-t-0 md:border-l border-outline-variant/30 pt-4 md:pt-0 md:pl-6 text-right">
                                <button @@click="bookGuide()"
                                        class="w-full text-center bg-primary text-white py-3 rounded-xl font-bold hover:bg-primary/90 transition-all shadow-sm hover:shadow-md">
                                    Book Custom
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <!-- Reviews -->
                <h2 class="text-2xl font-bold text-on-surface mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">reviews</span>
                    Traveler Reviews
                </h2>
                <div class="space-y-6">
                    @if (reviews.Any())
                    {
                        foreach (var review in reviews)
                        {
                            <div class="bg-white rounded-3xl p-6 shadow-sm border border-outline-variant/30">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-primary-container rounded-full flex items-center justify-center text-primary font-bold">
                                            T
                                        </div>
                                        <div>
                                            <p class="font-bold text-on-surface">Traveler</p>
                                            <p class="text-xs text-on-surface-variant">@(review.CreatedAt.ToString("MMMM yyyy"))</p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                    </div>
                                </div>
                                <p class="text-on-surface-variant leading-relaxed">
                                    "@review.Comment"
                                </p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="bg-surface-variant rounded-3xl p-8 text-center text-on-surface-variant">
                            <span class="material-symbols-outlined text-4xl mb-2">reviews</span>
                            <p>No reviews yet. Be the first to book and review this guide!</p>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>

    <!-- ═══ Tour Detail Modal ═══ -->
    <div x-show="showModal" x-transition.opacity class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4" style="display: none;" @@click.self="showModal = false">
        <div class="bg-white rounded-3xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl" @@click.stop x-transition.scale.95>
            <!-- Modal Header -->
            <div class="sticky top-0 bg-white border-b border-outline-variant/30 p-6 rounded-t-3xl flex items-center justify-between z-10">
                <h2 class="text-2xl font-bold text-on-surface" x-text="modal.title"></h2>
                <button @@click="showModal = false" class="w-10 h-10 rounded-full hover:bg-surface-variant flex items-center justify-center transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="p-6 md:p-8 space-y-6">
                <!-- Tour Meta -->
                <div class="flex flex-wrap gap-4">
                    <div class="flex items-center gap-2 bg-primary-container/50 px-4 py-2 rounded-xl">
                        <span class="material-symbols-outlined text-primary text-sm">schedule</span>
                        <span class="font-bold text-sm" x-text="modal.duration + ' hours'"></span>
                    </div>
                    <div class="flex items-center gap-2 bg-surface-variant px-4 py-2 rounded-xl">
                        <span class="material-symbols-outlined text-on-surface-variant text-sm">group</span>
                        <span class="font-bold text-sm" x-text="'Max ' + modal.maxGroup + ' people'"></span>
                    </div>
                </div>

                <!-- Description / Itinerary -->
                <div>
                    <h3 class="text-lg font-bold text-on-surface mb-3 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-xl">route</span> Tour Description
                    </h3>
                    <p class="text-on-surface-variant leading-relaxed whitespace-pre-line" x-text="modal.description"></p>
                </div>

                <!-- Included Items -->
                <div x-show="modal.includedItems.length > 0">
                    <h3 class="text-lg font-bold text-on-surface mb-3 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-xl">check_circle</span> What's Included
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                        <template x-for="item in modal.includedItems" :key="item">
                            <div class="flex items-center gap-2 bg-green-50 border border-green-100 px-3 py-2 rounded-lg">
                                <span class="material-symbols-outlined text-green-600 text-sm">check</span>
                                <span class="text-sm text-green-800 font-medium" x-text="item"></span>
                            </div>
                        </template>
                    </div>
                </div>

                <!-- Guide Info -->
                <div class="bg-surface-variant/50 rounded-2xl p-5 flex items-center gap-4">
                    <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-primary/20 shrink-0 bg-gray-100">
                        @if (!string.IsNullOrEmpty(Model.Profile?.AvatarUrl))
                        {
                            <img src="@Model.Profile.AvatarUrl" alt="@Model.Profile.FullName" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-3xl text-gray-400 mt-2 block text-center">person</span>
                        }
                    </div>
                    <div>
                        <p class="text-sm text-on-surface-variant">Created by</p>
                        <p class="font-bold text-on-surface text-lg">@Model.Profile?.FullName</p>
                        <div class="flex items-center gap-1 text-sm">
                            <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="font-bold">@(Model.AverageRating?.ToString("0.0") ?? "0.0")</span>
                            <span class="text-on-surface-variant">(@(Model.TotalReviews ?? 0) reviews)</span>
                        </div>
                    </div>
                </div>

                <!-- Price & Book -->
                <div class="bg-white border-2 border-primary/30 rounded-2xl p-6 flex items-center justify-between">
                    <div>
                        <p class="text-sm text-on-surface-variant">Price</p>
                        <p class="text-3xl font-extrabold text-primary" x-text="modal.priceLabel"></p>
                    </div>
                    <button @@click="startTourBooking(modal.id)"
                            class="bg-primary hover:bg-primary/90 text-white px-8 py-4 rounded-xl font-bold text-lg flex items-center gap-2 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">
                        <span class="material-symbols-outlined">lock</span>
                        Book This Tour
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ Booking Wizard Modal ═══ -->
    <div x-show="showWizard"
         style="display:none;"
         class="fixed inset-0 z-[200] flex items-center justify-center p-4"
         aria-modal="true" role="dialog">

        <!-- Backdrop -->
        <div class="fixed inset-0 bg-black/70 backdrop-blur-sm" @@click="showWizard = false"></div>

        <!-- Panel -->
        <div x-show="showWizard"
             x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100"
             x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95"
             class="relative bg-white rounded-3xl shadow-2xl max-w-md w-full z-10 overflow-hidden flex flex-col max-h-[90vh]">

            <!-- Header -->
            <div class="bg-gradient-to-r from-primary to-orange-500 px-6 py-4 text-white shrink-0">
                <div class="flex justify-between items-center">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="material-symbols-outlined text-white/90">flight_takeoff</span>
                            <span class="font-bold text-lg" x-text="bookingType === 'tour' ? modal.title : 'Custom Tour'"></span>
                        </div>
                        <p class="text-white/80 text-sm">
                            Step <span x-text="wizardStep"></span> of 3: 
                            <span x-show="wizardStep === 1">Trip Information</span>
                            <span x-show="wizardStep === 2">Confirm Details</span>
                            <span x-show="wizardStep === 3">Secure Payment</span>
                        </p>
                    </div>
                    <button @@click="showWizard = false" class="w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center transition-colors">
                        <span class="material-symbols-outlined text-white text-lg">close</span>
                    </button>
                </div>
            </div>

            <!-- Scrollable Body -->
            <div class="p-6 overflow-y-auto">
                <!-- Step 1: Trip Info -->
                <div x-show="wizardStep === 1" class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-on-surface mb-2">Select Date</label>
                        <input type="date" x-model="bookingDate" class="w-full px-4 py-3 bg-surface border border-outline-variant/50 rounded-xl focus:outline-none focus:border-primary">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-on-surface mb-2">Number of Guests</label>
                        <div class="flex items-center border border-outline-variant/50 rounded-xl overflow-hidden bg-surface">
                            <button @@click="if(bookingGuests > 1) bookingGuests--" class="px-4 py-3 bg-surface-variant hover:bg-outline-variant/30 text-on-surface font-bold transition-colors">-</button>
                            <input type="number" x-model.number="bookingGuests" class="w-full px-4 py-3 text-center focus:outline-none bg-transparent font-bold text-lg" min="1">
                            <button @@click="bookingGuests++" class="px-4 py-3 bg-surface-variant hover:bg-outline-variant/30 text-on-surface font-bold transition-colors">+</button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-on-surface mb-2">Notes for Guide (Optional)</label>
                        <textarea x-model="bookingNotes" rows="3" class="w-full px-4 py-3 bg-surface border border-outline-variant/50 rounded-xl focus:outline-none focus:border-primary resize-none" placeholder="Any special requests or dietary requirements?"></textarea>
                    </div>
                </div>

                <!-- Step 2: Confirm Details -->
                <div x-show="wizardStep === 2" class="space-y-5">
                    <div class="bg-primary/5 rounded-2xl p-4 border border-primary/20">
                        <div class="flex gap-3 mb-3 pb-3 border-b border-primary/10">
                            <span class="material-symbols-outlined text-primary">calendar_month</span>
                            <div>
                                <p class="text-xs text-on-surface-variant font-bold uppercase">Date</p>
                                <p class="font-bold text-on-surface" x-text="new Date(bookingDate).toLocaleDateString('en-GB')"></p>
                            </div>
                        </div>
                        <div class="flex gap-3">
                            <span class="material-symbols-outlined text-primary">group</span>
                            <div>
                                <p class="text-xs text-on-surface-variant font-bold uppercase">Guests</p>
                                <p class="font-bold text-on-surface"><span x-text="bookingGuests"></span> Person(s)</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-surface-variant/30 rounded-2xl p-4 space-y-2">
                        <p class="text-sm font-bold text-on-surface mb-2">Price Breakdown</p>
                        <div class="flex justify-between text-sm text-on-surface-variant">
                            <span>Subtotal</span>
                            <span x-text="new Intl.NumberFormat('vi-VN').format(guideEarnings) + ' ₫'"></span>
                        </div>
                        <div class="flex justify-between text-sm text-on-surface-variant">
                            <span>Platform Fee (15%)</span>
                            <span x-text="new Intl.NumberFormat('vi-VN').format(platformFee) + ' ₫'"></span>
                        </div>
                        <div class="flex justify-between font-bold text-lg text-primary pt-2 border-t border-outline-variant/30 mt-2">
                            <span>Total (Escrow)</span>
                            <span x-text="new Intl.NumberFormat('vi-VN').format(computedTotal) + ' ₫'"></span>
                        </div>
                    </div>
                </div>

                <!-- Step 3: Payment -->
                <div x-show="wizardStep === 3" class="space-y-4">
                    <div class="bg-green-50 text-green-800 p-3 rounded-xl flex items-center gap-2 mb-4 text-sm font-medium border border-green-200">
                        <span class="material-symbols-outlined text-green-600">security</span>
                        Your payment is held safely until the tour is completed.
                    </div>
                    <label class="flex items-center gap-4 p-4 rounded-2xl border-2 cursor-pointer transition-all"
                           :class="selectedMethod === 'Credit Card' ? 'border-primary bg-primary-container/30' : 'border-outline-variant/30 hover:border-primary/40'">
                        <input type="radio" name="payMethod" value="Credit Card" x-model="selectedMethod" class="accent-primary">
                        <span class="material-symbols-outlined text-primary text-2xl">credit_card</span>
                        <div>
                            <p class="font-bold text-on-surface text-sm">Credit / Debit Card</p>
                            <p class="text-xs text-on-surface-variant">Visa, Mastercard, JCB</p>
                        </div>
                    </label>
                    <label class="flex items-center gap-4 p-4 rounded-2xl border-2 cursor-pointer transition-all"
                           :class="selectedMethod === 'Bank Transfer' ? 'border-primary bg-primary-container/30' : 'border-outline-variant/30 hover:border-primary/40'">
                        <input type="radio" name="payMethod" value="Bank Transfer" x-model="selectedMethod" class="accent-primary">
                        <span class="material-symbols-outlined text-primary text-2xl">account_balance</span>
                        <div>
                            <p class="font-bold text-on-surface text-sm">Bank Transfer</p>
                            <p class="text-xs text-on-surface-variant">VietcomBank, Techcombank, MB Bank</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Footer Actions -->
            <div class="px-6 py-4 border-t border-outline-variant/20 bg-surface shrink-0 flex gap-3">
                <button x-show="wizardStep > 1" @@click="prevStep()" :disabled="paymentInProgress"
                        class="flex-1 py-3 rounded-xl font-bold text-on-surface bg-surface-variant hover:bg-outline-variant/30 transition-colors">
                    Back
                </button>
                <button x-show="wizardStep < 3" @@click="nextStep()"
                        class="flex-[2] bg-primary hover:bg-primary/90 text-white py-3 rounded-xl font-bold transition-all shadow-md">
                    Continue
                </button>
                <button x-show="wizardStep === 3" @@click="submitBooking()" :disabled="paymentInProgress || !selectedMethod"
                        class="flex-[2] bg-primary hover:bg-primary/90 disabled:opacity-60 text-white py-3 rounded-xl font-bold transition-all shadow-md flex items-center justify-center gap-2">
                    <span x-show="!paymentInProgress" class="material-symbols-outlined text-sm">lock</span>
                    <span x-show="paymentInProgress" class="material-symbols-outlined text-sm animate-spin">progress_activity</span>
                    <span x-text="paymentInProgress ? 'Processing...' : 'Confirm & Pay'"></span>
                </button>
            </div>
        </div>
    </div>
</div>



<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('guideProfilePage', () => ({
            showModal: false,
            showWizard: false,
            wizardStep: 1,
            bookingType: '',
            bookingPackageId: '',
            bookingDate: new Date(Date.now() + 7 * 86400000).toISOString().split('T')[0],
            bookingGuests: 1,
            bookingNotes: '',
            selectedMethod: 'Credit Card',
            
            basePrice: @(Model.PricePerHour ?? 500000),
            
            get computedTotal() {
                if (this.bookingType === 'tour' && this.modal.pricePerSession > 0) {
                    return this.modal.pricePerSession;
                } else if (this.bookingType === 'tour' && this.modal.pricePerPerson > 0) {
                    return this.modal.pricePerPerson * this.bookingGuests;
                } else {
                    return this.basePrice * this.bookingGuests;
                }
            },
            get platformFee() {
                return Math.round(this.computedTotal * 0.15);
            },
            get guideEarnings() {
                return this.computedTotal - this.platformFee;
            },
            
            paymentInProgress: false,
            isSaved: false,
            modal: {
                id: '', title: '', description: '', duration: 0,
                pricePerSession: 0, pricePerPerson: 0, maxGroup: 6,
                includedItems: [], priceLabel: ''
            },

            async init() {
                await this.checkSavedState();
            },

            async checkSavedState() {
                const token = localStorage.getItem('accessToken');
                if (!token) return;
                try {
                    const res = await fetch(`/Traveler/IsGuideSavedAjax/@Model.Id`, {
                        headers: { 'Authorization': 'Bearer ' + token }
                    });
                    if (res.ok) {
                        const data = await res.json();
                        this.isSaved = data.saved;
                    }
                } catch(e) { console.error(e); }
            },

            async toggleSaveGuide() {
                const token = localStorage.getItem('accessToken');
                if (!token) {
                    window.location.href = '/Auth/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                    return;
                }
                
                try {
                    const res = await fetch(`/Traveler/ToggleSaveGuideAjax/@Model.Id`, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token }
                    });
                    if (res.ok) {
                        const data = await res.json();
                        this.isSaved = data.saved;
                        
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: this.isSaved ? 'success' : 'info',
                            title: this.isSaved ? 'Guide saved to Favorites!' : 'Removed from Favorites',
                            showConfirmButton: false,
                            timer: 2000,
                            customClass: { popup: 'swal-top-fix' }
                        });
                    }
                } catch (e) {
                    console.error('Toggle save error:', e);
                }
            },

            openTourModal(id, title, description, duration, pricePerSession, pricePerPerson, maxGroup, includedItemsStr) {
                this.modal.id = id;
                this.modal.title = title;
                this.modal.description = description;
                this.modal.duration = duration;
                this.modal.pricePerSession = pricePerSession;
                this.modal.pricePerPerson = pricePerPerson;
                this.modal.maxGroup = maxGroup;
                this.modal.includedItems = includedItemsStr ? includedItemsStr.split(',').map(s => s.trim()).filter(s => s) : [];

                const fmt = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 });
                if (pricePerSession > 0) {
                    this.modal.priceLabel = fmt.format(pricePerSession) + '/session';
                } else if (pricePerPerson > 0) {
                    this.modal.priceLabel = fmt.format(pricePerPerson) + '/person';
                } else {
                    this.modal.priceLabel = 'Contact';
                }
                this.showModal = true;
            },

            startCustomBooking() {
                const token = localStorage.getItem('accessToken');
                if (!token) {
                    window.location.href = '/Auth/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                    return;
                }
                this.bookingType = 'custom';
                this.wizardStep = 1;
                this.showWizard = true;
            },

            startTourBooking(packageId) {
                const token = localStorage.getItem('accessToken');
                if (!token) {
                    window.location.href = '/Auth/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                    return;
                }
                this.bookingType = 'tour';
                this.bookingPackageId = packageId;
                this.wizardStep = 1;
                this.showWizard = true;
                this.showModal = false; // close tour modal
            },

            nextStep() {
                if (this.wizardStep < 3) this.wizardStep++;
            },

            prevStep() {
                if (this.wizardStep > 1) this.wizardStep--;
            },

            async submitBooking() {
                const token = localStorage.getItem('accessToken');
                if (!token || this.paymentInProgress) return;
                this.paymentInProgress = true;

                try {
                    const formData = new FormData();
                    formData.append('guideId', '@Model.Id');
                    formData.append('date', this.bookingDate);
                    formData.append('guests', this.bookingGuests);
                    if (this.bookingNotes) formData.append('notes', this.bookingNotes);
                    
                    let url = '/Traveler/Book';
                    if (this.bookingType === 'tour') {
                        formData.append('packageId', this.bookingPackageId);
                        url = '/Traveler/BookTour';
                    }

                    const res = await fetch(url, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token },
                        body: formData
                    });

                    if (res.ok) {
                        this.showWizard = false;
                        await Swal.fire({
                            title: 'Payment Received! 🎉',
                            html: `<p class="text-gray-600">Your booking & payment are secured in escrow.</p><p class="mt-2 font-semibold">The guide will confirm within <strong>48 hours</strong>.</p>`,
                            icon: 'success',
                            confirmButtonColor: '#ff7a00',
                            confirmButtonText: 'View My Bookings'
                        });
                        window.location.href = '/Traveler/Dashboard';
                    } else if (res.status === 400) {
                        const errorData = await res.json();
                        Swal.fire({ title: 'Notice', text: errorData.error || 'Booking failed.', icon: 'info' });
                    } else {
                        Swal.fire({ title: 'Error', text: 'Booking failed. Please try again.', icon: 'error' });
                    }
                } catch(err) {
                    console.error('Booking error:', err);
                    Swal.fire('Error', 'Connection error. Please try again.', 'error');
                } finally {
                    this.paymentInProgress = false;
                }
            }
        }))
    })
</script>
