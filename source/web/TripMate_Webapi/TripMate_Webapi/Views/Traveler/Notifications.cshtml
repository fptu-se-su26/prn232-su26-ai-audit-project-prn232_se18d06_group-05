@model List<TripMate_Webapi.Entities.NotificationEntity>

@{
    ViewData["Title"] = "My Notifications";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-surface flex">
    <partial name="_TravelerSidebar" />

    <main class="flex-1 p-8 md:p-10 overflow-y-auto h-[calc(100vh-80px)]">
        <!-- Header Section -->
        <div class="bg-surface border-b border-outline-variant/30 sticky top-0 z-40 -mx-8 -mt-8 px-8 py-6 mb-8">
            <div class="max-w-4xl mx-auto flex justify-between items-center">
                <div>
                    <h1 class="text-3xl font-extrabold text-on-surface mb-1 tracking-tight">Notifications</h1>
                    <p class="text-on-surface-variant font-medium">Stay updated with your trips and guides</p>
                </div>
                <button onclick="markAllAsRead()" class="flex items-center gap-2 bg-primary-container text-primary hover:bg-primary hover:text-white px-5 py-2.5 rounded-full font-bold transition-all">
                    <span class="material-symbols-outlined text-[20px]">done_all</span>
                    Mark all as read
                </button>
            </div>
        </div>

        <div class="max-w-4xl mx-auto">
        @if (Model == null || !Model.Any())
        {
            <!-- Empty State -->
            <div class="bg-white rounded-3xl p-16 text-center shadow-sm border border-outline-variant/20 mt-8 flex flex-col items-center">
                <div class="w-24 h-24 bg-surface-variant rounded-full flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-5xl text-on-surface-variant/50">notifications_paused</span>
                </div>
                <h2 class="text-2xl font-bold text-on-surface mb-3">You're all caught up!</h2>
                <p class="text-on-surface-variant text-lg max-w-md mx-auto mb-8 leading-relaxed">
                    You don't have any notifications right now. Check back later for updates on your trips and requests.
                </p>
                <a href="/Home/Explore" class="bg-primary hover:bg-primary/90 text-white px-8 py-3.5 rounded-full font-bold transition-all shadow-md hover:shadow-lg inline-block">
                    Explore Destinations
                </a>
            </div>
        }
        else
        {
            <div class="bg-white rounded-3xl shadow-sm border border-outline-variant/20 overflow-hidden">
                @foreach (var notif in Model)
                {
                    var isUnread = !notif.IsRead;
                    var bgClass = isUnread ? "bg-primary/5" : "hover:bg-surface-variant/50";
                    
                    var icon = notif.Type switch
                    {
                        "booking" => "book_online",
                        "trip_request" => "flight_takeoff",
                        "review" => "star",
                        "system" => "info",
                        _ => "notifications"
                    };
                    
                    var iconColor = notif.Type switch
                    {
                        "booking" => "text-blue-600 bg-blue-100",
                        "trip_request" => "text-green-600 bg-green-100",
                        "review" => "text-orange-500 bg-orange-100",
                        "system" => "text-gray-600 bg-gray-100",
                        _ => "text-primary bg-primary-container"
                    };

                    <a href="@(notif.LinkUrl ?? "#")" onclick="markAsRead('@notif.Id')" class="block p-6 border-b border-outline-variant/20 transition-colors @bgClass relative group">
                        <div class="flex gap-5 items-start">
                            <div class="w-12 h-12 rounded-full flex items-center justify-center shrink-0 @iconColor">
                                <span class="material-symbols-outlined text-[24px]">@icon</span>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-lg font-bold text-on-surface mb-1">@notif.Title</h3>
                                <p class="text-on-surface-variant mb-3 leading-relaxed">@notif.Message</p>
                                <div class="flex items-center text-sm font-medium text-on-surface-variant/70 gap-1.5">
                                    <span class="material-symbols-outlined text-[16px]">schedule</span>
                                    <span>@notif.CreatedAt.ToString("MMM dd, yyyy 'at' hh:mm tt")</span>
                                </div>
                            </div>
                            @if (isUnread)
                            {
                                <div class="w-3 h-3 bg-primary rounded-full mt-2 shrink-0 shadow-sm" id="dot-@notif.Id"></div>
                            }
                        </div>
                    </a>
                }
            </div>
        }
    </main>
</div>

@section Scripts {
    <script>
        async function markAsRead(id) {
            try {
                const response = await fetch(`/api/notifications/${id}/read`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' }
                });
                if(response.ok) {
                    const dot = document.getElementById('dot-' + id);
                    if(dot) dot.remove();
                }
            } catch(e) {
                console.error(e);
            }
        }

        async function markAllAsRead() {
            try {
                const response = await fetch('/api/notifications/read-all', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                if (response.ok) {
                    window.location.reload();
                }
            } catch (e) {
                console.error(e);
            }
        }
    </script>
}
