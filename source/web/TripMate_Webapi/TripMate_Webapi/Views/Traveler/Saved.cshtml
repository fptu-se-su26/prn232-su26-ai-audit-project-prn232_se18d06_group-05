@{
    ViewData["Title"] = "Saved Guides";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-surface flex">
    
    <partial name="_TravelerSidebar" />

    <!-- Main Content -->
    <main class="flex-1 p-8 md:p-12 overflow-y-auto h-[calc(100vh-80px)]">
        
        <div class="mb-10">
            <h1 class="text-4xl font-extrabold text-on-surface mb-2 flex items-center gap-3">
                <span class="material-symbols-outlined text-red-500 text-4xl" style="font-variation-settings: 'FILL' 1;">favorite</span>
                Saved Local Soulmates
            </h1>
            <p class="text-lg text-on-surface-variant">Guides you've bookmarked for future adventures.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <!-- Saved Guide Card 1 -->
            <div class="bg-white rounded-3xl overflow-hidden tonal-elevation border border-outline-variant/30 relative flex flex-col group">
                <!-- Unfavorite Button -->
                <button class="absolute top-4 right-4 w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-red-500 hover:bg-red-50 transition-all z-10 shadow-sm">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">favorite</span>
                </button>
                
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-on-surface flex items-center gap-1 z-10 shadow-sm">
                    <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span> 5.0 (124)
                </div>

                <div class="h-64 relative bg-gray-200 overflow-hidden">
                    <img src="/images/guide_1.png" alt="Minh Anh" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"/>
                </div>

                <div class="p-8 flex-1 flex flex-col">
                    <div class="flex justify-between items-center mb-1">
                        <h4 class="text-2xl font-bold text-on-surface">Minh Anh</h4>
                        <span class="text-xs font-bold bg-primary-container text-primary px-2 py-1 rounded-md border border-primary/20">ENFP</span>
                    </div>
                    <p class="text-on-surface-variant text-sm mb-4 flex items-center gap-1 font-medium">
                        <span class="material-symbols-outlined text-sm">location_on</span> Hanoi, Vietnam
                    </p>
                    
                    <div class="flex flex-wrap gap-2 mb-6">
                        <span class="bg-surface-variant text-xs font-bold px-2 py-1 rounded">Photography</span>
                        <span class="bg-surface-variant text-xs font-bold px-2 py-1 rounded">Hidden Cafes</span>
                        <span class="bg-surface-variant text-xs font-bold px-2 py-1 rounded">Art</span>
                    </div>
                    
                    <div class="mt-auto grid grid-cols-2 gap-3">
                        <a href="/Guide/Profile/1" class="col-span-2 bg-primary hover:bg-primary/90 text-white text-center py-3 rounded-xl font-bold transition-all shadow-md">
                            View Profile
                        </a>
                    </div>
                </div>
            </div>

            <!-- Saved Guide Card 2 -->
            <div class="bg-white rounded-3xl overflow-hidden tonal-elevation border border-outline-variant/30 relative flex flex-col group">
                <button class="absolute top-4 right-4 w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-red-500 hover:bg-red-50 transition-all z-10 shadow-sm">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">favorite</span>
                </button>
                
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-on-surface flex items-center gap-1 z-10 shadow-sm">
                    <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span> 4.9 (86)
                </div>

                <div class="h-64 relative bg-gray-200 overflow-hidden">
                    <img src="/images/guide_2.png" alt="Linh Chi" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"/>
                </div>

                <div class="p-8 flex-1 flex flex-col">
                    <div class="flex justify-between items-center mb-1">
                        <h4 class="text-2xl font-bold text-on-surface">Linh Chi</h4>
                        <span class="text-xs font-bold bg-primary-container text-primary px-2 py-1 rounded-md border border-primary/20">INFJ</span>
                    </div>
                    <p class="text-on-surface-variant text-sm mb-4 flex items-center gap-1 font-medium">
                        <span class="material-symbols-outlined text-sm">location_on</span> Da Lat, Vietnam
                    </p>
                    
                    <div class="flex flex-wrap gap-2 mb-6">
                        <span class="bg-surface-variant text-xs font-bold px-2 py-1 rounded">Nature Walks</span>
                        <span class="bg-surface-variant text-xs font-bold px-2 py-1 rounded">Local History</span>
                    </div>
                    
                    <div class="mt-auto grid grid-cols-2 gap-3">
                        <a href="/Guide/Profile/2" class="col-span-2 bg-white border-2 border-primary text-primary hover:bg-primary hover:text-white text-center py-3 rounded-xl font-bold transition-all shadow-sm">
                            View Profile
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </main>
</div>
