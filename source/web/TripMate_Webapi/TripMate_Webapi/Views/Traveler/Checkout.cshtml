@model TripMate_Webapi.Entities.BookingEntity
@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-surface min-h-screen py-12 px-4" x-data="checkoutForm()">
    <div class="max-w-[1000px] mx-auto">
        
        <div class="mb-8 flex items-center gap-4">
            <a href="/Traveler/BookingDetails/@Model.Id" class="w-10 h-10 rounded-full bg-white border border-outline-variant/50 flex items-center justify-center text-on-surface-variant hover:text-primary transition-all shadow-sm">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <h1 class="text-3xl font-extrabold text-on-surface">Secure Checkout</h1>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Left Column: Payment Form -->
            <div class="space-y-8">
                <!-- Payment Method Selection -->
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 tonal-elevation">
                    <h2 class="text-xl font-bold text-on-surface mb-6">Select Payment Method</h2>
                    
                    <div class="space-y-4">
                        <!-- Credit Card -->
                        <label class="cursor-pointer">
                            <input type="radio" name="paymentMethod" value="card" x-model="method" class="peer sr-only">
                            <div class="p-5 rounded-xl border-2 border-outline-variant/30 flex items-center gap-4 hover:bg-primary-container peer-checked:bg-primary-container peer-checked:border-primary peer-checked:text-primary transition-all">
                                <span class="material-symbols-outlined text-3xl">credit_card</span>
                                <span class="font-bold text-lg">Credit / Debit Card</span>
                            </div>
                        </label>

                        <!-- VNPay -->
                        <label class="cursor-pointer">
                            <input type="radio" name="paymentMethod" value="vnpay" x-model="method" class="peer sr-only">
                            <div class="p-5 rounded-xl border-2 border-outline-variant/30 flex items-center gap-4 hover:bg-primary-container peer-checked:bg-primary-container peer-checked:border-primary peer-checked:text-primary transition-all">
                                <span class="material-symbols-outlined text-3xl">account_balance</span>
                                <span class="font-bold text-lg">VNPay / Bank Transfer</span>
                            </div>
                        </label>
                        
                        <!-- Momo -->
                        <label class="cursor-pointer">
                            <input type="radio" name="paymentMethod" value="momo" x-model="method" class="peer sr-only">
                            <div class="p-5 rounded-xl border-2 border-outline-variant/30 flex items-center gap-4 hover:bg-primary-container peer-checked:bg-primary-container peer-checked:border-primary peer-checked:text-primary transition-all">
                                <span class="material-symbols-outlined text-3xl">wallet</span>
                                <span class="font-bold text-lg">MoMo E-Wallet</span>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Card Details Form (Shows only if card is selected) -->
                <div x-show="method === 'card'" x-transition class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 tonal-elevation">
                    <h2 class="text-xl font-bold text-on-surface mb-6">Card Details</h2>
                    
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-bold text-on-surface mb-2">Name on Card</label>
                            <input type="text" placeholder="JOHN DOE" class="w-full bg-surface border-outline-variant/50 rounded-xl p-3 text-on-surface focus:ring-primary focus:border-primary uppercase">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-bold text-on-surface mb-2">Card Number</label>
                            <div class="relative">
                                <input type="text" placeholder="0000 0000 0000 0000" class="w-full bg-surface border-outline-variant/50 rounded-xl p-3 pl-12 text-on-surface focus:ring-primary focus:border-primary">
                                <span class="material-symbols-outlined absolute left-4 top-3 text-outline-variant">credit_card</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-on-surface mb-2">Expiry Date</label>
                                <input type="text" placeholder="MM/YY" class="w-full bg-surface border-outline-variant/50 rounded-xl p-3 text-on-surface focus:ring-primary focus:border-primary">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-on-surface mb-2">CVV</label>
                                <input type="password" placeholder="123" class="w-full bg-surface border-outline-variant/50 rounded-xl p-3 text-on-surface focus:ring-primary focus:border-primary">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Order Summary -->
            <div>
                <form action="/Traveler/ProcessPayment" method="POST" id="paymentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="paymentMethod" x-bind:value="method" />

                    <div class="bg-white rounded-3xl p-8 shadow-2xl border-2 border-primary/20 sticky top-24">
                        <h3 class="text-2xl font-bold text-on-surface mb-6">Order Summary</h3>
                        
                        <div class="flex items-start gap-4 mb-8 pb-6 border-b border-outline-variant/30">
                            <div class="w-20 h-20 bg-gray-200 rounded-xl shrink-0 overflow-hidden relative border-2 border-outline-variant/20">
                                <img src="@(string.IsNullOrEmpty(Model.GuideProfile?.Profile?.AvatarUrl) ? "/images/default_avatar.png" : Model.GuideProfile.Profile.AvatarUrl)" alt="Guide" class="w-full h-full object-cover"/>
                            </div>
                            <div>
                                <h4 class="font-bold text-on-surface text-lg">@(Model.ExperiencePackage?.Title ?? "Custom Tour")</h4>
                                <p class="text-sm text-on-surface-variant">@Model.BookingDate.ToString("MMM dd") • @Model.GuestCount Guests</p>
                                <p class="text-sm text-primary font-bold mt-1">Guide: @(Model.GuideProfile?.Profile?.FullName ?? "Unknown Guide")</p>
                            </div>
                        </div>
                        
                        <div class="space-y-4 mb-6 border-b border-outline-variant/30 pb-6">
                            <div class="flex justify-between text-on-surface-variant">
                                <span>Subtotal</span>
                                <span class="font-medium text-on-surface">@((Model.TotalAmount - Model.PlatformFee).ToString("#,##0")) ₫</span>
                            </div>
                            <div class="flex justify-between text-on-surface-variant">
                                <span>Service Fee</span>
                                <span class="font-medium text-on-surface">@(Model.PlatformFee.ToString("#,##0")) ₫</span>
                            </div>
                        </div>
                        
                        <div class="flex justify-between items-end mb-8">
                            <span class="font-bold text-on-surface">Total to Pay</span>
                            <span class="text-4xl font-extrabold text-primary">@(Model.TotalAmount.ToString("#,##0")) ₫</span>
                        </div>

                        <!-- Social Proof Nudge (M4 Scarcity Feature) -->
                        <div class="bg-orange-50 border border-orange-200 rounded-xl p-3 mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-orange-500 text-sm">local_fire_department</span>
                            <p class="text-xs text-orange-700 font-medium">
                                <span id="viewerCount">3</span> others are viewing this guide right now.
                                Your slot is reserved for <span id="countdown" class="font-bold">15:00</span>.
                            </p>
                        </div>

                        <button type="submit" @@click.prevent="processPayment()" class="w-full bg-primary hover:bg-primary/90 text-white py-4 rounded-xl font-bold text-xl shadow-lg hover:-translate-y-1 transition-all flex justify-center items-center gap-2 relative overflow-hidden group">
                            <span x-show="!processing" class="flex items-center gap-2">
                                <span class="material-symbols-outlined">lock</span> Confirm & Pay
                            </span>
                            <span x-show="processing" class="flex items-center gap-2" style="display: none;">
                                <span class="material-symbols-outlined animate-spin">sync</span> Processing...
                            </span>
                            <!-- Button Glow Effect -->
                            <div class="absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                        </button>

                        <p class="text-xs text-center text-on-surface-variant mt-4 flex items-center justify-center gap-1">
                            <span class="material-symbols-outlined text-sm">verified_user</span> Payments are secure and encrypted.
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('checkoutForm', () => ({
            method: 'card',
            processing: false,
            
            processPayment() {
                if (this.processing) return;
                this.processing = true;
                // Xóa Ghost Booking trước khi submit
                localStorage.removeItem('ghostBookingGuideId');
                setTimeout(() => {
                    document.getElementById('paymentForm').submit();
                }, 1500);
            }
        }))
    })

    // ── Social Proof: Countdown Timer ────────────────────────────────────────
    (function() {
        // Random viewer count 2-6
        const viewers = Math.floor(Math.random() * 5) + 2;
        const viewerEl = document.getElementById('viewerCount');
        if (viewerEl) viewerEl.textContent = viewers;

        // 15-minute countdown
        let totalSeconds = 15 * 60;
        const countdownEl = document.getElementById('countdown');

        const timer = setInterval(() => {
            if (!countdownEl) { clearInterval(timer); return; }
            totalSeconds--;
            if (totalSeconds <= 0) {
                clearInterval(timer);
                countdownEl.textContent = 'Expired';
                countdownEl.classList.add('text-red-600');
                return;
            }
            const m = Math.floor(totalSeconds / 60).toString().padStart(2, '0');
            const s = (totalSeconds % 60).toString().padStart(2, '0');
            countdownEl.textContent = m + ':' + s;

            // Đổi màu đỏ khi còn < 2 phút
            if (totalSeconds < 120) countdownEl.classList.add('text-red-600');
        }, 1000);
    })();
</script>
