@model TripMate_Webapi.Entities.BookingEntity
@{
    ViewData["Title"] = "Secure Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var package = ViewBag.Package as TripMate_WebAPI.Services.ExperiencePackageRow;
    var tourTitle = package?.Title ?? "Custom Itinerary";
    var guideName = package?.GuideProfile?.Profile?.FullName ?? "Local Guide";
}

<div class="min-h-screen bg-surface py-12" x-data="checkoutPage()">
    <div class="max-w-[1000px] mx-auto px-6 md:px-12">
        
        <div class="mb-8">
            <h1 class="text-3xl font-extrabold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-3xl">lock</span>
                Secure Checkout
            </h1>
            <p class="text-on-surface-variant mt-2">Complete your booking securely via TripMate Escrow.</p>
        </div>

        <div class="flex flex-col md:flex-row gap-8">
            <!-- Left: Payment Form -->
            <div class="flex-1">
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 mb-6">
                    <h2 class="text-xl font-bold text-on-surface mb-6">Payment Method</h2>
                    
                    <!-- Mock Card -->
                    <div class="bg-primary/5 border border-primary/20 rounded-2xl p-6 relative overflow-hidden mb-6">
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                            <span class="material-symbols-outlined text-8xl">credit_card</span>
                        </div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-center mb-6">
                                <span class="text-primary font-bold tracking-widest text-lg">MOCK CARD</span>
                                <div class="flex gap-2">
                                    <div class="w-8 h-5 bg-blue-500 rounded-sm"></div>
                                    <div class="w-8 h-5 bg-red-500 rounded-full mix-blend-multiply opacity-80 -ml-4"></div>
                                </div>
                            </div>
                            <p class="font-mono text-xl tracking-[0.2em] text-on-surface mb-4">**** **** **** 4242</p>
                            <div class="flex justify-between text-sm text-on-surface-variant font-medium">
                                <span>TRAVELER NAME</span>
                                <span>12/28</span>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-bold text-on-surface mb-2">Cardholder Name</label>
                            <input type="text" value="Traveler" class="w-full px-4 py-3 bg-surface-variant/50 border border-outline-variant/50 rounded-xl focus:outline-none focus:border-primary transition-colors text-on-surface" readonly>
                        </div>
                        <div class="flex gap-4">
                            <div class="flex-1">
                                <label class="block text-sm font-bold text-on-surface mb-2">Expiry Date</label>
                                <input type="text" value="12/28" class="w-full px-4 py-3 bg-surface-variant/50 border border-outline-variant/50 rounded-xl focus:outline-none focus:border-primary transition-colors text-on-surface" readonly>
                            </div>
                            <div class="flex-1">
                                <label class="block text-sm font-bold text-on-surface mb-2">CVC</label>
                                <input type="text" value="***" class="w-full px-4 py-3 bg-surface-variant/50 border border-outline-variant/50 rounded-xl focus:outline-none focus:border-primary transition-colors text-on-surface" readonly>
                            </div>
                        </div>
                    </div>
                </div>

                <button @@click="processPayment()" :disabled="processing" class="w-full bg-primary text-white py-4 rounded-xl font-bold text-lg hover:bg-primary/90 transition-all shadow-md hover:shadow-lg flex items-center justify-center gap-2">
                    <span x-show="!processing" class="material-symbols-outlined">payments</span>
                    <span x-show="!processing">Confirm & Pay @(Model.TotalAmount.ToString("#,##0")) ₫</span>
                    <span x-show="processing" class="material-symbols-outlined animate-spin">refresh</span>
                    <span x-show="processing">Processing...</span>
                </button>
                <p class="text-center text-xs text-on-surface-variant mt-4 flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">gpp_good</span>
                    Your payment is held securely in escrow until the tour is completed.
                </p>
            </div>

            <!-- Right: Order Summary -->
            <div class="w-full md:w-[400px]">
                <div class="bg-surface-variant/30 rounded-3xl p-6 border border-outline-variant/30 sticky top-24">
                    <h2 class="text-xl font-bold text-on-surface mb-4">Order Summary</h2>
                    
                    <div class="flex gap-4 pb-6 border-b border-outline-variant/30 mb-6">
                        <div class="w-20 h-20 bg-gray-200 rounded-xl overflow-hidden shrink-0 flex items-center justify-center">
                             <span class="material-symbols-outlined text-3xl text-gray-400">landscape</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-on-surface line-clamp-2 mb-1">@tourTitle</h3>
                            <p class="text-sm text-on-surface-variant flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">person</span>
                                With @guideName
                            </p>
                        </div>
                    </div>

                    <div class="space-y-3 mb-6 pb-6 border-b border-outline-variant/30">
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-on-surface-variant flex items-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">calendar_today</span> Date
                            </span>
                            <span class="font-bold text-on-surface">@Model.BookingDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-on-surface-variant flex items-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">group</span> Guests
                            </span>
                            <span class="font-bold text-on-surface">@Model.GuestCount</span>
                        </div>
                    </div>

                    <div class="space-y-3 mb-6 pb-6 border-b border-outline-variant/30">
                        <div class="flex justify-between items-center">
                            <span class="text-on-surface-variant">Subtotal</span>
                            <span class="font-bold text-on-surface">@((Model.TotalAmount - Model.PlatformFee).ToString("#,##0")) ₫</span>
                        </div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-on-surface-variant">Service Fee (15%)</span>
                            <span class="font-bold text-on-surface">@Model.PlatformFee.ToString("#,##0") ₫</span>
                        </div>
                    </div>

                    <div class="flex justify-between items-center">
                        <span class="font-bold text-lg text-on-surface">Total</span>
                        <span class="font-extrabold text-2xl text-primary">@Model.TotalAmount.ToString("#,##0") ₫</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('checkoutPage', () => ({
            processing: false,
            bookingId: '@Model.Id',

            async processPayment() {
                this.processing = true;
                const token = localStorage.getItem('accessToken');
                
                try {
                    // Simulate network delay for realistic mock UI
                    await new Promise(r => setTimeout(r, 1500));

                    const res = await fetch('/Traveler/ProcessPaymentAjax/' + this.bookingId, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token }
                    });

                    if (res.ok) {
                        Swal.fire({
                            title: 'Payment Successful!',
                            text: 'Your payment is safely held in escrow.',
                            icon: 'success',
                            confirmButtonColor: '#ff7a00'
                        }).then(() => {
                            window.location.href = '/Traveler/Trips';
                        });
                    } else {
                        const err = await res.json();
                        Swal.fire({
                            title: 'Payment Failed',
                            text: err.error || 'Please try again.',
                            icon: 'error',
                            confirmButtonColor: '#ff7a00'
                        });
                    }
                } catch(e) {
                    Swal.fire({
                        title: 'Error',
                        text: 'Connection error during payment.',
                        icon: 'error',
                        confirmButtonColor: '#ff7a00'
                    });
                } finally {
                    this.processing = false;
                }
            }
        }))
    });
</script>
