@model List<TripMate_Webapi.Entities.BookingEntity>
@{
    ViewData["Title"] = "Traveler Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var upcomingBookings = Model?.Where(b => b.Status == 0 || b.Status == 1).OrderBy(b => b.BookingDate).ToList() ?? new List<TripMate_Webapi.Entities.BookingEntity>();
    var pastBookings = Model?.Where(b => b.Status == 2).OrderByDescending(b => b.BookingDate).ToList() ?? new List<TripMate_Webapi.Entities.BookingEntity>();
}

<div class="min-h-screen bg-surface flex">
    
    <partial name="_TravelerSidebar" />

    <!-- Main Content -->
    <main class="flex-1 p-8 md:p-12 overflow-y-auto h-[calc(100vh-80px)]">
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-8 bg-green-100 border border-green-200 text-green-800 px-6 py-4 rounded-xl flex items-center gap-3 animate-fade-in">
                <span class="material-symbols-outlined text-green-600">check_circle</span>
                <span class="font-bold">@TempData["SuccessMessage"]</span>
            </div>
        }

        <div class="flex justify-between items-end mb-10">
            <div>
                <h1 class="text-4xl font-extrabold text-on-surface mb-2" data-welcome>Welcome back, @(ViewBag.TravelerName ?? "Traveler")!</h1>
                <p class="text-lg text-on-surface-variant">Ready for your next adventure?</p>
            </div>
            <a href="/Traveler/CreateTripRequest" class="bg-primary text-on-primary px-6 py-3 rounded-full font-bold flex items-center gap-2 hover:bg-primary/90 transition-all shadow-md">
                <span class="material-symbols-outlined">add</span>
                Plan New Trip
            </a>
        </div>

        <!-- Upcoming Trips -->
        <h2 class="text-2xl font-bold text-on-surface mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">calendar_month</span>
            Upcoming Trips
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
            @if (upcomingBookings.Any())
            {
                foreach(var booking in upcomingBookings)
                {
                    <div class="bg-white rounded-3xl p-8 shadow-xl border border-outline-variant/30 relative overflow-hidden tonal-elevation group cursor-pointer hover:-translate-y-1 transition-all">
                        <!-- Status Badge -->
                        <div class="absolute top-6 right-6 @(booking.Status == 0 ? "bg-yellow-100 text-yellow-700 border-yellow-200" : "bg-blue-100 text-blue-700 border-blue-200") px-3 py-1 rounded-full text-xs font-bold border flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">@(booking.Status == 0 ? "pending" : "check_circle")</span> @(booking.Status == 0 ? "Pending Approval" : "Approved")
                        </div>

                        <h3 class="text-2xl font-extrabold text-on-surface mb-1">@(booking.ExperiencePackage?.Title ?? "Custom Tour")</h3>
                        <p class="text-primary font-medium mb-6">With @(booking.GuideProfile?.Profile?.FullName ?? "Local Guide")</p>
                        
                        <div class="grid grid-cols-2 gap-4 mb-8">
                            <div class="bg-surface-variant p-4 rounded-xl">
                                <span class="block text-xs text-on-surface-variant mb-1 font-bold">DATE</span>
                                <span class="text-on-surface font-medium">@booking.BookingDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="bg-surface-variant p-4 rounded-xl">
                                <span class="block text-xs text-on-surface-variant mb-1 font-bold">TOTAL PRICE</span>
                                <span class="text-on-surface font-medium text-lg text-primary">@booking.TotalAmount.ToString("N0")₫</span>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            @if(booking.Status == 1 && string.IsNullOrEmpty(booking.PaymentReference))
                            {
                                <a href="/Traveler/Checkout/@booking.Id" class="flex-1 bg-primary text-on-primary hover:bg-primary/90 py-3 rounded-xl font-bold flex items-center justify-center gap-2 transition-all shadow-md">
                                    <span class="material-symbols-outlined">payments</span> Pay Now
                                </a>
                            }
                            <a href="/Traveler/BookingDetails/@booking.Id" class="flex-1 border-2 border-primary text-primary hover:bg-primary-container py-3 rounded-xl font-bold flex items-center justify-center transition-all">
                                View Details
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full bg-surface-variant/30 rounded-3xl p-8 text-center border border-dashed border-outline-variant">
                    <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2">luggage</span>
                    <h3 class="text-lg font-bold text-on-surface mb-1">No upcoming trips yet</h3>
                    <p class="text-on-surface-variant">Your confirmed and pending bookings will appear here.</p>
                </div>
            }
        </div>

        <!-- Past Trips -->
        <h2 class="text-2xl font-bold text-on-surface mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-gray-500">history</span>
            Past Trips
        </h2>

        @if (pastBookings.Any())
        {
            foreach(var booking in pastBookings)
            {
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/30 flex flex-col md:flex-row items-center gap-8 mb-6 opacity-80 hover:opacity-100 transition-opacity">
                    <div class="w-32 h-32 rounded-2xl bg-gray-200 overflow-hidden shrink-0 relative">
                        @if (!string.IsNullOrEmpty(booking.GuideProfile?.CoverPhotoUrl))
                        {
                            <img src="@booking.GuideProfile.CoverPhotoUrl" alt="Tour Cover" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="absolute inset-0 flex items-center justify-center">
                                <span class="material-symbols-outlined text-5xl text-gray-400">landscape</span>
                            </div>
                        }
                    </div>
                    
                    <div class="flex-1">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-xl font-bold text-on-surface">@(booking.ExperiencePackage?.Title ?? "Custom Tour")</h3>
                            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold border border-green-200">Completed</span>
                        </div>
                        <p class="text-on-surface-variant mb-4">Guided by <span class="font-bold text-on-surface">@(booking.GuideProfile?.Profile?.FullName ?? "Local Guide")</span> • @booking.BookingDate.ToString("MMM yyyy")</p>
                        
                        <div class="flex items-center gap-1 text-primary">
                            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                            <span class="ml-2 text-sm text-on-surface-variant font-medium">Pending your review</span>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row gap-3 w-full md:w-auto mt-4 md:mt-0">
                        <a href="/Traveler/Review/@booking.Id" class="border border-primary bg-primary text-white hover:bg-primary/90 text-center px-6 py-3 rounded-xl font-bold transition-all shadow-md">
                            Leave Review
                        </a>
                        <button class="border border-outline-variant text-on-surface-variant hover:bg-surface-variant px-6 py-3 rounded-xl font-bold transition-all">
                            Book Again
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="bg-surface-variant/30 rounded-3xl p-8 text-center border border-dashed border-outline-variant mb-12">
                <p class="text-on-surface-variant">You have no past trips.</p>
            </div>
        }

    </main>
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.5s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    // Cập nhật tên hiển thị từ localStorage nếu server không có claim
    document.addEventListener('DOMContentLoaded', () => {
        const userEmail = localStorage.getItem('userEmail');
        if (userEmail) {
            const atIdx = userEmail.indexOf('\u0040');
            const displayName = atIdx > 0 ? userEmail.substring(0, atIdx) : userEmail;
            const welcomeEl = document.querySelector('h1[data-welcome]');
            if (welcomeEl) {
                welcomeEl.textContent = 'Welcome back, ' + displayName + '!';
            }
        }

        // Ghost Booking: Kiểm tra nếu có pending booking intent từ trước khi login
        const ghostGuideId = localStorage.getItem('ghostBookingGuideId');
        if (ghostGuideId) {
            const notifBanner = document.createElement('div');
            notifBanner.className = 'mb-6 bg-orange-50 border border-orange-200 rounded-2xl p-4 flex items-center justify-between gap-4 animate-fade-in';
            notifBanner.innerHTML =
                '<div class="flex items-center gap-3">' +
                    '<span class="material-symbols-outlined text-orange-500">schedule</span>' +
                    '<div>' +
                        '<p class="font-bold text-orange-800">You have a pending booking request!</p>' +
                        '<p class="text-sm text-orange-600">You were browsing a guide before logging in. Continue your booking now.</p>' +
                    '</div>' +
                '</div>' +
                '<div class="flex gap-2 shrink-0">' +
                    '<a href="/Guide/Profile/' + ghostGuideId + '" class="bg-primary text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-primary/90 transition-all">Continue Booking</a>' +
                    '<button onclick="dismissGhostBooking()" class="border border-orange-200 text-orange-600 px-4 py-2 rounded-xl text-sm font-bold hover:bg-orange-100 transition-all">Dismiss</button>' +
                '</div>';
            const mainContent = document.querySelector('main');
            mainContent?.insertBefore(notifBanner, mainContent.firstChild);
        }
    });

    function dismissGhostBooking() {
        localStorage.removeItem('ghostBookingGuideId');
        fetch('/Survey/ClearSession', { method: 'POST' }).catch(() => {});
        document.querySelector('.bg-orange-50')?.remove();
    }
</script>
