@{
    ViewData["Title"] = "Traveler Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-surface flex">
    <partial name="_TravelerSidebar" />

    <main class="flex-1 p-8 md:p-10 overflow-y-auto h-[calc(100vh-80px)]">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-5 py-4 rounded-2xl flex items-center gap-3 animate-fade-in">
                <span class="material-symbols-outlined text-green-600">check_circle</span>
                <span class="font-bold">@TempData["SuccessMessage"]</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-5 py-4 rounded-2xl flex items-center gap-3 animate-fade-in">
                <span class="material-symbols-outlined text-red-600">error</span>
                <span class="font-bold">@TempData["ErrorMessage"]</span>
            </div>
        }

        <!-- Welcome -->
        <div class="mb-8">
            <h1 class="text-3xl font-extrabold text-on-surface mb-1" data-welcome>Welcome back, @(ViewBag.TravelerName ?? "Traveler")!</h1>
            <p class="text-on-surface-variant">Here's a quick overview of your travel activity.</p>
        </div>

        <div x-data="dashboardApp()">

            <!-- Quick Stats Row -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                <div class="bg-white rounded-2xl p-5 border border-outline-variant/30 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center"><span class="material-symbols-outlined text-blue-600 text-xl">calendar_month</span></div>
                        <span class="text-2xl font-extrabold text-on-surface" x-text="totalUpcoming">0</span>
                    </div>
                    <p class="text-xs text-on-surface-variant font-bold uppercase tracking-wider">Upcoming</p>
                </div>
                <div class="bg-white rounded-2xl p-5 border border-outline-variant/30 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center"><span class="material-symbols-outlined text-green-600 text-xl">check_circle</span></div>
                        <span class="text-2xl font-extrabold text-on-surface" x-text="totalCompleted">0</span>
                    </div>
                    <p class="text-xs text-on-surface-variant font-bold uppercase tracking-wider">Completed</p>
                </div>
                <div class="bg-white rounded-2xl p-5 border border-outline-variant/30 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-orange-100 flex items-center justify-center"><span class="material-symbols-outlined text-orange-600 text-xl">pending</span></div>
                        <span class="text-2xl font-extrabold text-on-surface" x-text="totalPendingPayment">0</span>
                    </div>
                    <p class="text-xs text-on-surface-variant font-bold uppercase tracking-wider">Needs Payment</p>
                </div>
                <div class="bg-white rounded-2xl p-5 border border-outline-variant/30 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center"><span class="material-symbols-outlined text-purple-600 text-xl">luggage</span></div>
                        <span class="text-2xl font-extrabold text-on-surface" x-text="bookings.length">0</span>
                    </div>
                    <p class="text-xs text-on-surface-variant font-bold uppercase tracking-wider">Total Trips</p>
                </div>
            </div>

            <!-- Two-column: Left = Trips, Right = Action Required -->
            <div class="flex flex-col lg:flex-row gap-6">

                <!-- LEFT COLUMN: Trips -->
                <div class="flex-1 min-w-0">

                    <!-- Upcoming Trips -->
                    <div class="mb-8">
                        <h2 class="text-xl font-bold text-on-surface flex items-center gap-2 mb-5">
                            <span class="material-symbols-outlined text-primary">calendar_month</span> Upcoming Trips
                        </h2>

                        <template x-if="loading">
                            <div class="text-center py-10"><div class="w-8 h-8 border-3 border-primary border-t-transparent rounded-full animate-spin mx-auto"></div></div>
                        </template>

                        <div class="space-y-4">
                            <template x-for="b in upcomingTrips" :key="b.id">
                                <div class="bg-white rounded-2xl p-5 shadow-sm border border-outline-variant/30 flex flex-col md:flex-row items-start md:items-center gap-4 hover:shadow-md transition-all">
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2 mb-1">
                                            <h3 class="font-bold text-on-surface truncate" x-text="b.packageTitle"></h3>
                                            <span class="px-2 py-0.5 rounded-full text-[11px] font-bold border shrink-0"
                                                  :class="b.status === 0 ? 'bg-yellow-50 text-yellow-700 border-yellow-200' : 'bg-blue-50 text-blue-700 border-blue-200'"
                                                  x-text="b.status === 0 ? 'Pending' : 'Approved'"></span>
                                        </div>
                                        <p class="text-sm text-on-surface-variant">With <span class="font-bold" x-text="b.guideName"></span> • <span x-text="b.bookingDate"></span></p>
                                    </div>
                                    <div class="flex items-center gap-3 shrink-0">
                                        <span class="text-primary font-extrabold" x-text="b.totalAmount.toLocaleString('vi-VN') + '₫'"></span>
                                        <template x-if="b.status === 1 && b.amountPaid < b.totalAmount && !b.isPastDeadline">
                                            <button @@click="showPaymentConfirm(b)" class="bg-primary text-white hover:bg-primary/90 px-4 py-2 rounded-xl text-sm font-bold transition-colors shadow-sm flex items-center gap-2">
                                                <span class="material-symbols-outlined text-sm">payment</span> Pay 70%
                                            </button>
                                        </template>
                                        <a :href="'/Traveler/BookingDetails/' + b.id" class="border border-primary text-primary hover:bg-primary-container px-4 py-2 rounded-xl text-sm font-bold transition-all">Details</a>
                                    </div>
                                </div>
                            </template>
                        </div>

                        <template x-if="!loading && upcomingTrips.length === 0">
                            <div class="bg-surface-variant/30 rounded-2xl p-8 text-center border border-dashed border-outline-variant">
                                <span class="material-symbols-outlined text-3xl text-on-surface-variant mb-2">luggage</span>
                                <p class="text-sm text-on-surface-variant font-medium">No upcoming trips yet.</p>
                            </div>
                        </template>
                    </div>

                    <!-- Past Trips -->
                    <div class="mb-6">
                        <h2 class="text-xl font-bold text-on-surface flex items-center gap-2 mb-5">
                            <span class="material-symbols-outlined text-gray-500">history</span> Recent Trips
                        </h2>
                        <div class="space-y-4">
                            <template x-for="b in pastTrips" :key="b.id">
                                <div class="bg-white rounded-2xl p-5 shadow-sm border border-outline-variant/30 flex flex-col md:flex-row items-center gap-4 opacity-90 hover:opacity-100 transition-opacity">
                                    <div class="w-16 h-16 rounded-xl bg-gray-100 overflow-hidden shrink-0">
                                        <template x-if="b.guideCoverPhoto"><img :src="b.guideCoverPhoto" class="w-full h-full object-cover" /></template>
                                        <template x-if="!b.guideCoverPhoto"><div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-2xl text-gray-400">landscape</span></div></template>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="font-bold text-on-surface truncate" x-text="b.packageTitle"></h3>
                                        <p class="text-sm text-on-surface-variant">With <span class="font-bold" x-text="b.guideName"></span> • <span x-text="b.bookingDate"></span></p>
                                    </div>
                                    <div class="flex gap-2 shrink-0">
                                        <template x-if="!b.hasReviewed">
                                            <button @@click="leaveReview(b.id)" class="bg-primary text-white px-4 py-2 rounded-xl text-xs font-bold hover:bg-primary/90 transition-all">Review</button>
                                        </template>
                                        <a :href="'/Traveler/BookingDetails/' + b.id" class="border border-outline-variant text-on-surface-variant hover:bg-surface-variant px-3 py-2 rounded-xl text-xs font-bold transition-all">Details</a>
                                    </div>
                                </div>
                            </template>
                        </div>

                        <template x-if="!loading && pastTrips.length === 0">
                            <div class="bg-surface-variant/30 rounded-2xl p-6 text-center border border-dashed border-outline-variant mt-4">
                                <p class="text-sm text-on-surface-variant">No completed trips yet.</p>
                            </div>
                        </template>
                    </div>


                    <!-- View All -->
                    <div class="text-center">
                        <a href="/Traveler/Trips" class="inline-flex items-center gap-2 bg-surface-variant hover:bg-primary-container text-on-surface font-bold px-6 py-3 rounded-xl transition-all text-sm">
                            <span class="material-symbols-outlined text-sm">list</span> View All Trips
                        </a>
                    </div>
                </div>

                <!-- RIGHT COLUMN: Action Required -->
                <div class="w-full lg:w-[340px] shrink-0">
                    <div class="sticky top-4">
                        <!-- Action Required Panel -->
                        <template x-if="!loading && incompleteBookings.length > 0">
                            <div class="bg-white rounded-2xl border border-orange-200 shadow-lg overflow-hidden">
                                <div class="px-5 py-4 bg-gradient-to-r from-orange-500 to-red-500 flex items-center gap-3">
                                    <span class="material-symbols-outlined text-white animate-pulse">warning</span>
                                    <h2 class="text-base font-extrabold text-white">Action Required</h2>
                                    <span class="ml-auto bg-white/25 text-white text-xs font-bold px-2 py-0.5 rounded-full" x-text="incompleteBookings.length"></span>
                                </div>
                                <div class="divide-y divide-outline-variant/20 max-h-[400px] overflow-y-auto">
                                    <template x-for="b in incompleteBookings" :key="b.id">
                                        <div class="p-4" :class="b.isPastDeadline ? 'opacity-60 bg-red-50/50' : (b.isApproachingDeadline ? 'bg-orange-50/50' : '')">
                                            <div class="flex justify-between items-start mb-1 gap-2">
                                                <p class="font-bold text-on-surface text-sm truncate" x-text="b.packageTitle"></p>
                                                <span class="text-[10px] font-bold px-2 py-0.5 rounded-full border shrink-0"
                                                      :class="b.status === -1 ? 'bg-orange-50 text-orange-700 border-orange-200' : 'bg-red-50 text-red-700 border-red-200'"
                                                      x-text="b.status === -1 ? '30% Deposit' : '70% Final'"></span>
                                            </div>
                                            <p class="text-xs text-on-surface-variant mb-0.5">
                                                <span x-text="b.guideName"></span> • <span x-text="b.bookingDate"></span>
                                            </p>
                                            
                                            <template x-if="b.isPastDeadline">
                                                <p class="text-xs text-red-600 font-bold mb-3 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">timer_off</span> Deadline passed</p>
                                            </template>
                                            <template x-if="b.isApproachingDeadline && !b.isPastDeadline">
                                                <p class="text-xs text-orange-600 font-bold mb-1 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">warning</span> Deadline approaching</p>
                                            </template>
                                            <template x-if="!b.isPastDeadline">
                                                <p class="text-primary font-extrabold text-base mb-3" 
                                                   x-text="(b.status === -1 ? (b.totalAmount * 0.3) : (b.totalAmount * 0.7)).toLocaleString('vi-VN') + '₫'"></p>
                                            </template>

                                            <div class="flex gap-2">
                                                <button @@click="showPaymentConfirm(b)" :disabled="b.isPastDeadline"
                                                        class="flex-1 bg-primary text-white px-3 py-2 rounded-xl text-xs font-bold hover:bg-primary/90 transition-all flex items-center justify-center gap-1 disabled:opacity-50 disabled:cursor-not-allowed">
                                                    <span class="material-symbols-outlined text-sm">payment</span> Pay Now
                                                </button>
                                                <button @@click="cancelBooking(b.id)" class="border border-red-300 text-red-500 px-3 py-2 rounded-xl text-xs font-bold hover:bg-red-50 transition-all" title="Cancel">
                                                    <span class="material-symbols-outlined text-sm">close</span>
                                                </button>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </div>
                        </template>

                        <!-- All clear state -->
                        <template x-if="!loading && incompleteBookings.length === 0">
                            <div class="bg-white rounded-2xl border border-outline-variant/30 shadow-sm p-6 text-center">
                                <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                    <span class="material-symbols-outlined text-green-600 text-2xl">task_alt</span>
                                </div>
                                <p class="font-bold text-on-surface text-sm">All Clear!</p>
                                <p class="text-xs text-on-surface-variant mt-1">No pending actions required.</p>
                            </div>
                        </template>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Payment Confirmation Modal -->
<div id="paymentModal" class="fixed inset-0 bg-black/50 z-[9999] items-center justify-center" style="display:none;">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md mx-4 overflow-hidden animate-fade-in">
        <div class="bg-gradient-to-r from-primary to-orange-500 p-6 text-white">
            <h3 class="text-xl font-extrabold flex items-center gap-2"><span class="material-symbols-outlined">receipt_long</span> Confirm Payment</h3>
            <p class="text-sm opacity-90 mt-1">Review your booking before proceeding.</p>
        </div>
        <div class="p-6 space-y-4">
            <div class="bg-surface-variant/50 rounded-xl p-4 space-y-3">
                <div class="flex justify-between"><span class="text-sm text-on-surface-variant">Tour</span><span id="pm-tour" class="text-sm font-bold text-on-surface text-right max-w-[60%] truncate"></span></div>
                <div class="flex justify-between"><span class="text-sm text-on-surface-variant">Guide</span><span id="pm-guide" class="text-sm font-bold text-on-surface"></span></div>
                <div class="flex justify-between"><span class="text-sm text-on-surface-variant">Date</span><span id="pm-date" class="text-sm font-bold text-on-surface"></span></div>
                <div class="flex justify-between"><span class="text-sm text-on-surface-variant">Guests</span><span id="pm-guests" class="text-sm font-bold text-on-surface"></span></div>
                <hr class="border-outline-variant/30" />
                <div class="flex justify-between"><span class="font-bold text-on-surface">Total</span><span id="pm-total" class="text-xl font-extrabold text-primary"></span></div>
            </div>
            <div class="text-center">
                <p class="text-xs text-on-surface-variant mb-1">Payment link expires in</p>
                <div id="pm-countdown" class="text-3xl font-extrabold text-primary tabular-nums">05:00</div>
            </div>
        </div>
        <div class="px-6 pb-6 flex gap-3">
            <button id="pm-cancel" class="flex-1 border-2 border-outline-variant text-on-surface-variant hover:bg-surface-variant py-3 rounded-xl font-bold transition-all">Cancel</button>
            <button id="pm-proceed" class="flex-1 bg-primary text-white hover:bg-primary/90 py-3 rounded-xl font-bold transition-all shadow-lg flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">lock</span> Pay Now
            </button>
        </div>
    </div>
</div>

<style>
    .animate-fade-in { animation: fadeIn 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userEmail = localStorage.getItem('userEmail');
        if (userEmail) {
            const atIdx = userEmail.indexOf('\u0040');
            const displayName = atIdx > 0 ? userEmail.substring(0, atIdx) : userEmail;
            const el = document.querySelector('h1[data-welcome]');
            if (el) el.textContent = 'Welcome back, ' + displayName + '!';
        }
        const ghostGuideId = localStorage.getItem('ghostBookingGuideId');
        if (ghostGuideId) {
            const banner = document.createElement('div');
            banner.className = 'mb-6 bg-orange-50 border border-orange-200 rounded-2xl p-4 flex items-center justify-between gap-4 animate-fade-in';
            banner.innerHTML = '<div class="flex items-center gap-3"><span class="material-symbols-outlined text-orange-500">schedule</span><div><p class="font-bold text-orange-800">Pending booking request!</p><p class="text-sm text-orange-600">Continue from where you left off.</p></div></div><div class="flex gap-2 shrink-0"><a href="/Guide/Profile/' + ghostGuideId + '" class="bg-primary text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-primary/90 transition-all">Continue</a><button onclick="dismissGhostBooking()" class="border border-orange-200 text-orange-600 px-4 py-2 rounded-xl text-sm font-bold hover:bg-orange-100 transition-all">Dismiss</button></div>';
            const main = document.querySelector('main');
            main?.insertBefore(banner, main.children[0]);
        }
    });

    function dismissGhostBooking() {
        localStorage.removeItem('ghostBookingGuideId');
        fetch('/Survey/ClearSession', { method: 'POST' }).catch(() => {});
        document.querySelector('.bg-orange-50')?.remove();
    }

    // Payment Modal
    let paymentCountdownInterval = null;
    let currentPaymentBookingId = null;

    function openPaymentModal(booking) {
        currentPaymentBookingId = booking.id;
        document.getElementById('pm-tour').textContent = booking.packageTitle;
        document.getElementById('pm-guide').textContent = booking.guideName;
        document.getElementById('pm-date').textContent = booking.bookingDate;
        document.getElementById('pm-guests').textContent = (booking.guestCount || 1) + ' guest(s)';
        
        let payAmount = booking.status === -1 ? (booking.totalAmount * 0.3) : (booking.totalAmount * 0.7);
        document.getElementById('pm-total').textContent = payAmount.toLocaleString('vi-VN') + '₫';

        const modal = document.getElementById('paymentModal');
        modal.style.display = 'flex';

        let timeLeft = 300;
        const countdownEl = document.getElementById('pm-countdown');
        const proceedBtn = document.getElementById('pm-proceed');
        proceedBtn.disabled = false;
        proceedBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        proceedBtn.innerHTML = '<span class="material-symbols-outlined text-sm">lock</span> Pay Now';
        countdownEl.classList.remove('text-red-500');

        function tick() {
            const m = Math.floor(timeLeft / 60), s = timeLeft % 60;
            countdownEl.textContent = String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
            if (timeLeft <= 60) countdownEl.classList.add('text-red-500');
            if (timeLeft <= 0) { clearInterval(paymentCountdownInterval); countdownEl.textContent = 'EXPIRED'; proceedBtn.disabled = true; proceedBtn.classList.add('opacity-50','cursor-not-allowed'); proceedBtn.innerHTML = '<span class="material-symbols-outlined text-sm">timer_off</span> Expired'; }
            timeLeft--;
        }
        tick();
        if (paymentCountdownInterval) clearInterval(paymentCountdownInterval);
        paymentCountdownInterval = setInterval(tick, 1000);
    }

    function closePaymentModal() {
        document.getElementById('paymentModal').style.display = 'none';
        if (paymentCountdownInterval) clearInterval(paymentCountdownInterval);
        currentPaymentBookingId = null;
    }

    document.getElementById('pm-cancel').addEventListener('click', closePaymentModal);
    document.getElementById('pm-proceed').addEventListener('click', async () => {
        if (!currentPaymentBookingId) return;
        const btn = document.getElementById('pm-proceed');
        btn.disabled = true;
        btn.innerHTML = '<div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Processing...';
        const token = localStorage.getItem('accessToken');
        try {
            const res = await fetch('/Traveler/RetryPayment', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }, body: JSON.stringify({ bookingId: currentPaymentBookingId }) });
            if (res.ok) { const data = await res.json(); if (data.paymentUrl) window.location.href = data.paymentUrl; }
            else { const err = await res.json(); Swal.fire({ title: 'Error', text: err.error || 'Failed.', icon: 'error' }); closePaymentModal(); }
        } catch (e) { Swal.fire({ title: 'Error', text: 'Connection error.', icon: 'error' }); closePaymentModal(); }
    });
</script>

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('dashboardApp', () => ({
            bookings: [], loading: true,
            async init() {
                const token = localStorage.getItem('accessToken');
                if (!token) { this.loading = false; return; }
                try { const res = await fetch('/Traveler/GetMyBookings', { headers: { 'Authorization': 'Bearer ' + token } }); if (res.ok) this.bookings = await res.json(); } catch(e) { console.error(e); }
                finally { this.loading = false; }
            },
            get incompleteBookings() { return this.bookings.filter(b => b.status === -1 || (b.status === 1 && b.amountPaid < b.totalAmount)); },
            get upcomingTrips() { return this.bookings.filter(b => b.status === 0 || b.status === 1).sort((a,b) => new Date(a.bookingDate) - new Date(b.bookingDate)).slice(0, 4); },
            get pastTrips() { return this.bookings.filter(b => b.status === 2).sort((a,b) => new Date(b.bookingDate) - new Date(a.bookingDate)).slice(0, 3); },

            get totalUpcoming() { return this.bookings.filter(b => b.status === 0 || b.status === 1).length; },
            get totalCompleted() { return this.bookings.filter(b => b.status === 2).length; },
            get totalPendingPayment() { return this.incompleteBookings.length; },
            showPaymentConfirm(b) { openPaymentModal(b); },
            async cancelBooking(id) {
                const booking = this.bookings.find(b => b.id === id);
                if (!booking) return;
                
                let warnText = 'This booking will be permanently deleted.';
                if (booking.amountPaid > 0) {
                    warnText = 'Warning: You will lose your deposit of ' + booking.amountPaid.toLocaleString('vi-VN') + '₫ if you cancel!';
                }

                Swal.fire({ title: 'Cancel Booking?', text: warnText, icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#6b7280', confirmButtonText: 'Yes, cancel', cancelButtonText: 'Keep it' }).then(async (result) => {
                    if (result.isConfirmed) {
                        const token = localStorage.getItem('accessToken');
                        try {
                            const res = await fetch('/Traveler/CancelBookingAjax/' + id, { method: 'POST', headers: { 'Authorization': 'Bearer ' + token } });
                            if (res.ok) { this.bookings = this.bookings.filter(b => b.id !== id); Swal.fire({ title: 'Cancelled!', text: 'Booking removed.', icon: 'success', timer: 1500, showConfirmButton: false }); }
                            else { const err = await res.json(); Swal.fire({ title: 'Error', text: err.error || 'Failed to cancel.', icon: 'error' }); }
                        } catch(e) { Swal.fire({ title: 'Error', text: 'Connection error.', icon: 'error' }); }
                    }
                });
            },
            async leaveReview(id) {
                const { value: fv } = await Swal.fire({ title: 'Rate your Trip', html: '<div class="mb-4"><label class="block text-sm font-bold mb-2">Rating (1-5)</label><input id="swal-rating" type="number" min="1" max="5" class="w-full border rounded-lg p-2" value="5"></div><div><label class="block text-sm font-bold mb-2">Comment</label><textarea id="swal-comment" class="w-full border rounded-lg p-2" rows="3" placeholder="Your experience..."></textarea></div>', focusConfirm: false, showCancelButton: true, confirmButtonText: 'Submit', confirmButtonColor: '#ff7a00', preConfirm: () => ({ rating: document.getElementById('swal-rating').value, comment: document.getElementById('swal-comment').value }) });
                if (fv) {
                    const token = localStorage.getItem('accessToken');
                    try {
                        const res = await fetch('/Traveler/SubmitReviewAjax', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }, body: JSON.stringify({ bookingId: id, rating: parseInt(fv.rating), comment: fv.comment }) });
                        if (res.ok) { Swal.fire({ title: 'Thank you!', icon: 'success', timer: 1500, showConfirmButton: false }); this.bookings = this.bookings.map(b => b.id === id ? { ...b, hasReviewed: true } : b); }
                        else { const err = await res.json(); Swal.fire({ title: 'Error', text: err.error || 'Failed.', icon: 'error' }); }
                    } catch (e) { Swal.fire({ title: 'Error', text: 'Connection error.', icon: 'error' }); }
                }
            }
        }));
    });
</script>
