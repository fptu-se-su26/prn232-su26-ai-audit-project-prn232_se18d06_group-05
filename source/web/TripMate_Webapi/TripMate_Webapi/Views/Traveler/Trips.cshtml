@{
    ViewData["Title"] = "My Trips Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-surface flex">
    <partial name="_TravelerSidebar" />

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto h-[calc(100vh-80px)]">
        <!-- Dashboard Header -->
        <div class="bg-white border-b border-outline-variant/30 pt-10 pb-6 px-6 md:px-12">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <div>
                    <h1 class="text-3xl font-extrabold text-on-surface">My Trips</h1>
                    <p class="text-on-surface-variant mt-1">Manage your upcoming adventures and trip requests.</p>
                </div>
                <a href="/Traveler/CreateTripRequest" class="bg-primary text-white font-bold px-6 py-3 rounded-xl shadow-lg hover:shadow-primary/30 transition-all hover:-translate-y-1 flex items-center gap-2">
                    <span class="material-symbols-outlined">add</span>
                    New Trip Request
                </a>
            </div>
        </div>

        <!-- Success / Error Message -->
        <div id="alert-box" class="hidden max-w-[1200px] mx-auto mt-6 px-6">
            <div id="alert-inner" class="px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined" id="alert-icon">check_circle</span>
                <p class="font-medium" id="alert-text"></p>
            </div>
        </div>

        <!-- Main Content Tabs -->
        <div class="px-6 md:px-12 mt-8" x-data="{ tab: 'requests' }">
            <!-- Tabs -->
            <div class="flex gap-8 border-b border-outline-variant/30 mb-8 overflow-x-auto">
                <button @@click="tab = 'bookings'" :class="tab === 'bookings' ? 'border-primary text-primary' : 'border-transparent text-on-surface-variant hover:text-on-surface'" class="border-b-2 pb-4 px-2 font-bold whitespace-nowrap transition-colors">
                    My Bookings <span id="bookings-count" class="ml-1 text-on-surface-variant">(0)</span>
                </button>
                <button @@click="tab = 'requests'" :class="tab === 'requests' ? 'border-primary text-primary' : 'border-transparent text-on-surface-variant hover:text-on-surface'" class="border-b-2 pb-4 px-2 font-bold whitespace-nowrap transition-colors">
                    My Requests <span id="requests-count" class="ml-1 text-on-surface-variant">(0)</span>
                </button>
            </div>

            <!-- Requests Tab -->
            <div x-show="tab === 'requests'" class="space-y-6 animate-fade-in-up">
                <div id="requests-loading" class="text-center py-16">
                    <div class="w-10 h-10 border-4 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
                    <p class="text-on-surface-variant">Loading your trip requests...</p>
                </div>
                <div id="requests-list" class="space-y-6 hidden"></div>
                <div id="requests-empty" class="hidden text-center py-20 bg-white rounded-2xl border border-outline-variant/30">
                    <div class="w-20 h-20 bg-surface-variant rounded-full flex items-center justify-center mx-auto mb-4">
                        <span class="material-symbols-outlined text-3xl text-on-surface-variant">search_off</span>
                    </div>
                    <h3 class="text-xl font-bold text-on-surface mb-2">No active requests</h3>
                    <p class="text-on-surface-variant mb-6">You haven't posted any trip requests yet.</p>
                    <a href="/Traveler/CreateTripRequest" class="inline-block bg-primary text-white font-bold px-6 py-3 rounded-xl hover:bg-primary/90 transition-colors">Post a Request</a>
                </div>
            </div>

            <!-- Bookings Tab -->
            <div x-show="tab === 'bookings'" class="space-y-6 animate-fade-in-up">
                <!-- Search & Filter Bar -->
                <div class="flex flex-col xl:flex-row gap-4 justify-between mb-6">
                    <div class="w-full xl:w-1/3 relative shrink-0">
                        <span class="material-symbols-outlined absolute left-4 top-3 text-on-surface-variant">search</span>
                        <input type="text" id="booking-search-input" class="w-full bg-surface pl-12 pr-4 py-3 rounded-xl border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" placeholder="Search by guide, city, or tour..." oninput="filterBookings()">
                    </div>
                    
                    <div class="flex gap-2 overflow-x-auto pb-2 xl:pb-0 scrollbar-hide flex-nowrap" id="booking-filters">
                        <button class="booking-filter-btn active px-4 py-2 rounded-full font-bold text-sm bg-primary text-white whitespace-nowrap transition-all" data-filter="all" onclick="setBookingFilter('all', this)">All Trips</button>
                        <button class="booking-filter-btn px-4 py-2 rounded-full font-bold text-sm bg-surface-variant text-on-surface hover:bg-outline-variant/30 whitespace-nowrap transition-all" data-filter="pending-deposit" onclick="setBookingFilter('pending-deposit', this)">Pending Deposit</button>
                        <button class="booking-filter-btn px-4 py-2 rounded-full font-bold text-sm bg-surface-variant text-on-surface hover:bg-outline-variant/30 whitespace-nowrap transition-all" data-filter="action-required" onclick="setBookingFilter('action-required', this)">Action Required</button>
                        <button class="booking-filter-btn px-4 py-2 rounded-full font-bold text-sm bg-surface-variant text-on-surface hover:bg-outline-variant/30 whitespace-nowrap transition-all" data-filter="upcoming" onclick="setBookingFilter('upcoming', this)">Upcoming</button>
                        <button class="booking-filter-btn px-4 py-2 rounded-full font-bold text-sm bg-surface-variant text-on-surface hover:bg-outline-variant/30 whitespace-nowrap transition-all" data-filter="completed" onclick="setBookingFilter('completed', this)">Completed</button>
                        <button class="booking-filter-btn px-4 py-2 rounded-full font-bold text-sm bg-surface-variant text-on-surface hover:bg-outline-variant/30 whitespace-nowrap transition-all" data-filter="cancelled" onclick="setBookingFilter('cancelled', this)">Cancelled</button>
                    </div>
                </div>

                <div id="bookings-loading" class="text-center py-16">
                    <div class="w-10 h-10 border-4 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
                    <p class="text-on-surface-variant">Loading your bookings...</p>
                </div>
                
                <div id="bookings-list" class="space-y-6 hidden"></div>
                
                <div id="bookings-empty" class="hidden text-center py-20">
                    <div class="w-24 h-24 bg-surface-variant rounded-full flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-4xl text-on-surface-variant">search_off</span>
                    </div>
                    <h3 class="text-xl font-bold text-on-surface mb-2">No trips found</h3>
                    <p class="text-on-surface-variant max-w-md mx-auto mb-6">We couldn't find any trips matching your criteria.</p>
                    <button onclick="setBookingFilter('all', document.querySelector('[data-filter=all]')); document.getElementById('booking-search-input').value=''; filterBookings();" class="inline-block bg-on-surface text-white font-bold px-6 py-3 rounded-xl hover:bg-on-surface/90 transition-colors">Clear Filters</button>
                </div>
            </div>

        </div>
    </main>
</div>

<style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .booking-item.hidden { display: none !important; }
</style>

<script>
    const token = localStorage.getItem('accessToken');

    function showAlert(message, type = 'success') {
        const box = document.getElementById('alert-box');
        const inner = document.getElementById('alert-inner');
        const icon = document.getElementById('alert-icon');
        const text = document.getElementById('alert-text');
        if (type === 'success') {
            inner.className = 'bg-green-100 border border-green-300 text-green-800 px-6 py-4 rounded-xl flex items-center gap-3';
            icon.textContent = 'check_circle';
        } else {
            inner.className = 'bg-red-100 border border-red-300 text-red-800 px-6 py-4 rounded-xl flex items-center gap-3';
            icon.textContent = 'error';
        }
        text.textContent = message;
        box.classList.remove('hidden');
        setTimeout(() => box.classList.add('hidden'), 5000);
    }

    function getBudgetLabel(budget) {
        const labels = { economy: 'Economy (< 1M VND/day)', standard: 'Standard (1M-2M VND/day)', premium: 'Premium (2M-5M VND/day)', luxury: 'Luxury (> 5M VND/day)' };
        return labels[budget] || budget || 'Flexible';
    }

    async function loadTrips() {
        if (!token) {
            window.location.href = '/Auth/Login?returnUrl=/Traveler/Trips';
            return;
        }

        try {
            const res = await fetch('/Traveler/GetMyTrips', {
                headers: { 'Authorization': 'Bearer ' + token }
            });

            const loading = document.getElementById('requests-loading');
            const list = document.getElementById('requests-list');
            const empty = document.getElementById('requests-empty');
            const count = document.getElementById('requests-count');
            loading.classList.add('hidden');

            if (!res.ok) {
                empty.classList.remove('hidden');
                return;
            }

            const trips = await res.json();
            count.textContent = `(${trips.length})`;

            if (trips.length === 0) {
                empty.classList.remove('hidden');
                return;
            }

            list.classList.remove('hidden');
            list.innerHTML = trips.map(trip => {
                const isClosed = trip.status?.toLowerCase() === 'closed';
                return `
                <div id="trip-card-${trip.id}" class="bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-outline-variant/30 ${isClosed ? 'opacity-60' : ''}">
                    <div class="flex flex-col md:flex-row justify-between items-start gap-6">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-2">
                                <span class="${isClosed ? 'bg-gray-100 text-gray-700' : 'bg-blue-100 text-blue-700'} text-xs font-bold px-3 py-1 rounded-full">
                                    ${isClosed ? 'CLOSED' : 'ACTIVE REQUEST'}
                                </span>
                                <span class="text-sm text-on-surface-variant flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">schedule</span>
                                    Posted ${trip.createdAt}
                                </span>
                            </div>
                            <h2 class="text-2xl font-bold text-on-surface mb-2">Trip to ${trip.destination}</h2>
                            <div class="flex flex-wrap gap-4 text-sm text-on-surface-variant mb-4">
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                                    ${trip.startDate} - ${trip.endDate}
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[18px]">group</span>
                                    ${trip.groupSize} People
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[18px]">payments</span>
                                    ${getBudgetLabel(trip.budget)}
                                </span>
                            </div>
                            ${trip.notes ? `<p class="text-on-surface-variant mb-6 line-clamp-2">"${trip.notes}"</p>` : ''}
                            ${!isClosed ? `
                            <div class="bg-surface p-4 rounded-xl border border-outline-variant/30 flex items-center gap-3">
                                <div class="w-10 h-10 bg-primary-container rounded-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-primary">mail</span>
                                </div>
                                <div>
                                    <p class="font-bold text-on-surface">Waiting for Offers</p>
                                    <p class="text-xs text-on-surface-variant">Local guides have not responded yet.</p>
                                </div>
                            </div>` : ''}
                        </div>
                        <div class="w-full md:w-48 flex flex-col gap-3">
                            <button onclick="toggleStatus('${trip.id}', '${trip.status}')"
                                class="${isClosed ? 'bg-green-100 text-green-700 hover:bg-green-200' : 'bg-surface-variant text-on-surface hover:bg-outline-variant/30'} px-4 py-2 rounded-lg font-bold text-sm transition-colors w-full">
                                ${isClosed ? 'Reactivate Request' : 'Close Request'}
                            </button>
                            <button onclick="deleteTrip('${trip.id}')"
                                class="w-full text-red-600 px-4 py-2 rounded-lg font-bold text-sm hover:bg-red-50 transition-colors">
                                Delete Request
                            </button>
                        </div>
                    </div>
                </div>`;
            }).join('');

        } catch (err) {
            console.error('Failed to load trips:', err);
            document.getElementById('requests-loading').classList.add('hidden');
            document.getElementById('requests-empty').classList.remove('hidden');
        }
    }

    let currentFilter = 'all';

    function setBookingFilter(filter, btnElement) {
        currentFilter = filter;
        // Update active button state
        document.querySelectorAll('.booking-filter-btn').forEach(btn => {
            btn.classList.remove('bg-primary', 'text-white');
            btn.classList.add('bg-surface-variant', 'text-on-surface', 'hover:bg-outline-variant/30');
        });
        btnElement.classList.remove('bg-surface-variant', 'text-on-surface', 'hover:bg-outline-variant/30');
        btnElement.classList.add('bg-primary', 'text-white');
        
        filterBookings();
    }

    function filterBookings() {
        const searchTerm = document.getElementById('booking-search-input').value.toLowerCase().trim();
        const items = document.querySelectorAll('.booking-item');
        let visibleCount = 0;

        items.forEach(item => {
            const status = item.getAttribute('data-status');
            const searchData = item.getAttribute('data-search').toLowerCase();

            // Match filter
            let matchFilter = false;
            if (currentFilter === 'all') matchFilter = true;
            else if (currentFilter === 'pending-deposit' && status === '-1') matchFilter = true;
            else if (currentFilter === 'action-required' && status === 'action-required') matchFilter = true;
            else if (currentFilter === 'upcoming' && status === 'upcoming') matchFilter = true;
            else if (currentFilter === 'completed' && status === '2') matchFilter = true;
            else if (currentFilter === 'cancelled' && status === '3') matchFilter = true;

            // Match search
            const matchSearch = searchTerm === '' || searchData.includes(searchTerm);

            if (matchFilter && matchSearch) {
                item.classList.remove('hidden');
                visibleCount++;
            } else {
                item.classList.add('hidden');
            }
        });

        const emptyState = document.getElementById('bookings-empty');
        if (visibleCount === 0 && items.length > 0) {
            emptyState.classList.remove('hidden');
        } else {
            emptyState.classList.add('hidden');
        }
    }

    async function loadBookings() {
        if (!token) return;
        try {
            const res = await fetch('/Traveler/GetMyBookings', {
                headers: { 'Authorization': 'Bearer ' + token }
            });

            if (!res.ok) {
                document.getElementById('bookings-loading').classList.add('hidden');
                document.getElementById('bookings-empty').classList.remove('hidden');
                return;
            }

            const bookings = await res.json();
            
            document.getElementById('bookings-count').textContent = `(${bookings.length})`;
            document.getElementById('bookings-loading').classList.add('hidden');

            if (bookings.length === 0) {
                document.getElementById('bookings-empty').classList.remove('hidden');
                return;
            }

            const list = document.getElementById('bookings-list');
            list.classList.remove('hidden');
            
            list.innerHTML = bookings.map(b => {
                // Determine normalized status for filtering
                let filterStatus = b.status.toString();
                if (b.status === 1) {
                    if (b.amountPaid < b.totalAmount) filterStatus = 'action-required';
                    else filterStatus = 'upcoming';
                } else if (b.status === 0) {
                    filterStatus = 'upcoming';
                }

                // Determine badge UI
                let badgeHtml = '';
                let opacityClass = '';
                if (b.status === -1) {
                    badgeHtml = `<span class="bg-orange-100 text-orange-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase">Pending Deposit</span>`;
                } else if (b.status === 0) {
                    badgeHtml = `<span class="bg-yellow-100 text-yellow-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase">Pending Approval</span>`;
                } else if (b.status === 1) {
                    if (b.amountPaid < b.totalAmount) {
                        badgeHtml = `<span class="bg-red-100 text-red-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase">Action Required</span>`;
                    } else {
                        badgeHtml = `<span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase">Confirmed</span>`;
                    }
                } else if (b.status === 2) {
                    badgeHtml = `<span class="bg-green-100 text-green-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase">Completed</span>`;
                } else if (b.status === 3) {
                    badgeHtml = `<span class="bg-gray-100 text-gray-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase">Cancelled</span>`;
                    opacityClass = 'opacity-75 grayscale';
                }

                // Compile search string
                const searchString = `${b.packageTitle} ${b.guideName} ${b.bookingDate}`.replace(/"/g, '');

                return `
                    <div class="booking-item bg-white rounded-2xl p-6 shadow-sm border border-outline-variant/30 flex flex-col md:flex-row gap-6 items-start ${opacityClass}" 
                         data-status="${filterStatus}" 
                         data-search="${searchString}">
                        <div class="w-14 h-14 rounded-full bg-primary-container flex items-center justify-center shrink-0">
                            ${b.guideAvatar ? `<img src="${b.guideAvatar}" class="w-14 h-14 rounded-full object-cover">` : `<span class="material-symbols-outlined text-primary text-2xl">person</span>`}
                        </div>
                        <div class="flex-1 min-w-0 w-full">
                            <div class="flex items-center gap-3 mb-1">
                                <h3 class="text-xl font-bold text-on-surface truncate">${b.packageTitle}</h3>
                                ${badgeHtml}
                            </div>
                            <p class="text-sm text-on-surface-variant mb-1">${b.bookingDate}</p>
                            <p class="text-sm font-medium text-on-surface mb-3">Guided by <span class="text-primary">${b.guideName}</span></p>
                            <div class="flex flex-wrap items-center gap-4">
                                <span class="text-sm font-bold text-on-surface">${(b.totalAmount || 0).toLocaleString()} VND</span>
                                ${b.status === 2 && !b.hasReviewed ? `
                                <a href="/Traveler/Review/${b.id}" class="bg-primary text-white text-sm font-bold flex items-center gap-1.5 px-4 py-2 rounded-xl hover:bg-primary/90 transition-all shadow-sm">
                                    <span class="material-symbols-outlined text-[16px]">star</span> Write a Review
                                </a>
                                ` : ''}
                                ${b.status === 2 && b.hasReviewed ? `
                                <span class="bg-green-100 text-green-700 text-sm font-bold flex items-center gap-1.5 px-4 py-2 rounded-xl">
                                    <span class="material-symbols-outlined text-[16px]">check_circle</span> Reviewed
                                </span>
                                ` : ''}
                                <a href="/Traveler/BookingDetails/${b.id}" class="text-primary text-sm font-bold flex items-center gap-1 hover:underline">
                                    <span class="material-symbols-outlined text-[16px]">info</span> View Details
                                </a>
                                ${b.status === 0 || b.status === -1 ? `
                                <button onclick="cancelBooking('${b.id}')" class="text-red-500 text-sm font-bold flex items-center gap-1 hover:underline ml-auto" title="Cancel Booking">
                                    <span class="material-symbols-outlined text-[16px]">delete</span> Cancel
                                </button>
                                ` : ''}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            // Apply default filter
            filterBookings();

        } catch (err) {
            console.error('Failed to load bookings:', err);
        }
    }

    async function deleteTrip(id) {
        if (!confirm('Are you sure you want to delete this trip request?')) return;
        try {
            const res = await fetch(`/Traveler/DeleteTripAjax?id=${id}`, {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (res.ok) {
                document.getElementById(`trip-card-${id}`)?.remove();
                showAlert('Trip request deleted successfully.');
                const currentCount = parseInt(document.getElementById('requests-count').textContent.replace(/\D/g,'')) || 0;
                document.getElementById('requests-count').textContent = `(${Math.max(0, currentCount - 1)})`;
                if (document.getElementById('requests-list').children.length === 0) {
                    document.getElementById('requests-list').classList.add('hidden');
                    document.getElementById('requests-empty').classList.remove('hidden');
                }
            }
        } catch (err) {
            showAlert('Failed to delete. Please try again.', 'error');
        }
    }

    async function toggleStatus(id, currentStatus) {
        if (!token) return;
        try {
            const res = await fetch('/Traveler/ToggleTripStatusAjax/' + id, {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (res.ok) {
                loadTrips();
            }
        } catch (err) {
            console.error('Failed to toggle status:', err);
        }
    }

    async function cancelBooking(id) {
        Swal.fire({
            title: 'Cancel Booking?',
            text: "Are you sure you want to cancel this booking request?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff7a00',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, cancel it!',
            cancelButtonText: 'No, keep it'
        }).then(async (result) => {
            if (result.isConfirmed) {
                if (!token) return;
                try {
                    const res = await fetch('/Traveler/CancelBookingAjax/' + id, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token }
                    });
                    if (res.ok) {
                        Swal.fire({
                            title: 'Cancelled!', 
                            text: 'Your booking has been deleted.', 
                            icon: 'success',
                            customClass: { popup: 'swal-top-fix' }
                        });
                        loadBookings();
                    } else {
                        Swal.fire({title: 'Error', text: 'Failed to cancel booking.', icon: 'error', customClass: { popup: 'swal-top-fix' }});
                    }
                } catch (err) {
                    Swal.fire({title: 'Error', text: 'Connection error.', icon: 'error', customClass: { popup: 'swal-top-fix' }});
                }
            }
        });
    }

    async function leaveReview(id) {
        const { value: formValues } = await Swal.fire({
            title: 'Rate your Trip',
            html: `
                <div class="mb-4">
                    <label class="block text-sm font-bold text-on-surface mb-2">Rating (1-5 Stars)</label>
                    <input id="swal-rating" type="number" min="1" max="5" class="w-full border rounded p-2" value="5">
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">Comment</label>
                    <textarea id="swal-comment" class="w-full border rounded p-2" rows="3" placeholder="Tell us about your experience..."></textarea>
                </div>
            `,
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: 'Submit Review',
            confirmButtonColor: '#ff7a00',
            preConfirm: () => {
                return {
                    rating: document.getElementById('swal-rating').value,
                    comment: document.getElementById('swal-comment').value
                }
            }
        });

        if (formValues) {
            try {
                const res = await fetch('/Traveler/SubmitReviewAjax', {
                    method: 'POST',
                    headers: { 
                        'Authorization': 'Bearer ' + token,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        bookingId: id,
                        rating: parseInt(formValues.rating),
                        comment: formValues.comment
                    })
                });

                if (res.ok) {
                    Swal.fire({ title: 'Success', text: 'Thank you for your review!', icon: 'success', customClass: { popup: 'swal-top-fix' }});
                    loadBookings(); // reload to update UI
                } else {
                    const err = await res.json();
                    Swal.fire({ title: 'Error', text: err.error || 'Failed to submit review.', icon: 'error', customClass: { popup: 'swal-top-fix' }});
                }
            } catch (e) {
                Swal.fire({ title: 'Error', text: 'Connection error.', icon: 'error', customClass: { popup: 'swal-top-fix' }});
            }
        }
    }

    // Load data on page ready
    document.addEventListener('DOMContentLoaded', function () {
        loadTrips();
        loadBookings();
    });
</script>
