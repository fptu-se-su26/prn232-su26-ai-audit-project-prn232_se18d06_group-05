@{
    ViewData["Title"] = "How It Works";
    Layout = "~/Views/Shared/_LandingLayout.cshtml";
}

<div class="bg-brand-cream text-brand-dark min-h-screen">
    <!-- Header Section -->
    <section class="py-24 px-8 md:px-16 max-w-[1000px] mx-auto text-center border-b border-cream-dark">
        <span class="text-brand-orange font-bold text-xs tracking-[0.2em] uppercase mb-4 block">THE PROCESS</span>
        <h1 class="font-serif-custom text-5xl md:text-6xl font-semibold leading-tight mb-6">
            Your Journey, Tailored.
        </h1>
        <p class="text-lg text-brand-dark/70 font-serif-custom italic">
            "Connecting with the perfect local guide has never been simpler. Four steps to an unforgettable experience."
        </p>
    </section>

    <!-- Steps Section -->
    <section class="py-24 px-8 md:px-16 max-w-[1200px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 relative">
            
            <!-- Step 1 -->
            <div class="flex gap-8">
                <div class="text-6xl font-serif-custom text-brand-orange/30 font-bold">01</div>
                <div>
                    <h3 class="text-2xl font-bold mb-3">Tell Us Your Vibe</h3>
                    <p class="text-brand-dark/70 leading-relaxed">
                        Take our 2-minute personality quiz. Tell us if you prefer hidden alleys or luxury resorts, street food or fine dining. We use this to understand your unique travel style.
                    </p>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="flex gap-8">
                <div class="text-6xl font-serif-custom text-brand-orange/30 font-bold">02</div>
                <div>
                    <h3 class="text-2xl font-bold mb-3">Meet Your Matches</h3>
                    <p class="text-brand-dark/70 leading-relaxed">
                        Our algorithm pairs you with 3 local guides who perfectly match your personality and interests. Review their profiles, read their stories, and choose your favorite.
                    </p>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="flex gap-8">
                <div class="text-6xl font-serif-custom text-brand-orange/30 font-bold">03</div>
                <div>
                    <h3 class="text-2xl font-bold mb-3">Craft The Itinerary</h3>
                    <p class="text-brand-dark/70 leading-relaxed">
                        Chat directly with your chosen guide. They will design a custom itinerary just for you, avoiding the tourist traps and focusing on authentic, meaningful experiences.
                    </p>
                </div>
            </div>

            <!-- Step 4 -->
            <div class="flex gap-8">
                <div class="text-6xl font-serif-custom text-brand-orange/30 font-bold">04</div>
                <div>
                    <h3 class="text-2xl font-bold mb-3">Experience Vietnam</h3>
                    <p class="text-brand-dark/70 leading-relaxed">
                        Arrive with confidence. Your guide will meet you and lead the way. Secure payments, 24/7 support, and memories that will last a lifetime.
                    </p>
                </div>
            </div>

        </div>

        <div class="mt-24 text-center">
            <a href="/Survey/Index" class="bg-brand-orange hover:bg-brand-dark text-white px-10 py-4 text-sm font-bold tracking-[0.2em] uppercase transition-all duration-300 shadow-lg inline-block">
                Start Your Journey Now
            </a>
        </div>
    </section>
</div>
