<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TripMate</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">
                    <i class="bi bi-compass me-2"></i>TripMate
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">
                                <i class="bi bi-house me-1"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Tours/Index">
                                <i class="bi bi-map me-1"></i>Tours
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Bookings/Index">
                                <i class="bi bi-calendar-check me-1"></i>Đặt chỗ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Messages/Index">
                                <i class="bi bi-chat-dots me-1"></i>Tin nhắn
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @{
                            var currentUser = Context.Session.GetString("CurrentUser");
                        }
                        @if (string.IsNullOrEmpty(currentUser))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Auth/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Auth/Register">
                                    <i class="bi bi-person-plus me-1"></i>Đăng ký
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i>@currentUser
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-area="" asp-page="/Profile/Index">
                                        <i class="bi bi-person me-2"></i>Hồ sơ
                                    </a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-page="/Dashboard/Index">
                                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-area="" asp-page="/Auth/Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                    </a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5">
        <div class="container py-4">
            <div class="row">
                <div class="col-md-4">
                    <h5 class="fw-bold text-primary">TripMate</h5>
                    <p class="small">Nền tảng kết nối du khách và hướng dẫn viên địa phương.</p>
                </div>
                <div class="col-md-4">
                    <h6>Liên kết</h6>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-decoration-none">Về chúng tôi</a></li>
                        <li><a href="#" class="text-decoration-none">Điều khoản sử dụng</a></li>
                        <li><a href="#" class="text-decoration-none">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6>Liên hệ</h6>
                    <p class="small mb-1"><i class="bi bi-envelope me-2"></i>support@tripmate.vn</p>
                    <p class="small"><i class="bi bi-telephone me-2"></i>+84 123 456 789</p>
                </div>
            </div>
            <hr>
            <div class="text-center small">
                &copy; 2026 - TripMate - Tất cả quyền được bảo lưu
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>